ds_map_add(global.text_data_en, "obj_monsterkidtrigger7_500", "* W-wojownicy nie odpoczywają^1,&  huh?/")
ds_map_add(global.text_data_en, "obj_monsterkidtrigger7_501", "* Undyne..^1. jesteś taka czadowa./%%")
ds_map_add(global.text_data_en, "obj_monsterkidtrigger7_643", "* J..^1. j..^1. jo..^1. ziom.../")
ds_map_add(global.text_data_en, "obj_monsterkidtrigger7_644", "* Jeśli..^1. jeśli c^1-chcesz&  skrzywdzić mojego&  przyjaciela.../")
ds_map_add(global.text_data_en, "obj_monsterkidtrigger7_645", "* Będziesz musiała najpierw&  przejść przeze mnie./%%")
ds_map_add(global.text_data_en, "obj_monsterkidtrigger7_714", "* Poszła sobie.../")
ds_map_add(global.text_data_en, "obj_monsterkidtrigger7_715", "* Jo^1, naprawdę uratowałeś&  mi skórę./")
ds_map_add(global.text_data_en, "obj_monsterkidtrigger7_716", "* Najwyraźniej bycie wrogami to&  tylko miła myśl^1, haha./")
ds_map_add(global.text_data_en, "obj_monsterkidtrigger7_717", "* Będziemy musieli po prostu&  być przyjaciółmi./")
ds_map_add(global.text_data_en, "obj_monsterkidtrigger7_718", "* ... ziom^1, ja NAPRAWDĘ&  powinienem iść do domu.../")
ds_map_add(global.text_data_en, "obj_monsterkidtrigger7_719", "* Moi rodzice pewnie trząsą&  portkami przeze mnie!/%%")
ds_map_add(global.text_data_en, "obj_monsterkidtrigger7_757", "* Siema^1, ziom!/%%")
ds_map_add(global.text_data_en, "obj_monsterkidtrigger7_836", "* Oh..^1.&* O rany.../")
ds_map_add(global.text_data_en, "obj_monsterkidtrigger7_837", "* (Jeju^1, moje s-serce bije&  przez moją klatkę...)/")
ds_map_add(global.text_data_en, "obj_monsterkidtrigger7_838", "* (... co by Undyne zrobiła?)/")
ds_map_add(global.text_data_en, "obj_monsterkidtrigger7_839", "* (...)/")
ds_map_add(global.text_data_en, "obj_monsterkidtrigger7_840", "* Jo.../")
ds_map_add(global.text_data_en, "obj_monsterkidtrigger7_841", "* L-lepiej się z-zatrzymaj&  t-tam^1, g-gdzie jesteś.../")
ds_map_add(global.text_data_en, "obj_monsterkidtrigger7_842", "* Bo jeśli c-chcesz skrzywdzić&  kogokolwiek innego..^1. musisz.../")
ds_map_add(global.text_data_en, "obj_monsterkidtrigger7_843", "* Musisz najpierw przejść&  przeze mnie./")
ds_map_add(global.text_data_en, "obj_monsterkidtrigger7_844", "* I..^1. i..^1. i..^1.%%")
ds_map_add(global.text_data_en, "obj_monsterkidtrigger7_901", "* W-widzisz^1?&* Wiedziałem, że nie&  j-jesteś taki zły!/")
ds_map_add(global.text_data_en, "obj_monsterkidtrigger7_902", "* Muszę iść powiedzieć Undyne&  że myliła się co do ciebie!/%%")
ds_map_add(global.text_data_en, "obj_monsterkidtrigger8_85", "* Undyne..^1.&* Ty...^1.&* Uratowałaś mnie!/")
ds_map_add(global.text_data_en, "obj_monsterkidtrigger8_86", "* Huh^1?&* A on uciekł?/")
ds_map_add(global.text_data_en, "obj_monsterkidtrigger8_87", "* Jo^1, mylisz się.../")
ds_map_add(global.text_data_en, "obj_monsterkidtrigger8_88", "* On poszedł po pomoc!/")
ds_map_add(global.text_data_en, "obj_monsterkidtrigger8_89", "* On wróci tutaj lada chwila!!/")
ds_map_add(global.text_data_en, "obj_monsterkidtrigger8_90", "* O-okej^1, pójdę do domu.../%%")
