ds_map_add(global.text_data_en, "obj_judgeshroom_214", "* Mój trud w oderwaniu się^1.&* Mój trud, by uciec^1.&* Ale niestety^1, bezskutecznie./%%")
ds_map_add(global.text_data_en, "obj_judgeshroom_218", "* Gdybym tylko mógł zobaczyć&  świat powyżej./")
