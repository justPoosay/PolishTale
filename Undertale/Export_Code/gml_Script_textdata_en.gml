ds_map_add(global.text_data_en, "obj_lesserdoge_463", "* Musiałeś skoczyć żeby&  pogłaskać Piesa./^")
ds_map_add(global.text_data_en, "obj_lesserdoge_464", "* Nawet go nie głaszczesz^1.&* Sam się robi bardziej&  podekscytowany./^")
ds_map_add(global.text_data_en, "obj_lesserdoge_465", "* Nie da się zatrzymać&  tego szaleństwa./^")
ds_map_add(global.text_data_en, "obj_lesserdoge_466", "* Mniejszejszy Pies sięga&  chmur w niebie./^")
ds_map_add(global.text_data_en, "obj_lesserdoge_467", "* Zawołałeś Pieska, ale było&  za późno^1.&* Ono cię nie słyszy./^")
ds_map_add(global.text_data_en, "obj_lesserdoge_468", "* .../^")
ds_map_add(global.text_data_en, "obj_lesserdoge_469", "* Znów dosięgasz do&  Mniejszejszego Psa./^")
ds_map_add(global.text_data_en, "obj_lesserdoge_470", "* Głaszczesz Mniejszejszego&  Psa./^")
ds_map_add(global.text_data_en, "obj_lesserdoge_471", "* Możliwe^1, że możesz&  mieć mały problem./^")
ds_map_add(global.text_data_en, "obj_lesserdoge_472", "* Mniejszejszy Pies jest już&  nietykalny ale docenia&  twoje starania./^")
ds_map_add(global.text_data_en, "obj_lesserdoge_473", "* Być może ludzkość nie była&  przeznaczona do takiej&  ilości głaskania./^")
