ds_map_add(global.text_data_en, "obj_blookdiary_64", "%%")
ds_map_add(global.text_data_en, "obj_blookdiary_70", "* Dear Diary^1:&* Shyren's sister " + '"' + "fell down" + '"' + "&  recently./")
ds_map_add(global.text_data_en, "obj_blookdiary_71", "* It's sad^1.&* Without her sister to&  speak for her.../")
ds_map_add(global.text_data_en, "obj_blookdiary_72", "* She's become more&  reclusive than ever./")
ds_map_add(global.text_data_en, "obj_blookdiary_73", "* So I reached out to her^1,&  and told her.../")
ds_map_add(global.text_data_en, "obj_blookdiary_74", "* That she^1, Blooky^1, and I&  should all perform together&  sometime./")
ds_map_add(global.text_data_en, "obj_blookdiary_75", "* She seemed to like&  that idea./%%")
ds_map_add(global.text_data_en, "obj_blookdiary_80", "* Dearer Diary^1:&* I like to buy a new diary&  for every entry I make./")
ds_map_add(global.text_data_en, "obj_blookdiary_81", "* I love to collect diaries./%%")
ds_map_add(global.text_data_en, "obj_blookdiary_85", "* Dearest Diary^1:&* Our cousin left the farm&  to become a training dummy./")
ds_map_add(global.text_data_en, "obj_blookdiary_86", "* That leaves just Blooky&  and I./")
ds_map_add(global.text_data_en, "obj_blookdiary_87", "* Blooky asked me if I was&  going to try to become&  corporeal^1, too./")
ds_map_add(global.text_data_en, "obj_blookdiary_88", "* They sounded so..^1.&* Resigned.../")
ds_map_add(global.text_data_en, "obj_blookdiary_89", "* Come on^1, Blooky^1.&* You know I'd never leave&  you behind./")
ds_map_add(global.text_data_en, "obj_blookdiary_90", "* And besides.../")
ds_map_add(global.text_data_en, "obj_blookdiary_91", "* I'd never find the kind&  of body I'm looking for^1,&  anyway./%%")
ds_map_add(global.text_data_en, "obj_blookdiary_96", "* My Darling Diary^1:&* I met someone..^1.&* Interesting today./")
ds_map_add(global.text_data_en, "obj_blookdiary_97", "* Last week I posted that&  advertisement for my&  Human Fanclub./")
ds_map_add(global.text_data_en, "obj_blookdiary_98", "* Today was our first meeting./")
ds_map_add(global.text_data_en, "obj_blookdiary_99", "* Only one other person came./")
ds_map_add(global.text_data_en, "obj_blookdiary_100", "* Honestly^1, she's a dork^1.&* And she's obsessed with&  these awful cartoons./")
ds_map_add(global.text_data_en, "obj_blookdiary_101", "* But she's kind of funny^1,&  too..../")
ds_map_add(global.text_data_en, "obj_blookdiary_102", "* I want to see her again./%%")
ds_map_add(global.text_data_en, "obj_blookdiary_107", "* Diary... My dear:&* My diary collection is&  going fabulously./")
ds_map_add(global.text_data_en, "obj_blookdiary_108", "* I have like five now./%%")
ds_map_add(global.text_data_en, "obj_blookdiary_115", "* Dear Diary^1:&* She surpised me with&  something today./")
ds_map_add(global.text_data_en, "obj_blookdiary_116", "* Sketches of a body that&  she wants to create for&  me.../")
ds_map_add(global.text_data_en, "obj_blookdiary_117", "* A form beyond my wildest&  fantasies./")
ds_map_add(global.text_data_en, "obj_blookdiary_118", "* In a form like that^1, I&  could finally feel&  like... " + '"' + "myself." + '"' + "/")
ds_map_add(global.text_data_en, "obj_blookdiary_119", "* After all^1, there's no&  way I can be a star&  the way I am now./")
ds_map_add(global.text_data_en, "obj_blookdiary_120", "* Sorry^1, Blooky^1.&* My dreams can't wait&  for anyone.../%%")
ds_map_add(global.text_data_en, "obj_blueattackgen_60", "* Jesteś teraz niebieski.")
ds_map_add(global.text_data_en, "obj_blueattackgen_90", " JESTEŚ TERAZ& NIEBIESKI./")
ds_map_add(global.text_data_en, "obj_blueattackgen_91", " TO MÓJ ATAK!/")
ds_map_add(global.text_data_en, "obj_blueattackgen_92", " NYEH HEH HEH& HEH HEH HEH& HEH HEH HEH!!!/%%")
ds_map_add(global.text_data_en, "obj_bonebox_63", "HEJ^1, TO SĄ MOJE&ATAKI KTÓRE NA&TOBIE UŻYŁEM./")
ds_map_add(global.text_data_en, "obj_bonebox_64", "ŚWIETNE&WSPOMNIENIA^1, HUH?/")
ds_map_add(global.text_data_en, "obj_bonebox_65", "WYDAJE SIĘ^1, JAKBY&TO BYŁO JESZCZE&WCZORAJ.../")
ds_map_add(global.text_data_en, "obj_bonebox_66", "\E3POMIMO TEGO ŻE TO&DOSŁOWNIE PRZED&CHWILĄ SIĘ STAŁO./%%")
ds_map_add(global.text_data_en, "obj_bonebox_70", "HEJ^1, TO SĄ MOJE&ATAKI KTÓRYCH NA&TOBIE NIE UŻYŁEM./")
ds_map_add(global.text_data_en, "obj_bonebox_71", "\WJAKI FARCIARZ^1!&GDYBYM TYLKO UŻYŁ&\YSPECJALNEGO ATAKU\W,/")
ds_map_add(global.text_data_en, "obj_bonebox_72", "\E2Z PEWNOŚCIĄ BYŚ&ZOSTAŁ WYSTRZE-&LONY DO.../")
ds_map_add(global.text_data_en, "obj_bonebox_73", "\WH\E3EJ.^1 CHWILA^1.&GDZIE SIĘ PODZIAŁ&MÓJ \YSPECJALNY ATAK\W?/")
ds_map_add(global.text_data_en, "obj_bonebox_74", "\E1NIE^1! ZOSTAŁEM&PSIOKRADZIONY PRZEZ&TĄ CHOLERNĄ PSIUNIĘ!/")
ds_map_add(global.text_data_en, "obj_bonebox_75", "\E3TEN CHYTRY SZCZUR&KOCHA SIĘ ZAKRADAĆ&DO MOJEGO POKOJU./")
ds_map_add(global.text_data_en, "obj_bonebox_76", "\E5CZASAMI NAWET SIĘ&CZŁAPIE POD ŁÓŻKO&KIEDY SOBIE ŚPIĘ./")
ds_map_add(global.text_data_en, "obj_bonebox_77", "\E3MAŁO TEGO^1, ON MA&BARDZO ZIMNE ŁAPKI^2.&\E2I TROCHĘ MI GO ŻAL/%%")
ds_map_add(global.text_data_en, "obj_bonebox_81", "* (To pudło kości.)/%%")
ds_map_add(global.text_data_en, "obj_bonebox_85", "* (To pudło kości.)/%%")
ds_map_add(global.text_data_en, "obj_bonedrawer_check_84", "%%")
ds_map_add(global.text_data_en, "obj_boysnightout_80", "* Hej^1! Ty^1!&* Stop!/%%")
ds_map_add(global.text_data_en, "obj_boysnightout_113", "* We've^1, like^1, received an&  anonymous tip about a human&  wearing a striped shirt./")
ds_map_add(global.text_data_en, "obj_boysnightout_114", "* They told us they were&  wandering around Hotland&  right now.../")
ds_map_add(global.text_data_en, "obj_boysnightout_115", "* I know^1, sounds scary^1, huh?/")
ds_map_add(global.text_data_en, "obj_boysnightout_116", "* Well^1, just stay chill^1.&* We'll bring you someplace&  safe^1, OK?/%%")
ds_map_add(global.text_data_en, "obj_boysnightout_117", "%%%")
ds_map_add(global.text_data_en, "obj_boysnightout_156", "* ... Huh^1?&* What is it, bro?/")
ds_map_add(global.text_data_en, "obj_boysnightout_157", "* The shirt they're wearing?/")
ds_map_add(global.text_data_en, "obj_boysnightout_158", "* ... like^1, what about it?/%%")
ds_map_add(global.text_data_en, "obj_boysnightout_181", "* Bro.../")
ds_map_add(global.text_data_en, "obj_boysnightout_182", "* Are you thinkin..^1.&* What I'm thinkin?/")
ds_map_add(global.text_data_en, "obj_boysnightout_183", "* Bummer^1.&* This is^1, like..^1.&* Mega embarrassing./")
ds_map_add(global.text_data_en, "obj_boysnightout_184", "* We^1, like^1, actually&  totally have to kill&  you and stuff./%%")
ds_map_add(global.text_data_en, "obj_businessmanticore_70", "* This elevator goes straight&  to the capital^1.&* But it stopped working./")
ds_map_add(global.text_data_en, "obj_businessmanticore_71", "* The hotel's doing its best to&  accomodate everybody&  stuck here./%%")
ds_map_add(global.text_data_en, "obj_businessmanticore_75", "* Me^1?&* I just like explaining things&  to passersby./%%")
ds_map_add(global.text_data_en, "obj_businessmanticore_80", "* Good news^1!&* The elevator started working&  again./")
ds_map_add(global.text_data_en, "obj_businessmanticore_81", "* But now it's been so busy^1,&  we still haven't gotten the&  chance to ride it./%%")
ds_map_add(global.text_data_en, "obj_businessmanticore_86", "* Mettaton hasn't made a&  performance for more&  than five minutes.../")
ds_map_add(global.text_data_en, "obj_businessmanticore_87", "* What's happening...^1?&* Can you explain it?/%%")
ds_map_add(global.text_data_en, "obj_butterflybullet_102", "* Whimsalot doesn't want to&  fight anymore.")
ds_map_add(global.text_data_en, "obj_cactus_55", "* Ah^1, kaktus.&* Szczerze najlepsza&  roślina ze wszystkich./%%")
ds_map_add(global.text_data_en, "obj_cactus_58", "* To nie tak^1, że ten kaktus&  czekał^1, aż wrócisz&  czy coś.../%%")
ds_map_add(global.text_data_en, "obj_carbed_63", "TO MOJE ŁÓŻKO!/")
ds_map_add(global.text_data_en, "obj_carbed_64", "JEŚLI&KIEDYKOLWIEK DOTRĘ&NA POWIERZCHNIĘ.../")
ds_map_add(global.text_data_en, "obj_carbed_65", "TO CHCIAŁBYM&POJEŹDZIĆ PO&AUTOSTRADZIE./")
ds_map_add(global.text_data_en, "obj_carbed_66", "WIATR W MYCH&WŁOSACH.../")
ds_map_add(global.text_data_en, "obj_carbed_67", "SŁOŃCE NA MEJ&SKÓRZE.../")
ds_map_add(global.text_data_en, "obj_carbed_68", "\E3OCZYWIŚCIE^1, TO&TYLKO SEN./")
ds_map_add(global.text_data_en, "obj_carbed_69", "\E0WIĘC W ZAMIAN&JA DRYFUJĘ W ŚNIE./%%")
ds_map_add(global.text_data_en, "obj_carbed_72", "CZEMU JESTEŚ TAKI&ZAINTERESOWANY W&MOIM ŁÓŻKU?/")
ds_map_add(global.text_data_en, "obj_carbed_73", "\E3JESTEŚ ZMĘCZONY?/%%")
ds_map_add(global.text_data_en, "obj_carbed_78", "* (To samochodzikowe łóżko^1,&  ładnie pościelone.)/%%")
ds_map_add(global.text_data_en, "obj_carrybird_95", "* Czyż mój mały Cynamonek&  nie jest przesłodki?/")
ds_map_add(global.text_data_en, "obj_carrybird_96", "* Bun-buny są takie słodkie..^1.&* Tee hee!/%%")
ds_map_add(global.text_data_en, "obj_carrybird_98", "* Bun-bun-bun-bun-bun.../%%")
ds_map_add(global.text_data_en, "obj_chairiel_118", "* (Wydaje się być właściwym&  rozmiarem dla Toriel.)/%%")
ds_map_add(global.text_data_en, "obj_chairiel_123", "* (To duże krzesło czytelnicze.^1)&* (Ale nie wydaje się żeby^1, go&  ktokolwiek używał.)/%%")
ds_map_add(global.text_data_en, "obj_cheesetable1_58", "* Ten ser tu stoi już&  od dłuższego czasu./")
ds_map_add(global.text_data_en, "obj_cheesetable1_59", "* Jest przyklejony&  do stolika.../%%")
ds_map_add(global.text_data_en, "obj_cheesetable1_62", "* (Looks like cheese has a&  nibble taken out of it.)/%%")
ds_map_add(global.text_data_en, "obj_chewtoy_98", "* (It's a squeaky chew toy.)/%%")
ds_map_add(global.text_data_en, "obj_chilldrake_246", "Brush my&teeth?&No way&in heck!")
ds_map_add(global.text_data_en, "obj_chilldrake_247", "NEVER do&your&homework&!!")
ds_map_add(global.text_data_en, "obj_chilldrake_248", "No&bedtime!&Only&DEADTIME")
ds_map_add(global.text_data_en, "obj_chilldrake_249", "*turns&music up&all the&way*")
ds_map_add(global.text_data_en, "obj_chilldrake_254", "Do you...&really&...")
ds_map_add(global.text_data_en, "obj_chilldrake_255", "I don't&think&you...")
ds_map_add(global.text_data_en, "obj_chilldrake_256", "To tell&you the&truth...")
ds_map_add(global.text_data_en, "obj_chilldrake_258", "You&don't&know my&cause!!")
ds_map_add(global.text_data_en, "obj_chilldrake_265", "Only&Snowy&can do&that.")
ds_map_add(global.text_data_en, "obj_chilldrake_266", "You&ain't&Snowy.")
ds_map_add(global.text_data_en, "obj_chilldrake_267", "Stick to&puns.&They're&better.")
ds_map_add(global.text_data_en, "obj_chilldrake_272", "WRONG!&Let's&fight&and die.")
ds_map_add(global.text_data_en, "obj_chilldrake_273", "Actually&...&Death?")
ds_map_add(global.text_data_en, "obj_chilldrake_274", "Defiance&can't be&defied!")
ds_map_add(global.text_data_en, "obj_chilldrake_279", "IT'S&JUST&LIKE&'EM")
ds_map_add(global.text_data_en, "obj_chilldrake_280", "HAHA&WOWEE")
ds_map_add(global.text_data_en, "obj_chilldrake_281", "YOU&NAILED&IT")
ds_map_add(global.text_data_en, "obj_chilldrake_286", "Where's&Snowy&right&now?")
ds_map_add(global.text_data_en, "obj_chilldrake_287", "Ha...&Ha...")
ds_map_add(global.text_data_en, "obj_chilldrake_288", "Nice&try,&laugh&Picasso.")
ds_map_add(global.text_data_en, "obj_chilldrake_296", "%%%")
ds_map_add(global.text_data_en, "obj_chilldrake_493", "* Chilldrake starts a one-&  monster riot.")
ds_map_add(global.text_data_en, "obj_chilldrake_494", "* Chilldrake is chanting an&  anarchist spell.")
ds_map_add(global.text_data_en, "obj_chilldrake_495", "* Chilldrake is eating its&  own homework.")
ds_map_add(global.text_data_en, "obj_chilldrake_496", "* It smells like " + '"' + "Ice" + '"' + "&  scented body-spray.")
ds_map_add(global.text_data_en, "obj_chilldrake_497", "* Chilldrake is wondering&  where Snowy went.")
ds_map_add(global.text_data_en, "obj_chilldrake_498", "* Chilldrake feels neutered&  by your agreement.")
ds_map_add(global.text_data_en, "obj_chilldrake_499", "* Chilldrake is laughing at&  your imitation of its&  cohort.")
ds_map_add(global.text_data_en, "obj_chilldrake_500", "* Chilldrake pretends not to&  care.")
ds_map_add(global.text_data_en, "obj_chilldrake_501", "* Chilldrake is puffed up..")
ds_map_add(global.text_data_en, "obj_chilldrake_502", "* Chilldrake is flaking&  apart.")
ds_map_add(global.text_data_en, "obj_chilldrake_518", "* CHILLDRAKE - ATK 12 DEF 7&* Rebels against everything!!&* Looking for its friend Snowy./^")
ds_map_add(global.text_data_en, "obj_chilldrake_527", "* You tell Chilldrake it's&  all wrong./^")
ds_map_add(global.text_data_en, "obj_chilldrake_539", "* You agree with Chilldrake&  before it gives its speech./^")
ds_map_add(global.text_data_en, "obj_chilldrake_540", "* You agree with Chilldrake^1.&* It seems to get very&  uncomfortable.../^")
ds_map_add(global.text_data_en, "obj_chilldrake_548", "* You make fun of Chilldrake./^")
ds_map_add(global.text_data_en, "obj_chilldrake_550", "* You make fun of Chilldrake./")
ds_map_add(global.text_data_en, "obj_chilldrake_551", "* The other monsters think&  it's hilarious.../^")
ds_map_add(global.text_data_en, "obj_chilldrakenpc_70", "* Heh..^1. us teens live&  self-sufficiently off&  the fat of the land.../")
ds_map_add(global.text_data_en, "obj_chilldrakenpc_71", "* Oh^1, and the box lunches my&  parents bring us every&  day./%%")
ds_map_add(global.text_data_en, "obj_chilldrakenpc_72", "* Besides Snowy^1.&* We have to share ours&  with him../%%")
ds_map_add(global.text_data_en, "obj_chilldrakenpc_76", "* Heh..^1.&* I guess we'll have to go to&  the surface./")
ds_map_add(global.text_data_en, "obj_chilldrakenpc_77", "* There are woods there we can&  live in^1, right?/%%")
ds_map_add(global.text_data_en, "obj_chilldrakenpc_82", "* Guh huh huh huh^1./")
ds_map_add(global.text_data_en, "obj_chilldrakenpc_83", "* Us teens rule these woods&  with a smaller-than-&  adult fist./%%")
ds_map_add(global.text_data_en, "obj_chilldrakenpc_87", "* I'm worried about getting&  older..^1.&* I'll stop being a teen./")
ds_map_add(global.text_data_en, "obj_chilldrakenpc_88", "* No^1! I refuse^1!&* I'll just invent new numbers^1,&  like twenty-teen!/%%")
ds_map_add(global.text_data_en, "obj_chipdoor_l_78", "* (Te drzwi są zamknięte.)/%%")
ds_map_add(global.text_data_en, "obj_chipdoor_l_79", "* (O to drzwio jest otwarte.)/%%")
ds_map_add(global.text_data_en, "obj_chipdoor_l_82", "* (Drzwi są otwarte.)/%%")
ds_map_add(global.text_data_en, "obj_chipdoor_l_87", "* (Drzwi są otwarte.)/%%")
ds_map_add(global.text_data_en, "obj_chipdoor_r_84", "* (Te drzwi są zamknięte.)/%%")
ds_map_add(global.text_data_en, "obj_chipdoor_r_85", "* (O to drzwio jest otwarte.)/%%")
ds_map_add(global.text_data_en, "obj_chipdoor_r_89", "* (Drzwi są otwarte.)/%%")
ds_map_add(global.text_data_en, "obj_chipdoor_r_94", "* (Drzwi są otwarte.)/%%")
ds_map_add(global.text_data_en, "obj_clamgirl_74", "* I'm visiting Waterfall&  from the city./")
ds_map_add(global.text_data_en, "obj_clamgirl_75", "* Synchronicity...^1?&* My neighbor's daughter looks&  about your age./")
ds_map_add(global.text_data_en, "obj_clamgirl_76", "\W* Her name is " + '"' + "\YSuzy\W.^1" + '"' + "&* I feel like you two should&  be friends./")
ds_map_add(global.text_data_en, "obj_clamgirl_77", "* You have..^1.&* A neighbor's blessing!!!/%%")
ds_map_add(global.text_data_en, "obj_clamgirl_81", "* Not knowing where I live&  is no issue^1.&* Fate finds a way./")
ds_map_add(global.text_data_en, "obj_clamgirl_82", "* In life's grand scheme^1, she&  might be why you came here&  in the first place.../%%")
ds_map_add(global.text_data_en, "obj_clamgirl_93", "* I sense a disturbance in&  the nearby aura.../")
ds_map_add(global.text_data_en, "obj_clamgirl_94", "* I think you should leave&  that girl alone./%%")
ds_map_add(global.text_data_en, "obj_clamgirl_102", "* So you never met my&  neighbor's daughter./")
ds_map_add(global.text_data_en, "obj_clamgirl_103", "* Don't despair^1.&* This world has infinite&  opportunities./")
ds_map_add(global.text_data_en, "obj_clamgirl_104", "* But there's a limit to the&  things you can do today^1.&* Accepting this is healthy./")
ds_map_add(global.text_data_en, "obj_clamgirl_105", "* Take my neighbor's blessing^1!&* And consider this blessing&  for anything you like!/%%")
ds_map_add(global.text_data_en, "obj_clamgirl_110", "* I wanted to tell you about&  my neighbor's daughter./")
ds_map_add(global.text_data_en, "obj_clamgirl_111", "* But you walked right by me&  before I could tell you./")
ds_map_add(global.text_data_en, "obj_clamgirl_112", "* Fate has decided that I&  should not tell you./%%")
ds_map_add(global.text_data_en, "obj_clamguy_73", "* O, k, k, k, k.../")
ds_map_add(global.text_data_en, "obj_clamguy_74", "* I was thirsty^1, so I came&  over from Waterfall to get&  a drink!/%%")
ds_map_add(global.text_data_en, "obj_clamguy_78", "* O, k, k.../")
ds_map_add(global.text_data_en, "obj_clamguy_79", "* What are you doing with&  all of that water?/%%")
ds_map_add(global.text_data_en, "obj_clamguy_83", "* O, k, k, k, k.../")
ds_map_add(global.text_data_en, "obj_clamguy_84", "* So now we have a private pool^1?&* Worse things have happened./%%")
ds_map_add(global.text_data_en, "obj_clamguy_89", "* O, k, k, k, k.../")
ds_map_add(global.text_data_en, "obj_clamguy_90", "* Are you just carrying that&  around to look sophisticated?/")
ds_map_add(global.text_data_en, "obj_clamguy_91", "* Cause it's not working./%%")
ds_map_add(global.text_data_en, "obj_clamguy_98", "* O, k, k, k, k.../")
ds_map_add(global.text_data_en, "obj_clamguy_99", "* I'll be able to have a nice&  drink on the surface./%%")
ds_map_add(global.text_data_en, "obj_colorlever_77", "* (To jakiś rodzaj dźwigni.^1)&* (Jest czerwony zamek&  w środku.)/%%")
