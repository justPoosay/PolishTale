ds_map_add(global.text_data_en, "obj_papdate_454", "TO WSZYSTKO JUŻ&ZAPLANOWAŁEŚ!!!/")
ds_map_add(global.text_data_en, "obj_papdate_457", "JESTEŚ O WIELE&LEPSZY W RANDKO-&WANIU NIŻ JA!!!/")
ds_map_add(global.text_data_en, "obj_papdate_458", "\XN\E6-NIEEEE!!!&TWOJA \BMOC RANDKI\X &...!!!/%%")
ds_map_add(global.text_data_en, "obj_papdate_460", "JESTEŚ O WIELE&LEPSZY W SPOT-&KANIACH NIŻ JA!!!/")
ds_map_add(global.text_data_en, "obj_papdate_461", "\XN\E6-NIEEEE!!!&TWOJA \BMOC&        PRZYJAŹNI\X!!!/%%")
ds_map_add(global.text_data_en, "obj_papdate_465", "\E3POMIMO TEGO^1, TY&POSTANOWIŁEŚ ZAŁO-&ŻYĆ UBRANIE DZISIAJ^1,&ZE WSZYSTKICH DNI...?/")
ds_map_add(global.text_data_en, "obj_papdate_468", "\E2TWÓJ INTERES MNĄ.../")
ds_map_add(global.text_data_en, "obj_papdate_469", "\XN\E6-NIEEEE!!!&TWOJA \BMOC RANDKI\X &...!!!/%%")
ds_map_add(global.text_data_en, "obj_papdate_470", "\E2TWOJA PRZYJAŹŃ.../")
ds_map_add(global.text_data_en, "obj_papdate_471", "\XN\E6-NIEEEE!!!&TWOJA \BMOC&        PRZYJAŹNI\X!!!/%%")
ds_map_add(global.text_data_en, "obj_papdate_472", "\F3TO WSZYSTKO BYŁO&ZAPLANOWANE!?!?/")
ds_map_add(global.text_data_en, "obj_papdate_520", "NYEH!/")
ds_map_add(global.text_data_en, "obj_papdate_521", "NYEH HEH HEH!!!/%%")
ds_map_add(global.text_data_en, "obj_papdate_535", "\F0NIE MYŚL SOBIE,&ŻE JUŻ MNIE&POKONAŁEŚ!/")
ds_map_add(global.text_data_en, "obj_papdate_536", "JA^1, WIELKI&PAPYRUS.../")
ds_map_add(global.text_data_en, "obj_papdate_539", "NIGDY NIE ZOSTAŁEM&POKONANY W RANDKO-&WANIU^1, I NIGDY NIE BĘDĘ!/")
ds_map_add(global.text_data_en, "obj_papdate_540", "JUST IN CASE&SOMEBODY HAPPENS&TO ASK ME ON&A DATE!!!/")
ds_map_add(global.text_data_en, "obj_papdate_541", "HAVE NEVER BEEN&BEATEN AT HANGING&OUT^1, AND I NEVER&WILL!/")
ds_map_add(global.text_data_en, "obj_papdate_542", "JUST IN CASE&SOMEONE WANTS&TO HANG OUT!/")
ds_map_add(global.text_data_en, "obj_papdate_543", "\E0I CAN EASILY&KEEP UP WITH&YOU!!!/")
ds_map_add(global.text_data_en, "obj_papdate_544", "\E1YOU SEE^1,&I^1, TOO^1, CAN WEAR&CLOTHING!!!/")
ds_map_add(global.text_data_en, "obj_papdate_545", "\E3IN FACT.../")
ds_map_add(global.text_data_en, "obj_papdate_546", "\E1I ALWAYS WEAR MY&" + '"' + "SPECIAL" + '"' + " CLOTHES&UNDERNEATH MY&REGULAR CLOTHES!!/")
ds_map_add(global.text_data_en, "obj_papdate_547", "\E0BEHOLD!!!/%%")
ds_map_add(global.text_data_en, "obj_papdate_573", "\E1NYEH!&WHAT DO YOU&THINK OF MY&SECRET STYLE!?!/*")
ds_map_add(global.text_data_en, "obj_papdate_586", "                              &   I love it       I hate it&                            ")
ds_map_add(global.text_data_en, "obj_papdate_611", "\E6NO!!!/")
ds_map_add(global.text_data_en, "obj_papdate_614", "A GENUINE&COMPLIMENT...!!!/%%")
ds_map_add(global.text_data_en, "obj_papdate_618", "YOUR HONESTY...^1!&IT SHOWS HOW&MUCH YOU REALLY&CARE!!!/%%")
ds_map_add(global.text_data_en, "obj_papdate_667", "\E3HOWEVER.../")
ds_map_add(global.text_data_en, "obj_papdate_668", "\XY\E0OU DON'T TRULY&UNDERSTAND THE\R &HIDDEN POWER\X OF&THIS OUTFIT!!!/")
ds_map_add(global.text_data_en, "obj_papdate_669", "\E3THEREFORE.../%%")
ds_map_add(global.text_data_en, "obj_papdate_679", "\E1WHAT YOU JUST&SAID IS INVALID!!!/")
ds_map_add(global.text_data_en, "obj_papdate_681", "THIS DATE WON'T&ESCALATE ANY&FURTHER!!!/")
ds_map_add(global.text_data_en, "obj_papdate_683", "THIS HANG-OUT&WON'T ESCALATE&ANY FURTHER!/")
ds_map_add(global.text_data_en, "obj_papdate_684", "\X.\E7.. UNLESS&YOU FIND \RMY&SECRET\X!!/")
ds_map_add(global.text_data_en, "obj_papdate_685", "BUT THAT WON'T&HAPPEN!!/%%")
ds_map_add(global.text_data_en, "obj_papdate_705", "* (Move and inspect with \*Z.)")
ds_map_add(global.text_data_en, "obj_papdate_721", "\E3MY HAT...?/")
ds_map_add(global.text_data_en, "obj_papdate_722", "\E8MY HAT./")
ds_map_add(global.text_data_en, "obj_papdate_723", "\E0MY HAT!/")
ds_map_add(global.text_data_en, "obj_papdate_724", "NYEH HEH HEH!/%%")
ds_map_add(global.text_data_en, "obj_papdate_740", "W-WELL THEN..^1.&YOU FOUND MY&SECRET!/")
ds_map_add(global.text_data_en, "obj_papdate_741", "I SUPPOSE I HAVE&NO CHOICE!/")
ds_map_add(global.text_data_en, "obj_papdate_742", "IT'S A PRESENT.../")
ds_map_add(global.text_data_en, "obj_papdate_743", "A PRESENT J-JUST&FOR YOU!!!/")
ds_map_add(global.text_data_en, "obj_papdate_744", "GO AHEAD^1!&OPEN IT!/*")
ds_map_add(global.text_data_en, "obj_papdate_756", "                              &   Open it         Don't    &                            ")
ds_map_add(global.text_data_en, "obj_papdate_780", "\E2YOU CAN'T EVEN&BRING YOURSELF TO&HARM MY DELICATE&WRAPPING??/")
ds_map_add(global.text_data_en, "obj_papdate_781", "\E7N-NO..^1.&THAT TECHNIQUE!/")
ds_map_add(global.text_data_en, "obj_papdate_782", "\E6IT'S TOO STRONG!/")
ds_map_add(global.text_data_en, "obj_papdate_783", "\E7COUNTERATTACK^1!&I'LL OPEN THE&PRESENT MYSELF!!/%%")
ds_map_add(global.text_data_en, "obj_papdate_802", "\E0DO YOU KNOW WHAT&THIS IS?/*")
ds_map_add(global.text_data_en, "obj_papdate_815", "                              &   Of course       No idea  &                            ")
ds_map_add(global.text_data_en, "obj_papdate_842", "\E0" + '"' + "SPAGHETTI." + '"' + "/")
ds_map_add(global.text_data_en, "obj_papdate_843", "\E3THAT'S WHAT&YOU'RE THINKING^1,&ISN'T IT?/")
ds_map_add(global.text_data_en, "obj_papdate_844", "\E0RIGHT!/")
ds_map_add(global.text_data_en, "obj_papdate_845", "\E1BUT OH-SO WRONG!/%%")
ds_map_add(global.text_data_en, "obj_papdate_849", "\E0NYEH HEH HEH^1!&THAT'S RIGHT./")
ds_map_add(global.text_data_en, "obj_papdate_850", "YOU HAVE NO IDEA!/")
ds_map_add(global.text_data_en, "obj_papdate_851", "\E3THOUGH THIS&APPEARS TO BE&SPAGHETTI.../%%")
ds_map_add(global.text_data_en, "obj_papdate_864", "\E1THIS AIN'T ANY&PLAIN OL' PASTA!/")
ds_map_add(global.text_data_en, "obj_papdate_865", "\E0THIS IS AN&ARTISAN'S WORK!/")
ds_map_add(global.text_data_en, "obj_papdate_866", "\E3SILKEN SPAGHETTI^1,&FINELY AGED IN&AN OAKEN CASK.../")
ds_map_add(global.text_data_en, "obj_papdate_867", "\E0THEN COOKED BY&ME^1, MASTER CHEF&PAPYRUS!/")
ds_map_add(global.text_data_en, "obj_papdate_868", "\E1HUMAN!!^1!&IT'S TIME TO&END THIS!!/")
ds_map_add(global.text_data_en, "obj_papdate_869", "THERE'S NO WAY&THIS CAN GO&ANY FURTHER!/")
ds_map_add(global.text_data_en, "obj_papdate_870", "EAT THIS^1!&MY ULTIMATE&TECHNIQUE!!!/*")
ds_map_add(global.text_data_en, "obj_papdate_885", "                              &   Eat it          Refuse   &                            ")
ds_map_add(global.text_data_en, "obj_papdate_911", "* (You take a small bite.)/")
ds_map_add(global.text_data_en, "obj_papdate_912", "* (Your face reflexively&  scrunches up.)/")
ds_map_add(global.text_data_en, "obj_papdate_913", "* (The taste is indescribable...)/%%")
ds_map_add(global.text_data_en, "obj_papdate_928", "\E0WHAT A PASSIONATE&EXPRESSION!!!/")
ds_map_add(global.text_data_en, "obj_papdate_929", "\E3YOU MUST REALLY&LOVE MY COOKING!/")
ds_map_add(global.text_data_en, "obj_papdate_930", "\E2AND BY EXTENSION^1,&ME!!!/")
ds_map_add(global.text_data_en, "obj_papdate_931", "\E6MAYBE EVEN MORE&THAN I DO!!!/%%")
ds_map_add(global.text_data_en, "obj_papdate_935", "\E3YOU MEAN.../")
ds_map_add(global.text_data_en, "obj_papdate_936", "\E2YOU'RE LETTING ME&HAVE IT INSTEAD?/")
ds_map_add(global.text_data_en, "obj_papdate_937", "\E2BECAUSE YOU KNOW&HOW MUCH I LOVE&PASTA.../")
ds_map_add(global.text_data_en, "obj_papdate_938", "\E6IMPOSSIBLE!^1!&TAKING MY PRESENT&AND TURNING IT&AROUND ON ME!/%%")
ds_map_add(global.text_data_en, "obj_papdate_948", "AUGH!!^5!%%")
ds_map_add(global.text_data_en, "obj_papdate_967", "URRRGH!!^5!%%")
ds_map_add(global.text_data_en, "obj_papdate_987", "NOOOOOOOO!!^4!%%")
ds_map_add(global.text_data_en, "obj_papdate_1021", "HUMAN^1.&IT'S CLEAR NOW./")
ds_map_add(global.text_data_en, "obj_papdate_1022", "YOU'RE MADLY IN&LOVE WITH ME./")
ds_map_add(global.text_data_en, "obj_papdate_1023", "EVERYTHING YOU DO^1.&EVERYTHING&YOU SAY./")
ds_map_add(global.text_data_en, "obj_papdate_1024", "IT'S ALL BEEN&FOR MY SAKE./")
ds_map_add(global.text_data_en, "obj_papdate_1025", "HUMAN^1. I WANT&YOU TO BE&HAPPY^1, TOO./")
ds_map_add(global.text_data_en, "obj_papdate_1026", "IT'S TIME FOR ME&TO EXPRESS MY&FEELINGS./")
ds_map_add(global.text_data_en, "obj_papdate_1027", "IT'S TIME THAT&I TOLD YOU./")
ds_map_add(global.text_data_en, "obj_papdate_1028", "I^1, PAPYRUS.../%%")
ds_map_add(global.text_data_en, "obj_papdate_1032", "HUMAN^1.&IT'S CLEAR NOW./")
ds_map_add(global.text_data_en, "obj_papdate_1033", "YOU'RE COMPLETELY&OBSESSED WITH ME./")
ds_map_add(global.text_data_en, "obj_papdate_1034", "EVERYTHING YOU DO^1.&EVERYTHING&YOU SAY./")
ds_map_add(global.text_data_en, "obj_papdate_1035", "IT'S ALL BEEN&FOR MY SAKE./")
ds_map_add(global.text_data_en, "obj_papdate_1036", "HUMAN^1. I WANT&YOU TO BE&HAPPY^1,TOO./")
ds_map_add(global.text_data_en, "obj_papdate_1037", "IT'S TIME FOR ME&TO EXPRESS MY&FEELINGS./")
ds_map_add(global.text_data_en, "obj_papdate_1038", "IT'S TIME THAT&I TOLD YOU./")
ds_map_add(global.text_data_en, "obj_papdate_1039", "\E8I^1, PAPYRUS.../%%")
ds_map_add(global.text_data_en, "obj_papdate_1079", "I.../")
ds_map_add(global.text_data_en, "obj_papdate_1080", "UM.../")
ds_map_add(global.text_data_en, "obj_papdate_1081", "\E4BOY^1, IS IT HOT&IN HERE^1, OR IS&IT JUST ME??/")
ds_map_add(global.text_data_en, "obj_papdate_1082", "\E4.../")
ds_map_add(global.text_data_en, "obj_papdate_1083", "\E5OH^1, SHOOT./")
ds_map_add(global.text_data_en, "obj_papdate_1084", "HUMAN^1, I.../")
ds_map_add(global.text_data_en, "obj_papdate_1085", "I'M SORRY./")
ds_map_add(global.text_data_en, "obj_papdate_1086", "I DON'T LIKE YOU&THE WAY YOU&LIKE ME./")
ds_map_add(global.text_data_en, "obj_papdate_1087", "\E4ROMANTICALLY^1,&I MEAN./")
ds_map_add(global.text_data_en, "obj_papdate_1088", "\E6I MEAN^1, I TRIED&VERY HARD TO!/")
ds_map_add(global.text_data_en, "obj_papdate_1089", "\E8I THOUGHT THAT&BECAUSE YOU&FLIRTED WITH ME.../")
ds_map_add(global.text_data_en, "obj_papdate_1090", "THAT I WAS&SUPPOSED&TO GO ON A&DATE WITH YOU./")
ds_map_add(global.text_data_en, "obj_papdate_1091", "\E0THEN^1, ON THE DATE^1,&FEELINGS WOULD&BLOSSOM FORTH!!!/")
ds_map_add(global.text_data_en, "obj_papdate_1092", "\E2I WOULD BE ABLE&TO MATCH YOUR&PASSION FOR ME!/")
ds_map_add(global.text_data_en, "obj_papdate_1093", "\E4BUT ALAS..^1.&I^1, THE GREAT&PAPYRUS.../")
ds_map_add(global.text_data_en, "obj_papdate_1094", "\E5HAVE FAILED./")
ds_map_add(global.text_data_en, "obj_papdate_1095", "I FEEL JUST THE&SAME AS BEFORE./")
ds_map_add(global.text_data_en, "obj_papdate_1096", "AND INSTEAD^1, BY&DATING YOU.../")
ds_map_add(global.text_data_en, "obj_papdate_1097", "I HAVE ONLY DRAWN&YOU DEEPER.../")
ds_map_add(global.text_data_en, "obj_papdate_1098", "\E6INTO YOUR INTENSE&LOVE FOR ME!/")
ds_map_add(global.text_data_en, "obj_papdate_1099", "\E5A DARK PRISON OF&PASSION^1, WITH NO&ESCAPE./")
ds_map_add(global.text_data_en, "obj_papdate_1100", "HOW COULD I HAVE&DONE THIS TO MY&DEAR FRIEND...?/")
ds_map_add(global.text_data_en, "obj_papdate_1101", ".../")
ds_map_add(global.text_data_en, "obj_papdate_1102", "\E6NO^1! WAIT^1!&THAT'S WRONG!/")
ds_map_add(global.text_data_en, "obj_papdate_1103", "I CAN'T FAIL AT&ANYTHING!!!/")
ds_map_add(global.text_data_en, "obj_papdate_1104", "\E1HUMAN!!^1!&I'LL HELP YOU&THROUGH THESE&TRYING TIMES!!!/")
ds_map_add(global.text_data_en, "obj_papdate_1105", "\E0I'LL KEEP BEING&YOUR COOL&FRIEND.../")
ds_map_add(global.text_data_en, "obj_papdate_1106", "\E8AND ACT LIKE THIS&ALL NEVER&HAPPENED./")
ds_map_add(global.text_data_en, "obj_papdate_1107", "\E0AFTER ALL^1, YOU&ARE VERY GREAT./")
ds_map_add(global.text_data_en, "obj_papdate_1108", "\E5IT WOULD BE&TRAGIC TO LOSE&YOUR FRIENDSHIP./")
ds_map_add(global.text_data_en, "obj_papdate_1109", "\E0SO PLEASE..../")
ds_map_add(global.text_data_en, "obj_papdate_1110", "\E5DON'T CRY BECAUSE&I WON'T KISS YOU./")
ds_map_add(global.text_data_en, "obj_papdate_1111", "\E4BECAUSE^1, I DON'T&EVEN HAVE LIPS./")
ds_map_add(global.text_data_en, "obj_papdate_1112", "\E0AND HEY^1, SOMEDAY^1,&YOU'LL FIND&SOMEONE AS&GREAT AS ME./")
ds_map_add(global.text_data_en, "obj_papdate_1113", "\E8WELL, NO^1.&THAT'S NOT TRUE./")
ds_map_add(global.text_data_en, "obj_papdate_1114", "\E0BUT I'LL HELP YOU&SETTLE FOR&SECOND BEST!!!/")
ds_map_add(global.text_data_en, "obj_papdate_1115", "NYEH HEH HEH&HEH HEH!!!/%%")
ds_map_add(global.text_data_en, "obj_papdate_1121", "\E8HMM.../")
ds_map_add(global.text_data_en, "obj_papdate_1122", "\E0WELL^1, I'M FLATTERED&YOU CARE SO MUCH./")
ds_map_add(global.text_data_en, "obj_papdate_1123", "\E4BUT MAYBE COOL&IT A LITTLE BIT...?/")
ds_map_add(global.text_data_en, "obj_papdate_1124", "\E0YOU ARE A VERY&NICE PERSON./")
ds_map_add(global.text_data_en, "obj_papdate_1125", "I'M GLAD WE'RE&FRIENDS./")
ds_map_add(global.text_data_en, "obj_papdate_1126", "\E8BUT^1, I THINK YOU&CAN REACH YOUR&MAX POTENTIAL,,,/")
ds_map_add(global.text_data_en, "obj_papdate_1127", "\E0IF YOU LIVE MORE&FOR YOUR OWN SAKE^1,&RATHER THAN JUST&FOR MINE./")
ds_map_add(global.text_data_en, "obj_papdate_1128", "\E8HMMM.../")
ds_map_add(global.text_data_en, "obj_papdate_1129", "\E0HEY^1, I KNOW THE&SOLUTION!!!/")
ds_map_add(global.text_data_en, "obj_papdate_1130", "YOU SHOULD HANG&OUT WITH MY BOSS^1,&UNDYNE!!!/")
ds_map_add(global.text_data_en, "obj_papdate_1131", "I THINK IF YOU&SPREAD YOUR FRIEND-&ENERGY OUT MORE.../")
ds_map_add(global.text_data_en, "obj_papdate_1132", "YOU'LL HAVE A MORE&HEALTHY LIFESTYLE./")
ds_map_add(global.text_data_en, "obj_papdate_1133", "YEAH!!^1!&LET'S BE FRIENDS&WITH UNDYNE!!!/")
ds_map_add(global.text_data_en, "obj_papdate_1134", "NYEH HEH HEH&HEH HEH!!!/%%")
ds_map_add(global.text_data_en, "obj_papdate_1175", "OH^1, AND IF YOU&EVER NEED TO&REACH ME.../")
ds_map_add(global.text_data_en, "obj_papdate_1176", "\XHERE'S MY \RPHONE&NUMBER\X./")
ds_map_add(global.text_data_en, "obj_papdate_1177", "YOU CAN CALL&ME ANY TIME!/")
ds_map_add(global.text_data_en, "obj_papdate_1178", "\E4PLATONICALLY./")
ds_map_add(global.text_data_en, "obj_papdate_1179", "\E0WELL^1, GOTTA GO^1!&NYEH HEH HEH!/%%")
ds_map_add(global.text_data_en, "obj_papfridge_71", "AHA^1!&ZACIEKAWIONY MOIM&MUZEUM JEDZENIA?/")
ds_map_add(global.text_data_en, "obj_papfridge_72", "PROSZĘ^1.&PODZIWIAJ MOJE KULI-&NARNE ARCYDZIEŁO./")
ds_map_add(global.text_data_en, "obj_papfridge_73", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_papfridge_74", "* (Połowa lodówki jest&  wypełniona pudełkami z&  oznaczeniem " + '"' + "spaghetti." + '"' + ")/")
ds_map_add(global.text_data_en, "obj_papfridge_75", "* (Druga połowa składa się&  wyłącznie z pustych opakowań&  po cipsach.)/%%")
ds_map_add(global.text_data_en, "obj_papfridge_77", "ŚWIETNA LODÓWKA^1,&CZYŻ NIE?/%%")
ds_map_add(global.text_data_en, "obj_papfridge_81", "* (Połowa lodówki jest&  wypełniona pudełkami z&  oznaczeniem " + '"' + "spaghetti." + '"' + ")/")
ds_map_add(global.text_data_en, "obj_papfridge_82", "* (Druga połowa składa się&  wyłącznie z pustych opakowań&  po cipsach.)/%%")
ds_map_add(global.text_data_en, "obj_paphouse_entrance_91", "* (Jest zamknięte.)/%%")
ds_map_add(global.text_data_en, "obj_paphouse_entrance_96", "WOW^1, YOU'RE SO&EAGER TO DATE&ME.../")
ds_map_add(global.text_data_en, "obj_paphouse_entrance_97", "WOW^1, YOU'RE SO&EAGER TO HANG&OUT.../")
ds_map_add(global.text_data_en, "obj_paphouse_entrance_98", "YOU'RE TRYING TO&GO INTO MY HOUSE&WITHOUT ME!/")
ds_map_add(global.text_data_en, "obj_paphouse_entrance_99", "THAT'S REALLY&WEIRD!!!/%%")
ds_map_add(global.text_data_en, "obj_paphouse_entrance_103", "* (It's unlocked.)/%%")
ds_map_add(global.text_data_en, "obj_papmailbox_74", "HOW NICE OF YOU&TO CHECK MY MAIL&FOR ME./")
ds_map_add(global.text_data_en, "obj_papmailbox_75", "\E3WAIT^1, NO^1.&THAT'S VERY&STRANGE./%%")
ds_map_add(global.text_data_en, "obj_papmailbox_78", "\E3STOP LOOKING IN&MY EMPTY&MAILBOX./")
ds_map_add(global.text_data_en, "obj_papmailbox_79", "\E0THAT'S MY&EMPTINESS^1, NOT&YOURS./%%")
ds_map_add(global.text_data_en, "obj_papmailbox_96", "* Oh my god^1!&* The letter's not&  to PAPYRUS!!!/")
ds_map_add(global.text_data_en, "obj_papmailbox_98", "YEAH^1, UNDYNE'S&GOT A POINT!/")
ds_map_add(global.text_data_en, "obj_papmailbox_99", "\E0WHY DIDN'T SHE&WRITE A LETTER&TO ME INSTEAD?/")
ds_map_add(global.text_data_en, "obj_papmailbox_101", "* Fine^1, you want a&  letter!?/")
ds_map_add(global.text_data_en, "obj_papmailbox_102", "* I'll give you a&  letter!!!/")
ds_map_add(global.text_data_en, "obj_papmailbox_103", "\E6* YOU GET AN " + '"' + "F" + '"' + "!/")
ds_map_add(global.text_data_en, "obj_papmailbox_105", "OH NO!!!/")
ds_map_add(global.text_data_en, "obj_papmailbox_106", "\E3WHAT'S THE F&FOR?/")
ds_map_add(global.text_data_en, "obj_papmailbox_108", "* Friendship!!!/%%")
ds_map_add(global.text_data_en, "obj_papsink_100", "ROBI WRAŻENIE^1?&PODWYŻSZYŁEM&MÓJ ZLEW./")
ds_map_add(global.text_data_en, "obj_papsink_101", "TERAZ MOGĘ ZMIEŚCIĆ&WIĘCEJ KOŚCI^1!&ZAJRZYJ SOBIE!/%%")
ds_map_add(global.text_data_en, "obj_papsink_106", "ZAPOMNIJ./%%")
ds_map_add(global.text_data_en, "obj_papsink_111", "* (Ten zlew jest tak wysoki^1, że&  nie możesz nawet umyć rąk...)/%%")
ds_map_add(global.text_data_en, "obj_papsink_234", "CO!?!?/%%")
ds_map_add(global.text_data_en, "obj_papsink_244", "ZŁAP TĄ&GŁUPIĄ PSINĘ!/%%")
ds_map_add(global.text_data_en, "obj_papsink_284", "CURSES!!!/%%")
ds_map_add(global.text_data_en, "obj_papsink_313", "SANS!/")
ds_map_add(global.text_data_en, "obj_papsink_314", "PRZESTAŃ OZDABIAĆ&MI ŻYCIE IRONICZNĄ&MUZYKĄ!!!/%%")
ds_map_add(global.text_data_en, "obj_papstove_71", "* (Jest pusta blacha do ciasta&  w kuchence.)/%%")
ds_map_add(global.text_data_en, "obj_papstove_75", "\E0MÓJ BRAT ZAWSZE&IDZIE SOBIE NA&JEDZENIE^1. ALE.../")
ds_map_add(global.text_data_en, "obj_papstove_76", "\E3OSTATNIO^1, ON SPRÓ-&BOWAŁ COŚ 'UPIEC'&SAMEMU./")
ds_map_add(global.text_data_en, "obj_papstove_77", "TO BYŁO JAKBY..^1.&KISZ./")
ds_map_add(global.text_data_en, "obj_papstove_78", "ALE WYPEŁNIONY&CUKROWĄ^1, BEZJAJ-&KOWĄ SUBSTANCJĄ./")
ds_map_add(global.text_data_en, "obj_papstove_79", "\E0JAKIE ABSURDALNE!/%%")
ds_map_add(global.text_data_en, "obj_papstove_82", "* (Jest pusta blacha do ciasta&  w kuchence.)/%%")
ds_map_add(global.text_data_en, "obj_paptrash_68", "* (Odwiedziłeś kosz na śmieci.)/%%")
ds_map_add(global.text_data_en, "obj_paptrash_72", "OTO KOSZ NA&ŚMIECI./")
ds_map_add(global.text_data_en, "obj_paptrash_73", "MOŻESZ GO&ODWIEDZAĆ KIEDY&CHCESZ./%%")
ds_map_add(global.text_data_en, "obj_paptv_152", "\E0OOH, TO MÓJ&ULUBIONY&TELETURNIEJ!/")
ds_map_add(global.text_data_en, "obj_paptv_153", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_paptv_154", "* (Pisze " + '"' + "BĄDŹ NA BIEŻĄCO&  Z NOWYM PROGRAMEM - MTT." + '"' + ")/")
ds_map_add(global.text_data_en, "obj_paptv_156", "\E1CO!!^1!&ZAZWYCZAJ JEST&LEPSZE OD TEGO!/")
ds_map_add(global.text_data_en, "obj_paptv_157", "\E2TO PO PROSTU&SŁABY ODCINEK!!^1!&NIE OCENIAJ MNIE!!!/%%")
ds_map_add(global.text_data_en, "obj_paptv_159", "* (Pisze " + '"' + "BĄDŹ NA BIEŻĄCO&  Z NOWYM PROGRAMEM - MTT.." + '"' + ")/%%")
ds_map_add(global.text_data_en, "obj_paptv_160", "* (Pisze " + '"' + "BĄDŹ NA BIEŻĄCO&  Z NOWYM PROGRAMEM - MTT.." + '"' + ")/%%")
ds_map_add(global.text_data_en, "obj_papyrus1_407", "WIĘC^1, TAK&JAK MÓWIŁEM&O UNDYNE,/%%")
ds_map_add(global.text_data_en, "obj_papyrus1_411", "\E2A WIĘC SANS^1!&KIEDY POJAWI&SIĘ CZŁOWIEK???/")
ds_map_add(global.text_data_en, "obj_papyrus1_412", "\E3CHCĘ WYGLĄDAĆ&NIEDZIELNIE&NAJLEPIEJ.../")
ds_map_add(global.text_data_en, "obj_papyrus1_413", "\E0ALBO CHOCIAŻ&WTORKOWO DOSYĆ&DOBRZE./")
ds_map_add(global.text_data_en, "obj_papyrus1_415", "\E1* czy ty nie masz&  tylko jeden strój?/")
ds_map_add(global.text_data_en, "obj_papyrus1_417", "\E2TA^1, ALE MOGĘ&UŁOŻYĆ LEPIEJ&MOJĄ FRYZURĘ!/")
ds_map_add(global.text_data_en, "obj_papyrus1_419", "\E0* oh^1. racja^1.&* dobry pomysł./")
ds_map_add(global.text_data_en, "obj_papyrus1_420", "\E1* powiedz^1, czemu nie&  spojrzyz o tam o?/%%")
ds_map_add(global.text_data_en, "obj_papyrus1_443", "SANS!!&O MÓJ BOŻE!!&CZY TO.../")
ds_map_add(global.text_data_en, "obj_papyrus1_444", "CZŁOWIEK!?!?&!??!?!/%%")
ds_map_add(global.text_data_en, "obj_papyrus1_453", "SANS!!&O MÓJ BOŻE!!&CZY TO.../")
ds_map_add(global.text_data_en, "obj_papyrus1_454", "CZŁOWIEK!?!?&!??!?!/")
ds_map_add(global.text_data_en, "obj_papyrus1_455", "I JESZCZE WYGLĄDA&ZNAJOMO...!!!/%%")
ds_map_add(global.text_data_en, "obj_papyrus1_459", "\E0SANS!!^1!&O MÓJ BOŻE!!!!/")
ds_map_add(global.text_data_en, "obj_papyrus1_460", "\E3NIEDOBRZE MI^1.&NA CO JA WŁAŚCIWIE&PATRZĘ?/")
ds_map_add(global.text_data_en, "obj_papyrus1_462", "\E1* prezentuję./%%")
ds_map_add(global.text_data_en, "obj_papyrus1_496", "* uhhhhh.../")
ds_map_add(global.text_data_en, "obj_papyrus1_497", "\E1* w sumie^1, to chyba&  zwykły kamień./%%")
ds_map_add(global.text_data_en, "obj_papyrus1_500", "* uhhhh..^1.&* dlatego wygląda&  znajomo.../")
ds_map_add(global.text_data_en, "obj_papyrus1_501", "\E1* bo to kamień?/%%")
ds_map_add(global.text_data_en, "obj_papyrus1_509", "\E0O MÓJ BOŻE!!!/%%")
ds_map_add(global.text_data_en, "obj_papyrus1_532", "OH^1./%%")
ds_map_add(global.text_data_en, "obj_papyrus1_534", "CZEMU KAŻESZ MI&PATRZEĆ SIĘ&NA KAMIEŃ./%%")
ds_map_add(global.text_data_en, "obj_papyrus1_547", "* hej^1, a co to takiego&  przed tym kamieniem?/%%")
ds_map_add(global.text_data_en, "obj_papyrus1_567", "O MÓJ BOŻE!!!/%%")
ds_map_add(global.text_data_en, "obj_papyrus1_579", "(CZY... CZY TO&CZŁOWIEK)/%%")
ds_map_add(global.text_data_en, "obj_papyrus1_581", "NIE MAM POJĘCIA&CO TO JEST./%%")
ds_map_add(global.text_data_en, "obj_papyrus1_592", "(tak)/%%")
ds_map_add(global.text_data_en, "obj_papyrus1_594", "* cóż^1.&* to nie kamień./%%")
ds_map_add(global.text_data_en, "obj_papyrus1_607", "O MÓJ BOŻE!!!/")
ds_map_add(global.text_data_en, "obj_papyrus1_608", "SANS!&W KOŃCU&TO ZROBIŁEM!!/")
ds_map_add(global.text_data_en, "obj_papyrus1_609", "UNDYNE BĘDZIE.../")
ds_map_add(global.text_data_en, "obj_papyrus1_610", "JA BĘDE.../")
ds_map_add(global.text_data_en, "obj_papyrus1_611", "JA BĘDE TAK.../")
ds_map_add(global.text_data_en, "obj_papyrus1_612", "POPULARNY!!^1!&POPULARNY!!^1!&POPULARNY!!^1!/")
ds_map_add(global.text_data_en, "obj_papyrus1_613", "\E3..^1.'AHEM'/")
ds_map_add(global.text_data_en, "obj_papyrus1_614", "\E1CZŁOWIEKU^1! &NIE PRZEJDZIESZS&TĄ DROGĄ!/")
ds_map_add(global.text_data_en, "obj_papyrus1_615", "JA^1, WIELKI PAPYRUS^1,&POWSTRZYMAM CIĘ!!!/")
ds_map_add(global.text_data_en, "obj_papyrus1_616", "I WTEDY&CIĘ PORWĘ!/")
ds_map_add(global.text_data_en, "obj_papyrus1_617", "BĘDZIESZ&PRZENIESIONY&DO STOLICY!/")
ds_map_add(global.text_data_en, "obj_papyrus1_618", "WTEDY..^1.&WTEDY!!^1!/")
ds_map_add(global.text_data_en, "obj_papyrus1_619", "\E3NIE JESTEM PEWIEN&CO WTEDY.../")
ds_map_add(global.text_data_en, "obj_papyrus1_620", "\E1W KAŻDYM RAZIE!/")
ds_map_add(global.text_data_en, "obj_papyrus1_621", "PRZEJDŹ DALEJ...&TYLKO JEŚLI&SIĘ ODWAŻYSZ!!!/%%")
ds_map_add(global.text_data_en, "obj_papyrus1_624", "\E3NIE KAMIEŃ...?/")
ds_map_add(global.text_data_en, "obj_papyrus1_625", "\E0NIENIE!!^1!&ELIMINUJĄC INNE&OPCJE.../")
ds_map_add(global.text_data_en, "obj_papyrus1_626", "\E0TO ZNACZY ŻE&TO CZŁOWIEK!!!/")
ds_map_add(global.text_data_en, "obj_papyrus1_627", "\E3AHEM!^1!&CZŁOWIEKU!!/")
ds_map_add(global.text_data_en, "obj_papyrus1_628", "\E4PRZYGOTUJ SIĘ!^1!&NA DUŻE WYZWANIA^1!&NA MAŁE WYZWANIA!/")
ds_map_add(global.text_data_en, "obj_papyrus1_629", "NIEBEZPIECZEŃSTWA^1!&ŁAMIGÓWKI^1!&SKOCZKI I ŻARTY!/")
ds_map_add(global.text_data_en, "obj_papyrus1_630", "BYCIE PORWANYM!^1!&I INNEGO RODZAJU&FAJNE AKTYWNOŚCI./")
ds_map_add(global.text_data_en, "obj_papyrus1_631", "PRZEKĄSKI ZOSTANĄ&PODAROWANE.../")
ds_map_add(global.text_data_en, "obj_papyrus1_632", "JEŚLI SIĘ ODWAŻYSZ!/%%")
ds_map_add(global.text_data_en, "obj_papyrus1_647", "NYEH HEH HEH&HEH HEH HEH&HEH HEH!!!/%%")
ds_map_add(global.text_data_en, "obj_papyrus1_667", "* cóż^1, to poszło dobrze./")
ds_map_add(global.text_data_en, "obj_papyrus1_668", "* nie stresuj się^1,&  wariacie./")
ds_map_add(global.text_data_en, "obj_papyrus1_669", "\E2* będę miał na ciebie&  oczodoły./%%")
ds_map_add(global.text_data_en, "obj_papyrus1_672", "* ... a ty nie mrugniesz&  nawet okiem^1, huh?/%%")
ds_map_add(global.text_data_en, "obj_papyrus2_201", "JESTEŚ TAKI&LENIWY!!/")
ds_map_add(global.text_data_en, "obj_papyrus2_202", "DRZEMAŁEŚ&SOBIE CAŁĄ&NOC!!/")
ds_map_add(global.text_data_en, "obj_papyrus2_204", "* to się chyba nazywa.../")
ds_map_add(global.text_data_en, "obj_papyrus2_205", "\E1* spaniem./")
ds_map_add(global.text_data_en, "obj_papyrus2_207", "WYMÓWKI^1,&WYMÓWKI!/%%")
ds_map_add(global.text_data_en, "obj_papyrus2_213", "ALE SZCZERZE!!^1!&TEN CZŁOWIEK!!!/")
ds_map_add(global.text_data_en, "obj_papyrus2_214", "\E2CZY ZNAM TĄ OSOBĘ???/")
ds_map_add(global.text_data_en, "obj_papyrus2_216", "* czy ty nie znasz.../")
ds_map_add(global.text_data_en, "obj_papyrus2_217", "\E1* kogo znasz?/")
ds_map_add(global.text_data_en, "obj_papyrus2_219", "PBPBPPBPT!!/")
ds_map_add(global.text_data_en, "obj_papyrus2_220", "OCZYWIŚCIĘ ŻE&ZNAM KOGO ZNAM!!/")
ds_map_add(global.text_data_en, "obj_papyrus2_221", "CHCIAŁEM WIEDZIEĆ&CZY TY ZNASZ.../")
ds_map_add(global.text_data_en, "obj_papyrus2_222", "CZY WIEM KOGO ZNAM&TAK SAMO JAK WIEM&ŻE ZNAM KOGO ZNAM!/")
ds_map_add(global.text_data_en, "obj_papyrus2_223", "\E2...WIESZ?/%%")
ds_map_add(global.text_data_en, "obj_papyrus2_256", "OHO^1!&PRZYBYWA&CZŁOWIEK!/")
ds_map_add(global.text_data_en, "obj_papyrus2_259", "OHO^1!&O WILKU MOWA!/")
ds_map_add(global.text_data_en, "obj_papyrus2_261", "ABY CIĘ&POWSTRZYMAĆ^1.../")
ds_map_add(global.text_data_en, "obj_papyrus2_262", "MÓJ BRAT I JA&PRZYGOTOWALIŚMY&KILKA PUZZLI!/")
ds_map_add(global.text_data_en, "obj_papyrus2_263", "LICZĘ^1, ŻE&UZNASZ&JĄ ZA.../")
ds_map_add(global.text_data_en, "obj_papyrus2_264", "\E2CAŁKIEM&SZOKUJĄCĄ!!!/")
ds_map_add(global.text_data_en, "obj_papyrus2_265", "\E0JAK WIDZISZ^1,&OTO NIEWIDZIALNY.../")
ds_map_add(global.text_data_en, "obj_papyrus2_266", "ISKRZĄCY&LABIRYNT!!!/")
ds_map_add(global.text_data_en, "obj_papyrus2_267", "JEŚLI DOTKNIESZ&ŚCIAN TEGO&LABIRYNTU,/")
ds_map_add(global.text_data_en, "obj_papyrus2_268", "TA KULA CIĘ&BRUTALNIE&PORAZI PRĄDEM!/")
ds_map_add(global.text_data_en, "obj_papyrus2_269", "\E2BRZMI&CIEKAWIE???/")
ds_map_add(global.text_data_en, "obj_papyrus2_270", "PONIEWAŻ!/")
ds_map_add(global.text_data_en, "obj_papyrus2_271", "BĘDZIESZ SIĘ&BAWIŁ,/")
ds_map_add(global.text_data_en, "obj_papyrus2_272", "\E3RACZEJ SŁABO./")
ds_map_add(global.text_data_en, "obj_papyrus2_273", "\E0OKEJ^1, MOŻESZ JUŻ&ZACZYNAĆ./%%")
ds_map_add(global.text_data_en, "obj_papyrus2_334", "SANS!!^1!&COŚ TY&ZROBIŁ?!?!/%%")
ds_map_add(global.text_data_en, "obj_papyrus2_347", "* wydaje mi się^1, że&  to człowiek musi&  trzymać kulę./%%")
ds_map_add(global.text_data_en, "obj_papyrus2_359", "OH^1, OKEJ./%%")
ds_map_add(global.text_data_en, "obj_papyrus2_396", "POTRZYMAJ TO&PROSZĘ!/%%")
ds_map_add(global.text_data_en, "obj_papyrus2_430", "OKEJ^1, SPRÓBUJ&TERAZ!/%%")
ds_map_add(global.text_data_en, "obj_papyrus2_452", "\E1NIESAMOWITE!!&TY CHYTRY&LISIE!!/")
ds_map_add(global.text_data_en, "obj_papyrus2_453", "\E3ROZWIĄZAŁEŚ TO&TAK PO PROSTU..^1.&ZBYT PROSTO!/")
ds_map_add(global.text_data_en, "obj_papyrus2_454", "\E0JEDNAKŻE!!/")
ds_map_add(global.text_data_en, "obj_papyrus2_455", "NASTĘPNA ZAGADKA&NIE BĘDZIE TAKA&ŁATWA!/")
ds_map_add(global.text_data_en, "obj_papyrus2_456", "ZOSTAŁA ZAPROJE-&KTOWANA PRZEZ MEGO&BRATA^1, SANSA!/")
ds_map_add(global.text_data_en, "obj_papyrus2_457", "Z PEWNOŚCIĄ&BĘDZIESZ MEGA&ZAMIESZANY!/")
ds_map_add(global.text_data_en, "obj_papyrus2_458", "WIEM^1, ŻE JA JESTEM!/")
ds_map_add(global.text_data_en, "obj_papyrus2_459", "NYEH HEH HEH&HEH HEH!!/%%")
ds_map_add(global.text_data_en, "obj_papyrus2_506", "OHO^1!&PRZYBYWA&CZŁOWIEK!/")
ds_map_add(global.text_data_en, "obj_papyrus2_507", "ABY CIĘ&POWSTRZYMAĆ^1.../")
ds_map_add(global.text_data_en, "obj_papyrus2_508", "MÓJ BRAT I JA&PRZYGOTOWALIŚMY&KILKA PUZZLI!/")
ds_map_add(global.text_data_en, "obj_papyrus2_509", "LICZĘ^1, ŻE&UZNASZ&JĄ ZA.../")
ds_map_add(global.text_data_en, "obj_papyrus2_510", "\E2CAŁKIEM&SZOKUJĄCĄ!!!/")
ds_map_add(global.text_data_en, "obj_papyrus2_511", "\E5TAK JAK WIDZISZ^1,&TO JEST.^1.&UH^1, NIEWIDZIALNY.../%%")
ds_map_add(global.text_data_en, "obj_papyrus2_552", "\E5UHHHHHH...?/")
ds_map_add(global.text_data_en, "obj_papyrus2_553", "\E3HMMM..^1. MUSISZ BYĆ&TERAZ W KULTU-&ROWYM SZOKU./")
ds_map_add(global.text_data_en, "obj_papyrus2_554", "\E0WIDZISZ^1, TAM^1, SKĄD&POCHODZĘ^1, TO JEST&KOCHANA TRADYCJA./")
ds_map_add(global.text_data_en, "obj_papyrus2_555", "ABY CIERPIEĆ PRZEZ&OKROPNE ZAGADKI BEZ&ŻADNEGO POWODU./")
ds_map_add(global.text_data_en, "obj_papyrus2_556", "\E5WIĘC^1, UH^1, PO PROSTU&WRÓC TAM I UM.../")
ds_map_add(global.text_data_en, "obj_papyrus2_557", ".../%%")
ds_map_add(global.text_data_en, "obj_papyrus2_601", "\E3EHH.../")
ds_map_add(global.text_data_en, "obj_papyrus2_602", "\E3CZEMU NIE MOGLIŚMY&TRAFIĆ NA CZŁOWIEKA&KTÓRY LUBI ZAGADKI??/%%")
ds_map_add(global.text_data_en, "obj_papyrus3_177", "CZŁOWIEKU!!^1!&MAM NADZIEJĘ^1, ŻE&JESTEŚ GOTOWY NA.../%%")
ds_map_add(global.text_data_en, "obj_papyrus3_200", "SANS!^1!&GDZIE JEST&ZAGADKA!!!/")
ds_map_add(global.text_data_en, "obj_papyrus3_202", "* jest dosłownie tu^1.&* na podłodze./")
ds_map_add(global.text_data_en, "obj_papyrus3_203", "\E1* uwierz mi^1.&* nie ma opcji^1, że&  on ominie tą./%%")
ds_map_add(global.text_data_en, "obj_papyrus3_206", "\E1* uwierz mi^1.&* nie ma opcji^1, że będzie&  w stanie ominąć tą./%%")
ds_map_add(global.text_data_en, "obj_papyrus3_245", "CO DO LICHA!!^1!&NIE POMINĄŁ&JEJ!?!?/")
ds_map_add(global.text_data_en, "obj_papyrus3_247", "* mówię ci^1.&* każdy lubi&  wykreślanki./")
ds_map_add(global.text_data_en, "obj_papyrus3_249", "O MÓJ BOŻE!!!/")
ds_map_add(global.text_data_en, "obj_papyrus3_250", "NIE MOGĘ PRACOWAĆ&W TYCH WARUNKACH!!/%%")
ds_map_add(global.text_data_en, "obj_papyrus3_254", "SANS!!^1!&TO NIC NIE ZROBIŁO!!!/")
ds_map_add(global.text_data_en, "obj_papyrus3_256", "* ups./")
ds_map_add(global.text_data_en, "obj_papyrus3_257", "\E2* wiedziałem^1, że&  powinienem był w zamian&  użyć krzyżówki./")
ds_map_add(global.text_data_en, "obj_papyrus3_259", "CO?!^1?&KRZYŻÓWKI!?/")
ds_map_add(global.text_data_en, "obj_papyrus3_260", "\E0W KOŃCU^1, COŚ NA CO&OBYDWOJE MOŻEMU&SIĘ ZGODZIĆ./%%")
ds_map_add(global.text_data_en, "obj_papyrus4_209", "HEJ!/")
ds_map_add(global.text_data_en, "obj_papyrus4_210", "TO TEN CZŁOWIEK!/")
ds_map_add(global.text_data_en, "obj_papyrus4_211", "\E0TA ŁAMIGÓWKA&CI SIĘ&SPODOBA!/")
ds_map_add(global.text_data_en, "obj_papyrus4_212", "ZOSTAŁO STWORZONE&PRZEZ.../%%")
ds_map_add(global.text_data_en, "obj_papyrus4_405", "\E3... TY TAK&NA POWAŻNIE?/")
ds_map_add(global.text_data_en, "obj_papyrus4_406", "\E1SANS!!^1!&POMOCY!!!/")
ds_map_add(global.text_data_en, "obj_papyrus4_407", "ON CIĄGLE POMIJA&MOJE PUZLE!/")
ds_map_add(global.text_data_en, "obj_papyrus4_408", "\E3ON POWINIENI POZ-&WOLIĆ WYTŁUMACZYĆ&MU ZASADY PUZZLI./")
ds_map_add(global.text_data_en, "obj_papyrus4_409", "\E0A POTEM IM POGROZIĆ&NIEŚMIESZNYMI&ŻARCIKAMI./")
ds_map_add(global.text_data_en, "obj_papyrus4_411", "* cóż^1, może on nie&  ma poczucia humoru./")
ds_map_add(global.text_data_en, "obj_papyrus4_413", "KAŻDY LUBI&ŻARTY!!!/")
ds_map_add(global.text_data_en, "obj_papyrus4_415", "* a co z undyne^1?&* czyż ona&  nienawidzi puzzli?/")
ds_map_add(global.text_data_en, "obj_papyrus4_417", "NIENAWIDZI PUZZLI^1.&ALE KOCHA ŻARTY./")
ds_map_add(global.text_data_en, "obj_papyrus4_419", "* to ma sens./")
ds_map_add(global.text_data_en, "obj_papyrus4_421", "CZŁOWIEKU!^1!&CO O TYM&MYŚLISZ!?/")
ds_map_add(global.text_data_en, "obj_papyrus4_422", "PUZZLE CZY ŻARTY?/")
ds_map_add(global.text_data_en, "obj_papyrus4_423", ".../")
ds_map_add(global.text_data_en, "obj_papyrus4_424", "\E3.../")
ds_map_add(global.text_data_en, "obj_papyrus4_425", "OKEJ^1, TO JEST&NORMALNIE CZĘŚĆ./")
ds_map_add(global.text_data_en, "obj_papyrus4_426", "W KTÓREJ ZGADZASZ&SIĘ ALBO NIE./")
ds_map_add(global.text_data_en, "obj_papyrus4_427", "I ZALEŻNIE OD&TWOJEJ DECYZJI./")
ds_map_add(global.text_data_en, "obj_papyrus4_428", "\E0MY MÓWIMY COŚ&ŚWIETNEGO W&ZAMIAN./")
ds_map_add(global.text_data_en, "obj_papyrus4_429", "\E3.../")
ds_map_add(global.text_data_en, "obj_papyrus4_430", "\E0DOBRA^1, MOŻE ROZWIĄ&ŻESZ TĄ ZAGADKĘ&SAMODZIELNIE./%%")
ds_map_add(global.text_data_en, "obj_papyrus5_209", "CZŁOWIEKU!/")
ds_map_add(global.text_data_en, "obj_papyrus5_210", "\E3HMMM..^1.&JAKBY TO&POWIEDZIEĆ.../")
ds_map_add(global.text_data_en, "obj_papyrus5_211", "\E0ZAJĘŁO CI TO&DUŻO CZASU^1, BY&PRZYBYĆ^1, WIĘC.../")
ds_map_add(global.text_data_en, "obj_papyrus5_212", "POSTANOWIŁEM&ULEPSZYĆ TĄ&ZAGADKĘ.../")
ds_map_add(global.text_data_en, "obj_papyrus5_213", "POPRZEZ UFORMOWANIE&ŚNIEGU^1, BY PRZYPO-&MINAŁO MOJĄ TWARZ./")
ds_map_add(global.text_data_en, "obj_papyrus5_214", "\E3NIESTETY^1,&ŚNIEG PRZYMARZŁ&DO PODŁOŻA./")
ds_map_add(global.text_data_en, "obj_papyrus5_215", "\E1TERAZ ROZWIĄZANIE&JEST INNE!/")
ds_map_add(global.text_data_en, "obj_papyrus5_216", "I^1, JAK ZWYKLE^1, MÓJ&LENIWY BRAT JEST&NIGDZIE W POBLIŻU./")
ds_map_add(global.text_data_en, "obj_papyrus5_217", "\E3ZAKŁADAM ŻE TO^1,&CO CHCĘ POWIEDZIEĆ&TO.../")
ds_map_add(global.text_data_en, "obj_papyrus5_218", "\E0NIE OBAWIAJ SIĘ^1,&CZŁOWIEKU!/")
ds_map_add(global.text_data_en, "obj_papyrus5_219", "JA^1, WIELKI PAPYRUS^1,&POMOGĘ ROZWIĄZAĆ&TEN DYLEMAT!/")
ds_map_add(global.text_data_en, "obj_papyrus5_220", "WTEDY BĘDZIEMY&MOGLI OBYDWOJE&KONTYNUOWAĆ!/")
ds_map_add(global.text_data_en, "obj_papyrus5_221", "W MIĘDZYCZASIE^1,&SPRÓBUJ SAMEMU&TO ROZWIĄZAĆ!/")
ds_map_add(global.text_data_en, "obj_papyrus5_222", "POSTARAM SIĘ&NIE PODAWAĆ&ROZWIĄZANIA!!!/%%")
ds_map_add(global.text_data_en, "obj_papyrus5_281", "WOW!!^1!&ROZWIĄZAŁEŚ TO!!/")
ds_map_add(global.text_data_en, "obj_papyrus5_282", "I ZROBIŁEŚ TO&WSZYSTKO BEZ&MOJEJ POMOCY.../")
ds_map_add(global.text_data_en, "obj_papyrus5_283", "MOJA RADA POMOGŁA^1!&NAPRAWDĘ CI&POMOGŁA!!/")
ds_map_add(global.text_data_en, "obj_papyrus5_289", "WSPANIAŁE^1!&JESTEM POD&WRAŻENIEM!!/")
ds_map_add(global.text_data_en, "obj_papyrus5_290", "MUSISZ KOCHAĆ&ŁAMIGÓWKI TAK&MOCNO JAK JA!/")
ds_map_add(global.text_data_en, "obj_papyrus5_291", "CÓŻ^1, JESTEM PEWNY&ŻE POKOCHASZ&TĄ ŁAMIGÓWKĘ!/")
ds_map_add(global.text_data_en, "obj_papyrus5_292", "TO MOŻE BYĆ NAWET&ZBYT ŁATWE DLA&CIEBIE!!/")
ds_map_add(global.text_data_en, "obj_papyrus5_293", "NYEH^1!&HEH HEH^1!&HEHEHEH!!!/%%")
ds_map_add(global.text_data_en, "obj_papyrus6_138", "CZŁOWIEKU!/%%")
ds_map_add(global.text_data_en, "obj_papyrus7_156", "CZŁOWIEKU!/")
ds_map_add(global.text_data_en, "obj_papyrus7_157", "TO TWOJE FINALNE I&NAJBARDZIEJ NIEBEZ&-PIECZNE WYZWANIE!/")
ds_map_add(global.text_data_en, "obj_papyrus7_158", "STRZEŻ SIĘ^1!&OTO RĘKAWICA ŚMIER-&TELNEGO TERRORU!/%%")
ds_map_add(global.text_data_en, "obj_papyrus7_194", "KIEDY TYLKO POWIEM&SŁOWO^1, TO SIĘ W&PEŁNI URUCHOMI!!!/")
ds_map_add(global.text_data_en, "obj_papyrus7_195", "ARMATY WYSTRZELĄ^1!&KOLCZATKI PRZELECĄ^1!&OSTRZA POCIACHAJĄ^1!/")
ds_map_add(global.text_data_en, "obj_papyrus7_196", "WSZYSTKO BĘDZIE SIĘ&HUŚTAĆ BEZLITOŚNIE&W GÓRĘ I W DÓŁ!/")
ds_map_add(global.text_data_en, "obj_papyrus7_197", "POZOSTANIE&NAJMNIEJSZA SZANSA&PRZETRWANIA!!!/")
ds_map_add(global.text_data_en, "obj_papyrus7_198", "JESTEŚ GOTOWY!?/")
