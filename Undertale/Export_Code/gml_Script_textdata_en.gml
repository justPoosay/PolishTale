ds_map_add(global.text_data_en, "obj_jerry_164", "Guys, jest ZIMNO.&Czy KTOKOLWIEK&zwrócił uwagę?")
ds_map_add(global.text_data_en, "obj_jerry_165", "Czemu to robimy?&Co za porażka.")
ds_map_add(global.text_data_en, "obj_jerry_166", "Wow, wy guys&jesteście w tym&OKROPNI.")
ds_map_add(global.text_data_en, "obj_jerry_167", "SHHHH! Ja tu&MYŚLĘ, guys!!")
ds_map_add(global.text_data_en, "obj_jerry_168", "Ka-SIGH.")
ds_map_add(global.text_data_en, "obj_jerry_171", "Cóż... czy TY&dasz mi&podwózkę&do domu?")
ds_map_add(global.text_data_en, "obj_jerry_172", "Huh? Czy oni&mnie PORZUCILI...?&Tacy PRZYJACIELE!")
ds_map_add(global.text_data_en, "obj_jerry_173", "Ale siaraa.")
ds_map_add(global.text_data_en, "obj_jerry_174", "Więc, jakby,&co ty wogule&robisz?")
ds_map_add(global.text_data_en, "obj_jerry_175", "Wifi tutaj&ssie ;-;")
ds_map_add(global.text_data_en, "obj_jerry_199", "Hahaha!&Powiedz coś&śmiesznego!")
ds_map_add(global.text_data_en, "obj_jerry_200", "Haha! Wow!&Drake, ty&ssiesz!")
ds_map_add(global.text_data_en, "obj_jerry_201", "Hahaha!&Skąd ty bierzesz&te pomysły!?!")
ds_map_add(global.text_data_en, "obj_jerry_207", "%%%")
ds_map_add(global.text_data_en, "obj_jerry_407", "* Jerry je proszkowate jedzenie&  i głośno liże swoje ręce.")
ds_map_add(global.text_data_en, "obj_jerry_408", "* Jerry kicha nie zasłaniając&  twarzy?? XDD")
ds_map_add(global.text_data_en, "obj_jerry_409", "* Jerry mówi wszystkim że&  musi iść do toalety.")
ds_map_add(global.text_data_en, "obj_jerry_410", "* Jerry ziewa z nudów.")
ds_map_add(global.text_data_en, "obj_jerry_411", "* Pachnie jak....... Jerry.")
ds_map_add(global.text_data_en, "obj_jerry_412", "* Jerry jest zraniony.")
ds_map_add(global.text_data_en, "obj_jerry_414", "* Inne potwory celebrują&  zniknięcie Jerry'ego.")
ds_map_add(global.text_data_en, "obj_jerry_415", "* Powrót Jerry'ego.")
ds_map_add(global.text_data_en, "obj_jerry_442", "* JERRY - ATK 0 DEF 30&* Każdy zna Jerry'ego.&* Robi ataki 2 sekundy dłużej./^")
ds_map_add(global.text_data_en, "obj_jerry_450", "* Ty i inne potworu&  porzucacie Jerry'ego&  kiedy się odwrócił!/^")
ds_map_add(global.text_data_en, "obj_jetpackchara_198", "* PROSZĘ&  PROSZĘ./")
ds_map_add(global.text_data_en, "obj_jetpackchara_199", "* WYGLĄDA NA TO ŻE&  MNIE PRZECHYTRZYŁEŚ./")
ds_map_add(global.text_data_en, "obj_jetpackchara_200", "* ALE TYLKO DZIĘKI TEMU ŻE&  MIAŁEŚ POMOC WSPANIAŁEJ&  DOKTOR ALPHYS!/")
ds_map_add(global.text_data_en, "obj_jetpackchara_201", "* OH^1, BRZYDZĘ SIĘ MYŚLĄ&  CO BY SIĘ STAŁO TOBIE&  BEZ JEJ POMOCY!!!/")
ds_map_add(global.text_data_en, "obj_jetpackchara_203", "* CÓŻ^1, PAPATKI!!/%%")
ds_map_add(global.text_data_en, "obj_jetpackchara_223", "* O TAK^1!&* CO DO TEJ ALTERNATYWY.../")
