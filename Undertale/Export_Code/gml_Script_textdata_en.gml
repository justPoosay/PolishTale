ds_map_add(global.text_data_en, "obj_icecap_139", "Gdzie&TWOJA&czapka?")
ds_map_add(global.text_data_en, "obj_icecap_140", "Twoja&głowa&jest taka&...GOŁA")
ds_map_add(global.text_data_en, "obj_icecap_141", "Co za&świetna&czapka!&(Moja)")
ds_map_add(global.text_data_en, "obj_icecap_142", "Śnieg?&Nie! To&resztki&czapki.")
ds_map_add(global.text_data_en, "obj_icecap_143", "Po prostu&kooocham&mą czapkę.&OK?")
ds_map_add(global.text_data_en, "obj_icecap_148", "Dobra!!!&Nie&obchodzi&mnie to!!!")
ds_map_add(global.text_data_en, "obj_icecap_149", "OK!&Ja też&cię zig-&noruję.")
ds_map_add(global.text_data_en, "obj_icecap_150", "LepszY&czapkarZ&niż&HEJTER.")
ds_map_add(global.text_data_en, "obj_icecap_156", "HALO???&moja&czapka&jest tutaj.")
ds_map_add(global.text_data_en, "obj_icecap_157", "Co?&Co ty&robisz?")
ds_map_add(global.text_data_en, "obj_icecap_163", "DUH!&Kto&NIE&wie?")
ds_map_add(global.text_data_en, "obj_icecap_164", "Zazdrosny?&WOMP&WOMP!")
ds_map_add(global.text_data_en, "obj_icecap_165", "Moja czapka&jest zbyt&głośna by&cię słyszeć.")
ds_map_add(global.text_data_en, "obj_icecap_169", "WIEDZI-&AŁEM!!!&ZŁODZIEJ!!")
ds_map_add(global.text_data_en, "obj_icecap_170", "POMOCY!!!&PSI&PATROL!!")
ds_map_add(global.text_data_en, "obj_icecap_175", "Haha!&To było&ŚMIESZNE!")
ds_map_add(global.text_data_en, "obj_icecap_176", "Ha!&Podnie-&ciłeś&się!")
ds_map_add(global.text_data_en, "obj_icecap_177", "To&najlepszy&z wszys-&tkich!")
ds_map_add(global.text_data_en, "obj_icecap_182", "%%%")
ds_map_add(global.text_data_en, "obj_icecap_374", "* Pada łupież zamiast śniegu.")
ds_map_add(global.text_data_en, "obj_icecap_375", "* Ice Cap chce też czapkę&  na swój nos.")
ds_map_add(global.text_data_en, "obj_icecap_376", "* Ice Cap upewnia się, że jego&  czapka dalej tam leży.")
ds_map_add(global.text_data_en, "obj_icecap_377", "* Ice Cap myśli o jakimś&  artykule mody.")
ds_map_add(global.text_data_en, "obj_icecap_378", "* Oto nadchodzi zapach&  nowych ubrań.")
ds_map_add(global.text_data_en, "obj_icecap_379", "* Ice Cap sekretnie sprawdza&  czy patrzysz się na jego&  czapkę.")
ds_map_add(global.text_data_en, "obj_icecap_380", "* Ice Cap desperacko&  pragnie atencji.")
ds_map_add(global.text_data_en, "obj_icecap_381", "* Czapka Ice Capa jest luźna.")
