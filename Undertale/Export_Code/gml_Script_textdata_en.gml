ds_map_add(global.text_data_en, "obj_killerlab_event_120", "\M2* POSTANOWIŁA Z TOBĄ NIE WALCZYĆ^1.&* PROSZĘ PROSZĘ^1, ONA NAPRAWDĘ&  JEST JEDYNĄ MĄDRĄ^1, CZYŻ NIE?/%%")
