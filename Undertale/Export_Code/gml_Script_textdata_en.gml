ds_map_add(global.text_data_en, "obj_toriel_friendc_70", "* Hello^1, Frisk^1.&* Alphys upgraded my&  phone./")
ds_map_add(global.text_data_en, "obj_toriel_friendc_71", "* I am having a lot&  of fun with the&  " + '"' + "texting" + '"' + " feature./")
ds_map_add(global.text_data_en, "obj_toriel_friendc_72", "* Sans^1, " + '"' + "check out" + '"' + " this&  one./")
ds_map_add(global.text_data_en, "obj_toriel_friendc_74", "* oh man^1, tori.../")
ds_map_add(global.text_data_en, "obj_toriel_friendc_75", "\E1* that's brutal./")
ds_map_add(global.text_data_en, "obj_toriel_friendc_77", "I CAN'T BELIEVE&THE QUEEN HAS&RETURNED.../")
ds_map_add(global.text_data_en, "obj_toriel_friendc_78", "\E4AND ALSO THAT&SHE'S A HUGE&DORK!!!/")
ds_map_add(global.text_data_en, "obj_toriel_friendc_79", "YOU TWO ARE TWO&FEET AWAY FROM&EACH OTHER!!!/")
ds_map_add(global.text_data_en, "obj_toriel_friendc_80", "WHY ARE YOU&TEXTING!!!/")
ds_map_add(global.text_data_en, "obj_toriel_friendc_82", "* Worry not^1, Papyrus^1.&* We are texting for&  a good reason./")
ds_map_add(global.text_data_en, "obj_toriel_friendc_84", "WHY IS THAT./")
ds_map_add(global.text_data_en, "obj_toriel_friendc_86", "* well./")
ds_map_add(global.text_data_en, "obj_toriel_friendc_87", "\E2* cause we're huge&  dorks./")
ds_map_add(global.text_data_en, "obj_toriel_friendc_89", "* Sans^1, please do&  not say that./")
ds_map_add(global.text_data_en, "obj_toriel_friendc_90", "* You are not a dork./")
ds_map_add(global.text_data_en, "obj_toriel_friendc_91", "\E0* You are more of&  a bonehead!/")
ds_map_add(global.text_data_en, "obj_toriel_friendc_93", "HAHAHA^1, WOW!/")
ds_map_add(global.text_data_en, "obj_toriel_friendc_94", "\E0THOSE PUNS ARE&EVEN LESS FUNNY&COMING FROM HER!/")
ds_map_add(global.text_data_en, "obj_toriel_friendc_96", "* then why are you&  smiling?/")
ds_map_add(global.text_data_en, "obj_toriel_friendc_98", "IT'S A PITY&SMILE!!!/%%")
ds_map_add(global.text_data_en, "obj_toriel_friendc_103", "* Frisk^1, do not feel&  left out./")
ds_map_add(global.text_data_en, "obj_toriel_friendc_104", "* I have been writing&  messages to you as&  well!/")
ds_map_add(global.text_data_en, "obj_toriel_friendc_105", "\W* You still have \Ymy&  phone number\W after&  all this time.../")
ds_map_add(global.text_data_en, "obj_toriel_friendc_106", "* Do you not?/%%")
ds_map_add(global.text_data_en, "obj_toriel_friendc_111", "* Frisk^1, how about&  you go look around&  before we all go?/")
ds_map_add(global.text_data_en, "obj_toriel_friendc_112", "* Seeing how many good&  friends you've made&  here.../")
ds_map_add(global.text_data_en, "obj_toriel_friendc_113", "* I am almost certain&  you must have made&  some more./%%")
ds_map_add(global.text_data_en, "obj_torielboss_366", " .....")
ds_map_add(global.text_data_en, "obj_torielboss_367", " .....& .....")
ds_map_add(global.text_data_en, "obj_torielboss_368", " .....& .....& .....")
ds_map_add(global.text_data_en, "obj_torielboss_369", " ...?")
ds_map_add(global.text_data_en, "obj_torielboss_370", " Co ty& wypra-& wiasz?")
ds_map_add(global.text_data_en, "obj_torielboss_371", " Atakuj& albo& uciekaj!")
ds_map_add(global.text_data_en, "obj_torielboss_372", " Co ty& próbujesz& udo-& wodnić?")
ds_map_add(global.text_data_en, "obj_torielboss_373", " Walzc& albo& odejdź!")
ds_map_add(global.text_data_en, "obj_torielboss_374", " Przestań.")
ds_map_add(global.text_data_en, "obj_torielboss_376", " Przestań& tak na& mnie& patrzeć.")
ds_map_add(global.text_data_en, "obj_torielboss_377", " Idź& stąd!")
ds_map_add(global.text_data_en, "obj_torielboss_378", " ...")
ds_map_add(global.text_data_en, "obj_torielboss_380", " ...& ...")
ds_map_add(global.text_data_en, "obj_torielboss_388", "Wiem^1, że&chcesz iść&do domu^1,&ale...")
ds_map_add(global.text_data_en, "obj_torielboss_390", "Ale proszę&idź teraz&na górę.")
ds_map_add(global.text_data_en, "obj_torielboss_391", "Obiecuję^1, że&dobrze się&tobą zajmą.")
ds_map_add(global.text_data_en, "obj_torielboss_392", "Wiem^1, że&nie mamy&wiele^1, ale...")
ds_map_add(global.text_data_en, "obj_torielboss_393", "Możemy mieć&tutaj dobre&życie.")
ds_map_add(global.text_data_en, "obj_torielboss_395", "Dlaczego&musisz to&tak utrudniać?")
ds_map_add(global.text_data_en, "obj_torielboss_397", "Proszę^1, idź&na górę.")
ds_map_add(global.text_data_en, "obj_torielboss_399", ".....")
ds_map_add(global.text_data_en, "obj_torielboss_401", "Ha ha...")
ds_map_add(global.text_data_en, "obj_torielboss_402", "Żałosne^1, czyż nie^2?&Nie mogę nawet urato-&wać jednego dziecka.")
ds_map_add(global.text_data_en, "obj_torielboss_403", "...")
ds_map_add(global.text_data_en, "obj_torielboss_416", "Nie^1, rozumiem./")
ds_map_add(global.text_data_en, "obj_torielboss_417", "Byłbyś tylko&nieszczęśliwy&tu na dole./")
ds_map_add(global.text_data_en, "obj_torielboss_418", "RUINY są bardzo&małe, gdy się do&nich przyzwyczaisz./")
ds_map_add(global.text_data_en, "obj_torielboss_419", "To nie byłoby&odpowiedzialne^1,&byś dorastał&w takim miejscu./")
ds_map_add(global.text_data_en, "obj_torielboss_420", "Me oczekiwania...&Ma samotność...&Mój strach.../")
ds_map_add(global.text_data_en, "obj_torielboss_421", "Dla ciebie^1,&me dziecię...&odłoże te marzenia&na bok./%%")
ds_map_add(global.text_data_en, "obj_torielboss_445", "\E0Urgh.../")
ds_map_add(global.text_data_en, "obj_torielboss_446", "\E0Jesteś silniejszy&niż zakładałam.../")
ds_map_add(global.text_data_en, "obj_torielboss_447", "Słuchaj mnie& teraz^1, malutki.../")
ds_map_add(global.text_data_en, "obj_torielboss_448", "Jeśli wyjdziesz&za te drzwi,/")
ds_map_add(global.text_data_en, "obj_torielboss_449", "Idź przed siebie&cały czas./")
ds_map_add(global.text_data_en, "obj_torielboss_450", "Ostatecznie&dojdziesz do&wyjścia./")
ds_map_add(global.text_data_en, "obj_torielboss_451", "\E1..^1.&..../")
ds_map_add(global.text_data_en, "obj_torielboss_452", "\RASGORE\X..^1.&Nie pozwól \RASGOROWI\X &zabrać ci DUSZĘ./")
ds_map_add(global.text_data_en, "obj_torielboss_453", "Jego plan&nie może&się powieść./")
ds_map_add(global.text_data_en, "obj_torielboss_454", "\E2....../")
ds_map_add(global.text_data_en, "obj_torielboss_455", "Będziesz grzeczny^1,&prawda?/")
ds_map_add(global.text_data_en, "obj_torielboss_456", "\E3Habibi..      %%")
ds_map_add(global.text_data_en, "obj_torielboss_460", "N... Naprawdę...&tak bardzo mnie&nienawidzisz?/")
ds_map_add(global.text_data_en, "obj_torielboss_461", "Teraz widzę kogo&chroniłam przez&ten cały czas./")
ds_map_add(global.text_data_en, "obj_torielboss_462", "Nie ciebie.../")
ds_map_add(global.text_data_en, "obj_torielboss_463", "\E5Ale \RJĄ\X!/")
ds_map_add(global.text_data_en, "obj_torielboss_464", "\E3Ha... ha... %%")
ds_map_add(global.text_data_en, "obj_torielboss_469", "\E4Ty.../")
ds_map_add(global.text_data_en, "obj_torielboss_470", "... w moim&najbardziej&podatnym&momencie.../")
ds_map_add(global.text_data_en, "obj_torielboss_471", "I pomyśleć^1, że&martwiłam się&że nie wpasujesz&się tutaj.../")
ds_map_add(global.text_data_en, "obj_torielboss_472", "\E5Eheheheh!!!&Ty naprawdę&nie różnisz się&od nich!/")
ds_map_add(global.text_data_en, "obj_torielboss_473", "\E3Ha... ha... %%")
ds_map_add(global.text_data_en, "obj_torielboss_803", "* Toriel przygotowuje&  magiczny atak.")
ds_map_add(global.text_data_en, "obj_torielboss_804", "* Toriel patrzy przez ciebie.")
ds_map_add(global.text_data_en, "obj_torielboss_805", "* Toriel zachowuje&  się z dystansem.")
ds_map_add(global.text_data_en, "obj_torielboss_806", "* Toriel bierze głęboki oddech.")
ds_map_add(global.text_data_en, "obj_torielboss_809", "* ...")
ds_map_add(global.text_data_en, "obj_torielboss_834", "* TORIEL - ATK 80 DEF 80&* Wie co dla ciebie najlepsze./^")
ds_map_add(global.text_data_en, "obj_torielboss_843", "* Nie mogłeś wymyśkeć&  żadnego tematu&  do rozmowy./^")
ds_map_add(global.text_data_en, "obj_torielboss_847", "* Spróbowałeś coś&  znów wymyśleć^1, &  ale.../^")
ds_map_add(global.text_data_en, "obj_torielboss_848", "* Ironicznie^1, rozmowa nie&  wydaje się być rozwiązaniem&  do tej sytuacji./^")
ds_map_add(global.text_data_en, "obj_torielboss_850", "* Pomyślałeś, by powiedzieć&  Toriel^1, że widziałeś&  jak umiera./")
ds_map_add(global.text_data_en, "obj_torielboss_851", "* Ale...&* To zbyt mroczne./")
ds_map_add(global.text_data_en, "obj_torielboss_852", "* Czy dasz radę pokazać&  litość nie walcząc&  ani uciekając...?/^")
ds_map_add(global.text_data_en, "obj_torielboss_854", "* Czy dasz radę pokazać&  litość nie uciekając...?/^")
ds_map_add(global.text_data_en, "obj_torielboss_855", "* Niewarte twojego czsu./^")
ds_map_add(global.text_data_en, "obj_torielcall1_90", "* Dzyn dzyn..\E0.\TT /")
ds_map_add(global.text_data_en, "obj_torielcall1_91", "\F1 %")
ds_map_add(global.text_data_en, "obj_torielcall1_92", "* Halo?&* Mówi TORIEL./")
ds_map_add(global.text_data_en, "obj_torielcall1_93", "\E1* Nie opuściłes tamtego&  pomieszczenia^1, prawda?/")
ds_map_add(global.text_data_en, "obj_torielcall1_94", "* Jest kilka puzzli^1,&  których jeszczę ci&  nie wyjaśniłam./")
ds_map_add(global.text_data_en, "obj_torielcall1_95", "* Byłoby niebezpiezcnie,&  gdybyś samodzielnie&  próbował je rozwiązać./")
ds_map_add(global.text_data_en, "obj_torielcall1_96", "* Bądź grzeczny^1,&  w porządku?/")
ds_map_add(global.text_data_en, "obj_torielcall1_97", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_torielcall1_98", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_torielcall1_102", "* Dzyn..\E1.\TT /")
ds_map_add(global.text_data_en, "obj_torielcall1_103", "\F1 %")
ds_map_add(global.text_data_en, "obj_torielcall1_104", "* Halo^1? Halo^1?&* Mówi TORIEL./")
ds_map_add(global.text_data_en, "obj_torielcall1_105", "* Moje kondolencje^1.&* Dziwny pieseł&  ukradł mi telefon./")
ds_map_add(global.text_data_en, "obj_torielcall1_106", "* Więc jeśli dzwoniłeś^1,&  nie byłam w stanie&  ci pomóc./")
ds_map_add(global.text_data_en, "obj_torielcall1_107", "\E0* Na szczęście^1,&  odzyskałam go./")
ds_map_add(global.text_data_en, "obj_torielcall1_108", "* A ty jesteś nadal&  w pomieszczeniu^1,&  prawda?/")
ds_map_add(global.text_data_en, "obj_torielcall1_109", "* Jakim grzecznym&  dzieckiem jesteś./")
ds_map_add(global.text_data_en, "obj_torielcall1_110", "\E1* Jest kilka puzzli^1,&  których jeszczę ci&  nie wyjaśniłam./")
ds_map_add(global.text_data_en, "obj_torielcall1_111", "* Byłoby niebezpiezcnie,&  gdybyś samodzielnie&  próbował je rozwiązać./")
ds_map_add(global.text_data_en, "obj_torielcall1_112", "\E1* Bądź grzeczny^1, okej?/")
ds_map_add(global.text_data_en, "obj_torielcall1_113", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_torielcall1_114", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_torielcall3_88", "* Dzyn dzyn..\E0.\TT /")
ds_map_add(global.text_data_en, "obj_torielcall3_89", "\F1 %")
ds_map_add(global.text_data_en, "obj_torielcall3_90", "* Halo?&* Mówi TORIEL./")
ds_map_add(global.text_data_en, "obj_torielcall3_91", "\E1* Nie BRZYDZISZ się&  natomiast toffi^1,&  prawda?/")
ds_map_add(global.text_data_en, "obj_torielcall3_92", "\E1* Nie BRZYDZISZ się&  natomiast cynamonu^1,&  prawda?/")
ds_map_add(global.text_data_en, "obj_torielcall3_93", "* Poznałam twoją&  preferencję^1, ale.../")
ds_map_add(global.text_data_en, "obj_torielcall3_94", "* Odmówiłbyś, gdybyś&  to miał na talerzu?/")
ds_map_add(global.text_data_en, "obj_torielcall3_95", "* Tak^1, tak^1,&  rozumiem./")
ds_map_add(global.text_data_en, "obj_torielcall3_96", "\E0* Dziękuję za&  cierpliwość^1,&  tak wogule./")
ds_map_add(global.text_data_en, "obj_torielcall3_97", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_torielcall3_98", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_torielcall4_88", "* Dzyn dzyn..\E0.\TT /")
ds_map_add(global.text_data_en, "obj_torielcall4_89", "\F1 %")
ds_map_add(global.text_data_en, "obj_torielcall4_90", "* Halo?/")
ds_map_add(global.text_data_en, "obj_torielcall4_91", "\E1* Nie posiadasz żadnych&  alergii^1, prawda?/")
ds_map_add(global.text_data_en, "obj_torielcall4_92", "* Huh^1?&* Dlaczego pytam?/")
ds_map_add(global.text_data_en, "obj_torielcall4_93", "\E0* Bez powodu..^1.&* Z czystej ciekawości./")
ds_map_add(global.text_data_en, "obj_torielcall4_94", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_torielcall4_95", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_torielcall5_90", "* Dzyn dzyn..\E0.\TT /")
ds_map_add(global.text_data_en, "obj_torielcall5_91", "\F1 %")
ds_map_add(global.text_data_en, "obj_torielcall5_92", "* Halo?/")
ds_map_add(global.text_data_en, "obj_torielcall5_93", "\E1* Właśnie sobie&  uświadomiłam, że dawnu&  tu ostatnio sprzątałam./")
ds_map_add(global.text_data_en, "obj_torielcall5_94", "\E0* Nie spodziewałam się&  gości tak szybko./")
ds_map_add(global.text_data_en, "obj_torielcall5_95", "* Jest prawdopodnie wiele&  leżących tutaj wokół./")
ds_map_add(global.text_data_en, "obj_torielcall5_96", "* Możesz je podnieść^1,&  ale nie podnoś więcej&  niż potrzebuję./")
ds_map_add(global.text_data_en, "obj_torielcall5_97", "* Jednego dnia możesz&  znaleźć coś^1, co może ci&  się bardzo spodobać./")
ds_map_add(global.text_data_en, "obj_torielcall5_98", "* Będziech chciał&  zostawić trochę wolnego&  miejsca w kieszeniach./")
ds_map_add(global.text_data_en, "obj_torielcall5_99", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_torielcall5_100", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_torielcall5_104", "* Dzyn dzyn..\E0.\TT /")
ds_map_add(global.text_data_en, "obj_torielcall5_105", "\F1 %")
ds_map_add(global.text_data_en, "obj_torielcall5_106", "* Halo?/")
ds_map_add(global.text_data_en, "obj_torielcall5_107", "\E1* Mam pytanie./")
ds_map_add(global.text_data_en, "obj_torielcall5_108", "* Lubisz rzeczy ine niż&  toffi czy cynamon^1,&  również.../")
ds_map_add(global.text_data_en, "obj_torielcall5_109", "* Czyż nie?/")
ds_map_add(global.text_data_en, "obj_torielcall5_110", "\E0* ..^1. oh^1, o co ja&  pytam./")
ds_map_add(global.text_data_en, "obj_torielcall5_111", "* Pójdę szukać./%%")
ds_map_add(global.text_data_en, "obj_torielcall5_112", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_torielcall5_113", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_torieltrigger10_77", "* Każdego człowieka^1, który&  tu spada^1, czeka ten sam&  los./")
ds_map_add(global.text_data_en, "obj_torieltrigger10_78", "* Widziałam to już&  wielokrotnie./")
ds_map_add(global.text_data_en, "obj_torieltrigger10_79", "* Przychodzą./")
ds_map_add(global.text_data_en, "obj_torieltrigger10_80", "* Opuszczają./")
ds_map_add(global.text_data_en, "obj_torieltrigger10_81", "* Umierają./")
ds_map_add(global.text_data_en, "obj_torieltrigger10_82", "* Ty naiwne dziecko..^1.&* Jeśli opuścisz&  RUINY.../")
ds_map_add(global.text_data_en, "obj_torieltrigger10_83", "\W* Oni..^1.&* \RASGORE\W..^1.&* Zabiją cię./")
ds_map_add(global.text_data_en, "obj_torieltrigger10_84", "* Ja cię tylko chronię^1,&  rozumiesz?/")
ds_map_add(global.text_data_en, "obj_torieltrigger10_85", "* ... idź do twojego&  pokoju./%%")
ds_map_add(global.text_data_en, "obj_torieltrigger11_79", "* Nie próbuj mnie&  powstrzymać./")
ds_map_add(global.text_data_en, "obj_torieltrigger11_80", "* To twoje ostatnie&  ostrzeżenie./%%")
ds_map_add(global.text_data_en, "obj_torieltrigger12_86", "\E0* Żegnaj^1, me dziecko./%%")
ds_map_add(global.text_data_en, "obj_torieltrigger12_149", "\E2* Zgadza się./")
ds_map_add(global.text_data_en, "obj_torieltrigger12_150", "* Idź na górę./%%")
ds_map_add(global.text_data_en, "obj_torieltrigger12_183", "\E2* Jeśli szczerze chcesz&  opuścić RUINY.../")
ds_map_add(global.text_data_en, "obj_torieltrigger12_184", "* Nie powstrzymam cię./")
ds_map_add(global.text_data_en, "obj_torieltrigger12_185", "\E2* Jednakże^1, jeśli&  opuścisz.../")
ds_map_add(global.text_data_en, "obj_torieltrigger12_186", "\E1* Proszę nie powracaj./")
ds_map_add(global.text_data_en, "obj_torieltrigger12_187", "\E2* Mam nadzieję^1, że&  zrozumiesz./%%")
ds_map_add(global.text_data_en, "obj_torieltrigger12_325", "* Tak bardzo&  chcesz odejść?/")
ds_map_add(global.text_data_en, "obj_torieltrigger12_326", "\E6* Hmph./")
ds_map_add(global.text_data_en, "obj_torieltrigger12_327", "* Jesteś taki sam&  jak inni./")
ds_map_add(global.text_data_en, "obj_torieltrigger12_328", "\E7* Jest tylko jedno&  roziązanie na to./")
ds_map_add(global.text_data_en, "obj_torieltrigger12_329", "* Udowodnij.../")
ds_map_add(global.text_data_en, "obj_torieltrigger12_330", "* Udowodnij mi^1, że&  jesteś wystarczająco&  silny, by przetrwać./%%")
ds_map_add(global.text_data_en, "obj_torieltrigger12_336", "* Udowodnij mi^1, że&  jesteś wystarczająco&  silny, by przetrwać!/")
ds_map_add(global.text_data_en, "obj_torieltrigger12_337", "\E6* ... chwila./")
ds_map_add(global.text_data_en, "obj_torieltrigger12_338", "* ... czemu patrzysz&  tak na mnie?/")
ds_map_add(global.text_data_en, "obj_torieltrigger12_339", "* Jakbyś zobaczył&  ducha./")
ds_map_add(global.text_data_en, "obj_torieltrigger12_340", "\E7* Wiesz o czymś^1,&  o czym nie wiem?/")
ds_map_add(global.text_data_en, "obj_torieltrigger12_341", "* Nie...&* To nie możliwe./%%")
ds_map_add(global.text_data_en, "obj_torieltrigger12_346", "* Udowodnij mi^1,&  że jesteś.../")
ds_map_add(global.text_data_en, "obj_torieltrigger12_347", "\E1* Hej^1, daj mi dokończyć%%")
ds_map_add(global.text_data_en, "obj_torieltrigger12_353", "* Tak szybko?/")
ds_map_add(global.text_data_en, "obj_torieltrigger12_354", "* Co muszę zrobić^1,&  żebyś miał nauczkę?/%%")
ds_map_add(global.text_data_en, "obj_torieltrigger5_185", "* Jak się tu&  dostałeś^1, habibi^1?&* Czy jesteś skrzywdzony?/")
ds_map_add(global.text_data_en, "obj_torieltrigger5_186", "* Ani ryska..^1.&*\E0 Imponujące^1!&*\E1 Ale dalej.../")
ds_map_add(global.text_data_en, "obj_torieltrigger5_187", "* Już już^1&  wyleczę cię./")
ds_map_add(global.text_data_en, "obj_torieltrigger5_189", "* Któż ci to zrobił^2?\E5 &* Otrzymasz swoje&  przeprosiny./")
ds_map_add(global.text_data_en, "obj_torieltrigger5_190", "\E1* Nie powinnam była&  cię zostawiać samemu&  na tak długo./")
ds_map_add(global.text_data_en, "obj_torieltrigger5_191", "* To było bardzo&  nieodpowiedzialne^1, by&  próbować cię zaskoczyć./")
ds_map_add(global.text_data_en, "obj_torieltrigger5_192", "\E8* Err.../")
ds_map_add(global.text_data_en, "obj_torieltrigger5_193", "\E0* Cóż^1, chyba nie&  mogę tego już&  dłużej ukrywać./")
ds_map_add(global.text_data_en, "obj_torieltrigger5_194", "* Chodź^1, malutki!/%%")
ds_map_add(global.text_data_en, "obj_torieltrigger5_260", "* Ojejku^1, to zajęło&  dłużej niż ja&  zakładałam./%%")
ds_map_add(global.text_data_en, "obj_torieltrigger6_39", "* Czujesz ten zapach^1?/")
ds_map_add(global.text_data_en, "obj_torieltrigger6_40", "* Niespodzianka!/")
ds_map_add(global.text_data_en, "obj_torieltrigger6_41", "* To cynamonowo-&  toffi ciasto./")
ds_map_add(global.text_data_en, "obj_torieltrigger6_42", "* Pomyślałam^1, że byśmy&  mogli uczcić twoje&  przybycie./")
ds_map_add(global.text_data_en, "obj_torieltrigger6_43", "* Chcę^1, byś miał&  tutaj przyjemny&  pobyt./")
ds_map_add(global.text_data_en, "obj_torieltrigger6_44", "* Więc przetrzymam&  ślimakowe ciasto&  na noc./")
ds_map_add(global.text_data_en, "obj_torieltrigger6_45", "* Chodź^1, mam kolejną&  niespodziankę dla&  ciebie./%%")
ds_map_add(global.text_data_en, "obj_torieltrigger6_49", "* Czujesz ten zapach^1?/")
ds_map_add(global.text_data_en, "obj_torieltrigger6_50", "\E1* Er^1, zakładam^1, że&  twoja twarz mówi^1,&  że wiesz./")
ds_map_add(global.text_data_en, "obj_torieltrigger6_51", "\E0* N..^1. niespodzianka!/")
ds_map_add(global.text_data_en, "obj_torieltrigger6_52", "* Upiekłam ślimakowe&  ciasto./")
ds_map_add(global.text_data_en, "obj_torieltrigger6_53", "* Pomyślałam^1, że byśmy&  mogli uczcić twoje&  przybycie./")
ds_map_add(global.text_data_en, "obj_torieltrigger6_54", "* Chcę^1, byś miał&  tutaj przyjemny&  pobyt./")
ds_map_add(global.text_data_en, "obj_torieltrigger6_55", "\E1* Więc ja.../")
ds_map_add(global.text_data_en, "obj_torieltrigger6_56", "\E0* Chodź^1, mam dla ciebie&  kolejną niespodziankę./%%")
ds_map_add(global.text_data_en, "obj_torieltrigger7_41", "* To jest to.../%%")
ds_map_add(global.text_data_en, "obj_torieltrigger7_77", "* Czy coś się pali...?&* Um^1, czuj się jak&  w domu!/%%")
ds_map_add(global.text_data_en, "obj_torieltrigger7_243", "* Twój własny pokój.&* Liczę na to^1, że&  ci się spodoba!/%%")
ds_map_add(global.text_data_en, "obj_torieltrigger8_77", "* Myślę^1,że powinieneś&  się pobawić na górze./%%")
ds_map_add(global.text_data_en, "obj_torieltrigger8_78", "* To niebezpieczne^1, by&  się tu bawić./%%")
ds_map_add(global.text_data_en, "obj_torieltrigger8_79", "* W powietrzu jest asbest.&* Możesz zachorować&  na astmę./%%")
ds_map_add(global.text_data_en, "obj_torieltrigger8_80", "* To jest zakurzone.&* Będziesz kaszlał./%%")
ds_map_add(global.text_data_en, "obj_torieltrigger8_81", "* Nie ma tu nic&  do zobaczenia./%%")
ds_map_add(global.text_data_en, "obj_torieltrigger8_82", "* Chcesz przeczytać&  książkę?/%%")
ds_map_add(global.text_data_en, "obj_torieltrigger8_83", "\E7* Nie podoba mi się&  gra^1, w którą grasz./%%")
ds_map_add(global.text_data_en, "obj_torieltrigger8_84", "\E0* Czemu nie pójdziesz&  na spacerek po&  działce?/%%")
ds_map_add(global.text_data_en, "obj_torieltrigger8_85", "* Poważnie teraz./%%")
ds_map_add(global.text_data_en, "obj_torieltrigger8_86", "\E4* .../%%")
ds_map_add(global.text_data_en, "obj_torieltrigger8_90", "* Hej^1, nie idź tam&  na dół./")
ds_map_add(global.text_data_en, "obj_torieltrigger8_91", "* Mam coś do pokazania&  na górze./%%")
ds_map_add(global.text_data_en, "obj_torieltrigger9_77", "* Chcesz wiedzieć jak&  wrócić do " + '"' + "domu," + '"' + "&  prawda?/")
ds_map_add(global.text_data_en, "obj_torieltrigger9_78", "* Przed nami jest&  wyjście z RUIN./")
ds_map_add(global.text_data_en, "obj_torieltrigger9_79", "* Jednostronne wyjście&  do reszty podziemi./")
ds_map_add(global.text_data_en, "obj_torieltrigger9_80", "* Zniszczę to./")
ds_map_add(global.text_data_en, "obj_torieltrigger9_81", "* Nikt już nie będzie&  w stanie wyjść./")
ds_map_add(global.text_data_en, "obj_torieltrigger9_82", "* Teraz bądź grzecznym&  dzieckiem i idź&  na górę./%%")
ds_map_add(global.text_data_en, "obj_torinteractable7_82", "* Do not worry about&  me./")
ds_map_add(global.text_data_en, "obj_torinteractable7_83", "* Someone has to take&  care of these flowers./%%")
ds_map_add(global.text_data_en, "obj_torinteractable7_93", "* Don't worry about&  me./")
ds_map_add(global.text_data_en, "obj_torinteractable7_94", "* Someone has to take&  care of these flowers./%%")
ds_map_add(global.text_data_en, "obj_torinteractable7_99", "* Frisk^1, please leave&  me alone./")
ds_map_add(global.text_data_en, "obj_torinteractable7_100", "\E3* I can't come back^1.&* I just can't^1, OK?/%%")
ds_map_add(global.text_data_en, "obj_torinteractable7_106", "\E7* I don't want to break&  their hearts all over&  again./")
ds_map_add(global.text_data_en, "obj_torinteractable7_107", "* It's better if they&  never see me./%%")
ds_map_add(global.text_data_en, "obj_torinteractable7_113", "\E7* ... why are you still&  here?/")
ds_map_add(global.text_data_en, "obj_torinteractable7_114", "* Are you trying to keep&  me company?/")
ds_map_add(global.text_data_en, "obj_torinteractable7_115", "\E0* Frisk.../")
ds_map_add(global.text_data_en, "obj_torinteractable7_116", "* .../")
ds_map_add(global.text_data_en, "obj_torinteractable7_117", "\E7* Hey./")
ds_map_add(global.text_data_en, "obj_torinteractable7_118", "\E0* Let me ask you a&  question./")
ds_map_add(global.text_data_en, "obj_torinteractable7_119", "* Frisk..^1.&* Why did you come&  here?/")
ds_map_add(global.text_data_en, "obj_torinteractable7_120", "* Everyone knows the&  legend^1, right...?/")
ds_map_add(global.text_data_en, "obj_torinteractable7_121", "* " + '"' + "Travellers who climb&  Mt. Ebott are said&  to disappear." + '"' + "/")
ds_map_add(global.text_data_en, "obj_torinteractable7_122", "\E7* .../")
ds_map_add(global.text_data_en, "obj_torinteractable7_123", "* Frisk./")
ds_map_add(global.text_data_en, "obj_torinteractable7_124", "*\E0 Why would you ever&  climb a mountain&  like that?/")
ds_map_add(global.text_data_en, "obj_torinteractable7_125", "\E7* Was it foolishness?/")
ds_map_add(global.text_data_en, "obj_torinteractable7_126", "\E0* Was it fate?/")
ds_map_add(global.text_data_en, "obj_torinteractable7_127", "\E1* Or was it..^1.&* Because you...?/")
ds_map_add(global.text_data_en, "obj_torinteractable7_128", "\E7* Well./")
ds_map_add(global.text_data_en, "obj_torinteractable7_129", "\E0* Only you know the&  answer^1, don't you...?/%%")
ds_map_add(global.text_data_en, "obj_torinteractable7_135", "\E2* I know why \[C]&  climbed the mountain./")
ds_map_add(global.text_data_en, "obj_torinteractable7_136", "\E7* It wasn't for a&  very happy reason./")
ds_map_add(global.text_data_en, "obj_torinteractable7_137", "\E2* Frisk^1.&* I'll be honest with&  you./")
ds_map_add(global.text_data_en, "obj_torinteractable7_138", "\E7* \[C] hated humanity./")
ds_map_add(global.text_data_en, "obj_torinteractable7_139", "\E2* Why they did^1, they&  never talked about&  it./")
ds_map_add(global.text_data_en, "obj_torinteractable7_140", "\E1* But they felt very&  strongly about&  that./%%")
ds_map_add(global.text_data_en, "obj_torinteractable7_146", "\E2* Frisk..^1.&* You really ARE different&  from \[C]./")
ds_map_add(global.text_data_en, "obj_torinteractable7_147", "\E0* In fact^1, though you&  have similar^1, uh^1,&  fashion choices.../")
ds_map_add(global.text_data_en, "obj_torinteractable7_148", "* I don't know why I&  ever acted like you&  were the same person./")
ds_map_add(global.text_data_en, "obj_torinteractable7_149", "\E7* Maybe..^1.&* The truth is.../")
ds_map_add(global.text_data_en, "obj_torinteractable7_150", "\E1* \[C] wasn't really&  the greatest person./")
ds_map_add(global.text_data_en, "obj_torinteractable7_151", "\E7* While^1, Frisk.../")
ds_map_add(global.text_data_en, "obj_torinteractable7_152", "\E0* You're the type of&  friend I wish I&  always had./")
ds_map_add(global.text_data_en, "obj_torinteractable7_153", "\E7* So maybe I was kind&  of projecting a&  little bit./")
ds_map_add(global.text_data_en, "obj_torinteractable7_154", "\E0* Let's be honest^1.&* I did some weird&  stuff as a flower./%%")
ds_map_add(global.text_data_en, "obj_torinteractable7_160", "\E2* There's one last&  thing I feel like&  I should tell you./")
ds_map_add(global.text_data_en, "obj_torinteractable7_161", "* Frisk^1, when \[C]&  and I combined our&  SOULs together.../")
ds_map_add(global.text_data_en, "obj_torinteractable7_162", "* The control over our&  body was actually split&  between us./")
ds_map_add(global.text_data_en, "obj_torinteractable7_163", "* They were the one&  that picked up their&  own empty body./")
ds_map_add(global.text_data_en, "obj_torinteractable7_164", "* And then^1, when we&  got to the village.../")
ds_map_add(global.text_data_en, "obj_torinteractable7_165", "\E2* They were the one&  that wanted to.../")
ds_map_add(global.text_data_en, "obj_torinteractable7_166", "\E1* ... to use our full&  power./")
ds_map_add(global.text_data_en, "obj_torinteractable7_167", "\E2* I was the one that&  resisted./")
ds_map_add(global.text_data_en, "obj_torinteractable7_168", "\E7* And then^1, because of&  me^1, we.../")
ds_map_add(global.text_data_en, "obj_torinteractable7_169", "\E1* Well^1, that's why I&  ended up a flower./")
ds_map_add(global.text_data_en, "obj_torinteractable7_170", "\E2* Frisk.../")
ds_map_add(global.text_data_en, "obj_torinteractable7_171", "* This whole time^1, I've&  blamed myself for&  that decision./")
ds_map_add(global.text_data_en, "obj_torinteractable7_172", "* That's why I adopted&  that horrible view&  of the world./")
ds_map_add(global.text_data_en, "obj_torinteractable7_173", "* " + '"' + "Kill or be killed." + '"' + "/")
ds_map_add(global.text_data_en, "obj_torinteractable7_174", "\E7* But now..^1.&* After meeting you.../")
ds_map_add(global.text_data_en, "obj_torinteractable7_175", "\E0* Frisk^1, I don't regret&  that decision anymore./")
ds_map_add(global.text_data_en, "obj_torinteractable7_176", "\E4* I did the right&  thing./")
ds_map_add(global.text_data_en, "obj_torinteractable7_177", "* If I killed those&  humans.../")
ds_map_add(global.text_data_en, "obj_torinteractable7_178", "* We would have had to&  wage war against all&  of humanity./")
ds_map_add(global.text_data_en, "obj_torinteractable7_179", "\E0* And in the end^1,&  everyone went free^1,&  right?/")
ds_map_add(global.text_data_en, "obj_torinteractable7_180", "\E7* I still feel kind&  of sad knowing how&  long it took.../")
ds_map_add(global.text_data_en, "obj_torinteractable7_181", "\E0* ... so maybe it&  wasn't a perfect&  decision./")
ds_map_add(global.text_data_en, "obj_torinteractable7_182", "* But you can't regret&  hard choices your&  whole life^1, right?/")
ds_map_add(global.text_data_en, "obj_torinteractable7_183", "\E7* Well^1, not that I&  have much of a life&  left./")
ds_map_add(global.text_data_en, "obj_torinteractable7_184", "\E0* But that's besides&  the point./%%")
ds_map_add(global.text_data_en, "obj_torinteractable7_190", "* Frisk^1, thank you&  for listening to me./")
ds_map_add(global.text_data_en, "obj_torinteractable7_191", "* You should really go&  be with your friends&  now^1, OK?/")
ds_map_add(global.text_data_en, "obj_torinteractable7_192", "* Oh^1, and^1, please.../")
ds_map_add(global.text_data_en, "obj_torinteractable7_193", "\E7* In the future^1, if you&  uh^1, see me.../")
ds_map_add(global.text_data_en, "obj_torinteractable7_194", "* Don't think of it as&  me^1, OK?/")
ds_map_add(global.text_data_en, "obj_torinteractable7_195", "\E0* I just want you to&  remember me like this./")
ds_map_add(global.text_data_en, "obj_torinteractable7_196", "\E0* Someone that was your&  friend for a little&  while./")
ds_map_add(global.text_data_en, "obj_torinteractable7_197", "\E2* Oh^1, and Frisk.../")
ds_map_add(global.text_data_en, "obj_torinteractable7_198", "\E0* Be careful in the&  outside world^1, OK?/")
ds_map_add(global.text_data_en, "obj_torinteractable7_199", "* Despite what everyone&  thinks^1, it's not as&  nice as it is here./")
ds_map_add(global.text_data_en, "obj_torinteractable7_200", "\E7* There are a lot of&  Floweys out there./")
ds_map_add(global.text_data_en, "obj_torinteractable7_201", "\E2* And not everything can&  be resolved by just&  being nice./")
ds_map_add(global.text_data_en, "obj_torinteractable7_202", "\E0* Frisk.../")
ds_map_add(global.text_data_en, "obj_torinteractable7_203", "* Don't kill^1, and&  don't be killed^1,&  alright?/")
ds_map_add(global.text_data_en, "obj_torinteractable7_204", "* That's the best you&  can strive for./")
ds_map_add(global.text_data_en, "obj_torinteractable7_205", "* Well^1, see you./%%")
ds_map_add(global.text_data_en, "obj_torinteractable7_212", "\E7* Frisk.../")
ds_map_add(global.text_data_en, "obj_torinteractable7_213", "\E6* Don't you have&  anything better to&  do?/%%")
ds_map_add(global.text_data_en, "obj_torn_note_63", " error/%%")
ds_map_add(global.text_data_en, "obj_torn_note_67", "* (There's a note on the&  ground...^1)&* (You can't make it all out.)/")
ds_map_add(global.text_data_en, "obj_torn_note_68", "* " + '"' + "elevator..^1. lost power..^1." + '"' + "&* " + '"' + "enter the center door..." + '"' + "/")
ds_map_add(global.text_data_en, "obj_torn_note_69", "* (That's all you could read.)/%%")
ds_map_add(global.text_data_en, "obj_torn_note_74", "* (There's a note on the&  ground...^1)&* (You can't make it all out.)/")
ds_map_add(global.text_data_en, "obj_torn_note_75", "* " + '"' + "drain..^1. dropped it..." + '"' + "/")
ds_map_add(global.text_data_en, "obj_torn_note_76", "* (That's all you could read.)/%%")
ds_map_add(global.text_data_en, "obj_torn_note_81", "* (There's a note on the&  ground...^1)&* (You can't make it all out.)/")
ds_map_add(global.text_data_en, "obj_torn_note_82", "* " + '"' + "cold..." + '"' + "/")
ds_map_add(global.text_data_en, "obj_torn_note_83", "* (That's all you could read.)/%%")
ds_map_add(global.text_data_en, "obj_torn_note_88", "* (There's a note on the&  ground...^1)&* (You can't make it all out.)/")
ds_map_add(global.text_data_en, "obj_torn_note_89", "* " + '"' + "curtain..." + '"' + "/")
ds_map_add(global.text_data_en, "obj_torn_note_90", "* (That's all you could read.)/%%")
ds_map_add(global.text_data_en, "obj_torn_note_95", "* (There's a note on the&  ground...^1)&* (You can't make it all out.)/")
ds_map_add(global.text_data_en, "obj_torn_note_96", "* " + '"' + "under..^1. sheets..." + '"' + "/")
ds_map_add(global.text_data_en, "obj_torn_note_97", "* (That's all you could read.)/%%")
ds_map_add(global.text_data_en, "obj_townnpc_bear1_70", "* To miasteczko nie ma&  burmistrza./")
ds_map_add(global.text_data_en, "obj_townnpc_bear1_71", "* Ale jeśli jest jakiś problem^1,&  szkielet o tym opowie takiej&  rybie i po sprawie./")
ds_map_add(global.text_data_en, "obj_townnpc_bear1_72", "* Tooooo polityka!/%%")
ds_map_add(global.text_data_en, "obj_townnpc_bear1_73", "* Polityka./%%")
ds_map_add(global.text_data_en, "obj_townnpc_bear1_77", "* Co gdybym kandydatował na&  burmistrza...?/")
ds_map_add(global.text_data_en, "obj_townnpc_bear1_78", "* Nie sądzę^1, żebym robił dobrą&  robotę^1, a ja nienawidzę brania&  odpowiedzialności.../")
ds_map_add(global.text_data_en, "obj_townnpc_bear1_79", "* Ale kocham politykę^1.&* Więc może się do tego&  nadam./%%")
ds_map_add(global.text_data_en, "obj_townnpc_bear1_85", "* Słyszałem^1, że Dr. Alphys&  przyznała Królowi i Królowej&   swoje okrutne eksperymenty./")
ds_map_add(global.text_data_en, "obj_townnpc_bear1_86", "* Król się poczuł tak źle^1, że&  nie wiedział co zrobić^1.&* Dał jej dużego przytulasa./")
ds_map_add(global.text_data_en, "obj_townnpc_bear1_87", "* Wtedy królowa ją zwolniła./")
ds_map_add(global.text_data_en, "obj_townnpc_bear1_88", "* No i teraz nie mamy&  królewskiego naukowca.../")
ds_map_add(global.text_data_en, "obj_townnpc_bear1_89", "* Toooo polityka!/%%")
ds_map_add(global.text_data_en, "obj_townnpc_bear1_93", "* Szkoda^1, że nie ma polityki&  tam na powierzchni./%%")
ds_map_add(global.text_data_en, "obj_townnpc_bear1_99", "* Hmmm^1, zazwyczaj ten szkielet&  idzie się spotkać z Undyne&  jakoś teraz./")
ds_map_add(global.text_data_en, "obj_townnpc_bear1_100", "* Gdzie on jest...^1?&* Czuję^1, jak nasz system&  polityczny się rozpada.../%%")
ds_map_add(global.text_data_en, "obj_townnpc_beartree_70", "* Okrutne nastolatki nękały&  lokalnego mieszkańca poprzez&  dekorowanie jego rogów./")
ds_map_add(global.text_data_en, "obj_townnpc_beartree_71", "* Więc zaczęliśmy dawać temu&  potworowi prezenty żeby się&  poczuł lepiej./")
ds_map_add(global.text_data_en, "obj_townnpc_beartree_72", "* Teraz to jest tradycja^1, że się&  kładzie prezenty pod udekoro-&  waną choinką./%%")
ds_map_add(global.text_data_en, "obj_townnpc_beartree_74", "* Czyli chyba dobrze^1, że ci&  nastolatkowie gnębili&  tego potwora...?/%%")
ds_map_add(global.text_data_en, "obj_townnpc_beartree_78", "* Hmm^1?&* Układanie tych prezentów to&  moja odpowiedzialność./")
ds_map_add(global.text_data_en, "obj_townnpc_beartree_79", "* Nah^1, mówiąc szczerze^1,&  po prostu patrzę czy ja&  jakiś dostałem.../%%")
ds_map_add(global.text_data_en, "obj_townnpc_beartree_84", "* Fajnie będzie pokazać&  człowiekom naszą tradycję&  kładania prezentów pod choinkę./")
ds_map_add(global.text_data_en, "obj_townnpc_beartree_85", "* Oni pewnie się zdziwią./%%")
ds_map_add(global.text_data_en, "obj_townnpc_beartree_90", "* Wiesz co jest słodkie?/")
ds_map_add(global.text_data_en, "obj_townnpc_beartree_91", "* Te dwa ożenione pieski&  zawsze kładą prezenty sobie&  nawzajem pod choinką./")
ds_map_add(global.text_data_en, "obj_townnpc_beartree_92", "* To jest zawsze to samo^1.&* Pojedyncza kość./")
ds_map_add(global.text_data_en, "obj_townnpc_beartree_93", "* Ale za każdym razem^1, udają,&  że to pierwszy raz kiedy&  to dostali./")
ds_map_add(global.text_data_en, "obj_townnpc_beartree_94", "* Wtedy Papyrus przychodzi by&  wziąć jego kości spowrotem./")
ds_map_add(global.text_data_en, "obj_townnpc_beartree_95", "* Tak wogule^1, gdzie jest ta&  dwójka...?/%%")
ds_map_add(global.text_data_en, "obj_townnpc_beartree_100", "* Dziwne^1.&* Był tu prezent dla Papyrusa.../")
ds_map_add(global.text_data_en, "obj_townnpc_beartree_101", "* A teraz znikł^1.&* Czyżby ktoś go ukradł?/%%")
ds_map_add(global.text_data_en, "obj_townnpc_bunboy_70", "* Ta pani o tam o.../")
ds_map_add(global.text_data_en, "obj_townnpc_bunboy_71", "* Coś o niej mnie niepokoi./%%")
ds_map_add(global.text_data_en, "obj_townnpc_bunboy_72", "* Chyba wiem co^1.&* ... a^1, jednak nie./%%")
ds_map_add(global.text_data_en, "obj_townnpc_bunboy_76", "* Ta pani o tam o była&  na spacerze już od&  dłuższego czasu./")
ds_map_add(global.text_data_en, "obj_townnpc_bunboy_77", "* ... ale nie ruszyła się o&  centymetr od miejsca gdzie&  stoi./")
ds_map_add(global.text_data_en, "obj_townnpc_bunboy_78", "* C-cóż^1, ja też nie^1,&  ale nie chcę^1, żeby mnie&  zauważyła jak stoję.../%%")
ds_map_add(global.text_data_en, "obj_townnpc_bunboy_83", "* Uhhh.../")
ds_map_add(global.text_data_en, "obj_townnpc_bunboy_84", "* Czy tylko ja jestem zaniepoko-&  jonym tymi ogromnymi&  amalgamatami^1, czy...?/%%")
ds_map_add(global.text_data_en, "obj_townnpc_bunboy_85", "* ...../%%")
ds_map_add(global.text_data_en, "obj_townnpc_bunboy_90", "* Ta pani o tam o wydaje się&  dzisiaj być szczęśliwa./")
ds_map_add(global.text_data_en, "obj_townnpc_bunboy_91", "* Nie wiem czemu^1, ale to mi&  przynosi ciarki po plecach.../%%")
ds_map_add(global.text_data_en, "obj_townnpc_bunlady_70", "* Czyż mój mały Cynamonek&  nie jest przesłodki?/")
ds_map_add(global.text_data_en, "obj_townnpc_bunlady_71", "* Bun-buny są takie słodkie..^1.&* Tee hee!/%%")
ds_map_add(global.text_data_en, "obj_townnpc_bunlady_73", "* Bun-bun-bun-bun-bun.../%%")
ds_map_add(global.text_data_en, "obj_townnpc_bunlady_77", "* Huh^1? Tak^1, biorę mojego&  króliczka na spacerek./")
ds_map_add(global.text_data_en, "obj_townnpc_bunlady_78", "* Po prostu jest bardzo wolny./%%")
ds_map_add(global.text_data_en, "obj_townnpc_bunlady_83", "* Ten dzieciak o tam o&  mi powiedział^1, że to dziwne&  mieć króliczka za zwierzaka./")
ds_map_add(global.text_data_en, "obj_townnpc_bunlady_84", "* Po pierwsze^1, nie ma w&  tym nic dziwnego^1.&* To jest słodkie!/")
ds_map_add(global.text_data_en, "obj_townnpc_bunlady_85", "* Po drugie..^1.&* Co?/")
ds_map_add(global.text_data_en, "obj_townnpc_bunlady_86", "* To normalne oprowadzać&  młodszego brata na smyczy^1,&  prawda?/%%")
ds_map_add(global.text_data_en, "obj_townnpc_bunlady_91", "* Ah^1, jest tak cicho&  i spokojnie.../")
ds_map_add(global.text_data_en, "obj_townnpc_bunlady_92", "* Zazwyczaj jeden z tych piesków&  gania mojego małego Cynamonka&  wokół./%%")
ds_map_add(global.text_data_en, "obj_townnpc_bunlady_97", "* Ah^1, jest tak cicho&  i spokojnie.../")
ds_map_add(global.text_data_en, "obj_townnpc_bunlady_98", "* Zazwyczaj jeden z tych&  szkieletów gania mojego&  małego Cynamonka wokół./%%")
ds_map_add(global.text_data_en, "obj_townnpc_hatescity_70", "* Stolica robi się trochę&  przeludniona^1, więc słyszałem&  że zaczną się przeprowadzać tu./")
ds_map_add(global.text_data_en, "obj_townnpc_hatescity_71", "* Hmmm..^1.&* Nie chcę patrzeć na dekultu-&  ryzację naszego miasteczka./")
ds_map_add(global.text_data_en, "obj_townnpc_hatescity_72", "* Ale zdecydowanie chciałbym&  zobaczyć jak miejskie cwania-&  czki ślizgają się na tyłkach!/%%")
ds_map_add(global.text_data_en, "obj_townnpc_hatescity_73", "* Tak^1, przynoście je!/%%")
ds_map_add(global.text_data_en, "obj_townnpc_hatescity_77", "* Co się stanie z Grillbym&  kiedy każdy się do nas&  przeprowadzi...?/")
ds_map_add(global.text_data_en, "obj_townnpc_hatescity_78", "* Będziemy musieli przymocować&  krzesła do sufitu./%%")
ds_map_add(global.text_data_en, "obj_townnpc_hatescity_83", "* Hej^1! Potwory nie będą musieli&  już się przenosić z stolicy!/")
ds_map_add(global.text_data_en, "obj_townnpc_hatescity_84", "* Czyli nie stracimy naszej&  lokalnej kultury./")
ds_map_add(global.text_data_en, "obj_townnpc_hatescity_85", "* ... z wyjątkiem tego^1, że&  wszyscy się ztąd wynosimy^1,&  huh./")
ds_map_add(global.text_data_en, "obj_townnpc_hatescity_86", "* No cóż^1. Najwyraźniej&  wszystko ma swoją cenę./%%")
ds_map_add(global.text_data_en, "obj_townnpc_hatescity_91", "* Stolica robi się trochę&  przeludniona^1, więc słyszałem&  że zaczną się przeprowadzać tu./")
ds_map_add(global.text_data_en, "obj_townnpc_hatescity_92", "* ... kto wie^1.&* Może będziemy mieć&  trochę miejsca./%%")
ds_map_add(global.text_data_en, "obj_townnpc_icewolf_71", "* Ice Wolf już nie musi&  rzucać Kostek Lodu./")
ds_map_add(global.text_data_en, "obj_townnpc_icewolf_72", "* Ice Wolf może w końcu odsapnąć&  i kupić sobie jakieś spodnie./%%")
ds_map_add(global.text_data_en, "obj_townnpc_icewolf_74", "* Ice Wolf myśli o zmianie&  imienia na Jimmy Hotpants./%%")
ds_map_add(global.text_data_en, "obj_townnpc_innlady_114", "* Error./%%")
ds_map_add(global.text_data_en, "obj_townnpc_innlady_199", "* Heja^1!&* Wyglądasz, jakbyś miał&  jakościowy sen./")
ds_map_add(global.text_data_en, "obj_townnpc_innlady_200", "* Co jest niesamowite^1, biorąc&  pod uwagę^1, że spałeś tylko&  jakieś dwie minuty.../")
ds_map_add(global.text_data_en, "obj_townnpc_innlady_203", "* Trzymaj spowrotem kasę^1.&* Możesz mi zapłacić ponownie&  jeśli znów weźmiesz pokój./%%")
ds_map_add(global.text_data_en, "obj_townnpc_innlady_207", "* Wracaj śmiało jeśli znów&  się zmęczysz./%%")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_80", "* Jo^1!&* Też jesteś dzieckiem^1,&  co nie?/")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_81", "* Jestem w stanie to stwierdzić&  bo masz koszulę w paski./%%")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_82", "* Ciekawe czy ten dziwny&  szkielet jest dorosłym dzy&  dzieckiem./%%")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_88", "* Jo..^1.&* Tu jesteś!/")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_89", "* Trochę się martwiłem o ciebie&  odkąd postanowiłeś uciec./")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_90", "* ... ale teraz jestem po prostu&  wściekły^1, ha ha./")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_91", "* Gdyby Undyne mnie nie&  uratowała^1, źle by się&  to skończyło.../%%")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_93", "* .../%%")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_97", "* Jo..^1.&* Uh.../")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_98", "* Nie rozmawiaj ze mną./%%")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_100", "* .../%%")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_104", "* Jo!!^1!&* Co słychać!?/")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_105", "* Tak sobie myślałem.../")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_106", "* Że może Undyne...&* Nie jest taka czadowa&  jak zakładaliśmy./")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_107", "* Jest po prostu..^1. niemiła./")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_108", "* Ale JO!!^1!&* Właśnie znalazłem kogoś&  o WIEEEELE lepszego!!!/")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_109", "* Nyeh heh heh!!! /%%")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_111", "* Nyeh heh heh^1, dude. /%%")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_117", "* Jo^1, wszyscy gdzieś uciekli i&  się schowali./")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_118", "* Rany^1, dorośli to potrafią&  czasami być głupi^1, haha.../")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_119", "* Czy oni nie wiedzą^1, że mamy&  Undyne^1, która nas chroni!?/%%")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_122", "* Jo^1!&* Ty też się skradasz by&  ją zobaczyć na żywo?/")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_123", "* Niesamowite..^1.&* Jest najlepsza^1, co nie!?/")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_124", "* Chcę być taki jak ona kiedy&  będę dorosły.../")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_125", "* Hej^1, nie mów moim rodzicom&  że tu jestem^1.&* Ha ha./%%")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_127", "* OK^1, jestem gotowy kiedy&  ty jesteś./%%")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_129", "* Jo^1!&* W którą stronę szedłeś...?/")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_130", "* Moi rodzice nie kazali ci&  tu przychodzić^1, czyżby?/%%")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_132", "* Wiesz gdzie idziemy^1,&  co nie...?/")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_133", "* Chciałem cię po prostu&  śledzić..^1.&* Ha ha./%%")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_141", "* Jo^1, ta krawędź jest o wiele&  zbyt wysoka.../%%")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_147", "* Hmm..../%%")
ds_map_add(global.text_data_en, "obj_townnpc_monsterkid1_161", "* Jo^1, nie będziesz w stanie&  się wspiąć z parasolką./%%")
ds_map_add(global.text_data_en, "obj_townnpc_reddemon_70", "* Wszyscy wiemy^1, że podziemia&  mają problemy^1, ale i tak&  postanawiamy się uśmiechać./")
ds_map_add(global.text_data_en, "obj_townnpc_reddemon_71", "* Dlaczego?/")
ds_map_add(global.text_data_en, "obj_townnpc_reddemon_72", "* Nic na to nie poradzimy^1, więc&  czemu użalać się nad tym?/%%")
ds_map_add(global.text_data_en, "obj_townnpc_reddemon_73", "* Pamiętaj o uśmiechu./%%")
ds_map_add(global.text_data_en, "obj_townnpc_reddemon_83", "* Może dla odmiany spróbuję&  marszczenia./")
ds_map_add(global.text_data_en, "obj_townnpc_reddemon_84", "* ... nie^1.&* Nie dam rady./%%")
ds_map_add(global.text_data_en, "obj_townnpc_reddemon_89", "* Oh^1?&* Jesteśmy wolni?/")
ds_map_add(global.text_data_en, "obj_townnpc_reddemon_90", "* W końcu..^1.&* Będę mogła przestać&  się uśmiechać/%%")
ds_map_add(global.text_data_en, "obj_townnpc_reddemon_95", "* Jeszcze chwila^1, a moje&  mięśnie szczęki zaczęłyby&  opadać./")
ds_map_add(global.text_data_en, "obj_townnpc_reddemon_96", "* Coś nie tak?/%%")
ds_map_add(global.text_data_en, "obj_townnpc_slimedad_70", "* Ah^1, znów być młodym^1.&* Ten świat z pewnością&  wydawał się bez granic./%%")
ds_map_add(global.text_data_en, "obj_townnpc_slimedad_74", "* Lubisz podróżować widzę^1.&* Musisz być całkiem młody./%%")
ds_map_add(global.text_data_en, "obj_townnpc_slimedad_79", "* To wygląda na początek&  zupełnie nowego^1,&  nieograniczonego świata!.../")
ds_map_add(global.text_data_en, "obj_townnpc_slimedad_80", "* Wah-ha^1!&* Ten duch przygody^1!&* Znów się czuję jak dziecko!/")
ds_map_add(global.text_data_en, "obj_townnpc_slimedad_81", "* A moje dzieci to..^1.&* podwójne McDzieci./%%")
ds_map_add(global.text_data_en, "obj_townnpc_slimedad_86", "* Wysłałam dzieci do domu./")
ds_map_add(global.text_data_en, "obj_townnpc_slimedad_87", "* Dzisiaj wydaje się tu&  niebezpiecznie./%%")
ds_map_add(global.text_data_en, "obj_townnpc_slimedaughter_80", "* Nie zmienisz mnie spowrotem&  w człowieka^1, prawda?/%%")
ds_map_add(global.text_data_en, "obj_townnpc_slimedaughter_84", "* Możemy PROSZĘ pograć w&  coś innego...?/%%")
ds_map_add(global.text_data_en, "obj_townnpc_slimedaughter_89", "* Hmmm..^1.&* Gdy ludzie grają w&  Potworów i Ludzi.../")
ds_map_add(global.text_data_en, "obj_townnpc_slimedaughter_90", "* Nazywają to po prostu&  Ludzie i Ludzie?/%%")
ds_map_add(global.text_data_en, "obj_townnpc_slimeson_75", "* Zagrajmy w Potworów i Ludzi!/%%")
ds_map_add(global.text_data_en, "obj_townnpc_slimeson_79", "* Grajmy dalej w&  Potworów i Ludzi!/%%")
ds_map_add(global.text_data_en, "obj_townnpc_slimeson_84", "* Teraz możemy grać w&  Potworów i Ludzi z&  PRAWDZIWYMI ludźmi!/%%")
ds_map_add(global.text_data_en, "obj_townnpc_unfunny_70", "* Wszyscy sobie żartują&  i się cieszą ^1, próbując&  zapomnieć o obecnym kryzysie.../")
ds_map_add(global.text_data_en, "obj_townnpc_unfunny_71", "* Ponurość^1.&* Tłum ^1.&* Brak witaminy D…./")
ds_map_add(global.text_data_en, "obj_townnpc_unfunny_72", "* Dołączyłbym do nich^1, ale&  nie jestem zbytnio zabawny./%%")
ds_map_add(global.text_data_en, "obj_townnpc_unfunny_73", "* Przynajmniej nie robię&  sucharów./%%")
ds_map_add(global.text_data_en, "obj_townnpc_unfunny_77", "* Czekaj!^1!&* Mam fajny żart!/")
ds_map_add(global.text_data_en, "obj_townnpc_unfunny_78", "* Puk puk!/")
ds_map_add(global.text_data_en, "obj_townnpc_unfunny_79", "* ... Yyy^1.&*  Nie wiem co dalej./%%")
ds_map_add(global.text_data_en, "obj_townnpc_unfunny_85", "* Wygląda na to, że nie&  muszę się już martwić&  opowiadaniem kawałów./")
ds_map_add(global.text_data_en, "obj_townnpc_unfunny_86", "* .../")
ds_map_add(global.text_data_en, "obj_townnpc_unfunny_87", "* Planowałem właśnie powiedzieć&  żart^1, ale naprawdę nie&  mam żadnego./%%")
ds_map_add(global.text_data_en, "obj_townnpc_unfunny_92", "* Mam wrażenie że…^1.&* Wszystko się tylko&  robi coraz gorsze./%%")
ds_map_add(global.text_data_en, "obj_townnpc_weirdfish_72", "* Dzisiaj " + '"' + "wyłożyłem na linę" + '"' + "&  numer dla jakichś lasek./")
ds_map_add(global.text_data_en, "obj_townnpc_weirdfish_73", "* Ktoś mi powiedział, że& " + '"' + "tego kwiatku jest&  pół światu" + '"' + ".../")
ds_map_add(global.text_data_en, "obj_townnpc_weirdfish_74", "* Cóż^1, ja to biorę&  na poważnie./")
ds_map_add(global.text_data_en, "obj_townnpc_weirdfish_75", "* Dosłownie się prześpię&  z kwiatkiem./%%")
ds_map_add(global.text_data_en, "obj_townnpc_weirdfish_76", "* Niby Asgore posiada ogród z&  kwiatkami^1, ale ostatnio wkurzył&  się moją obecnością.../%%")
ds_map_add(global.text_data_en, "obj_townnpc_weirdfish_80", "* Nie złapałem jeszcze nikogo^1?&* Nie mogę na to patrzeć.../%%")
ds_map_add(global.text_data_en, "obj_townnpc_weirdfish_85", "* Sans jest najbardziej&  zwyczajny i najzwyklejszy&  ze wszystkich./")
ds_map_add(global.text_data_en, "obj_townnpc_weirdfish_86", "* Ale nie pojawia się tak&  często jak kiedyś./%%")
ds_map_add(global.text_data_en, "obj_townnpc_weirdfish_91", "* Gdzie do cholery jest Sans?/")
ds_map_add(global.text_data_en, "obj_townnpc_weirdfish_92", "* Mówił mi że ma&  jakąś przynętę dla mnie./")
ds_map_add(global.text_data_en, "obj_townnpc_weirdfish_93", "* Ale to zapewne&  jeden z jego żarcików./")
ds_map_add(global.text_data_en, "obj_townnpc_weirdfish_94", "* Ale chciałbym wiedzieć&  co to za " + '"' + "żarcik" + '"' + "!/%%")
ds_map_add(global.text_data_en, "obj_townnpc_weirdfish_99", "* Koniec końców^1, niczego&  jeszcze nie złapałem./")
ds_map_add(global.text_data_en, "obj_townnpc_weirdfish_100", "* Więc dzieciaku^1, pamiętaj.../")
ds_map_add(global.text_data_en, "obj_townnpc_weirdfish_101", "* Nie próbuj łowić hotówek&  za pomocą wędki./")
ds_map_add(global.text_data_en, "obj_townnpc_weirdfish_102", "* (Słyszysz w oddali jakieś&  narzekające  jęki.)/%%")
ds_map_add(global.text_data_en, "obj_treadmill_event_103", "HEJ^1, SANS^1,&WIDZIAŁEŚ MÓJ.../")
ds_map_add(global.text_data_en, "obj_treadmill_event_104", "\E0OH, WITAJ^1.&NIE JESTEŚ SANSEM./")
ds_map_add(global.text_data_en, "obj_treadmill_event_105", "\E3CHWILA MOMENT./")
ds_map_add(global.text_data_en, "obj_treadmill_event_106", "\E0CZEMU UŻYWAŁEŚ&BIEŻNI PO CIEMKU?/")
ds_map_add(global.text_data_en, "obj_treadmill_event_107", "\E3CZY SANS ŻARTUJE&SOBIE Z CIEBIE POZA&CZASOPRZESTRENIĄ?/")
ds_map_add(global.text_data_en, "obj_treadmill_event_108", "\E1NIENAWIDZĘ GDY&TAK ROBI!/")
ds_map_add(global.text_data_en, "obj_treadmill_event_109", "\E1 JAK  GŁUPKOWATYM& MOŻNA BYĆ?/")
ds_map_add(global.text_data_en, "obj_treadmill_event_110", "\E3TAK WOGULE^1, WIDZIA-&ŁEŚ GDZIEŚ MOJE&FIGURKI AKCJI?/")
ds_map_add(global.text_data_en, "obj_treadmill_event_111", "\E0CZEKAJ^1!&WIEM GDZIE &ICH SZUKAĆ!!!/")
ds_map_add(global.text_data_en, "obj_treadmill_event_112", "W MOJEJ KOLEKCJI^1!&NYEH HEH HEH!!!/")
ds_map_add(global.text_data_en, "obj_treadmill_event_113", "CZASAMI^1, JESTEM&NAPRAWDĘ GENIALNY^1.&CAŁY CZAS!./%%")
