ds_map_add(global.text_data_en, "SCR_TEXT_6876", "\F1 %")
ds_map_add(global.text_data_en, "SCR_TEXT_6877", "\E0* Mówi TORIEL./")
ds_map_add(global.text_data_en, "SCR_TEXT_6878", "* Chciałeś tylko&  powiedzieć cześć...^2?&* W takim razie./")
ds_map_add(global.text_data_en, "SCR_TEXT_6879", "\E0* 'Witaj!'/")
ds_map_add(global.text_data_en, "SCR_TEXT_6880", "* Dziękuję za telefon^1.&* Hee hee./")
ds_map_add(global.text_data_en, "SCR_TEXT_6881", "\TS \F0 \T0 %")
