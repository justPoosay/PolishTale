ds_map_add(global.text_data_en, "obj_lastsans_trigger_724", "\E1* to wyraz twarzy kogoś&  kto umarł dziesięć&  razy z rzędu./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_725", "\E2* hej^1, gratki^1!&* dwucyfrówka!/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_726", "\E1* zaprośmy wszystkich&  twoich przyjaciół na&  wielkie przyjęcie./")
