ds_map_add(global.text_data_en, "obj_mkid_battle_714", "W tym momencie^1,&wszyscy w tym&świecie.../")
ds_map_add(global.text_data_en, "obj_mkid_battle_715", "\E7Czuję ich serca&bijące jako jedno./")
ds_map_add(global.text_data_en, "obj_mkid_battle_716", "I wszyscy mamy&JEDEN cel./")
ds_map_add(global.text_data_en, "obj_mkid_battle_717", "\E8Pokonać CIEBIE./")
ds_map_add(global.text_data_en, "obj_mkid_battle_718", "\E7Człowieku^1.&Nie^1, CZYMKOLWIEK&jesteś./")
ds_map_add(global.text_data_en, "obj_mkid_battle_719", "\E8Dla dobra całego&świata.../%%")
ds_map_add(global.text_data_en, "obj_mkid_battle_728", "\E9Ja^1, UNDYNE^1,&powalę cię&na ziemię!/%%")
