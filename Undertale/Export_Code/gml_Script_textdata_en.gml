ds_map_add(global.text_data_en, "obj_shyren_470", "* Shyren nuci wstydliwie.")
ds_map_add(global.text_data_en, "obj_shyren_471", "* Shyren udaje^1, że jest&  pop idolem.")
ds_map_add(global.text_data_en, "obj_shyren_472", "* Shyren stuka małą nutkę&  płetwami.")
ds_map_add(global.text_data_en, "obj_shyren_473", "* Shyren myśli o robieniu&  samodzielnego karaoke.")
ds_map_add(global.text_data_en, "obj_shyren_474", "* Pachnie muzyką.")
ds_map_add(global.text_data_en, "obj_shyren_475", "* Głos Shyrena się zdziera.")
ds_map_add(global.text_data_en, "obj_shyren_476", "* Shyren wydaje się o wiele&  bardziej komfortowa w wspólnym&  śpiewaniu.")
