ds_map_add(global.text_data_en, "obj_knock_room_62", "%%")
ds_map_add(global.text_data_en, "obj_knock_room_65", "* (Nie wydaje się jakby&  ktokolwiek był w domu.)/%%")
ds_map_add(global.text_data_en, "obj_knock_room_67", "* (Jeśli ktoś jest w środku^1,&  on nie odpowiada na drzwi.)/%%")
ds_map_add(global.text_data_en, "obj_knock_room_69", "* (Nikogo nie ma w domu.^1)&* (I masz przeczucie że już&  nikogo tam nie będzie.)/%%")
ds_map_add(global.text_data_en, "obj_knock_room_71", "* (Słyszysz zirytowane jęki&  dochodzące ze środka.)/%%")
ds_map_add(global.text_data_en, "obj_knock_room_75", "* (Brzmi jakby tylko ogień&  tu teraz mieszkał.)/%%")
ds_map_add(global.text_data_en, "obj_knock_room_81", "* Kto tam^1?&* Jestem w środku mojego&  ulubionego programu TV./")
ds_map_add(global.text_data_en, "obj_knock_room_82", "* Wiem^1, wiem..^1.&* Gapienie się w ekran...&* Brzmi jak zanudzające hobby./")
ds_map_add(global.text_data_en, "obj_knock_room_83", "* Ale TV oferuje ucieczkę&  do innego świata^1.&* Naprawdę tego potrzebujemy./%%")
ds_map_add(global.text_data_en, "obj_knock_room_86", "* Chcesz też pooglądać^1?&* Sorry^1, to jest jednoosobowy&  program TV./%%")
ds_map_add(global.text_data_en, "obj_knock_room_91", "* Ahh^1, co za przepiękny puk..^1.!&* Może jeśli nie odpowiem^1, to&  usłyszę go ponownie./%%")
ds_map_add(global.text_data_en, "obj_knock_room_93", "* Ahh^1, moja cierpliwość mnie&  nagradza./%%")
ds_map_add(global.text_data_en, "obj_knock_room_95", "* Ahh.../%%")
ds_map_add(global.text_data_en, "obj_knock_room_99", "* (Brak odpowiedzi.)/%%")
ds_map_add(global.text_data_en, "obj_knock_room_113", "* (Brak odpowiedzi.)/%%")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_218", "* Hej^1!&* Przestańcie!!!/%%")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_258", "* Mam dla was trochę&  jedzenia^1, okej!?/%%")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_294", "\E4* Przepraszam za to.../")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_295", "\E2* Robią się nieco agre-&  sywni kiedy oni nie są&  nakarmiani na czas./")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_296", "\E3* Umm!!/")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_299", "\E3* Wydaje mi się^1, że oni&  wyczuli twoje czipsy&  w kieszeni^1, i.../")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_301", "\E3* W każdym razie!/")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_302", "\E6* Zasilanie wysiadło^1, i&  próbowałam go jakoś&  spowrotem przywrócić!/")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_303", "\E4* Ale wygląda na to^1, że&  byłeś o krok przede mną./")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_304", "\E2* To był prawdopodobnie&  ogromny kłopot dla&  ciebie.../")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_305", "\E4* A-ale doceniam to że&  przybyłeś tutaj aby&  mnie wesprzeć!/")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_306", "\E4* Tak jak mówiłam^1,&  obawiałam się że ja.../")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_307", "\E8* już nie powrócę.../")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_308", "\E5* Ale nie przez tych&  potworów czy coś!/")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_309", "\E4* Po prostu obawiałam się&  że za bardzo bym się&  bała tego.../")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_310", "\E9* Żeby powiedzieć&  wszystkim prawdę.../")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_311", "\E8* Że mogłabym uciec^1,&  albo coś zrobić.../")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_312", "\E9* Tchórzliwego./")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_313", "* .../")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_314", "*\E8 Uh..^1. Ja..^1.&* Myślę^1, że należy&  ci się wyjaśnienie./")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_315", "\E9* Jak pewnie wiesz^1,&  ASGORE poprosił mnie&  aby zbadać naturę DUSZ./")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_316", "\E3* Podczas moich badań^1,&  odizolowałam moc którą&  nazwałam " + '"' + "determinacją." + '"' + "/")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_317", "\E6* Wstrzyknęłam ją w&  potworów aby ich DUSZE&  przetrwały po śmierci./")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_318", "\E9* Ale eksperyment się&  nie powiódł./")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_319", "* Widzisz^1, w porównaniu do&  ludzi^1, ciała potworów&  nie mają wystarczająco../")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_320", "* Fizycznej materii aby&  udźwignęły te dawki&  " + '"' + "determinacji." + '"' + "/")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_321", "* Ich ciała zaczęły się&  topić^1, i utraciły całą&  fizyczność jaką mieli./")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_322", "\E3* Lada później^1, wszystkie&  obiekty testowe się&  roztopiły razem w.../")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_323", "\E8* Te coś./")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_324", "\E9* Widząc ich w takim&  stanie^1, wiedziałam.../")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_325", "\E8* Wiedziałam^1, że nie mogę&  powiedzieć ich rodzinom&  o tym wszystkim./")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_326", "\E8* Nie mogłam o tym&  nikomu powiedzieć./")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_327", "\E9* Niezależnie jak mocno&  wszyscy mnie wypytywali./")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_328", "\E9* I zbyt bardzo się bałam&  robienia więcej badań^1,&  wiedząc że.../")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_329", "\E8* ... wszystko co ja&  zrobiłam do tej pory&  było ogromną porażką./")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_330", "\E9* ... ale teraz./")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_331", "\E9* Teraz^1, zmieniłam&  zdanie o tym wszystkim./")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_332", "\E9* Powiem wszystkim to&  co ja zrobiłam./")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_333", "\E9* .../")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_335", "* Będzie ciężko./")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_336", "* Szczerze mówiąc..^1.&* Z wiarą w siebie.../")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_337", "* Jestem pewna że będą&  czasy w których będę&  się zmagała ze sobą./")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_338", "* Jestem pewna że będą&  czasy w których ja&  znów zchrzanię./")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_339", "\E0* Ale wiedząc^1, głęboko^1,&  że mam przyjaciół na&  których mogę upadać.../")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_340", "\E7* To wiem^1, że będzie&  o wiele łatwiej aby&  podnieść się samemu./")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_341", "* Dziękuję./%%")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_406", "* Chodźcie^1, chłopaki./")
ds_map_add(global.text_data_en, "obj_lab_powerswitch_407", "* Czas^1, aby każdy&  wrócił do domu./%%")
ds_map_add(global.text_data_en, "obj_labelevator_a_242", " UWAGA! UWAGA^6!%")
ds_map_add(global.text_data_en, "obj_labelevator_a_243", " WINDA TRACI ZASILANIE^6!%")
ds_map_add(global.text_data_en, "obj_labelevator_a_244", " WIĘŹ EM NIESTABILNA.^6!%")
ds_map_add(global.text_data_en, "obj_labelevator_a_245", " SPADEK WYSOKOŚCI^6!%%")
ds_map_add(global.text_data_en, "obj_labelevator_b_122", "* (Ring...)/")
ds_map_add(global.text_data_en, "obj_labelevator_b_123", "* (To głos, którego jeszcze&  nigdy nie słyszałeś.)/%%")
ds_map_add(global.text_data_en, "obj_labelevator_b_131", "* \[C]..^1.&* Jesteś tam?/")
ds_map_add(global.text_data_en, "obj_labelevator_b_132", "* Minęło dużo czasu^1,&  czyż nie...?/")
ds_map_add(global.text_data_en, "obj_labelevator_b_133", "* Ale dobrze sobie poradziłeś./")
ds_map_add(global.text_data_en, "obj_labelevator_b_134", "* Dzięki tobie^1, wszystko&  powróciło do swojego miejsca./")
ds_map_add(global.text_data_en, "obj_labelevator_b_135", "* \[C].../")
ds_map_add(global.text_data_en, "obj_labelevator_b_136", "* Widzimy się niedługo./%%")
ds_map_add(global.text_data_en, "obj_labtv_event_94", "* (Jest tu odtwarzacz taśm VHS&  z kilkoma taśmamy wystającymi&  z boku odtwarzacza...)/")
ds_map_add(global.text_data_en, "obj_labtv_event_95", "* (Wydają się być oznaczone&  w specyficznej kolejności.)/")
ds_map_add(global.text_data_en, "obj_labtv_event_96", "* (Obejrzysz jedno...?)/%%")
ds_map_add(global.text_data_en, "obj_labtv_event_98", "* (Wybierz taśmę do odtworzenia.)/%%")
ds_map_add(global.text_data_en, "obj_labtv_event_287", "* Psssst^1.&* Gorey^1, pobudka. \Ta/")
ds_map_add(global.text_data_en, "obj_labtv_event_288", "* Mmm^1?&* Co tam^1, kochanie?/")
ds_map_add(global.text_data_en, "obj_labtv_event_289", "* ... err^1, i dlaczego masz&  tą kamerę wideo? \TT/")
ds_map_add(global.text_data_en, "obj_labtv_event_290", "* Cii^1!&* Chcę złapać&  twoją reakcję./")
ds_map_add(global.text_data_en, "obj_labtv_event_291", "* Gorey^1, słońce^1.&* Jakie jest moje&  ulubione warzywo?\Ta/")
ds_map_add(global.text_data_en, "obj_labtv_event_292", "* Hmmm..^1.&* Marchewki^1, prawda?\TT/")
ds_map_add(global.text_data_en, "obj_labtv_event_293", "* Nie nie nie^1!&* Moim ULUBIONYM warzywem jest.../")
ds_map_add(global.text_data_en, "obj_labtv_event_294", "* Fasolki Eda-MAM-a./")
ds_map_add(global.text_data_en, "obj_labtv_event_295", "* ... łapiesz???\Ta/")
ds_map_add(global.text_data_en, "obj_labtv_event_296", "* .../")
ds_map_add(global.text_data_en, "obj_labtv_event_297", "* Idź spowrotem do łóżka^1, słońce.\TT/")
ds_map_add(global.text_data_en, "obj_labtv_event_298", "* Nie nie!^1!&* Jeszcze nie^1!&* Hee hee hee./")
ds_map_add(global.text_data_en, "obj_labtv_event_299", "* Teraz^1, Gdybym była pieskiem^1,&  jaką byłabym rasą?\Ta/")
ds_map_add(global.text_data_en, "obj_labtv_event_300", "* Hmm..^1. Nie mam pojęcia^1, słońce^1.&* Jaką rasą psa byś była?\TT/")
ds_map_add(global.text_data_en, "obj_labtv_event_301", "* Byłabym.../")
ds_map_add(global.text_data_en, "obj_labtv_event_302", "* MOMERANINEM.\Ta/")
ds_map_add(global.text_data_en, "obj_labtv_event_303", "* Hohoho!/")
ds_map_add(global.text_data_en, "obj_labtv_event_304", "* Z pewnością jesteś szczęśliwa&  że mamy to dziecko./")
ds_map_add(global.text_data_en, "obj_labtv_event_305", "* Wiesz^1, jeśli nadal&  będziesz robiła&  tego typu żarty.../")
ds_map_add(global.text_data_en, "obj_labtv_event_306", "* Jednego dnia^1, mogłabyś być.../")
ds_map_add(global.text_data_en, "obj_labtv_event_307", "* ... sławnym MAMikiem.\TT/")
ds_map_add(global.text_data_en, "obj_labtv_event_308", "* .../")
ds_map_add(global.text_data_en, "obj_labtv_event_309", "* Cóż^1, idę do łóżka.\Ta/")
ds_map_add(global.text_data_en, "obj_labtv_event_310", "* Hej^1!&* No weź^1, Tori^1!&* Ten żart był śmieszny!\TT/")
ds_map_add(global.text_data_en, "obj_labtv_event_311", "* Hahaha^1, wiem^1.&* Tak sobie tylko żartuję./")
ds_map_add(global.text_data_en, "obj_labtv_event_312", "* Dobranoc^1, słońce.\Ta/")
ds_map_add(global.text_data_en, "obj_labtv_event_313", "* Dobranoc, kochanie.\TT/")
ds_map_add(global.text_data_en, "obj_labtv_event_314", "* .../")
ds_map_add(global.text_data_en, "obj_labtv_event_315", "* O rany^1, chyba jest zbyt&  ciemno tutaj żeby ten&  film się przechwycił.../%%")
ds_map_add(global.text_data_en, "obj_labtv_event_350", "* Okej^1, \[C]^1, jesteś gotowy?/")
ds_map_add(global.text_data_en, "obj_labtv_event_351", "* Zrób twoją straszną twarz!/")
ds_map_add(global.text_data_en, "obj_labtv_event_352", "* AHHHHH!^1!&* Hee hee hee!/")
ds_map_add(global.text_data_en, "obj_labtv_event_353", "* Oh^1!&* Czekaj^1!&* Miałem założoną osłonę.../")
ds_map_add(global.text_data_en, "obj_labtv_event_354", "* Co!^1?&* Nie zrobisz tego&  ponownie...?/")
ds_map_add(global.text_data_en, "obj_labtv_event_355", "* No weź^1, przestań&  ze mnie żartować^1!&* Haha!/%%")
ds_map_add(global.text_data_en, "obj_labtv_event_391", "* Heja^1, \[C]^1!&* Uśmiech do kamery!/")
ds_map_add(global.text_data_en, "obj_labtv_event_392", "* Ha^1, tym razem MAM cię^1!&* Zostawiłem osłonę nałożoną..^1.&* CELOWO!/")
ds_map_add(global.text_data_en, "obj_labtv_event_393", "* I teraz się uśmiechasz&  bezzzzzz powodu^1!&* Hee hee hee!/")
ds_map_add(global.text_data_en, "obj_labtv_event_394", "* Co^1?&* Oh^1, ta^1, pamiętam./")
ds_map_add(global.text_data_en, "obj_labtv_event_395", "* Kiedy próbowaliśmy upiec&  ciasto toffi dla taty^1,&  prawda?/")
ds_map_add(global.text_data_en, "obj_labtv_event_396", "* W przepisie prosiło o&  trochę barwnika.../")
ds_map_add(global.text_data_en, "obj_labtv_event_397", "* Ale my przypadkiem daliśmy&  parę płatków barwinka./")
ds_map_add(global.text_data_en, "obj_labtv_event_398", "* Ta^1!&* Te kwiaty dosyć&  mocno go zatruły./")
ds_map_add(global.text_data_en, "obj_labtv_event_399", "* Miałem takie poczucie winy^1.&* Zawiedliśmy mocno Mamę./")
ds_map_add(global.text_data_en, "obj_labtv_event_400", "* Powinienem był to po prostu&  wiśmiać^1, tak jak ty.../")
ds_map_add(global.text_data_en, "obj_labtv_event_401", "* Um^1, w każdym razie^1, gdzie&  ty idziesz z tym czymś?/")
ds_map_add(global.text_data_en, "obj_labtv_event_402", "* Huh^1?&* Wyłączyć kamerę...^1?&* OK./%%")
ds_map_add(global.text_data_en, "obj_labtv_event_435", "* Ja..^1. Nie podoba mi się ten&  pomysł^1, \[C]./")
ds_map_add(global.text_data_en, "obj_labtv_event_436", "* C.^1. co^1?&* N-nie, ja nie.../")
ds_map_add(global.text_data_en, "obj_labtv_event_437", "* ... duże dzieci nie płaczą./")
ds_map_add(global.text_data_en, "obj_labtv_event_438", "* Ta^1, masz rację./")
ds_map_add(global.text_data_en, "obj_labtv_event_439", "* Nie^1!&* Nigdy bym w ciebie nie&  zwątpił^1, \[C]..^1. Nigdy!/")
ds_map_add(global.text_data_en, "obj_labtv_event_440", "* T..^1. tak^1!&* Będziemy silni^1!&* Uwolnimy wszystkich./")
ds_map_add(global.text_data_en, "obj_labtv_event_441", "* Pójdę po kwiaty./%%")
ds_map_add(global.text_data_en, "obj_labtv_event_473", "* \[C]..^1.&* Słyszysz mnie^1?&* Chcemy żebyś się obudził...\Ta/")
ds_map_add(global.text_data_en, "obj_labtv_event_474", "* \[C]^1!&* Musisz pozostać&  zdeterminowany!/")
ds_map_add(global.text_data_en, "obj_labtv_event_475", "* Nie możesz się poddać..^1.&* Jesteś przyszłością&  ludzi i potworów...\TR/")
ds_map_add(global.text_data_en, "obj_labtv_event_476", "* .../")
ds_map_add(global.text_data_en, "obj_labtv_event_477", "* Psst... \[C]..^1.&* Proszę..^1. obudź się.../")
ds_map_add(global.text_data_en, "obj_labtv_event_478", "* Już mi się nie&  podoba ten plan./")
ds_map_add(global.text_data_en, "obj_labtv_event_479", "* Ja..^1. Ja.../")
ds_map_add(global.text_data_en, "obj_labtv_event_480", "* ..^1. nie^1, mówiłem..^1.&* Mówiłem^1, że nigdy bym&  w ciebie nie zwątpił./")
ds_map_add(global.text_data_en, "obj_labtv_event_481", "* Sześć^1, prawda^1?&* Musimy tylko zyskać sześć.../")
ds_map_add(global.text_data_en, "obj_labtv_event_482", "* I zrobimy to razem^1, prawda?/%%")
ds_map_add(global.text_data_en, "obj_ladiesfishingrod_137", "* Spuściłeś&  linię spowrotem./%%")
ds_map_add(global.text_data_en, "obj_laserswitch1_90", "* (Nie zadziałało.)/%%")
ds_map_add(global.text_data_en, "obj_laserswitch1_119", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_laserswitch1_120", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_laserswitch1_121", "\E3* H-hej^1, uważaj^1!&* Możesz się naprawdę&  skrzywdzić!/")
ds_map_add(global.text_data_en, "obj_laserswitch1_122", "\E8* Nie mogę na to patrzeć^1.&* Wyłączam lasery./%%")
ds_map_add(global.text_data_en, "obj_laserswitch1_161", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_laserswitch1_162", "\E6* J..^1. już./")
ds_map_add(global.text_data_en, "obj_laserswitch1_163", "\E3* Bądź ostrożny^1, okej?/")
ds_map_add(global.text_data_en, "obj_laserswitch1_164", "\E8* .../")
ds_map_add(global.text_data_en, "obj_laserswitch1_165", "\E8* P-przepraszam^1, to&  m-moja wina że&  jesteś skrzywdzony./")
ds_map_add(global.text_data_en, "obj_laserswitch1_166", "\E8* Nie wyjaśniłam ci&  wystarczająco jak&  działają lasery^1, i../")
ds_map_add(global.text_data_en, "obj_laserswitch1_167", "\E8* Gdybym ja..^1.&* Gdybym ja..^1./")
ds_map_add(global.text_data_en, "obj_laserswitch1_168", "\E4* Um^1, opóźniłam je&  z moim hackowaniem^1,&  to znaczy.../")
ds_map_add(global.text_data_en, "obj_laserswitch1_169", "\E8* ... przepraszam./")
ds_map_add(global.text_data_en, "obj_laserswitch1_170", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_laserswitch1_171", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_laserswitch1_174", "\E8* P-przepraszam^1, to&  m-moja wina że&  jesteś skrzywdzony./")
ds_map_add(global.text_data_en, "obj_laserswitch1_175", "\E8* Nie wyjaśniłam ci&  wystarczająco jak&  działają lasery^1, i.../")
ds_map_add(global.text_data_en, "obj_laserswitch1_176", "\E3* O-oh^1, nie ma teraz&  na to czasu!/")
ds_map_add(global.text_data_en, "obj_laserswitch1_177", "\E8* Przepraszam./")
ds_map_add(global.text_data_en, "obj_laserswitch1_178", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_laserswitch1_179", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_lastbeam_230", "PRZESTAŃ!!")
ds_map_add(global.text_data_en, "obj_lastbeam_255", "PRZESTAŃ&TERAZ!!!")
ds_map_add(global.text_data_en, "obj_lastbeam_296", "* ...")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_187", "* A więc w końcu dotarłeś./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_188", "* Koniec twojej podróży jest&  w zasięgu ręki./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_189", "* Za lada chwilę^1,&  spotkasz króla./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_190", "* Razem.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_191", "* Zdeterminujecie&  przyszłość tego świata./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_192", "* To jest wtedy./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_193", "* A teraz./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_194", "* Będziesz osądzony./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_195", "* Będziesz osądzony za&  każdą twoją czynność./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_196", "* Będziesz osądzony za&  każde EXP które zdobyłeś./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_197", "* Czym jest EXP?/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_198", "* To akronim./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_199", "\W* Rozwinięcie skrótu to& " + '"' + "\Rpunkty egzekucyjne\W albo&  \Rexecution points\W." + '"' + "/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_200", "* Mierzy ona cierpienie&  zadane przez ciebie&  innym./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_201", "* Kiedy kogoś zabijasz^1,&  twoje EXP rośnie./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_202", "* Kiedy masz wystarczająco&  EXP^1, twoje LOVE rośnie./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_203", "* LOVE^1, także^1, jest&  akronimem./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_204", "\W* Rozwinięcie skrótu to& " + '"' + "\RPoziom Przemocy\W albo\R&  (Level of Violence)\W." + '"' + "/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_205", "* Mierzy ona zdolność&  osoby do zabijania./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_206", "* Im więcej zabijasz^1, tym&  łatwiej się staje&  unikanie innych./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_207", "* Im bardziej unikasz&  innych^1, ty mniej&  odniesiesz obrażenia./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_208", "* Tym łatwiej możesz się&  pozbierać do skrzywdzenia&  innych./%%")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_214", "* A więc w końcu dotarłeś.../%%")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_243", "* Teraz^1, rozumiesz./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_244", "* Czas zacząć&  twój wyrok./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_245", "* Spójrz w siebie./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_246", "* Czy na pewno zrobiłeś&  właściwą rzecz?/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_247", "* I^1, biorąc pod uwagę&  twoje czynności.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_248", "* Co zrobisz teraz?/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_249", "* Zajmij chwilę, by&  o tym pomyśleć./%%")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_268", "\TS* .../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_269", "\Ts*\E0 ... ale ty^1.&* ty nigdy nie zyskałeś&  żadnego LOVE./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_270", "\E1* wiadomo^1, to nie znaczy&  że jesteś kompletnie&  niewynny czy naiwny./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_271", "\E0* po prostu to, że&  utrzymałeś empatię&  w twoim sercu./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_274", "* nieważne nad jakimi&  trudnościami się&  zmierzyłeś.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_275", "* starałeś się&  zrobić właściwą&  rzecz./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_276", "* odmówiłeś&  skrzywdzenia&  kogokolwiek./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_277", "* nawet jeśli ty&  uciekałeś^1, robiłęś&  to z uśmiechem./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_278", "* nigdy nie zyskałeś&  LOVE^1, natomiast&  zyskałeś miłość./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_279", "* czy to ma sens?/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_280", "* może nie./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_283", "\E3* ..^1.&* teraz./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_284", "\E0* za chwilę się zmierzysz&  z największym wyzwaniem&  twojej całej podróży./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_285", "* tutaj twoje&  czynności.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_286", "* zdeterminują los&  całego świata./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_287", "* jeśli odmówisz walki.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_288", "* asgore odbierze&  twoją duszę i&  zniszczy ludzkość./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_289", "* ale jeśli ty zabijesz&  asgore'a i pójdziesz&  do domu.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_290", "* potwory pozostaną&  uwięzieni pod ziemią./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_291", "* co zrobisz?/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_292", "\E3* .../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_293", "* cóż^1, gdybym był tobą^1,&  rzuciłbym teraz&  białą flagę./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_294", "\E1* ale ty nie dotarłeś&  tak daleko poddawając&  się^1, czyż nie?/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_295", "\E0* zgadza się./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_296", "* posiadasz coś o nazwie& " + '"' + "determinacja." + '"' + "/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_297", "* więc dopóki będziesz&  się tego trzymał.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_298", "* więc dopóki będziesz&  podążał głosem&  serca.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_299", "* wierzę, że podejmiesz&  właściwą decyzję./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_300", "\E3* dobra./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_301", "\E0* wszyscy liczymy na&  ciebie, ziom./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_302", "\E2* powodzenia./%%")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_361", "\TS* .../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_362", "\Ts*\E0 szczerze^1, to nie ma&  za bardzo znaczenia&  co powiedziałeś./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_363", "\E0* liczy się to, że ty&  byłeś ze sobą szczery./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_364", "* co się stanie teraz.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_365", "* zostawiamy tobie&  do zdecydowania./%%")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_390", "* To dlaczego ty&  zabiłeś mojego&  brata?/%%")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_402", "* Ty brudny&  zabójco&  bratów./%%")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_421", "* huh^1?&* wyglądasz na&  znudzonego./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_422", "\E1* mam takie przeczucie że&  ty niczego nie wyniesiesz&  z tego i tak./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_423", "\E0* cóż^1, chyba muszę&  cię w takim razie&  osądzić./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_424", "* no weź^1.&* serio?/%%")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_428", "* lv2..^1.&* wydaje się^1, że zepsułeś&  o najmniejszą liczbę./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_429", "\E1* cóż^1.&* to całkiem smutne./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_430", "\E3* prawdopodobnie ty nie&  byłeś nawet świadom&  tego co robisz.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_431", "* a kiedy uświadomiłeś^1,&  było już za późno./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_432", "\E2* nah^1, żartuję tylko./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_433", "\E1* kto dochodzi do lv2&  przez przypadek^1?&* spadaj stąd./%%")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_437", "\E3* lv3.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_438", "\E1* 3 to w porządku liczba^1,&  wydaje mi się./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_439", "\E2*dam ci 3+./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_440", "\E1* możesz zrobić lepiej^1,&  prawda?/%%")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_444", "\E3* hmmm..^1.&* ponad lv3^1, huh./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_445", "\E0* zabiłeś parę osób&  celowo^1, czyż nie?/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_446", "\E1* to prawdopodobnie źle./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_447", "\E3* choć^1, może część z&  tego była w ramach&  samoobrony.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_448", "\E1* nie wiem^1.&* pomóż mi./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_449", "* nie oglądałem./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_450", "\E2* w każdym razie^1,&  nie rób tego./%%")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_454", "\E3* hmmm..^1.&* ponad lv9^1, huh./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_455", "\E0* to ponad połowa do&  lv20^1, maksimum./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_456", "\E1* ale nie myśl sobie że&  jesteś dalej w 50-&  procentach dobry./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_457", "\E3* 50-procent^1, 20-procent./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_458", "\E4* to są obydwa dalej&  nieprzepuszczalne&  oceny./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_459", "\E1* zresztą^1.&* jest szansa że.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_460", "* ja już próbowałem cię&  nakręcić na właściwą&  ścieżkę./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_461", "\E0* więc cóż mogę dodać?/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_462", "\E3* co mogę powiedzieć co&  zmieni twoje zdanie&  takiej istoty jak ty...?/%%")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_466", "\E3* hmmm..^1.&* ponad lv14^1, huh./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_467", "\E1* cóż^1, hmmm..^1.&* mówiąc wprost.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_468", "\E4* jesteś całkiem złą&  osobą./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_469", "* chodzisz w kółka^1,&  szukając innych.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_470", "* i zabijasz by zabrać&  ich pieniądze./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_471", "\E3* to już jest po&  prostu chore./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_472", "\E1* a co gorsza^1, to że&  jakkolwiek jesteś&  teraz zły.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_473", "\E2* nie jesteś nawet blisko&  temu jak gorszy&  mógłbyś być./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_474", "\E1* szczerze^1, ssiesz dupę&  w byciu złym./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_475", "\E1* serio^1, taka&  siara z ciebie./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_476", "\E2* ale może byłbyś&  lepszy.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_477", "\E1* w niezabijaniu nikogo?/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_478", "\E2* crazy^1, huh?/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_479", "\E0* daj mi znać jak&  to ci pójdzie./%%")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_485", "* ... huh?/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_486", "\E0* co jest z tym&  spojrzeniem w twoich&  oczach?/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_487", "\E3* czy ty właśnie&  zabiłeś kogoś.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_488", "\E3* tylko żeby zobaczyć&  co o tym powiem?/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_489", "\E1* wow^1./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_490", "\E2* jesteś dosyć&  obrzydliwą osobą^1,&  huh?/%%")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_494", "\E1* huh^1?&* ty NADAL wyglądasz&  na znudzonego./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_495", "\E2* okej^1, uznaj tą&  sesję za zakończoną./%%")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_513", "\E3* .../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_514", "\E1* chwila moment./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_515", "\E1* ten wyraz twarzy&  kiedy rozmawiałem.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_516", "\E2* ty już słyszałeś&  moją gadkę^1,&  czyż nie?/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_517", "\E3* podejrzewałem&  coś takiego./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_518", "\E3* zawsze się zachowujesz&  jakbyś wiedział co się&  dalej wydarzy./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_519", "\E1* jakbyś ty już to&  wszystko widział./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_520", "\E3* więc..^1.&* mam do ciebie prośbę./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_521", "\W*\E1 tak jakby mam takie&  \Ysekretne słowo\W &  które tylko ja znam./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_522", "\E0* więc wiem że jeśli&  ktoś mi to powie.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_523", "\E1* to musi zdecydowanie&  podróżować w czasie./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_524", "\E2* crazy^1, co nie?/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_525", "\E1* w każdym razie^1, oto&  moje słowo.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_526", "\E3* (szept^1, szept)/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_527", "\E2* liczę na ciebie że&  tu powrócisz i mi&  to powiesz./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_528", "\E1* widzimy się później./%%")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_532", "\E0* .../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_533", "\E1* huh^1?&* masz mi coś&  do powiedzenia?/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_534", "\E2* co^1? sekretne słowo^1?&* możesz powtórzyć&  troszeczkę głośniej?/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_535", "\E3* .../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_536", "* czy ty.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_537", "\E2* ... właśnie powiedziałeś& " + '"' + "jestem głupiutkim&  dupem dudu?" + '"' + "/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_538", "\E1* wow^1.&* nie wierzę że to&  powiedziałeś./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_539", "\E3* nie tylko jest to&  kompletnie dziecięce.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_540", "\E2* ale to też moje&  sekretne słowo./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_541", "\E3* to^1, natomiast^1, nie jest&  wystarczające./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_542", "\W*\E1 co potrzebujesz to&  \Ysekretne\W sekretne&  słówko./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_543", "\E2* to jest tylko dla osób&  które znają sekretne&  słówko./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_544", "\E0* w każdym razie^1, oto&  moje słówko.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_545", "\E4* (szepcik^1, szepcik).../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_546", "\E2* liczę na ciebie że&  tu powrócisz i mi&  to powiesz./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_547", "\E1* widzimy się później./%%")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_553", "\E0* .../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_554", "\E1* huh^1?&* masz mi coś&  do powiedzenia?/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_555", "\E2* co^1? sekretne słowo^1?&* możesz powtórzyć&  troszeczkę głośniej?/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_556", "\E3* .../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_557", "* czy ty.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_558", "\E2* ... właśnie powiedziałeś& " + '"' + "jestem legendarnym&  mistrzem pierdów?" + '"' + "/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_559", "\E1* wow./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_560", "\E1* to jest..^1. uh..^1.&* naprawdę dziecięce./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_561", "\E2* dlaczego myślałeś że&  to było sekretne&  sekretne słówko?/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_562", "\E1* ktokolwiek ci to&  powiedział jest&  brudnym kłamcą./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_563", "\E2* nie posiadam sekretnego&  sekretnego  słówka./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_564", "\E3* natomiast./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_565", "\E2* mam sekretne&  sekretne potrójnie&  sekretne słówko./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_566", "\E1* które właśnie&  powiedziałeś./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_567", "\E2* więc^1, chyba jesteś&  zakwalifikowany./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_568", "\E2* oto klucz do mojego&  pokoju./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_569", "\E3* już czas.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_570", "* abyś poznał prawdę./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_571", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_572", "* (Kiedy spojrzałeś^1, ten klucz&  już był na twoim breloczku.)/%%")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_578", "\E0* .../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_579", "\E1* huh^1?&* potrójnie sekretne&  słówko?/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_580", "\E2* nah^1, już mi się&  skończyły pomysły./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_581", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_582", "* (Poczułeś coś na twoim&  breloczku.)/%%")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_634", "\E0* heja./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_635", "\E1* byłeś zajęty^1,&  huh?/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_636", "* .../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_637", "\E0* więc^1, mam dla&  ciebie pytanko./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_638", "\E3* myślisz że nawet&  najgorsza osoba może&  się zmienić...?/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_639", "\E3* że każdy może być&  dobrą osobą^1, jeśli&  się tylko postara?/%%")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_643", "\E0* heja./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_644", "\E1* wyglądasz na&  sfrustrowanego&  czymś./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_645", "\E4* chyba jestem nieco&  dobry w mojej roli^1,&  huh?/%%")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_650", "\E0* hmm^1.&* ta twarz.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_651", "\E1* to wyraz twarzy kogoś&  kto umarł dwukrotnie&  z rzędu./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_652", "\E2* nietrudno stwierdzić^1,&  że wyglądasz nieco..^1.&* nieusatysfakcjonowany./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_653", "\E3* no spoko./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_654", "\E4* to może policzymy&  do trzech?/%%")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_659", "\E0* hmm^1.&* ta twarz.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_660", "\E1* to wyraz twarzy kogoś&  kto umarł trzykrotnie&  z rzędu./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_661", "\E3* .../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_662", "\E1* hej^1, co jest następne&  po " + '"' + "trzykrotnie^1," + '"' + "&  tak wogule?/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_663", "\E4* chcesz mi pomóc&  się dowiedzieć?/%%")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_668", "\E0* hmm^1.&* ta twarz.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_669", "\E1* to wyraz twarzy kogoś&  kto umarł czterokrotnie&  z rzędu./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_670", "\E1* czworokrotnie^1?&* czterkakrotnie?/")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_671", "\E4* cóż^1, nie będę musiał&  tego znów używać&  i tak./%%")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_676", "\E0* hmm^1.&* ta twarz.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_677", "\E1* to wyraz twarzy kogoś&  kto umarł pięć razy&  z rzędu./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_678", "\E2* dogodne^1, huh^1?&* to po jedno na&  każdy palec./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_679", "\E3* ale niedługo.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_680", "\E4* będziesz potrzebował&  ręki mutanta by liczyć&  twoje wszystkie śmierci./%%")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_685", "\E0* hmm^1.&* ta twarz.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_686", "\E1* to wyraz twarzy kogoś&  kto umarł sześć razy&  z rzędu./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_687", "\E2* to liczba palców na&  ręce mutanta./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_688", "\E3* ale niedługo.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_689", "\E4* będziesz musiał znaleźć&  rękę mutanta z jeszcze&  więcej palcami./%%")
