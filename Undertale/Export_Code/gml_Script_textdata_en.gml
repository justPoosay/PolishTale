ds_map_add(global.text_data_en, "obj_lesserdoge_475", "* Mniejszejszy Pies jest poza&  twoim zasięgiem./^")
ds_map_add(global.text_data_en, "obj_lesserdoge_476", "* Serio.../^")
ds_map_add(global.text_data_en, "obj_librarynpc_jumbler_70", "* Beautiful^1.&* An error message./%%")
ds_map_add(global.text_data_en, "obj_librarynpc_jumbler_73", "* That look in your eye.../")
ds_map_add(global.text_data_en, "obj_librarynpc_jumbler_74", "* You're someone that has&  difficulty solving Junior&  Jumble^1, aren't you?/%%")
ds_map_add(global.text_data_en, "obj_librarynpc_jumbler_78", "* That look in your eye.../")
ds_map_add(global.text_data_en, "obj_librarynpc_jumbler_79", "* You're someone that has&  trouble doing crosswords^1,&  aren't you?/%%")
ds_map_add(global.text_data_en, "obj_librarynpc_jumbler_84", "* That look in your eye.../")
ds_map_add(global.text_data_en, "obj_librarynpc_jumbler_85", "* You think Sudoku is just&  moderately challenging^1,&  don't you?/%%")
ds_map_add(global.text_data_en, "obj_librarynpc_jumbler_92", "* The greatest struggle of&  my life is over.../")
ds_map_add(global.text_data_en, "obj_librarynpc_jumbler_93", "* I just solved today's&  Junior Jumble./%%")
ds_map_add(global.text_data_en, "obj_librarynpc_jumbler_97", "* The greatest struggle of&  my life is over.../")
ds_map_add(global.text_data_en, "obj_librarynpc_jumbler_98", "* I just solved today's&  crossword./%%")
ds_map_add(global.text_data_en, "obj_librarynpc_lizard1_70", "* Welcome to the library^1.&* Yes^1, we know^1.&* The sign is misspelled./%%")
ds_map_add(global.text_data_en, "obj_librarynpc_lizard1_73", "* Yes^1, we know^1.&* The sign is misspelled./")
ds_map_add(global.text_data_en, "obj_librarynpc_lizard1_74", "* We have someone working on&  it!/%%")
ds_map_add(global.text_data_en, "obj_librarynpc_lizard1_79", "* Welcome to the library./")
ds_map_add(global.text_data_en, "obj_librarynpc_lizard1_80", "* This is the last day we'll&  be open^1, so make as much&  noise as you want./%%")
ds_map_add(global.text_data_en, "obj_librarynpc_lizard2_70", "* I love working on the&  newspaper./")
ds_map_add(global.text_data_en, "obj_librarynpc_lizard2_71", "* There's so little to report&  that we just fill it with&  comics and games./%%")
ds_map_add(global.text_data_en, "obj_librarynpc_lizard2_75", "* Yes^1.&* I illustrate all of the&  comics myself./")
ds_map_add(global.text_data_en, "obj_librarynpc_lizard2_76", "* Yes^1.&* I give everyone huge beautiful&  eyes and giant muscles./%%")
ds_map_add(global.text_data_en, "obj_librarynpc_lizard2_81", "* Oh my^1, there's so much&  news to report^1, I don't know&  where to begin!/")
ds_map_add(global.text_data_en, "obj_librarynpc_lizard2_82", "* How about this headline..^1.&* " + '"' + "Monsters Go Free From The&  Underground." + '"' + "/")
ds_map_add(global.text_data_en, "obj_librarynpc_lizard2_83", "* Nah^1, that doesn't have&  enough pizazz.../")
ds_map_add(global.text_data_en, "obj_librarynpc_lizard2_84", "* How about " + '"' + "Top 10 Monsters&  You Won't Believe Got Freed&  From The Underground?" + '"' + "/%%")
ds_map_add(global.text_data_en, "obj_librarynpc_wordsearch_70", "* (cough, cough)/")
ds_map_add(global.text_data_en, "obj_librarynpc_wordsearch_71", "* When I was younger^1, my teachers&  gave me word searches when&  they ran out of assignments./")
ds_map_add(global.text_data_en, "obj_librarynpc_wordsearch_72", "* I thought they were a waste&  of time./")
ds_map_add(global.text_data_en, "obj_librarynpc_wordsearch_73", "* But look at me now.../")
ds_map_add(global.text_data_en, "obj_librarynpc_wordsearch_74", "* I'm the number-one word-search&  creator in the entire&  underground!/%%")
ds_map_add(global.text_data_en, "obj_librarynpc_wordsearch_78", "* (cough^1, cough)/")
ds_map_add(global.text_data_en, "obj_librarynpc_wordsearch_79", "* There's a day I just don't&  want to work./")
ds_map_add(global.text_data_en, "obj_librarynpc_wordsearch_80", "* It's called " + '"' + "Today." + '"' + "/%%")
ds_map_add(global.text_data_en, "obj_librarynpc_wordsearch_85", "* This will be our newspaper's&  last issue.../")
ds_map_add(global.text_data_en, "obj_librarynpc_wordsearch_86", "* Why don't we just put a&  big " + '"' + "THE END" + '"' + " on the front&  and call it a day?/%%")
ds_map_add(global.text_data_en, "obj_lock_and_key_66", "* (The way is blocked by two&  padlocks.^1)&* (There's a note attached.)/")
ds_map_add(global.text_data_en, "obj_lock_and_key_67", "* (Howdy^1! I'm in the garden.)/")
ds_map_add(global.text_data_en, "obj_lock_and_key_68", "* (If you have anything you&  need to get off your chest^1,&  please don't hesitate to come.)/")
ds_map_add(global.text_data_en, "obj_lock_and_key_69", "* (The keys are in the kitchen&  and the hallway.)/%%")
ds_map_add(global.text_data_en, "obj_lock_and_key_73", "\R* (He leaves them in the&  kitchen and the hallway.)/%%")
ds_map_add(global.text_data_en, "obj_lock_and_key_78", "* (You'll need both keys to&  get through.)/%%")
ds_map_add(global.text_data_en, "obj_lock_and_key_82", "\R* (There are two keys.)/%%")
ds_map_add(global.text_data_en, "obj_lock_and_key_90", "* (You unlocked the chain.)/%%")
ds_map_add(global.text_data_en, "obj_lock_and_key_94", "\R* (I unlocked the chain.)/%%")
ds_map_add(global.text_data_en, "obj_longsnail_64", "* Ślum ślum..^1.&* (Długa podróż otwiera&  się przed tobą...)/")
ds_map_add(global.text_data_en, "obj_longsnail_65", "* Ślum ślum..^1.&* (Sięgaj daleko i rozciągaj&  poza horyzonty.)/")
ds_map_add(global.text_data_en, "obj_longsnail_66", "* Ślum ślum^1.&* (So snaileth Sam Byool.)/%%")
ds_map_add(global.text_data_en, "obj_longsnail_70", "* Ślum ślum./")
ds_map_add(global.text_data_en, "obj_longsnail_71", "* (Dobry boziu^1, czyż ja nie&  wyglądam na idealnie&  perfekcyjnego ślimaka?)/%%")
ds_map_add(global.text_data_en, "obj_longsnail_76", "* Ślum ślum^1.&* (Osiągnąłeś koniec twojej&  długiej podróży.)/")
ds_map_add(global.text_data_en, "obj_longsnail_77", "* Ślum ślum^1.&* (Co za długa podróż^1! Pamiętaj^1,&  by się porozciągać.)/%%")
ds_map_add(global.text_data_en, "obj_loox_197", "Mam&moje&oko na&ciebie.")
ds_map_add(global.text_data_en, "obj_loox_198", "Nie&wskazuj&na mnie&palcem.")
ds_map_add(global.text_data_en, "obj_loox_199", "Przestań&się na&mnie&gapić.")
ds_map_add(global.text_data_en, "obj_loox_200", "Co za&bez-&czel-&ność.")
ds_map_add(global.text_data_en, "obj_loox_201", "A może&kontest&gapie-&nia się?")
ds_map_add(global.text_data_en, "obj_loox_202", "Proszę&nie cze-&piaj się&mnie.")
ds_map_add(global.text_data_en, "obj_loox_205", "W końcu&ktoś&rozumie.")
ds_map_add(global.text_data_en, "obj_loox_209", "Ty&małpi-&szonie!")
ds_map_add(global.text_data_en, "obj_loox_213", "%%%")
ds_map_add(global.text_data_en, "obj_loox_403", "* Loox wpatruje się w ciebie.")
ds_map_add(global.text_data_en, "obj_loox_404", "* Loox wpatruje się prosto&  przez ciebie.")
ds_map_add(global.text_data_en, "obj_loox_405", "* Loox zgrzyta zębami.")
ds_map_add(global.text_data_en, "obj_loox_406", "* Pachnie kroplami do oczu.")
ds_map_add(global.text_data_en, "obj_loox_407", "* Loox ma przekrwione oczy.")
ds_map_add(global.text_data_en, "obj_loox_408", "* Loox już nie chce dłużej&  walczyć.")
ds_map_add(global.text_data_en, "obj_loox_409", "* Loox zaczyna łzawić.")
ds_map_add(global.text_data_en, "obj_loox_425", "* LOOX - ATK 6 DEF 6&* Nie czepiaj się go.&* Nazwosko rodowe: Eyewalker/^")
ds_map_add(global.text_data_en, "obj_maddummy_259", "\E1OWWWW^1, wy&GUPKI!!/")
ds_map_add(global.text_data_en, "obj_maddummy_260", "\XPatrzcie gdzie&celujecie swoje&\RMAGICZNE\X &ataki!/")
ds_map_add(global.text_data_en, "obj_maddummy_261", "\E3.../")
ds_map_add(global.text_data_en, "obj_maddummy_262", "\XHej^1! Ty^1! \E2&Zapomnij że&coś mówiłem&o \RMAGII\X!!!/%%")
ds_map_add(global.text_data_en, "obj_maddummy_319", "Masakra^1.&Masakra^1!&MASAKRA!/")
ds_map_add(global.text_data_en, "obj_maddummy_320", "Nawet jeśli&zaatakujesz moje&ciało^1, NIGDY&mnie nie skrzywdzisz!/")
ds_map_add(global.text_data_en, "obj_maddummy_321", "Dalej jestem&nieśmiertelny^1,&GŁUPKU!!!/%%")
ds_map_add(global.text_data_en, "obj_maddummy_422", "Głupku.&Głupku!&GŁUPKU!")
ds_map_add(global.text_data_en, "obj_maddummy_423", "Daremne.&Daremne!&DAREMNE!")
ds_map_add(global.text_data_en, "obj_maddummy_424", "Żałosne.&Żałosne!&ŻAŁOSNE!")
ds_map_add(global.text_data_en, "obj_maddummy_425", "Słabe.&Żałosne!&SŁABE!")
ds_map_add(global.text_data_en, "obj_maddummy_429", " Pokonam cię i& zabiorę twoją& DUSZĘ!")
ds_map_add(global.text_data_en, "obj_maddummy_430", " Użyję twojej DUSZY& aby przekroczyć& barierę!")
ds_map_add(global.text_data_en, "obj_maddummy_431", " Będę stał w oknie& prestiżowego sklepu!")
ds_map_add(global.text_data_en, "obj_maddummy_432", "\E3 WTEDY WSZYSTKO CO& BĘDĘ CHCIAŁ BĘDZIE& MOJE!")
ds_map_add(global.text_data_en, "obj_maddummy_433", "\E2 Huh?& Ta, chyba to& pomści mojego& kuzyna.")
ds_map_add(global.text_data_en, "obj_maddummy_434", "\E0 Jakie było& jego imię...?")
ds_map_add(global.text_data_en, "obj_maddummy_435", " Nieważne.& Nieważne!& NIEWAŻNE!!")
ds_map_add(global.text_data_en, "obj_maddummy_441", "MOJE&BOTY!&MAGICZNE&POCISKI!")
ds_map_add(global.text_data_en, "obj_maddummy_442", "MOJE&BOTY!&JESZCZE&RAZ!")
ds_map_add(global.text_data_en, "obj_maddummy_443", "MOJE&BOTY!&Jesteście&do dupy???")
ds_map_add(global.text_data_en, "obj_maddummy_444", "MOJE&BOTY!&FINALNY&ATAK!")
