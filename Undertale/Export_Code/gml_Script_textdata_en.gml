ds_map_add(global.text_data_en, "obj_shyren_483", "* Shyren myśli o swojej&  przyszłości.")
ds_map_add(global.text_data_en, "obj_shyren_502", "* SHYREN - ATK 19 DEF 0&* Tone deaf^1. Jest zbyt wstydliwa&  by nucić zabójczą melodię./^")
ds_map_add(global.text_data_en, "obj_shyren_503", "* SHYREN - ATK 19 DEF 0&* Utalentowana piosenkarka^1, z&  małą pomocą./^")
ds_map_add(global.text_data_en, "obj_shyren_504", "* SHYREN - ATK 19 DEF 0&* To Shyren^1.&* Jest twoją band-mate./^")
ds_map_add(global.text_data_en, "obj_shyren_514", "* Nucisz ruchliwą nutę^1.&* Shyren podąża twoim śladem./^")
ds_map_add(global.text_data_en, "obj_shyren_515", "* Nucisz smutną piosenkę^1.&* Shyren podąża twoim śladem./^")
ds_map_add(global.text_data_en, "obj_shyren_516", "* Nucisz jazzową balladę^1.&* Shyren podąża twoim śladem./^")
ds_map_add(global.text_data_en, "obj_shyren_517", "* Nucisz jeszcze trochę^1.&* Twoja muzyka przyciąga&  inne potwory./")
ds_map_add(global.text_data_en, "obj_shyren_518", "* Nagle^1, to się szybko&  przemienia w koncert.../^")
ds_map_add(global.text_data_en, "obj_shyren_519", "* Nucisz jeszcze więcej^1.&* Miejsca już się wyprzedały^1.&* Czujesz się jak gwiazda rocka./^")
ds_map_add(global.text_data_en, "obj_shyren_520", "* Nucisz jeszcze więcej^1.&* Ale ta atencja.../")
ds_map_add(global.text_data_en, "obj_shyren_521", "* Wycieczki..^1.&* Fancluby..^1.&* To wszystko.../^")
ds_map_add(global.text_data_en, "obj_shyren_522", "* Ty i Shyren zaszliście tak&  daleko^1, ale nadszedł&  już czas./")
ds_map_add(global.text_data_en, "obj_shyren_523", "* Obydwoje macie swoje własne&  życia do odbycia./")
ds_map_add(global.text_data_en, "obj_shyren_524", "* Nucisz pożegnalną nutę./^")
ds_map_add(global.text_data_en, "obj_shyren_537", "* Uśmiechasz się^1.&* Prosisz Shyrena^1, żeby&  też się uśmiechnęła./")
