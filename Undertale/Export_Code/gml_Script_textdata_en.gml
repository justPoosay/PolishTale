ds_map_add(global.text_data_en, "obj_icecap_npcg_70", "* Hej^1, przestań myśleć o&  mojej czapce!/")
ds_map_add(global.text_data_en, "obj_icecap_npcg_71", "* ... nie myślisz o mojej&  czapce?/")
ds_map_add(global.text_data_en, "obj_icecap_npcg_72", "* ... czy możesz zacząć^1,&  proszę?/%%")
ds_map_add(global.text_data_en, "obj_icecap_npcg_77", "* Ha^1!&* Po tym całym czasie^1, dalej&  myślisz o mojej czapce!/")
ds_map_add(global.text_data_en, "obj_icecap_npcg_78", "* .../")
ds_map_add(global.text_data_en, "obj_icecap_npcg_79", "* ... proszę?/%%")
ds_map_add(global.text_data_en, "obj_icecap_npcr_70", "* My wszyscy żyjemy w lesie^1,&  więc nikt nam nie może mówić&  co mamy robić!/")
ds_map_add(global.text_data_en, "obj_icecap_npcr_71", "* Ale teraz każdy nas ignoruje.../")
ds_map_add(global.text_data_en, "obj_icecap_npcr_72", "* Nie chcę wolności jeśli to&  znaczy, że nikt nie będzie&  zwracał na mnie uwagi./%%")
ds_map_add(global.text_data_en, "obj_icecap_npcr_77", "* Może ktoś na powierzchni&  zwróci na mnie uwagę./")
ds_map_add(global.text_data_en, "obj_icecap_npcr_78", "* Jest tyle ludzi^1, że ktoś&  musi^1, prawda!?/%%")
ds_map_add(global.text_data_en, "obj_icecube_174", "I...&I...")
ds_map_add(global.text_data_en, "obj_icecube_175", "Cóż mogę&rzec...")
ds_map_add(global.text_data_en, "obj_icecube_176", "Jaki&jest&cel...")
ds_map_add(global.text_data_en, "obj_icecube_177", "Tak...&Zimno...")
ds_map_add(global.text_data_en, "obj_icecube_181", "Ta...&Ja też&lubię&me włosy.")
ds_map_add(global.text_data_en, "obj_icecube_182", "Hmm...&Czapki&są dla&poserów.")
ds_map_add(global.text_data_en, "obj_icecube_183", "A więc&jeszcze&mogę cię&zaimponować?")
ds_map_add(global.text_data_en, "obj_icecube_184", "Chciałem&też być&czadowy.")
ds_map_add(global.text_data_en, "obj_icecube_188", "Haha!&To było&ŚMIESZNE!")
ds_map_add(global.text_data_en, "obj_icecube_189", "Ha!&Podnie-&ciłeś&się!")
ds_map_add(global.text_data_en, "obj_icecube_190", "To&najlepszy&z wszys-&tkich!")
ds_map_add(global.text_data_en, "obj_icecube_196", "%%%")
ds_map_add(global.text_data_en, "obj_icecube_377", "* 'Ice Cap' już nie Ice Capuje.")
ds_map_add(global.text_data_en, "obj_icecube_378", "* Pachnie jak zamarznięta&  rozpacz.")
ds_map_add(global.text_data_en, "obj_icecube_379", "* Lód nie kwestionuje swojej&  persony.")
ds_map_add(global.text_data_en, "obj_icecube_380", "* Topi się.")
