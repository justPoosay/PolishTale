ds_map_add(global.text_data_en, "SCR_TEXT_6887", "\E0* Mówi TORIEL./")
ds_map_add(global.text_data_en, "SCR_TEXT_6888", "* Chciałeś znów&  powiedzieć cześć?/")
ds_map_add(global.text_data_en, "SCR_TEXT_6889", "* 'Salutacje!'/")
ds_map_add(global.text_data_en, "SCR_TEXT_6890", "* Czy to wystarczy?/")
