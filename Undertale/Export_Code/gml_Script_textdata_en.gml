ds_map_add(global.text_data_en, "obj_papyrus7_200", "JA!/")
ds_map_add(global.text_data_en, "obj_papyrus7_201", "ZARAZ!/")
ds_map_add(global.text_data_en, "obj_papyrus7_202", "TO!/")
ds_map_add(global.text_data_en, "obj_papyrus7_203", "ZROBIĘ!/%%")
ds_map_add(global.text_data_en, "obj_papyrus7_221", " %")
ds_map_add(global.text_data_en, "obj_papyrus7_222", "* cóż^1?&* co to za pauza?/")
ds_map_add(global.text_data_en, "obj_papyrus7_224", "PAUZA!^1?&JAKA PAUZA!?/")
ds_map_add(global.text_data_en, "obj_papyrus7_225", "JA..^1.&WŁAŚNIE TO&URUCHAMIAM!/%%")
ds_map_add(global.text_data_en, "obj_papyrus7_244", " %")
ds_map_add(global.text_data_en, "obj_papyrus7_245", "* to^1, uh^1, nie wygląda&  na aktywowane./")
ds_map_add(global.text_data_en, "obj_papyrus7_247", "CÓŻ!!!/")
ds_map_add(global.text_data_en, "obj_papyrus7_248", "TO WYZWANIE!!!/")
ds_map_add(global.text_data_en, "obj_papyrus7_249", "\E3WYDAJE SIĘ.../")
ds_map_add(global.text_data_en, "obj_papyrus7_250", "MOŻE..^1. ZBYT ŁATWYM&SPOSOBEM^1, BY&POKONAĆ CZŁOWIEKA./")
ds_map_add(global.text_data_en, "obj_papyrus7_251", "\E1TAK^1!&NIE MOŻEMY&TEGO UŻYĆ!!!/")
ds_map_add(global.text_data_en, "obj_papyrus7_252", "JESTEM SZKIELETEM&ZE STANDARDAMI!!!/")
ds_map_add(global.text_data_en, "obj_papyrus7_253", "MOJE PUZZLE&SĄ BARDZO&SPRAWIEDLIWE!/")
ds_map_add(global.text_data_en, "obj_papyrus7_254", "I MOJE PUŁAPKI&SĄ DOSKONALE&UPIECZONE!/")
ds_map_add(global.text_data_en, "obj_papyrus7_255", "ALE TO JEST&ZBYT BEZPOŚREDNI^1!&BEZ SZACUNKU!/")
ds_map_add(global.text_data_en, "obj_papyrus7_256", "\E0I ZIUUUU ZNIKA!/%%")
ds_map_add(global.text_data_en, "obj_papyrus7_260", "CÓŻ!!!/")
ds_map_add(global.text_data_en, "obj_papyrus7_261", "\E3... ON PEWNIE&OMINIE TO&CAŁKOWICIE BOKIEM./")
ds_map_add(global.text_data_en, "obj_papyrus7_262", "I WOGULE NIE&BĘDZIE ZABAWNE./")
ds_map_add(global.text_data_en, "obj_papyrus7_264", "* hmmm...&* więc to wszystko&  było na marne^1, huh?/")
ds_map_add(global.text_data_en, "obj_papyrus7_266", "CÓŻ^1. W SENSIE^1.&CIESZĘ SIĘ^1, ŻE ZDO-&ŁAŁEM GO PORWAĆ./")
ds_map_add(global.text_data_en, "obj_papyrus7_267", "\E0WIĘC STANĘ SIĘ&POPULARNYM KRÓLEW-&SKIM RYCERZEM!!!/")
ds_map_add(global.text_data_en, "obj_papyrus7_268", "\E3ALE TEN CAŁY WYSI-&ŁEK WŁOŻONY W TE&PUZZLE.../")
ds_map_add(global.text_data_en, "obj_papyrus7_269", "JEST TROCHĘ JAK&ORGANIZOWANIE&URODZIN.../")
ds_map_add(global.text_data_en, "obj_papyrus7_271", "* bez pułapek i ognia?/")
ds_map_add(global.text_data_en, "obj_papyrus7_273", "DOKŁADNIE!^1!&NIE MA SENSU!!!/")
ds_map_add(global.text_data_en, "obj_papyrus7_274", "\E3MOŻE MIAŁEŚ PRAWO&DO BYCIA LENIWYM&W PUZZLACH./")
ds_map_add(global.text_data_en, "obj_papyrus7_276", "* ja^1?&* prawo do czegoś^1?&* naprawdę?/")
ds_map_add(global.text_data_en, "obj_papyrus7_278", ".../")
ds_map_add(global.text_data_en, "obj_papyrus7_279", "\E0NO TA!^1!&ALE POMIMO&TEGO!/")
ds_map_add(global.text_data_en, "obj_papyrus7_280", "DALEJ JESTEŚ&W KOMPLETNYM&BŁĘDZIE!/")
ds_map_add(global.text_data_en, "obj_papyrus7_281", "PO PROSTU MAM&NIEODPOWIEDNIĄ&WIDOWNIĘ!/")
ds_map_add(global.text_data_en, "obj_papyrus7_282", "POMYŚL SOBIE&ILE FRAJDY MIAŁABY&UNDYNE TUTAJ!/")
ds_map_add(global.text_data_en, "obj_papyrus7_283", "OGIEŃ^1, PRZEMOC^1.&TO TAKIE W&JEJ STYLU!/")
ds_map_add(global.text_data_en, "obj_papyrus7_284", "WIĘC NIE BĘDĘ&MARNOWAŁ TEGO&NA CIEBIE./")
ds_map_add(global.text_data_en, "obj_papyrus7_285", "PO PROSTU&DOCENIĘ.../")
ds_map_add(global.text_data_en, "obj_papyrus7_286", "PRZYJACIÓŁKĘ^1, KTÓRĄ&PRZECIEŻ JUŻ MAM!!!/%%")
ds_map_add(global.text_data_en, "obj_papyrus7_316", "UF!/%%")
ds_map_add(global.text_data_en, "obj_papyrus7_333", "NA CO SIĘ&GAPISZ!?/")
ds_map_add(global.text_data_en, "obj_papyrus7_334", "TO BYŁA KOLEJNA&PLANOWANA WYGRA-&NA DLA PAPYRUSA!!/")
