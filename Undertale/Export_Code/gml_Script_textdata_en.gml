ds_map_add(global.text_data_en, "obj_puzzlehater_76", "* Bahh!!^1!&* Nevermind!!/%%")
ds_map_add(global.text_data_en, "obj_puzzlehater_80", "* So^1?&* What are you waiting for!?/%%")
ds_map_add(global.text_data_en, "obj_puzzlehater_85", "* Bah^1! Today's monsters don't&  appreciate what makes&  puzzles great!/")
ds_map_add(global.text_data_en, "obj_puzzlehater_86", "* Nowadays " + '"' + "puzzles" + '"' + " are nothing&  but lasers and moving rocks.../")
ds_map_add(global.text_data_en, "obj_puzzlehater_87", "* Bahh!!!/")
ds_map_add(global.text_data_en, "obj_puzzlehater_88", "* There's no ART in that&  actiony^1, mindless schlock^1!&* It's just timing-based drivel!/")
ds_map_add(global.text_data_en, "obj_puzzlehater_89", "* Give me something that&  challenges the deepest&  reaches of my mind.../")
ds_map_add(global.text_data_en, "obj_puzzlehater_90", "* You^1!&* You're young^1!&* You've still got hope!/")
ds_map_add(global.text_data_en, "obj_puzzlehater_91", "* Geh heh heh...^1!&* Here..^1. try solving this&  block-pushing puzzle!/%%")
ds_map_add(global.text_data_en, "obj_puzzlehater_97", "* Geh^1?&* Who are you?/")
ds_map_add(global.text_data_en, "obj_puzzlehater_98", "* Freedom^1? What^1? Bah^1!&* You're pullin' my leg!/%%")
ds_map_add(global.text_data_en, "obj_puzzlehater_102", "* You again!^1?&* Bah^1! I don't care about&  going free!/")
ds_map_add(global.text_data_en, "obj_puzzlehater_103", "* .../")
ds_map_add(global.text_data_en, "obj_puzzlehater_104", "* Do you think humans could&  appreciate the details&  of classic puzzles...?/%%")
ds_map_add(global.text_data_en, "obj_puzzlehaterbox_78", "* (It's a box.^1)&* (Presumably to be pushed.)/%%")
ds_map_add(global.text_data_en, "obj_puzzlehaterbox_84", "* Bah!/%%")
ds_map_add(global.text_data_en, "obj_puzzlehaterbox_91", "* What...^1?&* WHAT are you doing!^1?&* You're pushing it ALL WRONG!/")
ds_map_add(global.text_data_en, "obj_puzzlehaterbox_92", "* Bah^1, forget it^1!&* This generation is REALLY&  hopeless!/%%")
ds_map_add(global.text_data_en, "obj_puzzlewall1_62", "NO WE!&NIE BĄDŹ&TAKI NIEMIŁY!!!/")
ds_map_add(global.text_data_en, "obj_puzzlewall1_63", "ZBUDOWAŁEM&TEN LABIRYNT&DLA CIEBIE!/%%")
ds_map_add(global.text_data_en, "obj_puzzlewall1_66", "\E3CZY TY TAK&TRAKTUJESZ&WŁASNĄ MATKĘ.../")
ds_map_add(global.text_data_en, "obj_puzzlewall1_67", "KIEDY ONA CI&ROBI ŁAMIGÓWKĘ&?!?!?/%%")
ds_map_add(global.text_data_en, "obj_puzzlewall1_71", "\E3TE CZŁOWIEKI.../%%")
ds_map_add(global.text_data_en, "obj_puzzlewall2_62", "SANS!!!^1!&CZŁOWIEK&UCIEKA!!!/")
ds_map_add(global.text_data_en, "obj_puzzlewall2_63", "ZROBIŁEŚ&TEN PUZZEL&ZBYT TRUDNY!!/")
ds_map_add(global.text_data_en, "obj_puzzlewall2_64", "HEJ TY!!^1!&WRACAJ TU!/%%")
ds_map_add(global.text_data_en, "obj_pyrope_266", "Hot!!!&Error.")
ds_map_add(global.text_data_en, "obj_pyrope_270", "Burn,&baby,&BURN!")
ds_map_add(global.text_data_en, "obj_pyrope_271", "Hot&enough&for&ya!?")
ds_map_add(global.text_data_en, "obj_pyrope_272", "Feel&the&heat.")
ds_map_add(global.text_data_en, "obj_pyrope_273", "Is it&cold in&here?")
ds_map_add(global.text_data_en, "obj_pyrope_280", "Hot!!&HOT!!&Hotter!&HOTTER!!")
ds_map_add(global.text_data_en, "obj_pyrope_285", "BRRRR!&What's&the&deal!?")
ds_map_add(global.text_data_en, "obj_pyrope_289", "Sorry!!&I'm all&tied&up!!")
ds_map_add(global.text_data_en, "obj_pyrope_294", "%%%")
ds_map_add(global.text_data_en, "obj_pyrope_492", "* Pyrope is protected by its&  winsome smile.")
ds_map_add(global.text_data_en, "obj_pyrope_493", "* Pyrope is pretending to&  pull the fire alarm.")
ds_map_add(global.text_data_en, "obj_pyrope_494", "* Pyrope is chuckling through&  its teeth.")
ds_map_add(global.text_data_en, "obj_pyrope_495", "* Pyrope is pretending to be&  a candle.")
ds_map_add(global.text_data_en, "obj_pyrope_496", "* Smells like rope burn.")
ds_map_add(global.text_data_en, "obj_pyrope_497", "* Pyrope wants more heat.")
ds_map_add(global.text_data_en, "obj_pyrope_498", "* The room is sweltering!")
ds_map_add(global.text_data_en, "obj_pyrope_524", "* PYROPE - ATK 29 DEF 14&* This mischievous monster&  is never warm enough./^")
ds_map_add(global.text_data_en, "obj_pyrope_534", "* You blow on Pyrope.&* Its flames die down.&* Pyrope's ATTACK dropped!/^")
ds_map_add(global.text_data_en, "obj_pyrope_555", "* You crank up the thermostat.&* Pyrope begins to get&  excited./^")
ds_map_add(global.text_data_en, "obj_pyrope_556", "* You crank up the thermostat.&* It's super hot!&* Pyrope looks satisfied./^")
ds_map_add(global.text_data_en, "obj_pyrope_557", "* You crank up the thermostat.&* It's SOOOO hot!/^")
ds_map_add(global.text_data_en, "obj_pyrope_571", "* You invite Pyrope to hang&  out./^")
ds_map_add(global.text_data_en, "obj_pyropenpc_72", "* Haha^1, ha ha ha^1.&* Secret^1, secret^1.&* I've done up a trouble./")
ds_map_add(global.text_data_en, "obj_pyropenpc_73", "* I set the lava on fire./")
ds_map_add(global.text_data_en, "obj_pyropenpc_74", "* No one will EVER know^1.&* It's the perfect crime.../%%")
ds_map_add(global.text_data_en, "obj_pyropenpc_78", "* Haha^1, ha ha ha^1.&* If we leave^1, no one will&  REALLY ever know!!/%%")
ds_map_add(global.text_data_en, "obj_pyropenpc_82", "* The lava's so spicey now./%%")
ds_map_add(global.text_data_en, "obj_pyropenpc_87", "* Haha^1, ha ha ha^1.&* Ya wanna " + '"' + "hang" + '"' + " out?/")
ds_map_add(global.text_data_en, "obj_pyropenpc_88", "* Haha^1, ha ha ha^1.&* Sorry^1, I'm all TIED UP!!!/")
ds_map_add(global.text_data_en, "obj_pyropenpc_89", "* Psyche^1! Owned^1!&* No one wants to be MY&  friend!!!/%%")
ds_map_add(global.text_data_en, "obj_pyropenpc_93", "* Haha^1, ha ha ha^1.&* Wonder if any humans would&  wanna be my friend./")
ds_map_add(global.text_data_en, "obj_pyropenpc_94", "* PSYYYYCHE^1!&* That'd NEVER happen!/%%")
ds_map_add(global.text_data_en, "obj_pyropenpc_97", "* I'm too spicey to have&  any friends./%%")
ds_map_add(global.text_data_en, "obj_questionasker_119", "ERROR? %%")
ds_map_add(global.text_data_en, "obj_questionasker_130", "HAHAHA, YOU WISH!&WRONG!")
ds_map_add(global.text_data_en, "obj_questionasker_132", "WRONG! IF ONLY ALPHYS&COULD HELP!")
ds_map_add(global.text_data_en, "obj_questionasker_134", "NOPE! TOO BAD ALPHYS&CAN'T HELP!")
ds_map_add(global.text_data_en, "obj_questionasker_136", "WRONG!!! WRONG!!!&WROOOOOOOONG!!")
ds_map_add(global.text_data_en, "obj_questionasker_138", "COMPLETELY UTTERLY&WRONG!!!!!!")
ds_map_add(global.text_data_en, "obj_questionasker_140", "BOY, THAT'S&EMBARRASSING, HUH?")
ds_map_add(global.text_data_en, "obj_questionasker_142", "TIME'S UP!&GUESS THAT'S A NO?? ")
ds_map_add(global.text_data_en, "obj_questionasker_144", "NO NO NO!&CAN'T YOU READ!?")
ds_map_add(global.text_data_en, "obj_questionasker_151", "RIGHT! SOUNDS LIKE&YOU GET IT!")
ds_map_add(global.text_data_en, "obj_questionasker_153", "CORRECT! WHAT A&TERRIFIC ANSWER!")
ds_map_add(global.text_data_en, "obj_questionasker_155", "TOO EASY FOR&YOU, HUH??????????")
ds_map_add(global.text_data_en, "obj_questionasker_157", "WONDERFUL! I'M&ASTOUNDED, FOLKS!")
ds_map_add(global.text_data_en, "obj_questionasker_159", "CORRECT! YOU'RE SO&LUCKY TODAY!!!")
ds_map_add(global.text_data_en, "obj_questionasker_161", "I'M SO FLATTERED YOU&REMEMBERED!")
ds_map_add(global.text_data_en, "obj_questionasker_163", "GREAT ANSWER!&I LOVE IT!!!!!!!")
ds_map_add(global.text_data_en, "obj_questionasker_165", "OF COURSE THAT&WAS EASY FOR YOU!")
ds_map_add(global.text_data_en, "obj_questionasker_176", "* The quiz show continues.")
ds_map_add(global.text_data_en, "obj_questionasker_538", "OH^1! OH^1! I KNOW&THIS ONE!!!&IT'S SNAIL ICE&CREAM!!!!!!!^1!%")
ds_map_add(global.text_data_en, "obj_questionasker_539", "IN THE FOURTH&CHAPTER EVERYONE&GOES TO THE&BEACH!!!%")
ds_map_add(global.text_data_en, "obj_questionasker_540", "AND SHE BUYS&ICE CREAM FOR&ALL OF HER&FRIENDS!!!!%")
ds_map_add(global.text_data_en, "obj_questionasker_541", "BUT IT'S SNAIL&FLAVOR AND SHE'S&THE ONLY ONE&WHO WANTS IT!!!!!!%")
ds_map_add(global.text_data_en, "obj_questionasker_542", "IT'S ONE OF MY&FAVORITE PARTS&OF THE GAME&BECAUSE%")
ds_map_add(global.text_data_en, "obj_questionasker_543", "IT'S ACTUALLY A&VERY POWERFUL&message abou^1t&friendshi^1p and..^2.%%")
ds_map_add(global.text_data_en, "obj_questionasker_566", "ALPHYS^1,&ALPHYS^1,&ALPHYS./")
ds_map_add(global.text_data_en, "obj_questionasker_567", "YOU AREN'T HELPING&OUR CONTESTANT,&ARE YOU?/")
ds_map_add(global.text_data_en, "obj_questionasker_568", "OOOOOOH!!!&YOU SHOULD HAVE&TOLD ME./")
ds_map_add(global.text_data_en, "obj_questionasker_569", "I'LL ASK A&QUESTION.../")
ds_map_add(global.text_data_en, "obj_questionasker_570", "YOU'LL BE SURE&TO KNOW THE&ANSWER TO!/%%")
ds_map_add(global.text_data_en, "obj_questionasker_598", "ALPHYS^1, ALPHYS^1,&ALPHYS./")
ds_map_add(global.text_data_en, "obj_questionasker_599", "YOU AREN'T HELPING&OUR CONTESTANT,&ARE YOU?/")
ds_map_add(global.text_data_en, "obj_questionasker_600", "OOOOOOH!!!&YOU SHOULD HAVE&TOLD ME./")
ds_map_add(global.text_data_en, "obj_questionasker_601", "I'LL ASK A&QUESTION.../")
ds_map_add(global.text_data_en, "obj_questionasker_602", "YOU'LL BE SURE&TO KNOW THE&ANSWER TO!/%%")
ds_map_add(global.text_data_en, "obj_questionasker_607", "SEE, ALPHYS?&I TOLD YOU IT&WAS OBVIOUS./")
ds_map_add(global.text_data_en, "obj_questionasker_608", "EVEN THE HUMAN&FIGURED IT OUT./")
ds_map_add(global.text_data_en, "obj_questionasker_609", "YES, SHE SCRAWLS&HER NAME IN THE&MARGINS OF HER&NOTES./")
ds_map_add(global.text_data_en, "obj_questionasker_610", "SHE NAMES PROGRAMMING&VARIABLES AFTER&HER./")
ds_map_add(global.text_data_en, "obj_questionasker_613", "SHE EVEN WRITES&STORIES OF THEM&TOGETHER.../")
ds_map_add(global.text_data_en, "obj_questionasker_614", "SHARING A DOMESTIC&LIFE./")
ds_map_add(global.text_data_en, "obj_questionasker_615", "PROBABILITY OF&CRUSH:&101 PERCENT./")
ds_map_add(global.text_data_en, "obj_questionasker_616", "MARGIN OF ERROR.&ONE PERCENT./%%")
ds_map_add(global.text_data_en, "obj_questionasker_624", "WHY WOULD SOMEONE&OUTFIT AN&AMUSEMENT ROBOT.../")
ds_map_add(global.text_data_en, "obj_questionasker_625", "WITH BRUTAL COMBAT&CAPABILITIES?/")
ds_map_add(global.text_data_en, "obj_questionasker_626", "SIMPLE./")
ds_map_add(global.text_data_en, "obj_questionasker_627", "TO IMPRESS MR.&ASGORE DREEMURR,&OF COURSE!/")
ds_map_add(global.text_data_en, "obj_questionasker_628", "OR AS ALPHYS&CALLS HIM.../")
ds_map_add(global.text_data_en, "obj_questionasker_629", '"' + "MR. DREAMY." + '"' + "/")
ds_map_add(global.text_data_en, "obj_questionasker_630", "THOSE STRONG ARMS.../")
ds_map_add(global.text_data_en, "obj_questionasker_631", "THAT LUSTROUS&BEARD.../")
ds_map_add(global.text_data_en, "obj_questionasker_632", "LIKE ALL THOSE WHO&CREATE WEAPONS./")
ds_map_add(global.text_data_en, "obj_questionasker_633", "SHE CRAVES THE&TENDER EMBRACE OF&A BURLY MAN./")
ds_map_add(global.text_data_en, "obj_questionasker_634", "CAN SHE TRULY&BE BLAMED?/%%")
ds_map_add(global.text_data_en, "obj_questionasker_642", "... SERIOUSLY?/")
ds_map_add(global.text_data_en, "obj_questionasker_643", "MY MY..^1.&HOW CONCEITED CAN&YOU GET...?/")
ds_map_add(global.text_data_en, "obj_questionasker_644", "I LOVE IT!/")
ds_map_add(global.text_data_en, "obj_questionasker_645", "AND WHILE YOU ARE&COMPLETELY WRONG^1,&YOU DESERVE SOME&CREDIT./")
ds_map_add(global.text_data_en, "obj_questionasker_646", "I'VE SEEN HER WATCH&YOU ON HER COMPUTER&SCREEN./")
ds_map_add(global.text_data_en, "obj_questionasker_647", "SMILING WHEN YOU&SUCCEED./")
ds_map_add(global.text_data_en, "obj_questionasker_648", "SHRIEKING WHEN YOU&FAIL./")
ds_map_add(global.text_data_en, "obj_questionasker_649", "AND ALWAYS, ALWAYS,&WHISPERING.../")
ds_map_add(global.text_data_en, "obj_questionasker_650", '"' + "NO! WRONG!&YOU HAVE TO&GO THAT WAY!" + '"' + "/")
ds_map_add(global.text_data_en, "obj_questionasker_651", "IN ITS OWN WAY^1,&IS THIS NOT&LOVE??/%%")
ds_map_add(global.text_data_en, "obj_questionasker_657", "CORRECT./")
ds_map_add(global.text_data_en, "obj_questionasker_658", "DR. ALPHYS HAS&A CRUSH ON.../")
ds_map_add(global.text_data_en, "obj_questionasker_659", "THE UNKNOWABLE./")
ds_map_add(global.text_data_en, "obj_questionasker_660", "YOU SEE, ALPHYS&BELIEVES THERE IS&SOMEONE OUT THERE./")
ds_map_add(global.text_data_en, "obj_questionasker_661", "SOMEONE WATCHING HER./")
ds_map_add(global.text_data_en, "obj_questionasker_662", "SOMEONE SHE THINKS&IS " + '"' + "CUTE" + '"' + " AND&" + '"' + "INTERESTING." + '"' + "/")
ds_map_add(global.text_data_en, "obj_questionasker_663", "HELLO, THEORETICAL&PERSON./")
ds_map_add(global.text_data_en, "obj_questionasker_664", "DR. ALPHYS LIKES&YOU./")
ds_map_add(global.text_data_en, "obj_questionasker_665", "TOO BAD YOU&ARE NOT REAL./")
ds_map_add(global.text_data_en, "obj_questionasker_666", "*DERISIVE&LAUGHTRACK*/%%")
ds_map_add(global.text_data_en, "obj_questionasker_691", "H-hey^1, I've done&research about this!/")
ds_map_add(global.text_data_en, "obj_questionasker_692", "There are alternate&universes out there!/")
ds_map_add(global.text_data_en, "obj_questionasker_693", "S-someday^1, maybe^1, I&could meet them.../%%")
ds_map_add(global.text_data_en, "obj_questionasker_704", "YOU SAID THE&EXACT SAME THING&ABOUT " + '"' + "MEW MEW&KISSY CUTIE." + '"' + "/")
ds_map_add(global.text_data_en, "obj_questionasker_705", "BUT I'LL GIVE YOU&THE BENEFIT OF&THE DOUBT./")
ds_map_add(global.text_data_en, "obj_questionasker_706", "PERSON^1, IF YOU'RE&OUT THERE.../")
ds_map_add(global.text_data_en, "obj_questionasker_707", "HOW ABOUT GIVING US&A SIGN^1, RIGHT NOW?/%%")
ds_map_add(global.text_data_en, "obj_questionasker_725", "THAT SETTLES&THAT, DOESN'T IT?/%%")
ds_map_add(global.text_data_en, "obj_questionasker_745", "WELL WELL WELL./")
ds_map_add(global.text_data_en, "obj_questionasker_746", "WITH DR. ALPHYS&HELPING YOU.../")
ds_map_add(global.text_data_en, "obj_questionasker_747", "THE SHOW HAS NO&DRAMATIC TENSION!/")
ds_map_add(global.text_data_en, "obj_questionasker_748", "WE CAN'T GO ON&LIKE THIS!!/")
ds_map_add(global.text_data_en, "obj_questionasker_749", "BUT./")
ds_map_add(global.text_data_en, "obj_questionasker_750", "BUT!!!/")
ds_map_add(global.text_data_en, "obj_questionasker_751", "THIS WAS JUST THE&PILOT EPISODE!!/")
ds_map_add(global.text_data_en, "obj_questionasker_752", "NEXT UP, MORE&DRAMA!/")
ds_map_add(global.text_data_en, "obj_questionasker_753", "MORE ROMANCE!!!/")
ds_map_add(global.text_data_en, "obj_questionasker_754", "MORE BLOODSHED!!!/")
ds_map_add(global.text_data_en, "obj_questionasker_755", "UNTIL NEXT TIME,&DARLINGS...!!!/%%")
ds_map_add(global.text_data_en, "obj_readable_modernbook_59", "%%")
ds_map_add(global.text_data_en, "obj_readable_modernbook_60", "* (Here I am..^1.&* Writing this book.)/")
ds_map_add(global.text_data_en, "obj_readable_modernbook_61", "* (A person comes in and picks&  up the book...)/")
ds_map_add(global.text_data_en, "obj_readable_modernbook_62", "* (They start reading it...!)/")
ds_map_add(global.text_data_en, "obj_readable_modernbook_63", "* Oh^1, sorry^1.&* I'm still writing that one./%%")
ds_map_add(global.text_data_en, "obj_readable_modernbook_68", "* (Some unfinished book.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_64", "%%")
ds_map_add(global.text_data_en, "obj_readable_room1_65", "* Tylko nieustraszeni mogą iść.&* Odważni, głupkowaci.&* Oboje idą nie w dobrą stronę./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_66", "* Zostań na ścieżce./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_67", "* Zachodnie pomieszczenie jest&  odbiciem wschodniego./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_68", "* Trzy z czterech szarych&  kamieni zalecają, żebyś&  je popchnął./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_69", "* (W szczelinie w ścianie&  czai żaba wielkości mrówki...^1)&* (Macha do ciebie.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_69_console_1", "* (W ścianie jeste&  mała szczelina.)/")
ds_map_add(global.text_data_en, "obj_readable_room1_69_console_2", "* (żabiec jest w środku...^2)&* (Czekaj^1! Są dwie żaby!)/")
ds_map_add(global.text_data_en, "obj_readable_room1_69_console_3", "* (Miałeś wspanniałe,&  ekskluzywne doświadczenie...)/")
ds_map_add(global.text_data_en, "obj_readable_room1_69_console_4", "* (... które tylko osoba&  widząca dwie żaby mogła&  doświadczyć.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_70", "* Jest tylko jeden&  przełącznik./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_71", "* Dalekie drzwi nie są wyjściem^1.&* Po prostu oznaczają rotację&  w perspektywie./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_72", "* Jeśli to czytasz^1,&  naciśnij niebieski guzik./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_73", "* Jeśli to czytasz^1,&  naciśnij czerwony guzik./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_74", "* Jeśli to czytasz^1,&  naciśnij zielony guzik./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_75", "* Te książki są ztarte...&* Musiały być przeczytane&  wiele razy./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_78", "* (Jest stary kalendarz&  z czasów 201X.^1)&* (Data jest zakreślona.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_79", "\R* (Data^1, w której przybyłxm.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_81", "* Końcówki narzędzi zostały&  spiłowane^1, aby zrobić&  je bezpieczniejszymi./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_82", "* Wyglądają na&  narzędzia ogrodnicze./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_83", "* Spójrz na te fajne zabawki^2!&* One wcale cię nie interesują./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_84", "* (Zakurzone zabawki.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_86", "* Sala Tronowa/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_90", "* (To trumna.^1)&* (Jest na niej wygrawerowane&  jakieś imię.)/")
ds_map_add(global.text_data_en, "obj_readable_room1_91", "* (" + '"' + "\[C]." + '"' + ")/")
ds_map_add(global.text_data_en, "obj_readable_room1_92", "* (Jest puste.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_96", "* (Trumna jest pusta...?)/")
ds_map_add(global.text_data_en, "obj_readable_room1_97", "* (Nie zauważyłeś tego&  wcześniej^1, ale jest coś&  przypominającego...)/")
ds_map_add(global.text_data_en, "obj_readable_room1_98", "* (... owijek mumii na&  dnie trumny.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_103", "\R* (Jest tak wygodne^1, na&  jakie wygląda.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_112", "* Zerkasz do środka..^2.&* Co za skandal!/")
ds_map_add(global.text_data_en, "obj_readable_room1_113", "* To kolekcja&  skarpet TORIEL./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_114", "* Nie możesz przestać&  patrzećna nie./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_118", "* (Przeszedłeś całą drogę&  spowrotem^1, by popatrzeć na&  skarpety Toriel.)/")
ds_map_add(global.text_data_en, "obj_readable_room1_119", "* (Masz niezłe priorytety&  w życiu ;-;.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_125", "* To szuflada na ubrania^1.&* Są tu szlafroki^1,&  koszulki na guziki.../")
ds_map_add(global.text_data_en, "obj_readable_room1_126", "* ... i różowy^1, ręcznie&  szydełkowany sweter z napisem&  " + '"' + "Pan Tata." + '"' + "/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_130", "\R* Dalej posiada ten sweter./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_134", "* (To tylko krzesło.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_139", "* (Tron.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_142", "* " + '"' + "Pokój pod renowacją." + '"' + "/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_143", "* " + '"' + "Pokój pod renowacją." + '"' + "/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_144", "* Z jakiegoś powodu^1, jest&  markowa tabliczka&  czekolady w lodówce./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_147", "* (Lodówka jest pełna&  nieotworzonych pojemników&  ze ślimakami.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_151", "\R* Nie ma czekolady./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_154", "* ...!^1?&* Jest kamera&  ukryta w krzakach./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_155", "* (Jego.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_158", "* Jest przycisk&  zakopany w śniegu^1.&* Klik!/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_159", "* Przycisk utknął./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_162", "* Jest tutaj przycisk^1.&* Został splątany&  z pnączami./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_164", "* Na podłodze leży&  pudło z pomerodzynkami./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_198", "* (To szkolny raport na&  temat pogrzebów potworów.)/")
ds_map_add(global.text_data_en, "obj_readable_room1_199", "* Pogrzeby potworów^1, technicznie&  rzecz mówiąc^2, są zarąbiste./")
ds_map_add(global.text_data_en, "obj_readable_room1_200", "* Kiedy potwory są stare i&  kopają w kalendarz^1, &  zamieniają się w proch./")
ds_map_add(global.text_data_en, "obj_readable_room1_201", "* Na pogrzebach^1, bierzemy te&  prochy i rozsypujemy na&  ulubiony przedmiot tej osoby./")
ds_map_add(global.text_data_en, "obj_readable_room1_202", "* Wtedy ich esencja będzie&  żyć na tym przedmiocie.../")
ds_map_add(global.text_data_en, "obj_readable_room1_203", "* Uhhh^1, czy osiągnąłem już&  minimum słów^1?&* Mam trochę dość pisania tego./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_208", "\W* Mama mówi^1, że sen&  leczy twoje zdrowie&  \Ypowyżej maksimum HP\W./")
ds_map_add(global.text_data_en, "obj_readable_room1_209", "* ... czym jest HP?/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_213", "* Mama mówi^1, że możemy już&  iść na powierzchnię!/")
ds_map_add(global.text_data_en, "obj_readable_room1_214", "* ... co jest w tym fajnego&  tak wogule^1?&* Nie chcę się przeprowadzać./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_219", "* (To ledwie przynęta na ciebie.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_228", "* " + '"' + "Zdolność wyodrębnienia&  ich DUSZY." + '"' + "/")
ds_map_add(global.text_data_en, "obj_readable_room1_229", "* " + '"' + "To moc, której&  obawiali się ludzie." + '"' + "/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_235", "* (Starożytne pismo pokrywa&  ściany..^1. jesteś w stanie&  wyciągnąć pojedyncze słowa.)/")
ds_map_add(global.text_data_en, "obj_readable_room1_236", "* " + '"' + "Wojna Ludzi i Potworów." + '"' + "/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_241", "* Północne pomieszczenie&  skrywa wartościowy skarb./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_247", "* Skrzywdzeni, pobici i bojaźliwi&  o nasze życia, poddaliśmy&  się ludziom./")
ds_map_add(global.text_data_en, "obj_readable_room1_248", "* Siedem z ich najzdolniejszych&  magów zapieczętował nas pod&  ziemią magicznym zaklęciem./")
ds_map_add(global.text_data_en, "obj_readable_room1_249", "* Wszystko może się przedrzeć&  przez pieczęć, ale tylko istoty&  z silną DUSZĄ mogą opuścić./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_256", "* Jednak...&* To tylko przepowiednia./")
ds_map_add(global.text_data_en, "obj_readable_room1_257", "* Anioł...&* Ten który widział&  Powierzchnię.../")
ds_map_add(global.text_data_en, "obj_readable_room1_258", "* Ono powróci.&* I podziemia staną&  się puste./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_263", "* Starożytne glify&  zostały przefarbowane listą&  21 różnych smaków./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_269", "* Apsik^1!&* Próbowałem złapać robaka^1, ale&  jedyne co mam to przeziębienie.../%%")
ds_map_add(global.text_data_en, "obj_readable_room1_274", "* Ludzie, bojący sę naszej&  mocy^1, zadeklarowali wojnę./")
ds_map_add(global.text_data_en, "obj_readable_room1_275", "* Zaatakowali nagle,&  bez litości./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_280", "* Nie mając świec ani magii, by&  dotrzeć do Domu^1, potwory&  używali kryształy do nawigacji./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_292", "* (To zniekształcona figurka&  kobiety z kocimi uszami.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_293", "* (Jest zbyt ciemno^1, by widzieć&  koło ścian.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_299", "* (Książki naukowe.^1)&* (Wydają się&  bardzo zakurzone.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_304", "* (To lodówka.^1)&* (Jest niepokojąco ciepła.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_306", "* (Jest zbyt ciemno^1, by widzieć&  koło ścian.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_312", "* MLEKO^1? JAJKA^1? W LODÓWCE?/")
ds_map_add(global.text_data_en, "obj_readable_room1_313", "* NIEDOWIARY^1, KOCHANY^1!&* ZROBIŁYBY SIĘ ZIMNE!!!/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_320", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_readable_room1_321", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_readable_room1_322", "* Um^1, czy to na pewno&  dobry pomysł, by&  brać przekąskę?/")
ds_map_add(global.text_data_en, "obj_readable_room1_323", "\E8* Cóż^1, w takim razie&  nie powinienem&  cię osądzać.../")
ds_map_add(global.text_data_en, "obj_readable_room1_324", "\E0* W końcu to ja jem&  moje czipsy&  ziemniaczane w piżamie!/")
ds_map_add(global.text_data_en, "obj_readable_room1_325", "\E5* Uhhh^1, To znaczy..^1.&* H-hej^1, idź tam&  na prawo!/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_328", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_readable_room1_329", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_readable_room1_330", "* H-hej^1!&* Kieruj się na&  prawo!/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_347", "* Nienawidzę chłodnego&  jedzenia./")
ds_map_add(global.text_data_en, "obj_readable_room1_349", "\E0* Więc Alphys naprawiła mi&  lodówkę tak^1, żeby&  ona ogrzewała jedzenie!/")
ds_map_add(global.text_data_en, "obj_readable_room1_350", "\E6* Gorąca Lodówka..^1.&* Najlepszy wynalazek&  jak dotąd!/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_354", "\E6* Gorąca Lodówka..^1.&* Najlepszy wynalazek&  jak dotąd!/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_360", "* Piec jest jakąś&  unikatową&  kolekcją MTT./")
ds_map_add(global.text_data_en, "obj_readable_room1_361", "\E4* Ale^1, no wiesz^1, tyle^1,&  ile technologia się&  ulepsza.../")
ds_map_add(global.text_data_en, "obj_readable_room1_362", "\E0* Nic nie pobije&  kuchni domowej z&  ogniową magią./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_369", "* (Wygląda na jakąś&  możną bransoletkę...)/")
ds_map_add(global.text_data_en, "obj_readable_room1_370", "* (Chwila.^1)&* (To tylko croissant...)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_375", "* (To tylko zwykła ściana.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_380", "* (Wschód...)&* (Koniec.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_385", "* (Rozwiąż zagadkę,&  a Koniec się otworzy.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_390", "* (Przemierz przez północne&  pomieszczenie^1, a Koniec&  się otworzy.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_395", "* (Nie mogę walczyć.)&* (Nie mogę myśleć.)/")
ds_map_add(global.text_data_en, "obj_readable_room1_396", "* (Jednak^1, z cierpliwością^1,&  przemierzę moją drogę.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_401", "* (Wynieś się stąd...)&* (I niech tak zostanie.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_406", "* (Czemu nie zrelaksować się i&  iść na fajną przekąskę?)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_416", "* (Jest kompletnie zniszczone.^1)&* (Nie ma opcji^1, by kiedykolwiek&  zostało naprawione.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_419", "* (Rozładowała się bateria.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_425", "* WPIS NUMER 1/")
ds_map_add(global.text_data_en, "obj_readable_room1_426", "* To jest to..^1.&* Czas by zrobić to^1, &  o co Król mnie prosił./")
ds_map_add(global.text_data_en, "obj_readable_room1_427", "* Stworzę moc, by&  nas wszystkich uwolnić./")
ds_map_add(global.text_data_en, "obj_readable_room1_428", "* Uwolnię surową moc&  DUSZY./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_430", "* (Wydaje się być wyłączone.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_435", "* POMIESZCZENIE ZASILANIA/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_436", "* (Wydaje się być wyłączone.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_441", "* WPIS NUMER 6/")
ds_map_add(global.text_data_en, "obj_readable_room1_442", "* ASGORE poprosił wszystkich&  spoza stolicy o potwory&  które już " + '"' + "przepadły." + '"' + "/")
ds_map_add(global.text_data_en, "obj_readable_room1_443", "* Ich ciała dzisiaj przyszły./")
ds_map_add(global.text_data_en, "obj_readable_room1_444", "* Są jeszcze w śpiączce..^1.&* I niedługo^1, one wszystkie&  przemienią się w proch./")
ds_map_add(global.text_data_en, "obj_readable_room1_445", "* Ale co się stanie jeśli&  wstrzyknę im " + '"' + "determinację" + '"' + "?/")
ds_map_add(global.text_data_en, "obj_readable_room1_446", "* Jeśli ich DUSZE wytrwają&  po tym jak wyginą^1, to.../")
ds_map_add(global.text_data_en, "obj_readable_room1_447", "* Wolność może być bliżej&  niż wszyscy myśleliśmy./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_449", "* (Wydaje się być wyłączone.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_454", "* WPIS NUMER 9/")
ds_map_add(global.text_data_en, "obj_readable_room1_455", "* sprawy nie toczą się dobrze./")
ds_map_add(global.text_data_en, "obj_readable_room1_456", "* żadne z ciał nie przemieniły&  się w proch^1, więc nie mogę&  zebrać ich DUSZ./")
ds_map_add(global.text_data_en, "obj_readable_room1_457", "* powiedziałam rodzinom że&  przyniosę ich prochy&  spowrotem na ich pogrzeb./")
ds_map_add(global.text_data_en, "obj_readable_room1_458", "* inni zaczęli mnie wypytywać&  co się dzieje./")
ds_map_add(global.text_data_en, "obj_readable_room1_459", "* co mam zrobić?/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_462", "* (Wydaje się być wyłączone.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_467", "* WPIS NUMER 12/")
ds_map_add(global.text_data_en, "obj_readable_room1_468", "* nic się nie wydarza^1.&* nie wiem co mam robić./")
ds_map_add(global.text_data_en, "obj_readable_room1_469", "* po prostu będę dalej&  wstrzykiwać we wszystko& " + '"' + "determinację." + '"' + "/")
ds_map_add(global.text_data_en, "obj_readable_room1_470", "* chcę, żeby to zadziałało./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_471", "* (Wydaje się być wyłączone.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_476", "* WPIS NUMER 14/")
ds_map_add(global.text_data_en, "obj_readable_room1_477", "* Wszyscy którzy przepadli.../")
ds_map_add(global.text_data_en, "obj_readable_room1_478", "* ... obudzili się./")
ds_map_add(global.text_data_en, "obj_readable_room1_479", "* Oni wszyscy chodzą wokół&  i rozmawiają jakby nic się&  nie stało./")
ds_map_add(global.text_data_en, "obj_readable_room1_480", "* Myślałam, że byli&  zgonami...?/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_481", "* (Wydaje się być wyłączone.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_486", "* WPIS NUMER 7/")
ds_map_add(global.text_data_en, "obj_readable_room1_487", "* Będziemy potrzebowali obiektów&  do okupacji aby władały DUSZAMI&  gdy przyjdzie na to czas./")
ds_map_add(global.text_data_en, "obj_readable_room1_488", "* W końcu^1, potwór nie może&  wchłonąć DUSZY drugiego&  potwora./")
ds_map_add(global.text_data_en, "obj_readable_room1_489", "* Tak samo jak człowiek nie&  może pochłonąć ludzkiej&  DUSZY.../")
ds_map_add(global.text_data_en, "obj_readable_room1_490", "* Więc.../")
ds_map_add(global.text_data_en, "obj_readable_room1_491", "* Co jeśli spróbuje pochłonąć&  coś co nie jest ani potworem&  ani człowiekiem?/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_492", "* (Wydaje się być wyłączone.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_497", "* WPIS NUMER 15/")
ds_map_add(global.text_data_en, "obj_readable_room1_498", "* Wydawałoby się, że te badania&  były ślepym zaułkiem.../")
ds_map_add(global.text_data_en, "obj_readable_room1_499", "* Ale przynajmniej otrzymaliśmy&  z tego szczęśliwe&  zakończenie...?/")
ds_map_add(global.text_data_en, "obj_readable_room1_500", "* Odesłałam ludzkie DUSZE&  ASGORE'owi^1, zwróciłam obiekt&  do okupacji do ogrodu..../")
ds_map_add(global.text_data_en, "obj_readable_room1_501", "* I zadzwoniłam do wszystkich&  rodzin i powiedziałam że&  wszyscy żyją./")
ds_map_add(global.text_data_en, "obj_readable_room1_502", "* Jutro odeślę wszystkich&  spowrotem. :) /%%")
ds_map_add(global.text_data_en, "obj_readable_room1_503", "* (Wydaje się być wyłączone.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_517", "* MASZYNA DO EKSTRAKCJI DT&* STATUS: NIEAKTYWNY/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_518", "* (Wydaje się być wyłączone.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_523", "* WPIS NUMER 4/")
ds_map_add(global.text_data_en, "obj_readable_room1_524", "* Robiłam research na ludzi &  aby zobaczyć czy mogę znaleźć&  jakiekolwiek info o ich DUSZY./")
ds_map_add(global.text_data_en, "obj_readable_room1_525", "* Skończyłam węsząc po zamku...&* I znalazłam te dziwne taśmy./")
ds_map_add(global.text_data_en, "obj_readable_room1_526", "* Wydaje mi się, że ASGORE ich&  jeszcze nie oglądał.../")
ds_map_add(global.text_data_en, "obj_readable_room1_527", "* Nie sądzę, że powinien./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_528", "* (Wydaje się być wyłączone.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_538", "* WPIS NUMER 19/")
ds_map_add(global.text_data_en, "obj_readable_room1_539", "* rodziny nadal wydzwaniają&  do mnie by spytać kiedy&  wszyscy wracają do domu./")
ds_map_add(global.text_data_en, "obj_readable_room1_540", "* co mam im powiedzieć?/")
ds_map_add(global.text_data_en, "obj_readable_room1_541", "* ja już nawet przestałam&  odbierać telefon./%%")
ds_map_add(global.text_data_en, "obj_readable_room1_542", "* (Wydaje się być wyłączone.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_543", "* (Jest zbyt ciemno by widzieć&  obok ścian.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_548", "* (Wydaje się być wyłączone.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_551", "* WPIS NUMER 8/")
ds_map_add(global.text_data_en, "obj_readable_room1_552", "* Wybrałam kandydata./")
ds_map_add(global.text_data_en, "obj_readable_room1_553", "* Nie mówiłam jeszcze ASGORE'owi^1,&  poniewa chciałam go tym&  zaskoczyć.../")
ds_map_add(global.text_data_en, "obj_readable_room1_554", "* W centrum jego ogrodu^1, jest&  coś specjalnego./")
ds_map_add(global.text_data_en, "obj_readable_room1_555", "* Pierwszy złoty kwiat^1, który&  wykwitł przed wszystkimi&  innymi./")
ds_map_add(global.text_data_en, "obj_readable_room1_556", "* Kwiatek z zewnętrznego świata./")
ds_map_add(global.text_data_en, "obj_readable_room1_557", "* Pojawił się tuż zanim królowa&  opuściła zamek./")
ds_map_add(global.text_data_en, "obj_readable_room1_558", "* Zastanawiam się.../")
ds_map_add(global.text_data_en, "obj_readable_room1_559", "* Co się stanie kiedy&  coś bez DUSZY zyska&  chęć do życia?/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_565", "* (Przyciski nie działają.^1)&* (Wydaje się, że winda&  straciła zasilanie.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_570", "* (Drzwi są zatrzaśnięte&  pnączami.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_575", "* (Wygląda na to, że kolejna&  winda straciła zasilanie.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_580", "* (Ta szafa grająca jest&  zepsuta.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_585", "* (Jest zamknięte.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_590", "* (To ztarty materac.^1)&* (Pościel jest zwinięta&  w dziwną^1, marną kulę.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_595", "* (W szufladzie jest album&  ze zdjęciami.)/")
ds_map_add(global.text_data_en, "obj_readable_room1_596", "* (Są tu zdjęcia z Sansem i&  wielu osób których nie&  rozpoznajesz.)/")
ds_map_add(global.text_data_en, "obj_readable_room1_597", "* (Wygląda na szczęśliwego.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_602", "* (W szufladzie jest album&  ze zdjęciami.)/")
ds_map_add(global.text_data_en, "obj_readable_room1_603", "* (Są tu zdjęcia z Sansem i&  wielu osób których nie&  rozpoznajesz.)/")
ds_map_add(global.text_data_en, "obj_readable_room1_604", "* (... oraz^1, jedno zdjęcie z&  tobą, Sansem oraz wszystkimi&  twoimi przyjaciółmi.)/")
ds_map_add(global.text_data_en, "obj_readable_room1_605", "* (Wygląda na szczęśliwego.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_610", "* (W szufladzie jest album&  ze zdjęciami.)/")
ds_map_add(global.text_data_en, "obj_readable_room1_611", "* (Są tu zdjęcia z..^1. Huh?)/")
ds_map_add(global.text_data_en, "obj_readable_room1_612", "* (Jakaś karta wystaje z&  tylniej klapy albumu.)/")
ds_map_add(global.text_data_en, "obj_readable_room1_613", "* (To marnie narysowany rysunek&  trzech uśmiechniętych osób.^1)&* (Pod spodem napis...)/")
ds_map_add(global.text_data_en, "obj_readable_room1_614", "* " + '"' + "nie zapomnij." + '"' + "/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_621", "* (To plakat promujący kolejny&  występ Mettatona.)/")
ds_map_add(global.text_data_en, "obj_readable_room1_622", "* (Dramatyczna powieść o dwóch&  kochankach^1, rozdzielonych&  niefortunną falą losu...)/")
ds_map_add(global.text_data_en, "obj_readable_room1_623", "* (Wygląda na to^1, że już prawie&  nadszedł czas na ten występ.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_628", "* (Jest zamknięte od środka.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_633", "* (Jest dedykacja na&  tej fontannie.)/")
ds_map_add(global.text_data_en, "obj_readable_room1_634", "* Królewska Fontanna Pomnikowa&* Data postawienia: 201X&* (Mettaton Dodany Tydzień Temu)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_639", "* (To Ściana Sławy&  pełna cytatów i zdjęć&  odwiedzających celebrytów.)/")
ds_map_add(global.text_data_en, "obj_readable_room1_640", "* " + '"' + "Jedzenie jest wspaniałe!^1" + '"' + "&* " + '"' + "Przepiękny wystrój i aromat!^1" + '"' + "&* " + '"' + "Moja twarz smakuje pysznie!" + '"' + "/")
ds_map_add(global.text_data_en, "obj_readable_room1_641", "* (... to wszystko Mettaton.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_646", "* (To lampa.^1)&* (Nie ma przełącznika.)/")
ds_map_add(global.text_data_en, "obj_readable_room1_647", "* (Pisze że gwiazdy tworzą&  swoje własne światło...)/%%")
ds_map_add(global.text_data_en, "obj_readable_room1_652", "* (Bogata historia Temów.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_60", "%%")
ds_map_add(global.text_data_en, "obj_readable_room2_63", "* (Pusta ramka na zdjęcie.)&* (Jest dosyć zakurzone...)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_67", "* (Pusta ramka na zdjęcie.)&* (Ktoś ją odkurzył.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_72", "* (To rodzinne zdjęcie.^1)&* (Wszyscy się uśmiechają.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_75", "\R* .../%%")
ds_map_add(global.text_data_en, "obj_readable_room2_80", "* To książka historyczna^1.&* Oto losowa strona.../")
ds_map_add(global.text_data_en, "obj_readable_room2_81", "* Uwięzieni za barierą i&  obawiający się dalszych&  ataków ludzi^1, wycofaliśmy się./")
ds_map_add(global.text_data_en, "obj_readable_room2_82", "* Daleko^1, daleko w ziemię&  szliśmy^1, dopóki dotarliśmy&  do końca jaskini./")
ds_map_add(global.text_data_en, "obj_readable_room2_83", "* To był nasze nowe schronienie^1,&  które nazwaliśmy.../")
ds_map_add(global.text_data_en, "obj_readable_room2_84", "* " + '"' + "Domem." + '"' + "/")
ds_map_add(global.text_data_en, "obj_readable_room2_85", "* Jak wspaniały jest nasz król^1,&  jest nieco parszywy w&  nazywaniu rzeczy./%%")
ds_map_add(global.text_data_en, "obj_readable_room2_90", "* To bureau./")
ds_map_add(global.text_data_en, "obj_readable_room2_91", "* Jest przebranie Mikołaja&  w środku./%%")
ds_map_add(global.text_data_en, "obj_readable_room2_94", "\R* Nic użytecznego./%%")
ds_map_add(global.text_data_en, "obj_readable_room2_100", "* (Są tu albumy ze zdjęciami...^1)&* (Brudnopisy...^1)&* (Poradniki na herbatę...)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_101", "* (One wszystkie się wydają&  bardzo stare i kruche.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_105", "\R* Nic użytecznego./%%")
ds_map_add(global.text_data_en, "obj_readable_room2_111", "* To złoty kwiatek./%%")
ds_map_add(global.text_data_en, "obj_readable_room2_114", "* W środku jest stary&  kalendarz z początków&  201X./%%")
ds_map_add(global.text_data_en, "obj_readable_room2_115", "* (To złoty kwiatek.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_119", "* (Jest kolejny tron zakryty&  białą narzutą.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_124", "* Zwyczajne stare wiadro^3 & &  ze ślimakami./%%")
ds_map_add(global.text_data_en, "obj_readable_room2_127", "* To encyklopedia&  egzotycznych roślin.&  Otwierasz na środek.../")
ds_map_add(global.text_data_en, "obj_readable_room2_128", "* " + '"' + "Typha" + '"' + " - Grupa mokro-&  glebich roślin z brązowymi^1,&  podłużnymi strąkami./")
ds_map_add(global.text_data_en, "obj_readable_room2_129", "* Również znane jako& " + '"' + "wodne kiełbaski." + '"' + "/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_135", "* Już widziałeś tego typu&  roślinę poprzednio^1, ale&  nie pamiętasz jej nazwy./%%")
ds_map_add(global.text_data_en, "obj_readable_room2_136", "* Oh^2!&* To " + '"' + "wodna kiełbaska." + '"' + "/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_140", "* Co za ładny zapach...&* Niestety^1, zbyt gorące^1,&  by zjeść./%%")
ds_map_add(global.text_data_en, "obj_readable_room2_141", "* Rozmiar ciasta zbyt&  bardzo cię kus^1, abyś&  go zjadł./%%")
ds_map_add(global.text_data_en, "obj_readable_room2_144", "* (Większość ciasta znikła.^1)&* (Są widoczne ślady psich&  łapek w cieście...)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_149", "* Kiedy potwory są głównie&  z magii^1, istoty ludzkie są&  głównie z wody./")
ds_map_add(global.text_data_en, "obj_readable_room2_150", "* Człowieki^1, z ich fizyczną&  formą^1, są o wiele silniejsi&  od nas./")
ds_map_add(global.text_data_en, "obj_readable_room2_151", "* Ale oni nigdy nie poznają&  radości z wyrażania siebie&  poprzez magię./")
ds_map_add(global.text_data_en, "obj_readable_room2_152", "* Oni nigdy nie dostaną&  kartki urodzinowej w&  kształcie pocisku.../%%")
ds_map_add(global.text_data_en, "obj_readable_room2_164", "* Drzwi./%%")
ds_map_add(global.text_data_en, "obj_readable_room2_166", "* ...!^1?&* Jest kamera&  ukryta w krzakach./%%")
ds_map_add(global.text_data_en, "obj_readable_room2_178", "\W* \OOdwaga^1. \YSprawiedliwość.\W  &*\B Uczciwość^1. \GŻyczliwość^1.\W &*\P Wytrwałość^1. \LCierpliwość. \W /")
ds_map_add(global.text_data_en, "obj_readable_room2_179", "\W* Dzięki temu^1, ty byłeś w&  stanie wygrać " + '"' + "\RGrę w Kulę\W." + '"' + "/")
ds_map_add(global.text_data_en, "obj_readable_room2_180", "* (Zostałeś nagrodzony 50G.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_186", "\W* \RCZERWONY\W - Staraj się do&  końca^1, a pozostaniesz sobą./")
ds_map_add(global.text_data_en, "obj_readable_room2_187", "* (Zostałeś nagrodzony 10G.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_194", "\W* \OPOMARAŃCZOWY\W - Jesteś typem&  osoby^1, która speedrunuje&  przez wszystkie przeszkody./")
ds_map_add(global.text_data_en, "obj_readable_room2_195", "* ( Zostałeś nagrodzony 5G.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_201", "\W* \YŻÓŁTY\W - Twoja dokładność&  i cel doprowadziły do&  pokonania " + '"' + "Kuli." + '"' + "/")
ds_map_add(global.text_data_en, "obj_readable_room2_202", "* (Zostałeś nagrodzony 3G.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_208", "\W* \BNIEBIESKI\W - Skakanie i adhd^1,&  twój oryginalny styl&  przepuścił cię do celu./")
ds_map_add(global.text_data_en, "obj_readable_room2_209", "* (Zostałeś wynagrodzony 2G.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_215", "\W* \GZIELONY\W - Twoja troska i&  dbałość o " + '"' + "Kulę" + '"' + " doprowadziła&  cię do smacznego zwycięstwa./")
ds_map_add(global.text_data_en, "obj_readable_room2_216", "* (Zostałeś wynagrodzony 1G.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_222", "\W* \PFIOLETOWY\W - Nawet kiedy czułeś&  się klastrofobicznie^1, robiłeś&  notatki i ukończyłeś " + '"' + "Kulę." + '"' + "/")
ds_map_add(global.text_data_en, "obj_readable_room2_223", "* (Zostałeś wynagrodzony 2G.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_229", "\W* \LJ.NIEBIESKI\W - " + '"' + "Kula" + '"' + " jest& " + '"' + "Mała.^1" + '"' + " Czekałeś^1, cierpliwie^1,&  na tą okoliczność.../")
ds_map_add(global.text_data_en, "obj_readable_room2_230", "* ... wtedy zdetronizowałeś& " + '"' + "Kulę" + '"' + " ostrym atakiem./")
ds_map_add(global.text_data_en, "obj_readable_room2_231", "* (Zostałeś wynagrodzony 4G.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_238", "* (Ta flaga nie ma nic więcej&  do zaoferowania.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_245", "\W* Ah^1! Wow^1! Ło^1!&* To " + '"' + "\RDziura\W" + '"' + "./%%")
ds_map_add(global.text_data_en, "obj_readable_room2_247", "* Jest tutaj dziura./%%")
ds_map_add(global.text_data_en, "obj_readable_room2_252", "* (Jej.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_259", "OTO KAMYK-ZWIERZAK&MOJEGO BRATA./")
ds_map_add(global.text_data_en, "obj_readable_room2_260", "\E1ZAWSZE ZAPOMINA&TO KARMIĆ./")
ds_map_add(global.text_data_en, "obj_readable_room2_261", "\E3WIĘC JAK ZWYKLE^1, &TO JA MUSZĘ BRAĆ&ODPOWIEDZIALNOŚĆ./")
ds_map_add(global.text_data_en, "obj_readable_room2_262", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_readable_room2_263", "* (Ten kamyk jest posypany&  posypką.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_266", "* (Ten kamyk jest posypany&  posypką.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_268", "* (Ten kamyk jest posypany&  posypką.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_276", "CZYŻ TA FLAGA&NIE JEST CZADOWA?/")
ds_map_add(global.text_data_en, "obj_readable_room2_277", "UNDYNE TO ZNALAZŁA&W ZATOCZCE.../")
ds_map_add(global.text_data_en, "obj_readable_room2_278", "\E3TO CHYBA JEST Z&TWOJEGO ŚWIATA?/")
ds_map_add(global.text_data_en, "obj_readable_room2_279", "\E0TERAZ^1, WIEM O CZYM&SOBIE MYŚLISZ./")
ds_map_add(global.text_data_en, "obj_readable_room2_280", "\E3CZEMU&FLAGA LUDZI.../")
ds_map_add(global.text_data_en, "obj_readable_room2_281", "MIAŁABY CZADOWEGO&SZKIELETA NA NIM?/")
ds_map_add(global.text_data_en, "obj_readable_room2_282", "CÓŻ..^1.&MAM PEWNĄ&TEORIĘ./")
ds_map_add(global.text_data_en, "obj_readable_room2_283", "\E3MYŚLĘ^1, ŻE LUDZIE.../")
ds_map_add(global.text_data_en, "obj_readable_room2_284", "\E0MUSIELI POCHODZIĆ&OD SZKIELETÓW!!!/")
ds_map_add(global.text_data_en, "obj_readable_room2_285", "NYEH HEH HEH!!!/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_287", "* (To podbita piracka flaga.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_288", "* (To podbita piracka flaga.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_295", "* Dlaczego ludzie zaatakowali^1?&* Wydawałoby się^1, że nie mieli&  niczego do obawy./")
ds_map_add(global.text_data_en, "obj_readable_room2_296", "* Ludzie są niewiarygodnie silni.&* Kosztowałaby DUSZA niemalże&  każdego potwora.../")
ds_map_add(global.text_data_en, "obj_readable_room2_297", "* ... tylko aby dorównać jednej&  DUSZY człowieka./%%")
ds_map_add(global.text_data_en, "obj_readable_room2_302", "* Ta surowa moc nie ma miary.&* Co prawda, człowiek nie może&  odebrać DUSZY potwora./")
ds_map_add(global.text_data_en, "obj_readable_room2_303", "* Kiedy potwór umiera, jego&  DUSZA umiera wraz z nim./")
ds_map_add(global.text_data_en, "obj_readable_room2_304", "* I niewiarygodna moc byłaby&  potrzebna^1, aby wyodrębnić&  DUSZĘ żyjącego potwora./%%")
ds_map_add(global.text_data_en, "obj_readable_room2_310", "* Jest tylko jeden sposób^1, by&  odwrócić to zaklęcie./")
ds_map_add(global.text_data_en, "obj_readable_room2_311", "* Jeśli ogromna siła^1, równa&  siedmiu ludzkich DUSZY^1,&  zaatakuje barierę.../")
ds_map_add(global.text_data_en, "obj_readable_room2_312", "* Zostanie ona zniszczona./%%")
ds_map_add(global.text_data_en, "obj_readable_room2_318", "* Finalnie^1, ciężko by to&  nazwać wojną./")
ds_map_add(global.text_data_en, "obj_readable_room2_319", "* Zjednoczeni^1, ludzie byli zbyt&  potężni^1, a my potwory^1,&  zbyt słabi./")
ds_map_add(global.text_data_en, "obj_readable_room2_320", "* Nawet jedna DUSZA nie była&  odebrana^1, a niezliczona ilość&  potworów przemieniona w pył.../%%")
ds_map_add(global.text_data_en, "obj_readable_room2_326", "* I'm catching bugs^1.&* But the underground doesn't&  have many.../")
ds_map_add(global.text_data_en, "obj_readable_room2_327", "* I keep catching the same&  one./%%")
ds_map_add(global.text_data_en, "obj_readable_room2_332", "* (To komputer.^1)&* (Kontroluje on jakąś&  łamigówkę w Snowdinie.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_333", "* (Jest zbyt ciemno^1, by widzieć&  koło ścian.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_343", "* (To piec.^1)&* (Wygląda całkiem&  nowocześnie.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_345", "* (Jest zbyt ciemno^1, by widzieć&  koło ścian.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_353", "* O TAK^1! MTT-BRAND PIECE MOGĄ &  OSIĄGNĄĆ TEMPERATURY AŻ DO&  DZIEWIĘCIU TYSIĘCY STOPNI!/")
ds_map_add(global.text_data_en, "obj_readable_room2_354", "* PIECZENIE^1! SMAŻENIE^1! SPALANIE^1!&* ZWĘGLANIE^1! JESTEŚ PODEKSCY-&  TOWANY^1, SŁOŃCE? (TM)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_360", "* (To piec.^1)&* (Wygląda jakby ktoś zapomniał&  go wcześniej podgrzać.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_373", "* Chcesz zobaczyć mój pokój?/")
ds_map_add(global.text_data_en, "obj_readable_room2_374", "\E3* WOMP WOMP^1!&* Zakaz wstępu nerdom!/")
ds_map_add(global.text_data_en, "obj_readable_room2_375", "\E9* ... cóż^1, może niektórym&  nerdom.../%%")
ds_map_add(global.text_data_en, "obj_readable_room2_377", "* Jesteś trochę psychopatyczny./%%")
ds_map_add(global.text_data_en, "obj_readable_room2_390", "* (To pajęczy pączek.^1)&* (Wygląda nieco bardziej...^1)&* (Gumowaty niż zwykle.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_395", "* (Północ^1, ścieżka wojownika.)&* (Zachód^1, ścieżka mędrca.)&* (Każda prowadzi do Końca.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_400", "* (Na Wschód idziemy^1!)&* (To jest Koniec.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_405", "* WPIS NUMER 2/")
ds_map_add(global.text_data_en, "obj_readable_room2_406", "* Bariera jest zablokowana&  mocą DUSZY../")
ds_map_add(global.text_data_en, "obj_readable_room2_407", "* Niestety^1, ta moc nie&  może zostać sztucznie&  odtworzona./")
ds_map_add(global.text_data_en, "obj_readable_room2_408", "* Moc DUSZY może tylko&  zostać od kogoś kto&  kiedyś żył./")
ds_map_add(global.text_data_en, "obj_readable_room2_409", "* Więc^1, aby stworzyć więcej^1,&  będziemy musieli użyć to&  co mamy teraz.../")
ds_map_add(global.text_data_en, "obj_readable_room2_410", "* DUSZE potworów./%%")
ds_map_add(global.text_data_en, "obj_readable_room2_412", "* (Wydaje się być wyłączone.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_417", "* WPIS NUMER 13/")
ds_map_add(global.text_data_en, "obj_readable_room2_418", "* jedno z ciał otworzyło&  swoje oczy./%%")
ds_map_add(global.text_data_en, "obj_readable_room2_419", "* (Wydaje się być wyłączone.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_424", "* (Ten zegar jest zepsuty.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_429", "* WPIS NUMER 10/")
ds_map_add(global.text_data_en, "obj_readable_room2_430", "* eksperymenty na obiektach&  są porażką./")
ds_map_add(global.text_data_en, "obj_readable_room2_431", "* nie wydają się zbytnio&  różnić od kontrolowanych&  przypadków./")
ds_map_add(global.text_data_en, "obj_readable_room2_432", "* nieważne^1.&* są męczące w&  badaniu i tak./")
ds_map_add(global.text_data_en, "obj_readable_room2_433", "* nasiona się do ciebie&  przylepiają^1, i nie chcą&  się odkleić.../%%")
ds_map_add(global.text_data_en, "obj_readable_room2_434", "* (Wydaje się być wyłączone.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_439", "* WPIS NUMER 16/")
ds_map_add(global.text_data_en, "obj_readable_room2_440", "* nie Nie NIE NIE NIE NIE NIE/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_441", "* (Wydaje się być wyłączone.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_446", "* (Jest tu masa kaset VHS.^1)&* (Wyglądają głównie na&  jakiegoś rodzaju kreskówki.)/")
ds_map_add(global.text_data_en, "obj_readable_room2_447", "* (Wydają się ułożone&  alfabetycznie^1, a niektóre...^1)&* (... są lepkie?)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_452", "* WPIS NUMER 11/")
ds_map_add(global.text_data_en, "obj_readable_room2_453", "* teraz jako że mettaton urósł&  w popularności^1, on już ze mną&  nie chce rozmawiać./")
ds_map_add(global.text_data_en, "obj_readable_room2_454", "* ... chyba że z pytaniem kiedy&  dokończę budować jego ciało./")
ds_map_add(global.text_data_en, "obj_readable_room2_455", "* ale martwię się że jeśli&  skończę jego ciało^1, to on już&  nie będzie mnie potrzebował.../")
ds_map_add(global.text_data_en, "obj_readable_room2_456", "* a wtedy już nigdy nie&  będziemy przyjaciółmi./")
ds_map_add(global.text_data_en, "obj_readable_room2_457", "* ... już nie wspominając^1, że za&  każdym razem kiedy pracuję nad&  tym^1, to strasznie się pocę.../%%")
ds_map_add(global.text_data_en, "obj_readable_room2_462", "* WPIS NUMER 20/")
ds_map_add(global.text_data_en, "obj_readable_room2_463", "* ASGORE zostawił mi&  dzisiaj pięć wiadomości./")
ds_map_add(global.text_data_en, "obj_readable_room2_464", "* cztery o tym jak&  wszyscy są wkurzeni/")
ds_map_add(global.text_data_en, "obj_readable_room2_465", "* i jedna o takiej słodkiej&  filiżance którą znalazł/")
ds_map_add(global.text_data_en, "obj_readable_room2_466", "* dzięki^1, asgore./%%")
ds_map_add(global.text_data_en, "obj_readable_room2_467", "* (Wydaje się być wyłączone.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_468", "* (Jest zbyt ciemno by widzieć&  obok ścian.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_473", "* (Wydaje się być wyłączone.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_476", "* WPIS NUMER 18/")
ds_map_add(global.text_data_en, "obj_readable_room2_477", "* kwiatek znikł./%%")
ds_map_add(global.text_data_en, "obj_readable_room2_483", "* (Jest zamknięte od&  środka.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_488", "PLEASE DON'T ENTER&THE MYSTERIOUS&SHACK./%%")
ds_map_add(global.text_data_en, "obj_readable_room2_492", "HELLO^1.&THAT'S NOT&MY HOUSE./")
ds_map_add(global.text_data_en, "obj_readable_room2_493", "THAT'S JUST MY&COOL TOOLSHED./")
ds_map_add(global.text_data_en, "obj_readable_room2_495", "* Do you call it&  your COOLSHED!?/")
ds_map_add(global.text_data_en, "obj_readable_room2_497", "NO!!^1!&I'VE NEVER THOUGHT&OF THAT!!!/")
ds_map_add(global.text_data_en, "obj_readable_room2_498", "THAT'S WHY WE'RE&FRIENDS^1,&UNDYNE./")
ds_map_add(global.text_data_en, "obj_readable_room2_499", "YOU ENRICH MY&LIFE WITH SHED-&BASED PUNS./")
ds_map_add(global.text_data_en, "obj_readable_room2_501", "* That's the only&  one I've ever&  made^1, dude./%%")
ds_map_add(global.text_data_en, "obj_readable_room2_506", "READY FOR ANOTHER&NIGHT IN THE&PUNISHMENT SHACK?/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_509", "READY FOR ANOTHER&NIGHT IN THE&PUNISHMENT SHACK?/")
ds_map_add(global.text_data_en, "obj_readable_room2_511", "* Oh my GOD^1, I don't&  even wanna KNOW./")
ds_map_add(global.text_data_en, "obj_readable_room2_513", "DON'T BE SO&JUDGMENTAL^1,&UNDYNE./")
ds_map_add(global.text_data_en, "obj_readable_room2_514", "MY SHACK IS A&FOUR STAR&ESTABLISHMENT./")
ds_map_add(global.text_data_en, "obj_readable_room2_516", "* What^1, lemme guess./")
ds_map_add(global.text_data_en, "obj_readable_room2_517", "\E6* Sometimes you cut a&  hot dog into the&  dog food^1, right?/")
ds_map_add(global.text_data_en, "obj_readable_room2_519", "WHAT!?!?/")
ds_map_add(global.text_data_en, "obj_readable_room2_520", "\E0HOW'D YOU KNOW?/")
ds_map_add(global.text_data_en, "obj_readable_room2_522", "* OH MY GOD^1! NO^1!&* I WAS JOKING!!^1!&* DON'T DO THIS!!!/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_528", "YOU SHOULD LEARN&A PRIVACY./%%")
ds_map_add(global.text_data_en, "obj_readable_room2_534", "* (You can't go through the&  fire exit because you're&  not made of fire.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_539", "* (It's an uncovered pillow.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_544", "* (You look in the drawer.^1)&* (There's some kind of badge.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_549", "* (It's a performance schedule.^1)&* (Comedians^1, dancers^1, Sans...^1)&* (Seems there's a break now.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_554", "* (It's some sort of giant bottle&  of perfume.^1)&* (Eau de Rectangle.)/")
ds_map_add(global.text_data_en, "obj_readable_room2_555", "* (The cap is so comically large^1,&  you can't open it.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_560", "* (Uczucie bycia obserwowanym.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_563", "* (Czeka na kogoś kto ją&  wypuści.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room2_569", "* (Te kryształy na południowej&  ścianie błyszczą w&  spektakularnym wzorze.)/")
ds_map_add(global.text_data_en, "obj_readable_room2_570", "* (To dobra rzecz że widzisz&  południową ścianę z tego kąta.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room3_59", "%%")
ds_map_add(global.text_data_en, "obj_readable_room3_60", "* (Pudło z dziecięcymi butami&  w różnych rozmiarach.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room3_63", "* (To rysunek złotego kwiatka.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room3_66", "\R* Mój rysunek./%%")
ds_map_add(global.text_data_en, "obj_readable_room3_71", "* (Definitywnie większe niż&  podwójne łóżko.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room3_74", "* (Wcześniej^1, identyfikowałeś&  to jako większe^1, niż&  podwójne łóżko.)/")
ds_map_add(global.text_data_en, "obj_readable_room3_75", "* (Ale teraz^1, uświadomiłeś sobie^1,&  że to po prostu o jeden rozmiar&  większy od normalnego.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room3_79", "* Węgielki są dalej ciepłe./%%")
ds_map_add(global.text_data_en, "obj_readable_room3_81", "* (Macaroni art &  prezentujące kwiatka.^1)&* ('Dla Króla Taty!')/%%")
ds_map_add(global.text_data_en, "obj_readable_room3_83", "* W środku szufladki są&  nasiona kwiatków i parę&  złamanych kredek./%%")
ds_map_add(global.text_data_en, "obj_readable_room3_84", "* Jest trochę białego futra&  utkniętego w zlewie./%%")
ds_map_add(global.text_data_en, "obj_readable_room3_85", "* (Jest trochę białego futra&  utkniętego w zlewie.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room3_89", "* Jako że oni są zrobione z&  magii^1, ciała potworów są&  przywiązane z ich DUSZĄ./")
ds_map_add(global.text_data_en, "obj_readable_room3_90", "* Jeśli potwór nie chce już&  walczyć^1, jego defensywa się&  obniży./")
ds_map_add(global.text_data_en, "obj_readable_room3_91", "* A im bardziej okrutne intencje&  naszych wrogów, tym bardziej&  ich ataki będą nas ranić./")
ds_map_add(global.text_data_en, "obj_readable_room3_92", "* Dlatego^1, jeśli istota z potężną&  DUSZĄ uderzyłaby z pragnieniem&  zabicia.../")
ds_map_add(global.text_data_en, "obj_readable_room3_93", "* Um^1, zakończmy tutaj ten&  rozdział.../%%")
ds_map_add(global.text_data_en, "obj_readable_room3_104", "* ...!^1?&* Jest kamera ukryta w&  stacyjce./%%")
ds_map_add(global.text_data_en, "obj_readable_room3_108", "* ...!^1?&* Jest kamera ukryta w..^1.&  " + '"' + "stacyjce." + '"' + "/%%")
ds_map_add(global.text_data_en, "obj_readable_room3_112", "* ...!^1?&* Jest kamera ukryta w&  tej kupce śniegu./%%")
ds_map_add(global.text_data_en, "obj_readable_room3_116", "* ...!^1?&* Jest kamera ukryta w&  tym drzewie./%%")
ds_map_add(global.text_data_en, "obj_readable_room3_120", "* ...!^1?&* Jest kamera ukryta w&  tym drzewie./%%")
ds_map_add(global.text_data_en, "obj_readable_room3_124", "* ...!^1?&* Jest kamera ukryta w&  stacyjce./%%")
ds_map_add(global.text_data_en, "obj_readable_room3_128", "* ...!^1?&* Jest kamera ukryta pod&  mostem./%%")
ds_map_add(global.text_data_en, "obj_readable_room3_132", "* ...!^1?&* Jest kamera ukryta w&  tych drzewach./%%")
ds_map_add(global.text_data_en, "obj_readable_room3_139", "* Kiedy cztery Nasiona Mostowe&  się zetkną w wodzie^1, to one&  zakwitną./%%")
ds_map_add(global.text_data_en, "obj_readable_room3_141", "* Jeśli błąd jest popełniony, &  Dzwonek może zawołać sadzonki&  spowrotem skąd zaczęły./%%")
ds_map_add(global.text_data_en, "obj_readable_room3_142", "* POKÓJ ŻYCZEŃ/%%")
ds_map_add(global.text_data_en, "obj_readable_room3_147", "* Ale ludzie mają jedną słabość.&* Ironicznie, to jest potęga&  ich własnej DUSZY./")
ds_map_add(global.text_data_en, "obj_readable_room3_148", "* Jego moc pozwala mu istnieć&  poza ludzkim ciałem, nawet po&  śmierci./%%")
ds_map_add(global.text_data_en, "obj_readable_room3_154", "* Ale jest jeden wyjątek./")
ds_map_add(global.text_data_en, "obj_readable_room3_155", "* DUSZA specjalnego gatunku&  potwora nazywanego&  " + '"' + "Potworem Bossowym." + '"' + "/")
ds_map_add(global.text_data_en, "obj_readable_room3_156", "* DUSZA Potwora Bossowego jest&  wystarczająco silna^1,&  by istnieć po śmierci.../")
ds_map_add(global.text_data_en, "obj_readable_room3_157", "* Jeśli tylko chociaż na chwilę./")
ds_map_add(global.text_data_en, "obj_readable_room3_158", "* Człowiek mógłby pochłonić&  taką DUSZĘ.&* Ale nigdy do tego nie doszło./")
ds_map_add(global.text_data_en, "obj_readable_room3_159", "* A teraz nigdy się nie dojdzie./%%")
ds_map_add(global.text_data_en, "obj_readable_room3_165", "* Ale to przeklęte miejsce nie ma&  żadnych wejść ani wyjść./")
ds_map_add(global.text_data_en, "obj_readable_room3_166", "* Nie ma opcji^1, żeby człowiek&  był w stanie tu wejść./")
ds_map_add(global.text_data_en, "obj_readable_room3_167", "* Pozostaniemy tu uwięzieni&  pod ziemią na zawsze./%%")
ds_map_add(global.text_data_en, "obj_readable_room3_175", "KLASYCZNY OBRAZ./")
ds_map_add(global.text_data_en, "obj_readable_room3_176", "ZAWSZE MI PRZYPO-&MINA TO CO WAŻNE&W ŻYCIU./%%")
ds_map_add(global.text_data_en, "obj_readable_room3_180", "* (To malowidło kreskówkowej&  kości.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room3_195", "* (Whenever the girl moves her&  net^1, this bug scurries straight&  into it.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room3_200", "* (Seems like the notes to&  something^1, but it's all&  written in chicken scratch.)/")
ds_map_add(global.text_data_en, "obj_readable_room3_201", "* (It seems like a walkthrough&  to a game^1, or...?)/%%")
ds_map_add(global.text_data_en, "obj_readable_room3_202", "* (Jest zbyt ciemno^1, by widzieć&  koło ścian.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room3_207", "* (VHSes and DVDs of various&  cartoons.)/")
ds_map_add(global.text_data_en, "obj_readable_room3_208", "* (They are all labelled " + '"' + "Human&  History." + '"' + ")/%%")
ds_map_add(global.text_data_en, "obj_readable_room3_213", "* (It's a specifically-regular&  -sized sink.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room3_215", "* (Jest zbyt ciemno^1, by widzieć&  koło ścian.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room3_222", "* THIS ISN'T A SHOW ABOUT&  WASHING YOUR HANDS, DARLING./")
ds_map_add(global.text_data_en, "obj_readable_room3_223", "* THAT'S ON WEDNESDAYS!/%%")
ds_map_add(global.text_data_en, "obj_readable_room3_228", "* THIS ISN'T A SHOW ABOUT&  WASHING YOUR HANDS, DARLING./")
ds_map_add(global.text_data_en, "obj_readable_room3_229", "* THAT'S ON WEDNESDAYS!/%%")
ds_map_add(global.text_data_en, "obj_readable_room3_242", "* One time^1, Alphys's..^1.&* Uh^1, friend??^1?&* Came over here./")
ds_map_add(global.text_data_en, "obj_readable_room3_243", "\E4* All he did was&  lie seductively&  on the piano.../")
ds_map_add(global.text_data_en, "obj_readable_room3_244", "\E5* And fed himself&  grapes./")
ds_map_add(global.text_data_en, "obj_readable_room3_245", "\E4* I don't really&  like that guy./")
ds_map_add(global.text_data_en, "obj_readable_room3_246", "\E3* But I admire&  his lifestyle./%%")
ds_map_add(global.text_data_en, "obj_readable_room3_248", "* What^1?&* I'm not gonna&  serenade you./%%")
ds_map_add(global.text_data_en, "obj_readable_room3_254", "* ENTRY NUMBER 3/")
ds_map_add(global.text_data_en, "obj_readable_room3_255", "* But extracting a SOUL from&  a living monster would&  require incredible power.../")
ds_map_add(global.text_data_en, "obj_readable_room3_256", "* Besides being impractical^1,&  doing so would instantly&  destroy the SOUL's host./")
ds_map_add(global.text_data_en, "obj_readable_room3_257", "* And^1, unlike the persistent&  SOULs of humans.../")
ds_map_add(global.text_data_en, "obj_readable_room3_258", "* The SOULs of most monsters&  disappear immediately upon&  death./")
ds_map_add(global.text_data_en, "obj_readable_room3_259", "* If only I could make a&  monster's SOUL last.../%%")
ds_map_add(global.text_data_en, "obj_readable_room3_261", "* (Wydaje się być wyłączone.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room3_266", "* (There are a bunch of VHSes.^1)&* (Seems like it's mostly&  cartoons of some kind.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room3_272", "* ENTRY NUMBER 21/")
ds_map_add(global.text_data_en, "obj_readable_room3_273", "* i spend all my time at&  the garbage dump now/")
ds_map_add(global.text_data_en, "obj_readable_room3_274", "* it's my element/%%")
ds_map_add(global.text_data_en, "obj_readable_room3_275", "* (Wydaje się być wyłączone.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room3_276", "* (Jest zbyt ciemno by widzieć&  obok ścian.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room3_286", "* (It's a thank-you letter.^1)&* (It's addressed to Santa.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room3_291", "* (Blueprints.^1)&* (You can't read the symbols&  they're written in...)/")
ds_map_add(global.text_data_en, "obj_readable_room3_292", "* (... or maybe it's just the&  handwriting.)/")
ds_map_add(global.text_data_en, "obj_readable_room3_293", "* (Looks like they relate to&  some kind of strange machine.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room3_303", "* oh..^1. to mój telewizor.../")
ds_map_add(global.text_data_en, "obj_readable_room3_304", "* jest taki serial który&  lubię na nim oglądać..^1.&* czasami.../%%")
ds_map_add(global.text_data_en, "obj_readable_room3_308", "* (To straszny stary telewizor.^1)&* (Większość guzików są już&  ztarte...)/")
ds_map_add(global.text_data_en, "obj_readable_room3_309", "* (Chociaż guzik do zmiany&  kanałów wygląda na nowy.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room3_315", "* (Rope.^1)&* (Looks like this dog does&  all its own stunts.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room3_320", "* (It's some kind of TV show&  featuring Mettaton.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room3_325", "* (Statuetka tem..^1. barco znana^1)&* (BARCDZO!!!!!!!!!)/%%")
ds_map_add(global.text_data_en, "obj_readable_room4_60", "%%")
ds_map_add(global.text_data_en, "obj_readable_room4_63", "* To ty!/%%")
ds_map_add(global.text_data_en, "obj_readable_room4_64", "* To dalej tylko ty^1, Frisk./%%")
ds_map_add(global.text_data_en, "obj_readable_room4_66", "* To ja^1, \[C]./%%")
ds_map_add(global.text_data_en, "obj_readable_room4_67", "* To złoty kwiatek./%%")
ds_map_add(global.text_data_en, "obj_readable_room4_70", "* Pomimo wszystkiego^1, to&  dalej ty./%%")
ds_map_add(global.text_data_en, "obj_readable_room4_73", "* To ja^1, \[C]./%%")
ds_map_add(global.text_data_en, "obj_readable_room4_76", "* W szufladce są foremki&  do potworkowych ciastek./%%")
ds_map_add(global.text_data_en, "obj_readable_room4_77", "\R* Gdzie są noże./%%")
ds_map_add(global.text_data_en, "obj_readable_room4_78", "* Kuchenka jest bardzo czysta^1.&* Toriel musiała chyba użyć&  magicznego ognia w zamian./%%")
ds_map_add(global.text_data_en, "obj_readable_room4_79", "* Nik już tego nie&  będzie używał.../%%")
ds_map_add(global.text_data_en, "obj_readable_room4_83", "* (To notatka.^1)&* Heja^1! Częstuj się&  czym tylko chcesz!/%%")
ds_map_add(global.text_data_en, "obj_readable_room4_84", "* Już to kiedyś czytałem./%%")
ds_map_add(global.text_data_en, "obj_readable_room4_90", "* (Kuchenka jest bardzo czysta.^1)&* (Ktoś chyba używa magicznego&  ognia w zamian.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room4_91", "* Kuchenka./%%")
ds_map_add(global.text_data_en, "obj_readable_room4_98", "* (Co za wygodne łóżko.^1)&* (Jeśli się tu położysz^1,&  możesz już nigdy nie wstać.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room4_99", "* My bed./%%")
ds_map_add(global.text_data_en, "obj_readable_room4_104", "* (It's a twin-sized bed.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room4_105", "* His bed./%%")
ds_map_add(global.text_data_en, "obj_readable_room4_110", "* (It's a king-sized bed.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room4_114", "* " + '"' + "MONSTER HISTORY PART 4" + '"' + "/")
ds_map_add(global.text_data_en, "obj_readable_room4_116", "* Fearing the humans no longer^1,&  we moved out of our old&  city^1, HOME./")
ds_map_add(global.text_data_en, "obj_readable_room4_117", "* We braved harsh cold^1, damp&  swampland^1, and searing heat.../")
ds_map_add(global.text_data_en, "obj_readable_room4_118", "* Until we reached what we now&  call our capital./")
ds_map_add(global.text_data_en, "obj_readable_room4_119", "* " + '"' + "NEW HOME." + '"' + "/")
ds_map_add(global.text_data_en, "obj_readable_room4_120", "* Again^1, our King is really&  bad at names...?/%%")
ds_map_add(global.text_data_en, "obj_readable_room4_126", "* Excuse me..^1.&* Yes^1, you^1, with the striped&  shirt./")
ds_map_add(global.text_data_en, "obj_readable_room4_127", "* Can you do something about&  your friend...?/")
ds_map_add(global.text_data_en, "obj_readable_room4_128", "* Yes^1, your friend..^1.&* The one behind you^1, with the&  creepy smile./%%")
ds_map_add(global.text_data_en, "obj_readable_room4_131", "* Hmmm^1?&* Where'd your friend go?/%%")
ds_map_add(global.text_data_en, "obj_readable_room4_139", "* Jeśli potwór pokona człowieka^1,&  będzie mógł mu odebrać DUSZĘ./")
ds_map_add(global.text_data_en, "obj_readable_room4_140", "* Potwór z ludzką DUSZĄ..^1.&* Okropne monstrum z&  niesprawiedliwą potęgą./%%")
ds_map_add(global.text_data_en, "obj_readable_room4_145", "* (It's a video feed of your&  location.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room4_146", "* It's you...?/%%")
ds_map_add(global.text_data_en, "obj_readable_room4_147", "* To ja^1, \[C]./%%")
ds_map_add(global.text_data_en, "obj_readable_room4_159", "* (It's a microwave.^1)&* (That's great if you're a&  microwave fan.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room4_161", "* (Jest zbyt ciemno^1, by widzieć&  koło ścian.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room4_168", "* MTT-BRAND MICROWAVE^1!&* ORIGIN OF THE MTT CHALLENGE!/")
ds_map_add(global.text_data_en, "obj_readable_room4_169", "* PUT YOUR FOOD IN AND SET&  THE MICROWAVE ON HIGH FOR&  FIVE MINUTES.../")
ds_map_add(global.text_data_en, "obj_readable_room4_170", "* IF YOU CAN STILL RECOGNIZE&  YOUR MEAL^1, WE'LL DOUBLE YOUR&  MONEY BACK!!!/%%")
ds_map_add(global.text_data_en, "obj_readable_room4_174", "* STILL FIDDLING WITH THAT&  MICROWAVE, EH, DARLING?/")
ds_map_add(global.text_data_en, "obj_readable_room4_175", "* CAN'T BLAME YOU FOR BEING&  TOTALLY ENAMORED WITH AN&  ELECTRONIC BOX./%%")
ds_map_add(global.text_data_en, "obj_readable_room4_182", "* (In the sink is a teacup&  in the shape of a fish.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room4_193", "* ENTRY NUMBER 5/")
ds_map_add(global.text_data_en, "obj_readable_room4_194", "* I've done it./")
ds_map_add(global.text_data_en, "obj_readable_room4_195", "* Using the blueprints^1, I've&  extracted it from the&  human SOULs./")
ds_map_add(global.text_data_en, "obj_readable_room4_196", "* I believe this is what&  gives their SOULs the strength&  to persist after death./")
ds_map_add(global.text_data_en, "obj_readable_room4_197", "* The will to keep living..^1.&* The resolve to change fate./")
ds_map_add(global.text_data_en, "obj_readable_room4_198", "* Let's call this power.../")
ds_map_add(global.text_data_en, "obj_readable_room4_199", "\Y* " + '"' + "Determination." + '"' + "/%%")
ds_map_add(global.text_data_en, "obj_readable_room4_201", "* (Wydaje się być wyłączone.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room4_206", "* (Golden flowers.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room4_212", "* (It's Sans's dirty sock pile.^1)&* (Sc..^1. scandalous...?)/%%")
ds_map_add(global.text_data_en, "obj_readable_room4_217", "* (There's a strange machine&  behind the curtain.^1)&* (It seems to be broken.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room4_222", "* (Jest zamknięte.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room4_226", "* (You unlocked the door and&  entered.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room4_234", "* (Finally^1, the pieces of the&  puzzle are coming together.^1)&* (The jigsaw puzzle.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room4_237", "* Huh!^1?&* There's a camera behind&  the waterfall./%%")
ds_map_add(global.text_data_en, "obj_readable_room5_64", "%%")
ds_map_add(global.text_data_en, "obj_readable_room5_68", "* (There are a lot of striped&  shirts in here.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room5_69", "* Our clothes./%%")
ds_map_add(global.text_data_en, "obj_readable_room5_74", "* (It's ASGORE's journal.)&* (All the current page says&  is 'Nice day today!')/")
ds_map_add(global.text_data_en, "obj_readable_room5_75", "* (The ink is still almost wet.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room5_78", "* (The ink's dry now.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room5_80", "* The entries are always the&  same./%%")
ds_map_add(global.text_data_en, "obj_readable_room5_82", "* (To tylko krzesło.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room5_92", "* (It's a teacup shaped like&  a yellow lizard.^1)&* (It's full of soda.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room5_93", "* (Jest zbyt ciemno^1, by widzieć&  koło ścian.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room5_104", "* (It's a promo poster for&  Mettaton's TV premiere.)/")
ds_map_add(global.text_data_en, "obj_readable_room5_105", "* (On the flap it says " + '"' + "Thank&  you for making my dreams&  come true." + '"' + ")/%%")
ds_map_add(global.text_data_en, "obj_readable_room5_110", "* (An incredible invention.)/")
ds_map_add(global.text_data_en, "obj_readable_room5_111", "* (When not in use^1, this bed&  folds into an extremely-&  easy-to-draw box.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room5_116", "* (Pink goop drips from this&  strange machine.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room5_126", "* Nawiedzająca piosenka odbija&  się wzdłuż korytarza...&* Nie przyłączysz się?/")
ds_map_add(global.text_data_en, "obj_readable_room5_127", "* Wystarczy tylko pierwsze 8./%%")
ds_map_add(global.text_data_en, "obj_readable_room5_131", "* (To ilustracja dziwnego&  stworzenia...)/")
ds_map_add(global.text_data_en, "obj_readable_room5_132", "* (Jest coś bardzo niepokojącego&  w tym rysunku.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room5_138", "* Love^1, hope^1, compassion..^1.&* This is what people say&  monster SOULs are made of./")
ds_map_add(global.text_data_en, "obj_readable_room5_139", "* But the absolute nature of&  " + '"' + "SOUL" + '"' + " is unknown./")
ds_map_add(global.text_data_en, "obj_readable_room5_140", "* After all^1, humans have proven&  their SOULs don't need these&  things to exist./%%")
ds_map_add(global.text_data_en, "obj_readable_room5_145", "* (There's a silverware drawer.^1)&* (It has forks^1, spoons^1,&  knives...)/")
ds_map_add(global.text_data_en, "obj_readable_room5_146", "* (... tiny swords^1, axes^1,&  spears^1, nunchucks...)/%%")
ds_map_add(global.text_data_en, "obj_readable_room5_154", "* I can't believe he&  leapt through the&  window like that./")
ds_map_add(global.text_data_en, "obj_readable_room5_155", "\E6* Normally he NAILS&  the landing./%%")
ds_map_add(global.text_data_en, "obj_readable_room5_160", "* (Small puddle forming.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room5_163", "* (Medium puddle forming.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room5_167", "* (Large puddle forming.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room5_171", "* (A small tree is growing in&  the puddle.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room5_177", "* (It's a bathroom sign.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room5_186", "* (Inside the drawer is a silver&  key.)/")
ds_map_add(global.text_data_en, "obj_readable_room5_187", "* (You put it on your keychain.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room5_192", "* (Clothes and trombones are&  shoved in haphazardly.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room5_197", "* (It appears to be a self-&  sustaining tornado made of&  trash.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room5_203", "* (It's glued to the table.)/%%")
ds_map_add(global.text_data_en, "obj_readable_room5_209", "* (What the hey is this?)/%")
ds_map_add(global.text_data_en, "obj_readable_room5_216", "* (Dumplings.)&* (They look slightly nibbled...)/")
ds_map_add(global.text_data_en, "obj_readable_room5_217", "* (Looks like the dog didn't&  like them very much...)/")
ds_map_add(global.text_data_en, "obj_readable_room5_218", "* (So far the donation money&  has been totally wasted.)/%")
ds_map_add(global.text_data_en, "obj_readable_room5_226", "* (Looks like the dog bought a&  CD for the boombox.)/")
ds_map_add(global.text_data_en, "obj_readable_room5_227", "* (... but^1, it's a game CD.^1)&* (... so it won't work...)/%")
ds_map_add(global.text_data_en, "obj_readable_room5_231", "* (It's some kind of inflatable&  mascot.)/")
ds_map_add(global.text_data_en, "obj_readable_room5_232", "* (It's not clear how this is&  going to encourage anyone&  to donate.)/%")
ds_map_add(global.text_data_en, "obj_readable_room5_236", "* (A framed photo of Papyrus.)/")
ds_map_add(global.text_data_en, "obj_readable_room5_237", "* (Looks like he's having fun&  making some kind of pasta...)/%")
ds_map_add(global.text_data_en, "obj_readable_room5_241", "* (A framed photo of Papyrus.)/")
ds_map_add(global.text_data_en, "obj_readable_room5_242", "* (It's a bit blurry^1, but it&  looks like he's angrily&  chasing the photographer...)/%")
ds_map_add(global.text_data_en, "obj_readable_room5_246", "* (The dog spent all of the money&  on a piece of rope.)/")
ds_map_add(global.text_data_en, "obj_readable_room5_247", "* (However^1, it's really not very&  much rope for the amount&  spent...)/")
ds_map_add(global.text_data_en, "obj_readable_room5_248", "* (It seems like the dog got&  ripped off...)/%")
ds_map_add(global.text_data_en, "obj_readable_room5_252", "* (It's a tap to dispense&  dog food.)/")
ds_map_add(global.text_data_en, "obj_readable_room5_253", "* (So is there a tank full&  of dog food in the&  walls...?)/%")
ds_map_add(global.text_data_en, "obj_readable_room5_257", "* (Huh!? Blueprints...!?)/")
ds_map_add(global.text_data_en, "obj_readable_room5_258", "* (Literally^1. It's white paper^1,&  but covered in little blue&  pawprints...)/")
ds_map_add(global.text_data_en, "obj_readable_room5_259", "* (Wait...)&* (Blue pawprints...)&* (Could it be a clue!?)/")
ds_map_add(global.text_data_en, "obj_readable_room5_260", "* (... No^1, it's totally useless.)/%")
ds_map_add(global.text_data_en, "obj_readable_room5_264", "* (It's another piece of rope.)/")
ds_map_add(global.text_data_en, "obj_readable_room5_265", "* (It's not even any bigger than&  the last one.)/%")
ds_map_add(global.text_data_en, "obj_readable_room5_269", "* (It's a framed letter from the&  Shrine Certification&  Committee.)/")
ds_map_add(global.text_data_en, "obj_readable_room5_270", "* (Apparently^1, the dog applied to&  have its Shrine officially&  recognized.)/")
ds_map_add(global.text_data_en, "obj_readable_room5_271", "* (... It was completely&  rejected...)/")
ds_map_add(global.text_data_en, "obj_readable_room5_272", "* (... It doesn't seem to have&  realized that at all...)/%")
ds_map_add(global.text_data_en, "obj_readable_sign2_55", "* Ominąłeś to?&* Wypieki Pająków&  na dół i w prawo./")
ds_map_add(global.text_data_en, "obj_readable_sign2_56", "* Chodź zjedz jedzenie zrobione&  przez pająków^1, dla pająków^1,&  z pająków!/%%")
ds_map_add(global.text_data_en, "obj_readable_switch1_65", "* Nie nie^1!/")
ds_map_add(global.text_data_en, "obj_readable_switch1_66", "\E0* Będziesz chciał włączyć&  drugi przełącznik./")
ds_map_add(global.text_data_en, "obj_readable_switch1_67", "\E1* Zaznaczyłam ci&  nawet.../%%")
ds_map_add(global.text_data_en, "obj_readable_switch1_71", "* Wygląda na to, że to& niewłaściwa dźwignia./%%")
ds_map_add(global.text_data_en, "obj_readable_switch1_81", "* (Wow!^1)&* (Jesteś super szybki w&  byciu idiotą.)/%%")
