ds_map_add(global.text_data_en, "obj_greatdog_440", "* Większejszy Pies czujnie cię&  obserwuje.")
ds_map_add(global.text_data_en, "obj_greatdog_441", "* Większejszy Pies oczekuje na&  twoje polecenie.")
ds_map_add(global.text_data_en, "obj_greatdog_442", "* Pachnie jak świeżo-&  wyciśnięty wywar z psa.")
ds_map_add(global.text_data_en, "obj_greatdog_443", "* Większejszy Pies poszukuje&  empatii.")
ds_map_add(global.text_data_en, "obj_greatdog_444", "* Większejszy Pies po prostu&  chce empatii.")
ds_map_add(global.text_data_en, "obj_greatdog_445", "* Większejszy Pies robi pieskie&  oczka.")
ds_map_add(global.text_data_en, "obj_greatdog_446", "* Większejszy Pies stompa po&  ziemi przednimi łapkami.")
ds_map_add(global.text_data_en, "obj_greatdog_447", "* Większejszy Pies chce&  troskliwej opieki.")
ds_map_add(global.text_data_en, "obj_greatdog_448", "* Pojemność głaskania wynosi&  40 procent.")
ds_map_add(global.text_data_en, "obj_greatdog_449", "* Większejszy Pies jest&  uradowany.")
ds_map_add(global.text_data_en, "obj_greatdog_450", "* Większejszy Pies powoli dyszy.")
ds_map_add(global.text_data_en, "obj_greatdog_466", "* Większejszy Pies - ATK 15 DEF 8&* Jest tak podekscytowany że&  traktuje to jako zabawę./^")
ds_map_add(global.text_data_en, "obj_greatdog_478", "* Uszy Większejszego Piesa&  unoszą się^1.&* Nic więcej się nie dzieje./^")
ds_map_add(global.text_data_en, "obj_greatdog_482", "* Wołasz Większejszego Piesa./")
ds_map_add(global.text_data_en, "obj_greatdog_483", "* Kłoni się nad toą^1,&  robiąc słodkie oczka./^")
ds_map_add(global.text_data_en, "obj_greatdog_495", "* Większejszy Pies podchodzi&  bliżej./^")
ds_map_add(global.text_data_en, "obj_greatdog_501", "* Większejszy Pies postanawia^1,&  że jesteś zbyt nudny./^")
ds_map_add(global.text_data_en, "obj_greatdog_512", "* Głaskasz piesa./^")
ds_map_add(global.text_data_en, "obj_greatdog_515", "* Głaskanie po brzuszku&  wzbronione./^")
ds_map_add(global.text_data_en, "obj_greatdog_520", "* Głaskasz zdecydowanie^1.&* Pojemność głaskania osiąga&  100 procent./")
ds_map_add(global.text_data_en, "obj_greatdog_521", "* Pies się przewraca na plecy&  wystawiając łapki do góry./^")
ds_map_add(global.text_data_en, "obj_greatdog_528", "* Jako głaszczesz psa^1,&  topi całą swoją masę&  na tobie.../")
ds_map_add(global.text_data_en, "obj_greatdog_529", "* Twój ruch się spowalnia./")
ds_map_add(global.text_data_en, "obj_greatdog_530", "* Ale^1, nadal jeszcze nie&  pogłaskałeś wystarczająco...!/^")
ds_map_add(global.text_data_en, "obj_greatdog_536", "* Ekscytacja Większejszego Piesa&  tworzy potężną barierę^1, która&  powstrzymuje głaskanie./^")
ds_map_add(global.text_data_en, "obj_greatdog_540", "* Większejszy Pies wspina się po&  twoich udach jako jest głaskany&  przez ciebie./")
ds_map_add(global.text_data_en, "obj_greatdog_541", "* Robi się tak komfortowy że&  zasypia.../")
ds_map_add(global.text_data_en, "obj_greatdog_542", "* Zzzzz.../")
ds_map_add(global.text_data_en, "obj_greatdog_543", "* .../")
ds_map_add(global.text_data_en, "obj_greatdog_544", "* I nagle się przebudza^1!&* Jest tak podekscytowany!/^")
ds_map_add(global.text_data_en, "obj_greatdog_549", "* Większejszy Pies jest zbyt&  daleko by pogłaskać^1.&* Głaszczesz powietrze./^")
ds_map_add(global.text_data_en, "obj_greatdog_558", "* Bawisz się z piesem./^")
ds_map_add(global.text_data_en, "obj_greatdog_561", "* Większejszy Pies jest  zbyt&  zmęczony^1, by się bawić./^")
ds_map_add(global.text_data_en, "obj_greatdog_565", "* Lepisz śnieżkę i rzucasz ją&  dla piesa by ten go zaportował./")
ds_map_add(global.text_data_en, "obj_greatdog_566", "* Rozplaskuje się na ziemi./")
ds_map_add(global.text_data_en, "obj_greatdog_567", "* Większejszy Pies podnosi cały&  śnieg w pobliżu i przynosi&  spowrotem do ciebie./")
ds_map_add(global.text_data_en, "obj_greatdog_568", "* Teraz pies jest zmęczony..^1.&* Kładzie swoją głowę na tobie.../^")
ds_map_add(global.text_data_en, "obj_greatdog_573", "* Większejszy Pies nie jest&  wystarczająco podekscytowany&  aby się bawić./^")
ds_map_add(global.text_data_en, "obj_grillbynpc_doggo_74", "* Myślę o kupieniu kolczatej&  obroży by ukazać moją personę./")
ds_map_add(global.text_data_en, "obj_grillbynpc_doggo_75", "* Wtedy zrobi wrażenie typu..^1.&* " + '"' + "Przypnij do mnie smycz i&  zabierz mnie na spacer proszę." + '"' + "/%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_doggo_79", "* On może tego nie lubić^1,&  ale ten duży gość pisze&  najwybitniejsze listy./")
ds_map_add(global.text_data_en, "obj_grillbynpc_doggo_80", "* Masz^1, spójrz sobie!/")
ds_map_add(global.text_data_en, "obj_grillbynpc_doggo_81", "* (To jedno słowo " + '"' + "woof" + '"' + "&  ale w zdobionej czcionce.)/%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_doggo_86", "* Papyrus^1?&* Czy to ty^1?&  No weź.../%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_doggo_91", "* Undyne!^1?&* Czy ty przyszłaś&  aż tutaj...?/%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_doggo_96", "* Huh^1?&* Od kiedy ty i Sans jes-&  teście przyjaciółmi...?/")
ds_map_add(global.text_data_en, "obj_grillbynpc_doggo_97", "* Nie lubię go..^1.&* On kocha pojawiać się&  bez poruszania./%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_doggo_101", "* A gdzie tamta dwójka^1?&* Nie mogę się bawić z tym&  dużym głupim typem samemu.../")
ds_map_add(global.text_data_en, "obj_grillbynpc_doggo_102", "* On po prostu wygra!!!/%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_doggo_104", "* Czasami inni lubią ze mnie&  żartować^1. Oni siedzą w&  bezruchu więc ich nie widzę./")
ds_map_add(global.text_data_en, "obj_grillbynpc_doggo_105", "* Oni muszą być tutaj^1, strojąc&  sobie ze mnie żarty./")
ds_map_add(global.text_data_en, "obj_grillbynpc_doggo_106", "* Po prostu poczekam aż jeden&  z nich się przyzna.../%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_doggo_110", "* Posiadanie bezkształtnego^1,&  trząsającego się członka&  rodziny jest świetne./")
ds_map_add(global.text_data_en, "obj_grillbynpc_doggo_111", "* Zawsze się rusza^1, więc&  mogę ich widzieć przez&  100 procent czasu!/%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_foodmonster_73", "* Hmmm..^1.&* Czy ludzkie jedzenie się nie&  różni od jedzenia dla potworów?/")
ds_map_add(global.text_data_en, "obj_grillbynpc_foodmonster_74", "* Robi rzeczy takie jak&  " + '"' + "gnijenie." + '"' + "/")
ds_map_add(global.text_data_en, "obj_grillbynpc_foodmonster_75", "* A kiedy to zjesz^1, to&  się przemieszcza przez&  całe twoje ciało./")
ds_map_add(global.text_data_en, "obj_grillbynpc_foodmonster_76", "* Obrzydliwe./")
ds_map_add(global.text_data_en, "obj_grillbynpc_foodmonster_77", "* Chciałbym tego kiedyś&  spróbować./%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_foodmonster_80", "* I słyszałem^1, że oni mają&  jakieś " + '"' + "łazienki" + '"' + "./%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_foodmonster_84", "* Dla człowieka^1, jedzenie dla&  potworów byłoby bardzo&  ciekawe./")
ds_map_add(global.text_data_en, "obj_grillbynpc_foodmonster_85", "* Bo kiedy to tylko zjesz^1, &  konwertuje się na czystą&  energię./")
ds_map_add(global.text_data_en, "obj_grillbynpc_foodmonster_86", "* ... to mnie ciekawi^1.&* Jak to robią ludzie?/")
ds_map_add(global.text_data_en, "obj_grillbynpc_foodmonster_87", "* Jeść podczas walki...?/%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_foodmonster_90", "* Lody w jednej ręce^1,&  miecz w drugiej./")
ds_map_add(global.text_data_en, "obj_grillbynpc_foodmonster_91", "* Tak przynajmniej robią&  potwory wojownicy.../%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_foodmonster_97", "* Hmmm^1, jakoś mniej więcej&  teraz Sans się zazwyczaj&  zjawia./")
ds_map_add(global.text_data_en, "obj_grillbynpc_foodmonster_98", "* Wtedy^1, chwilę później^1,&  jego brat przychodzi^1,&  zirytowany./")
ds_map_add(global.text_data_en, "obj_grillbynpc_foodmonster_99", "* Tak^1, jego brat^1.&* Papyrus./")
ds_map_add(global.text_data_en, "obj_grillbynpc_foodmonster_100", "* Jest zadziwiającym ziomem./")
ds_map_add(global.text_data_en, "obj_grillbynpc_foodmonster_101", "* Zawsze zamawia szklankę&  mleka.../")
ds_map_add(global.text_data_en, "obj_grillbynpc_foodmonster_102", "* Mówi^1, że to ważny budulec&  tkanki kościowej czy coś/%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_foodmonster_104", "* Oby się dzisiaj pokazał./%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_foodmonster_109", "* Niedługo^1, sam będę w stanie&  spróbować ludzkiego żarcia.../")
ds_map_add(global.text_data_en, "obj_grillbynpc_foodmonster_110", "* I wtedy chyba też spróbuję&  ludzkiej toalety./%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_foodmonster_115", "* Sans jest ciekawą osobą^1.&* Opowiedział mi o tych wszyst-&  kich wspaniałych jedzeniach./")
ds_map_add(global.text_data_en, "obj_grillbynpc_foodmonster_116", "* Ale^1, pomimo jego wiedzy^1,&  zawsze zamawia najgorszego&  burgera z menu./%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_grillby_73", "* ..^1.&* ..^1.&* ..^1./")
ds_map_add(global.text_data_en, "obj_grillbynpc_grillby_74", "* Grillbz powiedział^1, że zapropo-&  nowałby ci szklankę wody^1, ale&  on nie dotyka takich rzeczy./%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_grillby_78", "* .............^1.&* ..............^1.&* ... dobra robota./%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_grillby_83", "* ..^1.&* ..^1.&* ..^1./")
ds_map_add(global.text_data_en, "obj_grillbynpc_grillby_84", "* Grillbz powiedział^1, że&  twoje jedzenie już jest&  pewnie zimne./%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_hot2_73", "* Te psy należą do KRÓLEWSKIEJ&  GWARII^1, elitarnej grupy mili-&  tarnej pod wodzą UNDYNE./")
ds_map_add(global.text_data_en, "obj_grillbynpc_hot2_74", "* Jest niemiła^1, głośna^1, i bije&  każdego^1, kto stanie na jej&  drodze.../")
ds_map_add(global.text_data_en, "obj_grillbynpc_hot2_75", "* Nie dziwię się^1, że dzieciaki&  chcą być jak ona kiedy&  dorosną!/%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_hot2_77", "* Ja chcę być jak UNDYNE&  kiedy też dorosnę^1!&* Hoo hoo hoo!/%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_hot2_81", "* Sans jest " + '"' + "strażnikiem" + '"' + "^1.&* Ale nie pozwól sobie wmówić^1,&  że jego tytuł coś znaczy./")
ds_map_add(global.text_data_en, "obj_grillbynpc_hot2_82", "\W* Każdy wie^1, że on po prostu&  ma chillerkę w lesie i czyta&  \Yczasopisma motorowe\W./%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_hot2_87", "* Ehhhhhhhhnnnnn..^1.&* Chciałbym mieć co&  innego do roboty./%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_hot2_92", "* Te psy należą do KRÓLEWSKIEJ&  GWARII^1, czyli.../")
ds_map_add(global.text_data_en, "obj_grillbynpc_hot2_93", "* Huh^1?&* Gdzie one się podziały?/")
ds_map_add(global.text_data_en, "obj_grillbynpc_hot2_94", "* Coś tu mocno nie gra./%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_hot2_101", "* Wow^1, kompletnie nowy świat.../")
ds_map_add(global.text_data_en, "obj_grillbynpc_hot2_102", "* Mogę już nie być w stanie&  tłumaczyć więcej Grillby'ego.../")
ds_map_add(global.text_data_en, "obj_grillbynpc_hot2_103", "* ... ale nie szkodzi^1, jako że&  tak naprawdę zmyślałem sobie&  co on mówił./%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_hot2_109", "* Grillby stresuje się./")
ds_map_add(global.text_data_en, "obj_grillbynpc_hot2_110", "* Sans to jego najlepszy klient^1,&  a nie pokazał się jeszcze&  przez cały dzień.../%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_hot2_115", "* Coś jest naprawdę nie tak^1.&* Nasze życia nie sprowadzają&  się nigdzie^1, czyż nie...?/")
ds_map_add(global.text_data_en, "obj_grillbynpc_hot2_116", "* Chyba potrzebuję kolejnego&  shota espresso.../%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_hotandbothered_73", "* Nieważne gdzie pójdę^1,&  jest to samo menu^1, ci sami&  klienci.../")
ds_map_add(global.text_data_en, "obj_grillbynpc_hotandbothered_74", "* Pomocy^1!&* Chcę nowe drinki i&  ^1h-^1h-^1h-hot typów!!!!/%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_hotandbothered_75", "* Chyba ten barista jest taki&  ^1h-^1h-^1h-hot.../%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_hotandbothered_79", "* Chodźcie guys!!^1!&* ^1I-^1i-imprezujmy!!!/")
ds_map_add(global.text_data_en, "obj_grillbynpc_hotandbothered_80", "* ... ktokolwiek?/%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_hotandbothered_84", "* Sansyyyy..^1.&* Wracaj tu i siądź ze mną.../")
ds_map_add(global.text_data_en, "obj_grillbynpc_hotandbothered_85", "* Wszystko jest takie fajne&  kiedy ty jesteś!!!/%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_hotandbothered_90", "* Jest t-t-tak cicho tutaj./")
ds_map_add(global.text_data_en, "obj_grillbynpc_hotandbothered_91", "* L-lighten up everybody^1!&* This is why I hate&  th-this place./%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_hotandbothered_98", "* I w-wonder if the&  o-overworld h-has h-hot&  guys.../")
ds_map_add(global.text_data_en, "obj_grillbynpc_hotandbothered_99", "*  A-and neat d-drinks.../")
ds_map_add(global.text_data_en, "obj_grillbynpc_hotandbothered_100", "* Ooooooo^1, I'm ready!/%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_hotandbothered_105", "* H-hey^1, isn't Sansy s'posed&  to come swinging in right&  about now???/")
ds_map_add(global.text_data_en, "obj_grillbynpc_hotandbothered_106", "* C'mon Sansy^1!&* You're the life of the&  party.../%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_lesserdog_71", "* (On gra w pokera z samym sobą.)/")
ds_map_add(global.text_data_en, "obj_grillbynpc_lesserdog_72", "* (Wygląda na to że przegrywa.)/%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_lesserdog_76", "* (Przerzucił się na grę&  w rybki.)/%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_lesserdog_81", "* (W końcu wygrał rundę&  pokera z samym sobą...?)/%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_mandog_75", "* Patrz gdzie siedzisz&  tutaj^1, wariacie./")
ds_map_add(global.text_data_en, "obj_grillbynpc_mandog_76", "* Ponieważ ten duży gość SKOCZY&  na twoje uda i da ci dużo&  miłości i atencji./%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_mandog_80", "* Gdzie jest Sans..^1.&* Miał mnie pogłaskać&  po głowie.../%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_mandog_85", "* Ona nie odpowiada na&  nasze listy.../")
ds_map_add(global.text_data_en, "obj_grillbynpc_mandog_86", "* Może dlatego, że daliśmy&  kartkę i długopis Piesełowi./%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_mandog_91", "* Liczyłem na to^1, że Sans&  przyjdzie i da mi moje&  dzienne głaskanie./")
ds_map_add(global.text_data_en, "obj_grillbynpc_mandog_92", "* Intruz...!/%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_mandog_96", "* Gdzie ten duży gość^1?&* Nie możemy zacząć dopóki&  on się nie zjawi./%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_mandog_98", "* Pachnie trochę..^1. cicho./%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_mandog_103", "* Hmmm^1, teraz jako że nasi&  starzy są jedną istotą.../")
ds_map_add(global.text_data_en, "obj_grillbynpc_mandog_104", "* Czy to oznacza^1, że jestem&  ożeniony z moją siostrą?/")
ds_map_add(global.text_data_en, "obj_grillbynpc_mandog_105", "* .../")
ds_map_add(global.text_data_en, "obj_grillbynpc_mandog_106", "* Chwila^1, jesteśmy psami^1.&* To normalka./%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_sansdate_121", "* szybki skrót^1, huh?/%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_sansdate_129", "* heja^1, wszyscy./%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_sansdate_164", "* Hej^1, Sans.&* (Hej^1, Sans!!)/%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_sansdate_208", "* Witaj^1, Sans.&* Heja^1, Sansy~/%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_sansdate_245", "* Hej Sans^1, czyżbyś tu nie&  był na śniadanie jakieś&  parę minut temu?/")
ds_map_add(global.text_data_en, "obj_grillbynpc_sansdate_247", "* nah^1, nie miałem&  śniadanie od przynaj-&  mniej pół godziny./")
ds_map_add(global.text_data_en, "obj_grillbynpc_sansdate_248", "\E2* musisz chyba myśleć&  o obiedzie./%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_sansdate_286", "* no^1, zrelaksuj się./%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_sansdate_521", "* (Sięgasz po ketchup...)/")
ds_map_add(global.text_data_en, "obj_grillbynpc_sansdate_522", "* (Nakrętka odpada i&  cały ketchup w butelce&  wylewa się na jedzenie.)/%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_sansdate_545", "* ups./")
ds_map_add(global.text_data_en, "obj_grillbynpc_sansdate_546", "\E0* eh, nie szkodzi^1.&* możesz mieć moje./")
ds_map_add(global.text_data_en, "obj_grillbynpc_sansdate_547", "\E1* i tak nie&  jestem głodny./%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_sansdate_577", "* w każdym razie^1, czadowy&  czy nie^1, musisz przyznać&  że papyrus się stara./")
ds_map_add(global.text_data_en, "obj_grillbynpc_sansdate_578", "\E0* na przykład jak się&  stara o pozycję&  królewskiej gwarii./")
ds_map_add(global.text_data_en, "obj_grillbynpc_sansdate_579", "\E1* jednego dnia^1, poszedł&  do domu generała .../")
ds_map_add(global.text_data_en, "obj_grillbynpc_sansdate_580", "\E0* i błagał ją o&  przyłączenie./")
ds_map_add(global.text_data_en, "obj_grillbynpc_sansdate_581", "\E1* oczywiście^1, trzasnęła&  drzwiami jako że&  była północ./")
ds_map_add(global.text_data_en, "obj_grillbynpc_sansdate_582", "\E0* ale następnego dnia^1,&  obudziła się i zobaczyła&  go dalej stojącego./")
ds_map_add(global.text_data_en, "obj_grillbynpc_sansdate_583", "* widząc jego dedykację^1,&  postanowiła przeprowa-&  dzić wojowniczy trening./")
ds_map_add(global.text_data_en, "obj_grillbynpc_sansdate_584", "\E1* to^1, uh^1, dalej&  praca w toku./%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_sansdate_609", "\E1* o i jeszcze^1, chciałem&  cię o coś spytać./%%")
ds_map_add(global.text_data_en, "obj_grillbynpc_sansdate_683", "* welp^1, to była&  długa przerwa./")
