ds_map_add(global.text_data_en, "obj_nicecreamguy_152", "* Zrelokalizowałem moją&  budkę^1, ale dalej nie ma &  żadnych klientów.../%%")
ds_map_add(global.text_data_en, "obj_nicecreamguy_164", "* Musisz mieć coś lepszego do&  roboty niż czytać tą&  wiadomość./%%")
ds_map_add(global.text_data_en, "obj_nicecreamguy_183", "* Pomyślałem z pewnością że&  jeśli pójdę do Hotland^1,&  sprzedawałbym tam jakieś lody./")
ds_map_add(global.text_data_en, "obj_nicecreamguy_184", "* Ale nikt ich nie chce^1.&* Wszyscy tylko jedzą&  Starfaity i Glamburgery./")
ds_map_add(global.text_data_en, "obj_nicecreamguy_185", "* Więc!!!/%%")
ds_map_add(global.text_data_en, "obj_nicecreamguy_197", "* Musisz mieć coś lepszego do&  roboty niż czytać tą&  wiadomość./%%")
ds_map_add(global.text_data_en, "obj_nicecreamguy_211", "* Jestem taki szczęśliwy!^1!&* Fajne Lody naprawdę zmieniają&  świat na lepsze!!/%%")
ds_map_add(global.text_data_en, "obj_nicecreamguy_215", "* Hej^1!&* To ty^1!/")
ds_map_add(global.text_data_en, "obj_nicecreamguy_216", "* Biznes tu kręci się znakomicie^1!&* Te dwa ziomki (platoniczne)&  kupili WSZYSTKIE lody!/")
ds_map_add(global.text_data_en, "obj_nicecreamguy_217", "* Poraz pierwszy wyprzedał&  mi się towar!!!/")
ds_map_add(global.text_data_en, "obj_nicecreamguy_218", "* ... sorki./")
ds_map_add(global.text_data_en, "obj_nicecreamguy_219", "* Chwila^1!&* Dalej jeszcze mam&  coś dla ciebie!/")
ds_map_add(global.text_data_en, "obj_nicecreamguy_220", "* ... szeroki uśmiech^1!&* Co ty na to!/%%")
ds_map_add(global.text_data_en, "obj_nicecreamguy_227", "* I'm so excited to sell&  Nice Cream on the surface!/")
ds_map_add(global.text_data_en, "obj_nicecreamguy_230", "* If all humans are like you^1,&  then...!/")
ds_map_add(global.text_data_en, "obj_nicecreamguy_231", "* ... then I'll still be&  able to sell to monsters^1,&  I hope./%%")
ds_map_add(global.text_data_en, "obj_nicecreamguy_234", "* If all humans are like you^1,&  I think it'll be a modest&  success!/%%")
ds_map_add(global.text_data_en, "obj_nicecreamguy_236", "* If all humans are like you^1,&  I think it'll be really&  popular!/%%")
ds_map_add(global.text_data_en, "obj_nicecreamguy_288", "* OH!!!^1!&* KLIENT!!!/%%")
ds_map_add(global.text_data_en, "obj_nicecreamguy_291", "* Na szczęście^1, wymyśliłem&  rozwiązanie!!/")
ds_map_add(global.text_data_en, "obj_nicecreamguy_292", "* Karty Dziurkowane!!/")
ds_map_add(global.text_data_en, "obj_nicecreamguy_293", "* Za każdym razem^1, gdy kupisz&  Fajnego Loda^1, możesz wziąć&  taką kartę z pudła obok./")
ds_map_add(global.text_data_en, "obj_nicecreamguy_294", "* Jeśli masz 3 karty^1, możesz&  je wymienić na darmowego&  Fajnego Loda!/")
ds_map_add(global.text_data_en, "obj_nicecreamguy_295", "* To na pewno przekona&  klientów do powrotu!/%%")
ds_map_add(global.text_data_en, "obj_nicecreamguy_296", "* W każdym razie.../%%")
ds_map_add(global.text_data_en, "obj_nicecreamguy_302", "* Robię likwidację wyprzedażową&  przed terminacją mojej budki./%%")
ds_map_add(global.text_data_en, "obj_nicecreamguy_320", "* Musisz mieć coś lepszego do&  roboty niż czytać tą&  wiadomość./%%")
ds_map_add(global.text_data_en, "obj_nicesnowman_107", "* Oh^1?&* Coś o tym kawałku^1, który&  ci dałem?/")
ds_map_add(global.text_data_en, "obj_nicesnowman_108", "* .../")
ds_map_add(global.text_data_en, "obj_nicesnowman_109", "* ... przecież nigdy ci niczego&  nie dawałem..?/%%")
ds_map_add(global.text_data_en, "obj_nicesnowman_120", "* Ah..^1. Czuję^1, że ten kawałek&  mnie został odpowiednio&  zaopiekowany./")
ds_map_add(global.text_data_en, "obj_nicesnowman_121", "* Dziękuję./")
ds_map_add(global.text_data_en, "obj_nicesnowman_122", "* Hmmm...^1?&* Bariera już się otworzyła?/")
ds_map_add(global.text_data_en, "obj_nicesnowman_123", "* Hmmm..^1.&* W takim razie^1, jeśli to nie&  sprawi problemu.../")
ds_map_add(global.text_data_en, "obj_nicesnowman_124", "* ... mógłbyś zanieść ten&  kawałek mnie na powierzchnię?/")
ds_map_add(global.text_data_en, "obj_nicesnowman_125", "* Naprawdę bym to docenił./%%")
ds_map_add(global.text_data_en, "obj_nicesnowman_133", "* A więc^1, zaniosłeś ten&  kawałek mnie gdzieś&  bardzo daleko...?/")
ds_map_add(global.text_data_en, "obj_nicesnowman_134", "* .../")
ds_map_add(global.text_data_en, "obj_nicesnowman_135", "* Gdzie jest ten kawałek!?/%%")
ds_map_add(global.text_data_en, "obj_nicesnowman_140", "* Ah^1, bariera jest otwarta...?/")
ds_map_add(global.text_data_en, "obj_nicesnowman_141", "* Wiesz^1, że nie mogę się ruszać^1.&* To po co mi to mówisz^1?&* Żeby się pośmiać ze mnie?/")
ds_map_add(global.text_data_en, "obj_nicesnowman_142", "* Każdy może cię uważać za&  dobrą osobę^1, lecz ten bałwan&  zna prawdę./")
ds_map_add(global.text_data_en, "obj_nicesnowman_143", "* Pewnego dnia^1, twoi przyjaciele&  się dowiedzą^1, że twoje serce&  jest tak zimne jak mój tyłek./%%")
ds_map_add(global.text_data_en, "obj_nicesnowman_155", "* (Nosisz zbyt wiele rzeczy.)/%%")
ds_map_add(global.text_data_en, "obj_nicesnowman_161", "* Witaj^1.&* Jestem bałwanem^1.&* Nie mogę się ruszać./")
ds_map_add(global.text_data_en, "obj_nicesnowman_162", "* Podróżniku^1, gdybyś mógł.../")
ds_map_add(global.text_data_en, "obj_nicesnowman_163", "* (Dostałeś Kawałek Bałwana.)/%%")
ds_map_add(global.text_data_en, "obj_nicesnowman_167", "* O rany^1, o mój boże^1.&* Co ty wyprawiasz?/")
ds_map_add(global.text_data_en, "obj_nicesnowman_168", "* Niedługo nie pozostanie&  ze mnie nic.../")
ds_map_add(global.text_data_en, "obj_nicesnowman_169", "* (Dostałeś Kawałek Bałwana.)/%%")
ds_map_add(global.text_data_en, "obj_nicesnowman_173", "* Przestań..^1.&* Proszę.../")
ds_map_add(global.text_data_en, "obj_nicesnowman_174", "* (Dostałeś Kawałek Bałwana.)/%%")
ds_map_add(global.text_data_en, "obj_nicesnowman_177", "* (Bezużyteczna kupka śniegu.)/%%")
ds_map_add(global.text_data_en, "obj_notify_room_112", "\YALPHYS updated status.\W &* oopswait how's the humnan&  doing/%%")
ds_map_add(global.text_data_en, "obj_notify_room_120", "\YALPHYS updated status.\W &* Top 10 Shows That Make You&  Forget To Do Your Frickin Job/%%")
ds_map_add(global.text_data_en, "obj_notify_room_142", "\YALPHYS updated status.\W &* OMG? ppl think Mew Mew 2&  is better than Mew Mew 1?/")
ds_map_add(global.text_data_en, "obj_notify_room_143", "* LOLLLLL that's a joke&  right.../%%")
ds_map_add(global.text_data_en, "obj_notify_room_151", "\YALPHYS updated status.\W &* omg... DONT THEY GET IT RUINS&  Mew Mew's ENTIRE CHARACTER ARC/%%")
ds_map_add(global.text_data_en, "obj_notify_room_159", "\YALPHYS updated status.\W &* My Mew Mew 2 Review:/")
ds_map_add(global.text_data_en, "obj_notify_room_160", "* Mew Mew Kissy Cutie 2 Is&  Neither Kissy Nor Cutie.&* Its Trash. 0 stars/%%")
ds_map_add(global.text_data_en, "obj_notify_room_178", "\YALPHYS updated status.\W &* that's the last time i try&  to help with a puzzle lmao/%%")
ds_map_add(global.text_data_en, "obj_notify_room_197", "\YALPHYS posted a picture.\W &* dinner with the girlfriend ;)/")
ds_map_add(global.text_data_en, "obj_notify_room_198", "* (It's a picture of a catgirl&  figurine next to a bowl of&  instant noodles.)/%%")
ds_map_add(global.text_data_en, "obj_notify_room_206", "\YCoolSkeleton95 posted a picture.\W &* ARE WE POSTING HOT " + '"' + "PICS???" + '"' + "&* HERE IS ME AND MY COOL FRIEND/")
ds_map_add(global.text_data_en, "obj_notify_room_207", "* (It's a picture of Papyrus&  flexing in front of a mirror.)&* (He is wearing sunglasses.)/")
ds_map_add(global.text_data_en, "obj_notify_room_208", "* (Giant muscular biceps are&  pasted onto his arms.)/")
ds_map_add(global.text_data_en, "obj_notify_room_209", "* (The biceps are also wearing&  sunglasses.)/%%")
ds_map_add(global.text_data_en, "obj_notify_room_217", "\YALPHYS updated status.\W &* LOL, CoolSkeleton95!&* ... that's a joke^1, right?/%%")
ds_map_add(global.text_data_en, "obj_notify_room_225", "\YCoolSkeleton95 updated status.\W &* THE ONLY JOKE HERE^1, IS&  HOW STRONG MY MUSCLES ARE./%%")
ds_map_add(global.text_data_en, "obj_notify_room_243", "\YALPHYS updated status.\W &* whatever!!! i'll just explain&  it!!!/%%")
ds_map_add(global.text_data_en, "obj_notify_room_258", "\YALPHYS updated status.\W &* wonder if it would be unfun&  if i explained the puzzle.../%%")
ds_map_add(global.text_data_en, "obj_notify_room_279", "\YALPHYS updated status.\W &* Oh My God i Forgot to Tell&  THem Where To Go/%%")
ds_map_add(global.text_data_en, "obj_notify_room_284", "\YALPHYS posted a picture.\W &* CUte PIC OF ME RIGHT NOW ^0.^0 /")
ds_map_add(global.text_data_en, "obj_notify_room_285", "* (It's a photo of a garbage can&  with several pink^1, glittery&  filters over it.)/%%")
ds_map_add(global.text_data_en, "obj_notify_room_307", "\YALPHYS updated status.\W &* OMG I DID IT!!!/")
ds_map_add(global.text_data_en, "obj_notify_room_308", "* claws haven't shook like that&  since undyne called me to ask&  about the weather... v.v/%%")
ds_map_add(global.text_data_en, "obj_notify_room_314", "\YALPHYS updated status.\W &* WAIT THERE'S NO WEATHER DOWN&  HERE WHY DID SHE CALL ME/%%")
ds_map_add(global.text_data_en, "obj_notify_room_336", "\YALPHYS updated status.\W &* I HATE USING THE PHONE I DON'T&  WANT TO DO THIS LMAO ^0.^0 /%%")
ds_map_add(global.text_data_en, "obj_notify_room_342", "\YALPHYS updated status.\W &* omg ive had my claw over&  the last digit for 5 minutes/")
ds_map_add(global.text_data_en, "obj_notify_room_343", "* omg i'm just gonna do it&* i'm just gonna call!!!!/%%")
ds_map_add(global.text_data_en, "obj_notify_room_372", "\YALPHYS updated status.\W &* gonna call them in a&  minute!!! =^0.^0=/%%")
ds_map_add(global.text_data_en, "obj_notify_room_378", "\YALPHYS updated status.\W &* for now i gotta call up the&  human and guide them =^0.^0=/%%")
ds_map_add(global.text_data_en, "obj_notify_room_385", "\YALPHYS updated status.\W &* well i know she's unbeatable&  i'll ask her abt it later ^0.^0 /%%")
ds_map_add(global.text_data_en, "obj_notify_room_391", "\YALPHYS updated status.\W &* just realized i didn't watch&  undyne fight the human v.v/%%")
ds_map_add(global.text_data_en, "obj_notify_room_398", " ")
ds_map_add(global.text_data_en, "obj_npc_room_271", "* (It's a trash can.)/")
ds_map_add(global.text_data_en, "obj_npc_room_272", "* (It's full of crumpled-up&  recipes for butterscotch&  pie.)/%%")
ds_map_add(global.text_data_en, "obj_npc_room_277", "* (It's a trophy.^1)&* (Number 1 Nose-Nuzzle&  Champs '98!)/%%")
ds_map_add(global.text_data_en, "obj_npc_room_282", "* Oto Kwiatek Echo^1.&* Powtarza ostatnią rzecz którą&  słyszała w kółko.../%%")
ds_map_add(global.text_data_en, "obj_npc_room_283", "* Fajne^1, co nie?/%%")
ds_map_add(global.text_data_en, "obj_npc_room_284", "* Nigdy nie ufaj kwiatkowi..^1.&* To jedna z zasad tego świata./%%")
ds_map_add(global.text_data_en, "obj_npc_room_291", "* Ten ser tu był tak długo^1, że&  magiczny kryształ zaczął&  wyrastać wokół niego./")
ds_map_add(global.text_data_en, "obj_npc_room_292", "* Jest przyklejony&  do stolika.../%%")
ds_map_add(global.text_data_en, "obj_npc_room_295", "* (Wygląda na to, że myszka&  jakimś cudem zdołała odzyskać&  kawałek sera z kryształu.)/%%")
ds_map_add(global.text_data_en, "obj_npc_room_300", "* Czym jest gwizda?/")
ds_map_add(global.text_data_en, "obj_npc_room_301", "* Możesz ją dotknąć?/")
ds_map_add(global.text_data_en, "obj_npc_room_302", "* Możesz ją zjeść?/")
ds_map_add(global.text_data_en, "obj_npc_room_303", "* Możesz ją zabić?/")
ds_map_add(global.text_data_en, "obj_npc_room_304", "* .../")
ds_map_add(global.text_data_en, "obj_npc_room_305", "* Czy ty jesteś gwiazdą?/%%")
ds_map_add(global.text_data_en, "obj_npc_room_308", "* Co trzymasz^1?&* Czy to gwiazda?/%%")
ds_map_add(global.text_data_en, "obj_npc_room_313", "* Możemy już iść zobaczyć&  prawdziwe gwiazdy.../")
ds_map_add(global.text_data_en, "obj_npc_room_314", "* Ale nadal nie wiem czym&  one są./%%")
ds_map_add(global.text_data_en, "obj_npc_room_319", "* Jedna z gwiazd wyblakła./")
ds_map_add(global.text_data_en, "obj_npc_room_320", "* Co to oznacza...?/%%")
ds_map_add(global.text_data_en, "obj_npc_room_334", "* (To brudna skarpetka z&  serią notatek na nim.)/")
ds_map_add(global.text_data_en, "obj_npc_room_335", "\TP %")
ds_map_add(global.text_data_en, "obj_npc_room_336", "SANS^1!&PROSZĘ PODNIEŚ TWOJĄ&SKARPETKĘ!/")
ds_map_add(global.text_data_en, "obj_npc_room_337", "\Ts %")
ds_map_add(global.text_data_en, "obj_npc_room_338", "* ok./")
ds_map_add(global.text_data_en, "obj_npc_room_339", "\TP %")
ds_map_add(global.text_data_en, "obj_npc_room_340", "NIE KŁADŹ JEJ SPOWROTEM^1!&PRZESUŃ JĄ!/")
ds_map_add(global.text_data_en, "obj_npc_room_341", "\Ts %")
ds_map_add(global.text_data_en, "obj_npc_room_342", "* ok./")
ds_map_add(global.text_data_en, "obj_npc_room_343", "\TP %")
ds_map_add(global.text_data_en, "obj_npc_room_344", "PRZENIOSŁEŚ TO O PIĘĆ&CENTYMETRÓW^1! PRZENIEŚ JĄ&DO SWOJEGO POKOJU!/")
ds_map_add(global.text_data_en, "obj_npc_room_345", "\Ts %")
ds_map_add(global.text_data_en, "obj_npc_room_346", "* ok./")
ds_map_add(global.text_data_en, "obj_npc_room_347", "\TP %")
ds_map_add(global.text_data_en, "obj_npc_room_348", "I NIE PRZYNOŚ JEJ&SPOWROTEM!/")
ds_map_add(global.text_data_en, "obj_npc_room_349", "\Ts %")
ds_map_add(global.text_data_en, "obj_npc_room_350", "* ok./")
ds_map_add(global.text_data_en, "obj_npc_room_351", "\TP %")
ds_map_add(global.text_data_en, "obj_npc_room_352", "DALEJ TU LEŻY!/")
ds_map_add(global.text_data_en, "obj_npc_room_353", "\Ts %")
ds_map_add(global.text_data_en, "obj_npc_room_354", "* czy ty nie mówiłeś żeby nie&  przynosić jej spowrotem do&  pokoju?/")
ds_map_add(global.text_data_en, "obj_npc_room_355", "\TP %")
ds_map_add(global.text_data_en, "obj_npc_room_356", "ZAPOMNIJ JUŻ!/%%")
ds_map_add(global.text_data_en, "obj_npc_room_368", "* Co^1.&* Co^1?&* CO!?/")
ds_map_add(global.text_data_en, "obj_npc_room_369", "* To żyjątko./%%")
ds_map_add(global.text_data_en, "obj_npc_room_372", "* A więc^1, pomogłeś nam się&  uwolnić.../")
ds_map_add(global.text_data_en, "obj_npc_room_373", "* Chyba rzeczywiście zachowałem&  jak głupek wobec ciebie./%%")
ds_map_add(global.text_data_en, "obj_npc_room_377", "* Przepraszam^1, że zachowałem&  się w taki sposób./")
ds_map_add(global.text_data_en, "obj_npc_room_378", "* Naprawdę mi pomogłeś!!/%%")
ds_map_add(global.text_data_en, "obj_npc_room_384", "* (To ślimak.)/")
ds_map_add(global.text_data_en, "obj_npc_room_385", "* (Z jakiegoś powodu^1, nie możesz&  się powstrzymać od zastana-&  wiania się jak smakuje...)/%%")
ds_map_add(global.text_data_en, "obj_npc_room_388", "* (To ślimak.)/")
ds_map_add(global.text_data_en, "obj_npc_room_389", "* (Zastanawiasz się, czy Toriel&  widziała to miejsce.)/%%")
ds_map_add(global.text_data_en, "obj_npc_room_406", "* Mieliśmy sobie chillere kiedy&  nagle^1, setki puzzli włączyły&  się z nikąd./")
ds_map_add(global.text_data_en, "obj_npc_room_407", "* To ogromny problem..^1.&* Ale czad^1! Oni MUSZĄ odwołać&  przez to szkołę!/%%")
ds_map_add(global.text_data_en, "obj_npc_room_409", "* Chwila..^1.&* Auuuugh^1, są wakacje!/%%")
ds_map_add(global.text_data_en, "obj_npc_room_417", "* Hey^1, did you hear^1?&* The barrier's opened up!/")
ds_map_add(global.text_data_en, "obj_npc_room_418", "* Now school HAS to be&  cancelled^1, right!?/%%")
ds_map_add(global.text_data_en, "obj_npc_room_423", "* Why should we bother going&  to school^1, anyway...?/")
ds_map_add(global.text_data_en, "obj_npc_room_424", "* This world's got no future./%%")
ds_map_add(global.text_data_en, "obj_npc_room_430", "* Finally!&* Someone turned off that laser!/")
ds_map_add(global.text_data_en, "obj_npc_room_431", "* Now that we're free we can..^1.&* Well^1, uh^1, I guess we'll just&  keep standing here./%%")
ds_map_add(global.text_data_en, "obj_npc_room_434", "* Hm^1?&* Nice try^1, but your loitering&  technique still needs work./%%")
ds_map_add(global.text_data_en, "obj_npc_room_436", "* There will be lots of places&  to loiter on the surface^1,&  I bet./%%")
ds_map_add(global.text_data_en, "obj_npc_room_440", "* Loitering around..^1.&* What's the point?/%%")
ds_map_add(global.text_data_en, "obj_npc_room_451", "* The way to work is blocked^1,&  so I had time to catch&  Mettaton's show on my phone.../")
ds_map_add(global.text_data_en, "obj_npc_room_452", "* The special effects were&  amazing today^1!&* That human almost looked REAL!/%%")
ds_map_add(global.text_data_en, "obj_npc_room_454", "* Of course^1, an experienced&  viewer like me knows CGI&  when they see it.../%%")
ds_map_add(global.text_data_en, "obj_npc_room_458", "* The barrier's opened up^1, so&  we don't have to go to&  work today./")
ds_map_add(global.text_data_en, "obj_npc_room_459", "* I mean^1, sure^1, we're free^1,&  but it's the little&  things^1, you know?/%%")
ds_map_add(global.text_data_en, "obj_npc_room_464", "* That last episode had me&  really shaken.../")
ds_map_add(global.text_data_en, "obj_npc_room_465", "* But Mettaton's OK^1.&* Everyone knows it's just CGI!/%%")
ds_map_add(global.text_data_en, "obj_npc_room_470", "* Mettaton^1?&* Yeah^1, he's the most popular&  star in the underground!/")
ds_map_add(global.text_data_en, "obj_npc_room_471", "* His fan club probably has&  at least two..^1. no^1, THREE&  dozen members!/%%")
ds_map_add(global.text_data_en, "obj_npc_room_474", "* And that's not even counting&  me!/%%")
ds_map_add(global.text_data_en, "obj_npc_room_478", "* Today^1, we all started as&  co-workers.../")
ds_map_add(global.text_data_en, "obj_npc_room_479", "* Who knows what we'll be&  tomorrow?/%%")
ds_map_add(global.text_data_en, "obj_npc_room_484", "* What a heartbreaker./")
ds_map_add(global.text_data_en, "obj_npc_room_485", "* I bet his fanclub's almost&  doubled in size from that!/%%")
ds_map_add(global.text_data_en, "obj_npc_room_508", "* (There's a piece of cheese&  inside this computerized&  laser-safe.)/")
ds_map_add(global.text_data_en, "obj_npc_room_509", "* (The lasers have melted the&  edges of the cheese..^1.)&* (It's stuck to the table.)/%%")
ds_map_add(global.text_data_en, "obj_npc_room_513", "* (Seems like the mouse hacked&  the safe and took the&  cheese out.)/%%")
ds_map_add(global.text_data_en, "obj_npc_room_523", "* It's so nice to&  have you over!/")
ds_map_add(global.text_data_en, "obj_npc_room_524", "* Why not take a&  seat at the&  table?/%%")
ds_map_add(global.text_data_en, "obj_npc_room_527", "* Sit at the freakin'&  table^1, you little&  nerd./%%")
ds_map_add(global.text_data_en, "obj_npc_room_534", "* I..^1. I..^1. I ended up buying a&  donut.../")
ds_map_add(global.text_data_en, "obj_npc_room_535", "* I..^1. I..^1. I didn't want to^1, but&  that girl..^1. even though I told&  her no^1, she.../")
ds_map_add(global.text_data_en, "obj_npc_room_536", "* ... kept staring at me in this&  creepy way and licking her&  lips./")
ds_map_add(global.text_data_en, "obj_npc_room_537", "* N..^1. now I'm outta cash./%%")
ds_map_add(global.text_data_en, "obj_npc_room_540", "* Maybe I can sell it online&  and double my money back.../%%")
ds_map_add(global.text_data_en, "obj_npc_room_545", "* On the surface^1, I won't&  buy any donuts from&  spiders./")
ds_map_add(global.text_data_en, "obj_npc_room_546", "* That's my resolution./%%")
ds_map_add(global.text_data_en, "obj_npc_room_551", "* .../%%")
ds_map_add(global.text_data_en, "obj_npc_room_568", "* (It's just a regular flower.)/%%")
ds_map_add(global.text_data_en, "obj_npc_room_580", "* .../%%")
ds_map_add(global.text_data_en, "obj_npc_room_582", "* ... what?/%%")
ds_map_add(global.text_data_en, "obj_npc_room_588", "* (It's an empty dog food&  bowl.)/%%")
ds_map_add(global.text_data_en, "obj_npc_room_593", "* (It's a treadmill.^1)&* (There's a message attached.)/")
ds_map_add(global.text_data_en, "obj_npc_room_594", "* " + '"' + "the truth is that you got&  owned^1, nerd......" + '"' + "/%%")
ds_map_add(global.text_data_en, "obj_npc_room_599", "* (... he seems happy.)/%%")
ds_map_add(global.text_data_en, "obj_npc_room_604", "* Sn..^1. ow..^1. y.../%%")
ds_map_add(global.text_data_en, "obj_npc_room_615", "\E0* There you are^1,&  Frisk-darling./")
ds_map_add(global.text_data_en, "obj_npc_room_616", "\E8* Feast your eyes^1!&* Dr. Alphys completed&  my wonderful new body./")
ds_map_add(global.text_data_en, "obj_npc_room_617", "\E7* Oooh^1!&* And did you hear^1?&* The barrier's OPEN!/")
ds_map_add(global.text_data_en, "obj_npc_room_618", "\E4* I can't wait to see&  the sun.../")
ds_map_add(global.text_data_en, "obj_npc_room_619", "\E5* ... the greatest&  spotlight of all!!/")
ds_map_add(global.text_data_en, "obj_npc_room_620", "\E9* Oh yes^1.&* I suppose I should thank&  you^1, too^1, darling./")
ds_map_add(global.text_data_en, "obj_npc_room_621", "\E2* Before fighting you^1,&  I had.../")
ds_map_add(global.text_data_en, "obj_npc_room_622", "\E4* Forgotten how fun it&  was to perform with&  others./")
ds_map_add(global.text_data_en, "obj_npc_room_623", "\E6* So I've been searching&  for HOT TALENTS to fill&  up my upcoming troupe./")
ds_map_add(global.text_data_en, "obj_npc_room_624", "\E0* So far^1, Shyren's agreed&  to be my back-up singer./")
ds_map_add(global.text_data_en, "obj_npc_room_625", "\E0* And Bl..^1.&* Napstablook^1, here^1, will&  be my sound mixer!/")
ds_map_add(global.text_data_en, "obj_npc_room_626", "\E2* The three of us&  performing together.../")
ds_map_add(global.text_data_en, "obj_npc_room_627", "\E4* It really feels overdue^1,&  doesn't it?/%%")
ds_map_add(global.text_data_en, "obj_npc_room_631", "\E0* Frisk^1, darling^1.&* Can you help me with&  something?/")
ds_map_add(global.text_data_en, "obj_npc_room_632", "\E2* What kind of merchandise&  do you think humans&  would want to buy...?/")
ds_map_add(global.text_data_en, "obj_npc_room_633", "\E1* I've thought of a few&  ideas so far./")
ds_map_add(global.text_data_en, "obj_npc_room_634", "\E6* Buttons (with my face)&* Stickers (with my face)&* CDs (with my face)/")
ds_map_add(global.text_data_en, "obj_npc_room_635", "\E7* Posters (with my face)&* T-shirts (with my face)&* Underwear (with my face)/")
ds_map_add(global.text_data_en, "obj_npc_room_636", "\E9* ... and plush dolls of&  TORIEL./")
ds_map_add(global.text_data_en, "obj_npc_room_638", "\E8* But, you know^1.&* With my face instead&  of hers./")
ds_map_add(global.text_data_en, "obj_npc_room_640", "\E0* So what do you think?/")
ds_map_add(global.text_data_en, "obj_npc_room_641", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_npc_room_642", "* (...)/")
ds_map_add(global.text_data_en, "obj_npc_room_644", "* (A yes or no prompt was not&  provided.)/")
ds_map_add(global.text_data_en, "obj_npc_room_645", "\TS \F8 \TM %")
ds_map_add(global.text_data_en, "obj_npc_room_646", "\E9* Fabulous^1!&* I completely agree!/%%")
ds_map_add(global.text_data_en, "obj_npc_room_651", "\E2* Oh^1, Frisk^1.&* Why don't you go see&  how Alphys is doing?/")
ds_map_add(global.text_data_en, "obj_npc_room_652", "\E1* Since the flash of light&  she's been working hard&  to set everything right./")
ds_map_add(global.text_data_en, "obj_npc_room_653", "\E0* Ha-Ha^1.&* About time^1, huh?/%%")
ds_map_add(global.text_data_en, "obj_npc_room_662", "* (By barking with text-to-speech&  on^1, the dog accidentally&  programmed a whole game.)/")
ds_map_add(global.text_data_en, "obj_npc_room_663", "* (Hmmm..^1. seems fine.)/%%")
ds_map_add(global.text_data_en, "obj_npc_room_669", "* Blub blub..^1.&* You'll have to reserve a&  table to eat here./")
ds_map_add(global.text_data_en, "obj_npc_room_670", "* You'll also need to reserve&  your chair^1, your silverware^1,&  your food^1, your.../%%")
ds_map_add(global.text_data_en, "obj_npc_room_674", "* Blub blub..^1.&* Now we can live life&  without reservations./%%")
ds_map_add(global.text_data_en, "obj_npc_room_679", "* Blub blub..^1.&* Mettaton isn't here to press&  his face into the steaks./")
ds_map_add(global.text_data_en, "obj_npc_room_680", "* He told me that if he ever&  disappeared^1, we could use&  my face instead.../")
ds_map_add(global.text_data_en, "obj_npc_room_681", "* But^1, I'm nervous^1.&* What if my face doesn't&  taste very good...?/%%")
ds_map_add(global.text_data_en, "obj_npc_room_686", "* As I came in^1, I realized I&  forgot to make a reservation./")
ds_map_add(global.text_data_en, "obj_npc_room_687", "* But I didn't want to look&  like I messed up^1.&* So I kept walkin' in anyway./")
ds_map_add(global.text_data_en, "obj_npc_room_688", "* Now I'm just..^1. kinda..^1.&* Consuming dew off this ficus./%%")
ds_map_add(global.text_data_en, "obj_npc_room_692", "* Oh^1, we're all free?/")
ds_map_add(global.text_data_en, "obj_npc_room_693", "* Oh..^1.&* Guess I can..^1.&* Stop lickin' this ficus./")
ds_map_add(global.text_data_en, "obj_npc_room_694", "* ... but I don't want to look&  like I messed up^1, so&  I'll keep going.../%%")
ds_map_add(global.text_data_en, "obj_npc_room_699", "* What would Mettaton think if&  he saw me licking this&  plant of his...?/")
ds_map_add(global.text_data_en, "obj_npc_room_700", "* Eh..^1. who cares./%%")
ds_map_add(global.text_data_en, "obj_npc_room_709", "* I work at the CORE^1.&* The inside is a maze made of&  swappable parts.../")
ds_map_add(global.text_data_en, "obj_npc_room_710", "* That means we can shuffle the&  layout at will./")
ds_map_add(global.text_data_en, "obj_npc_room_711", "* Boy^1, was today a FUN day^1!&* I sure love PUZZLE!!!/%%")
ds_map_add(global.text_data_en, "obj_npc_room_715", "* So^1, if we're leaving^1, will&  my job...?/")
ds_map_add(global.text_data_en, "obj_npc_room_716", "* Ugh^1, and I just got a raise^1!&* Well^1, guess every apple has&  its CORE^1, heheh./%%")
ds_map_add(global.text_data_en, "obj_npc_room_721", "* Today^1, we received the&  promise of a lot of money&  from a strange source./")
ds_map_add(global.text_data_en, "obj_npc_room_722", "* It may not be kosher^1, but..^1.&* Whew^1! I love puzzle!/%%")
ds_map_add(global.text_data_en, "obj_npc_room_728", "* Originally^1, we dug mazes&  with puzzles in order to&  foil human attacks./")
ds_map_add(global.text_data_en, "obj_npc_room_729", "* But now^1, building things&  winding and confusing...^1.&* It's some awful tradition./")
ds_map_add(global.text_data_en, "obj_npc_room_730", "* You can't go (ugh) two feet&  without being up to your&  armpits in puzzles./%%")
ds_map_add(global.text_data_en, "obj_npc_room_734", "* The surface world..^1.&* Really!/")
ds_map_add(global.text_data_en, "obj_npc_room_735", "* Maybe I'll be able to&  go two feet without running&  into a puzzle./%%")
ds_map_add(global.text_data_en, "obj_npc_room_740", "* One thing I can say.../")
ds_map_add(global.text_data_en, "obj_npc_room_741", "* I respect Mettaton for not&  putting any puzzles here./")
ds_map_add(global.text_data_en, "obj_npc_room_742", "* At another hotel^1, I had&  to find 12 magic keys just to&  unlock the shower./%%")
ds_map_add(global.text_data_en, "obj_npc_room_751", "* Mettaton looked really..^1.&* Really cool in that dress./")
ds_map_add(global.text_data_en, "obj_npc_room_752", "* It sort of makes me feel like&  I could wear one^1, too!/%%")
ds_map_add(global.text_data_en, "obj_npc_room_756", "* Mettaton..^1.!&* He recognized my voice from&  when I called in^1, and.../")
ds_map_add(global.text_data_en, "obj_npc_room_757", "* He..^1. he gave me his dress^1!&* I'm so...^1!&* Ha ha ha!/%%")
ds_map_add(global.text_data_en, "obj_npc_room_762", "* Please don't talk to me^1.&* I am feeling discouraged&  about something./%%")
ds_map_add(global.text_data_en, "obj_npc_room_769", "* Welcome to MTT Resort - &* Hotland's biggest apartment-&  building-turned-hotel!/")
ds_map_add(global.text_data_en, "obj_npc_room_770", "* Whether you're here for a night&  or still live here^1, MTT Resort&  prides itself on a great stay!/")
ds_map_add(global.text_data_en, "obj_npc_room_771", "* Just passing through...^1? Nice^1!&* MTT Resort prides itself on&  being passed through!/%%")
ds_map_add(global.text_data_en, "obj_npc_room_775", "* Sorry - the resort's shutting&  down./")
ds_map_add(global.text_data_en, "obj_npc_room_776", "* But I think you'll find it's&  still great to pass through!/%%")
ds_map_add(global.text_data_en, "obj_npc_room_781", "* Welcome to MTT Resort^1!&* Have you seen Mettaton?/")
ds_map_add(global.text_data_en, "obj_npc_room_782", "* He hasn't come by lately^1.&* I have a lot of respect for&  that man./")
ds_map_add(global.text_data_en, "obj_npc_room_783", "* I had trouble getting a job&  because I am so pointy and&  angular./")
ds_map_add(global.text_data_en, "obj_npc_room_784", "* But^1, being a rectangle^1, he&  understood my struggles./%%")
ds_map_add(global.text_data_en, "obj_npc_room_792", "* I love hot dogs!/")
ds_map_add(global.text_data_en, "obj_npc_room_793", "* Hey..^1.&* Isn't it weird there's&  SNOW on that guy's roof?/")
ds_map_add(global.text_data_en, "obj_npc_room_794", "* ... guess he's just too lazy&  to clean it off./%%")
ds_map_add(global.text_data_en, "obj_npc_room_798", "* I love hot dogs!/")
ds_map_add(global.text_data_en, "obj_npc_room_799", "* But the hot dog guy left..^1.&* Even though all of his&  stuff is still here./")
ds_map_add(global.text_data_en, "obj_npc_room_800", "* ... guess he's just too lazy&  to clean it away./%%")
ds_map_add(global.text_data_en, "obj_npc_room_805", "* I wanted another hot dog^1.&* But the hot dog guy never&  came back./")
ds_map_add(global.text_data_en, "obj_npc_room_806", "* Besides that^1?&* Today was fine./")
ds_map_add(global.text_data_en, "obj_npc_room_807", "* Count your blessings^1.&* Even if you don't get a&  second hot dog./%%")
ds_map_add(global.text_data_en, "obj_npc_room_812", "* Toasty bun!/%%")
ds_map_add(global.text_data_en, "obj_npc_room_817", "* (Jest ugotowane na twardo.)/%%")
ds_map_add(global.text_data_en, "obj_onionsan_event_181", "* Heja..^1. &* Zauważyłem^1, że jesteś..^1.&* Tutaj.../")
ds_map_add(global.text_data_en, "obj_onionsan_event_182", "\M1* Jestem Onionsan^1!&* Onionsan^1, słyszysz!/%%")
ds_map_add(global.text_data_en, "obj_onionsan_event_211", "\M1* Odwiedzasz Waterfall^1, huh^1!&* Jest tu świetnie^1, huh^1!&* Kochasz tu^1, huh!/")
ds_map_add(global.text_data_en, "obj_onionsan_event_212", "\M0* Ta^1!&* Ja też^1!&* To moje ulubione miejsce./%%")
ds_map_add(global.text_data_en, "obj_onionsan_event_224", "\M3* Chociaż^1, ta woda się robi&  taka ciemna..^1./")
ds_map_add(global.text_data_en, "obj_onionsan_event_225", "* Ja^1, muszę tu siedzieć cały&  czas^1, ale.../")
ds_map_add(global.text_data_en, "obj_onionsan_event_226", "\M1* He^1-hej^1! Nie szkodzi^1!&* Lepsze to niż przeprowadzka&  do miasta!/")
ds_map_add(global.text_data_en, "obj_onionsan_event_227", "* I życia w ciasnym akwarium!/")
ds_map_add(global.text_data_en, "obj_onionsan_event_228", "\M2* Tak jak wszyscy moi&  przyjaciele!/%%")
ds_map_add(global.text_data_en, "obj_onionsan_event_241", "\M3* A akwarium i tak jest pełne^1,&  więc^1, nawet gdybym&  chciał^1, to ja.../")
ds_map_add(global.text_data_en, "obj_onionsan_event_242", "\M1* Ale nie szkodzi^1, słyszysz!&* Undyne wkrótce to wszystko&  naprawi^1, słyszysz!/")
ds_map_add(global.text_data_en, "obj_onionsan_event_243", "* Wydostanę się z tąd i będę&  mieszkał w oceanie^1!&* Słyszysz!/%%")
ds_map_add(global.text_data_en, "obj_onionsan_event_256", "\M2* Hej..^1.&* To koniec tego pomieszczenia./")
ds_map_add(global.text_data_en, "obj_onionsan_event_257", "* Widzimy się później^1!&* Miłego pobytu!/")
ds_map_add(global.text_data_en, "obj_onionsan_event_258", "* W Waterfalllllllllllllllll&  lllllllllllll/%%")
ds_map_add(global.text_data_en, "obj_onionsan_event_312", "\M1* Oh^1!&* Słyszałeś!!!/")
ds_map_add(global.text_data_en, "obj_onionsan_event_313", "\M1* .../")
ds_map_add(global.text_data_en, "obj_onionsan_event_314", "\M1* Nie mam niczego..^1.&* Do gadania.../%%")
ds_map_add(global.text_data_en, "obj_onionsan_event_317", "\M2* Zastanawiałem się kiedy my&  wszyscy będziemy wolni./")
ds_map_add(global.text_data_en, "obj_onionsan_event_318", "\M3* P-ponieważ..^1. gdybyśmy byli..^1.&* Skąd miałbym wiedzieć?/")
ds_map_add(global.text_data_en, "obj_onionsan_event_319", "\M1* Cóż^1, będę miał moje macki&  na tobie^1!&* Słyszysz!/")
ds_map_add(global.text_data_en, "obj_onionsan_event_320", "* Kiedy tylko się dowiem^1, będę&  pierwszy^1, który ci powie^1!&* Słyszysz!!/%%")
ds_map_add(global.text_data_en, "obj_onionsan_event_337", "\M0* Już lada chwila!/%%")
ds_map_add(global.text_data_en, "obj_operatingtable_64", "* (It's some kind of operating&  table.)/")
ds_map_add(global.text_data_en, "obj_operatingtable_65", "* (It's sticky...)/%%")
ds_map_add(global.text_data_en, "obj_otherphonecall_100", "* (Dzyn... dzyn...)/%%")
ds_map_add(global.text_data_en, "obj_otherphonecall_115", "* U-uhhh..^1.&* (Oh my god^1, help...)/")
ds_map_add(global.text_data_en, "obj_otherphonecall_116", "* I'd like to order a..^1.&* Um..^1.&* A pizza...?/")
ds_map_add(global.text_data_en, "obj_otherphonecall_117", "* With^1, uhh..^1.&* The toppings are^1, uh.../")
ds_map_add(global.text_data_en, "obj_otherphonecall_118", "* I have them copied^1, I'll&  just paste them to you./")
ds_map_add(global.text_data_en, "obj_otherphonecall_119", "\T0 %")
ds_map_add(global.text_data_en, "obj_otherphonecall_120", "* (Your phone is too old to&  receive texts...)/")
ds_map_add(global.text_data_en, "obj_otherphonecall_121", "* (It reads out loud^1, character-&  by-character^1, an ASCII art&  of an anime catgirl.)/")
ds_map_add(global.text_data_en, "obj_otherphonecall_122", "\TA* .../%%")
ds_map_add(global.text_data_en, "obj_otherphonecall_133", "* (Klik...)/%%")
ds_map_add(global.text_data_en, "obj_outsideworld_event_158", "\E0* welp./")
ds_map_add(global.text_data_en, "obj_outsideworld_event_159", "\E1* someone's gotta keep&  him from getting&  into trouble./")
ds_map_add(global.text_data_en, "obj_outsideworld_event_160", "\E2* see you guys./%%")
ds_map_add(global.text_data_en, "obj_outsideworld_event_183", "\E0* Man^1, do I have&  to do EVERYTHING?/")
ds_map_add(global.text_data_en, "obj_outsideworld_event_184", "\E6* Papyrus^1, wait!!!/%%")
ds_map_add(global.text_data_en, "obj_outsideworld_event_219", "\E0* Hey^1, Undyne!^1!&* Wait up!!/%%")
ds_map_add(global.text_data_en, "obj_outsideworld_event_255", "* Whoops./%%")
ds_map_add(global.text_data_en, "obj_outsideworld_event_273", "* Uh^1, should I do&  something?/")
ds_map_add(global.text_data_en, "obj_outsideworld_event_275", "* .../")
ds_map_add(global.text_data_en, "obj_outsideworld_event_277", "* Well^1, gotta go!/%%")
ds_map_add(global.text_data_en, "obj_outsideworld_event_309", "* It seems that everyone&  is quite eager to&  set off./%%")
ds_map_add(global.text_data_en, "obj_outsideworld_event_344", "* Co?/")
ds_map_add(global.text_data_en, "obj_outsideworld_event_345", "\E1* Frisk.../")
ds_map_add(global.text_data_en, "obj_outsideworld_event_346", "\E0* You really are a&  funny child./")
ds_map_add(global.text_data_en, "obj_outsideworld_event_347", "\E1* If you had said that&  earlier^1, none of this&  would have happened./")
ds_map_add(global.text_data_en, "obj_outsideworld_event_348", "\E0* It is a good thing&  you took so long to&  change your mind./")
ds_map_add(global.text_data_en, "obj_outsideworld_event_349", "* Hee hee hee./")
ds_map_add(global.text_data_en, "obj_outsideworld_event_350", "* Well..^1.&* I suppose./")
ds_map_add(global.text_data_en, "obj_outsideworld_event_351", "* If you really do&  not have any other&  place to go.../")
ds_map_add(global.text_data_en, "obj_outsideworld_event_352", "* I will do my best to&  take care of you^1, for&  as long as you need./")
ds_map_add(global.text_data_en, "obj_outsideworld_event_353", "* All right?/")
ds_map_add(global.text_data_en, "obj_outsideworld_event_354", "* Now^1, come along./%%")
ds_map_add(global.text_data_en, "obj_outsideworld_event_372", "* Everyone is waiting&  for us!/%%")
ds_map_add(global.text_data_en, "obj_outsideworld_event_413", "\E1* Ah./")
ds_map_add(global.text_data_en, "obj_outsideworld_event_414", "\E0* ... I see./")
ds_map_add(global.text_data_en, "obj_outsideworld_event_415", "\E1* .../")
ds_map_add(global.text_data_en, "obj_outsideworld_event_416", "\E0* Well^1, I hope that&  I am not keeping&  you./%%")
ds_map_add(global.text_data_en, "obj_outsideworld_event_478", "* Frisk./")
ds_map_add(global.text_data_en, "obj_outsideworld_event_479", "* " + '"' + "See you around." + '"' + "/%%")
ds_map_add(global.text_data_en, "obj_papbookshelf_63", "TA KSIĄŻKA JEST&JEDNĄ Z MOICH&ULUBIONYCH./")
ds_map_add(global.text_data_en, "obj_papbookshelf_64", '"' + "ZAAWANSOWANE&BUDOWANIE PUZZLI&DLA ANALITYKA." + '"' + "/")
ds_map_add(global.text_data_en, "obj_papbookshelf_66", "TA KSIĄŻKA OBOK&TEŻ NALEŻY DO&MOICH FAWORYTÓW./")
ds_map_add(global.text_data_en, "obj_papbookshelf_67", '"' + "A-KU-KU Z&PLUSZOWYM&KRÓLICZKIEM." + '"' + "/")
ds_map_add(global.text_data_en, "obj_papbookshelf_68", "\E3ZAKOŃCZENIE&ZAWSZE MNIE&ZASKAKUJE./%%")
ds_map_add(global.text_data_en, "obj_papbookshelf_71", "* (Kompleksowe instrukcje&  obsługi i książki dla dzieci.)/%%")
ds_map_add(global.text_data_en, "obj_papbookshelf_76", "* (Ta pułka jest pełna&  trudnych poradników do&  kreacji puzzli.)/")
ds_map_add(global.text_data_en, "obj_papbookshelf_77", "* (I książek dla dzieci)/%%")
ds_map_add(global.text_data_en, "obj_papcheckpoint_98", "* Jest jakaś narracja na&  tym kartonowym pudle./")
ds_map_add(global.text_data_en, "obj_papcheckpoint_99", "\TP %")
ds_map_add(global.text_data_en, "obj_papcheckpoint_100", "PRZED TOBĄ WIDZISZ&DOBRZE-ZBUDOWANĄ &STACYJKĘ OBSERWACYJNĄ./")
ds_map_add(global.text_data_en, "obj_papcheckpoint_101", "KTÓŻ MÓGŁBY JĄ&ZBUDOWAĆ^1, SIĘ&ZASTANAWIASZ.../")
ds_map_add(global.text_data_en, "obj_papcheckpoint_102", "ZAŁOŻĘ SIĘ, ŻE&TO TEN POPULARNY&KRÓLEWSKI RYCERZ!/")
ds_map_add(global.text_data_en, "obj_papcheckpoint_103", "(NOTA: JESZCZE NIE&TAKI POPULARNY&KRÓLEWSKI RYCERZ^1.)/%%")
ds_map_add(global.text_data_en, "obj_papcheckpoint_107", "(NOTA: JESZCZE NIE&TAKI POPULARNY&KRÓLEWSKI RYCERZ^1.)/")
ds_map_add(global.text_data_en, "obj_papcheckpoint_108", "(UPDATE: CZY JESTEM&JUŻ POPULARNYM&KRÓLEWSKIM RYCERZEM???)/%%")
ds_map_add(global.text_data_en, "obj_papcheckpoint_112", "* Te instrukcje są napisane&  w niewyraźy sposób./%%")
ds_map_add(global.text_data_en, "obj_papcomputer_63", "INTERNET^1!&JESTEM TAM CAŁKIEM&POPULARNY./")
ds_map_add(global.text_data_en, "obj_papcomputer_64", "JESZCZE TYLKO&DZIESIĄTKA.../")
ds_map_add(global.text_data_en, "obj_papcomputer_65", "A BĘDĘ MIAŁ&DWUCYFROWY&LICZNIK!/")
ds_map_add(global.text_data_en, "obj_papcomputer_66", "\E3OCZYWIŚCIE^1, SŁAWA&PRZYCHODZI Z&PEWNĄ CENĄ./")
ds_map_add(global.text_data_en, "obj_papcomputer_67", "\E1JAKIŚ ZAZDROŚNIAK&PODSZYWA SIĘ&DO MNIE./")
ds_map_add(global.text_data_en, "obj_papcomputer_68", "ZAWSZE MI WYSYŁA&KRINDŻOWE ŻARTY W&DZIWNEJ CZCIONCE.../%%/")
ds_map_add(global.text_data_en, "obj_papcomputer_73", "* (W wyszukiwarce internetowej&  jest otwarty instagram.)/%%")
ds_map_add(global.text_data_en, "obj_papcomputer_79", "* (W wyszukiwarce internetowej&  jest otwarty instagram.)/%%")
ds_map_add(global.text_data_en, "obj_papcomputer_84", "* (W wyszukiwarce internetowej&  jest otwarte forum muzyczne.)/%%")
ds_map_add(global.text_data_en, "obj_papcomputer_90", "* (Wygląda na to^1, że ten pies&  wstawia online wiele złych&  postów.)/")
ds_map_add(global.text_data_en, "obj_papcomputer_91", "* (Narracja ekranowa&  jest włączona.)/")
ds_map_add(global.text_data_en, "obj_papcomputer_92", "* (Wygląda na to^1, że ten pies&  szczeka i to tłumaczy na te&  złe posty.)/")
ds_map_add(global.text_data_en, "obj_papcomputer_93", "* (Chyba nie za bardzo wie&  o czym mówi.)/")
ds_map_add(global.text_data_en, "obj_papcomputer_94", "* (Wygląda na to^1, że większość&  lamusowych postów on-line^1, to&  tak naprawdę ten pies.)/")
ds_map_add(global.text_data_en, "obj_papcomputer_95", "* (Myśląc o tym...^1)&* (Czujesz ulgę.)/%%")
ds_map_add(global.text_data_en, "obj_papcouch_62", "* (Dotykasz kanapy.^1)&* (Wydaje z siebie&  dzyndzący dźwięk.)/")
ds_map_add(global.text_data_en, "obj_papcouch_63", "* (Znajdujesz wiele walących się&  monet w kanapie...)/")
ds_map_add(global.text_data_en, "obj_papcouch_64", "* (Dostałeś 20G.)/%%")
ds_map_add(global.text_data_en, "obj_papcouch_70", "* (To przesiąknięta stara&  kanapa.)/%%")
ds_map_add(global.text_data_en, "obj_papdate_150", "        RANDKA^1  START!^5 %%")
ds_map_add(global.text_data_en, "obj_papdate_151", "        SPOTKANIE^1 START!^5 %%")
ds_map_add(global.text_data_en, "obj_papdate_166", "OTO JESTEŚMY!^1!&NA NASZEJ RANDCE!!/")
ds_map_add(global.text_data_en, "obj_papdate_167", "OTO JESTEŚMY!^1!&NA NASZYM&SPOTKANIU!!/")
ds_map_add(global.text_data_en, "obj_papdate_169", "\E3W SUMIE TO NIGDY&TEGO JESZCZE NIE&ROBIŁEM./")
ds_map_add(global.text_data_en, "obj_papdate_170", "\E0ALE NIE&PRZEJMUJ SIĘ!!!/")
