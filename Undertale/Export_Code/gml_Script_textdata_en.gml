ds_map_add(global.text_data_en, "obj_garbagepile_72", "* (Jest kupka żółtych&  imion w śmieciach.)/%%")
ds_map_add(global.text_data_en, "obj_garbagepile_73", "* (Śmieci.)/%%")
ds_map_add(global.text_data_en, "obj_garbagepile_74", "* (Stos śmieci.)/%%")
ds_map_add(global.text_data_en, "obj_garbagepile_75", "* (Twoje nieustające&  śmiecenie nie pokazuje&  oznak wdzięczności.)/%%")
ds_map_add(global.text_data_en, "obj_garbagepile_76", "* (Złom.)/%%")
ds_map_add(global.text_data_en, "obj_gaster_follower_a_94", "* Alphys może pracować szybciej^1.&* Ale poprzedni Królewski&  Naukowiec^1, Doktor W.D. Gaster?/")
ds_map_add(global.text_data_en, "obj_gaster_follower_a_95", "* Jednego dnia^1, on zniknął&  bez śladu./")
ds_map_add(global.text_data_en, "obj_gaster_follower_a_96", "* Mówią, że on roztrzaskał się&  w czasie i przestrzeni./")
ds_map_add(global.text_data_en, "obj_gaster_follower_a_97", "* Ha ha..^1.&* Jak mogę to mówić&  bez strachu?/")
ds_map_add(global.text_data_en, "obj_gaster_follower_a_98", "* Trzymam kawałek jego&  dosłownie tutaj./%%")
ds_map_add(global.text_data_en, "obj_gaster_follower_b_94", "* Ma sens dlaczego zajęło&  ASGORE'owi tyle czasu aby&  zatrudnić nowego Naukowca./")
ds_map_add(global.text_data_en, "obj_gaster_follower_b_95", "* W końcu^1, poprzedni..^1.&* Dr. Gaster^1.&* Co za autorytet!/")
ds_map_add(global.text_data_en, "obj_gaster_follower_b_96", "* Mówią że on stworzył RDZEŃ./")
ds_map_add(global.text_data_en, "obj_gaster_follower_b_97", "* Jednak^1, jego życie..^1.&* Zostało szybko zakończone./")
ds_map_add(global.text_data_en, "obj_gaster_follower_b_98", "* Jednego dnia^1, on wpadł do&  jego dzieła^1, i.../%%")
ds_map_add(global.text_data_en, "obj_gaster_follower_b_102", "* Czy Alphys skończy w&  ten sam sposób?/%%")
ds_map_add(global.text_data_en, "obj_gaster_follower_c_95", "* Rozumiem dlaczego ASGORE&  czekał tak długo aby zatrudnić&  nowego Królewskiego Naukowca./")
ds_map_add(global.text_data_en, "obj_gaster_follower_c_96", "* Poprzedni..^1.&* Dr. Gaster./")
ds_map_add(global.text_data_en, "obj_gaster_follower_c_97", "* Jego znakomitość&  była niezastąpiona./")
ds_map_add(global.text_data_en, "obj_gaster_follower_c_98", "* Jednak^1, jego życie..^1.&* Zostało szybko zakończone./")
ds_map_add(global.text_data_en, "obj_gaster_follower_c_99", "* Jednego dnia^1, jego&  eksperymenty zawiodły^1, i.../%%")
ds_map_add(global.text_data_en, "obj_gaster_follower_c_103", "* Cóż^1, nie powinienem&  plotkować./")
ds_map_add(global.text_data_en, "obj_gaster_follower_c_104", "* W końcu^1, to niemiłe&  rozmawiać o kimś kto&  nadsłuchuje za plecami./%%")
