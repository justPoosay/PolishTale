ds_map_add(global.text_data_en, "obj_mkid_battle_702", "Moje ciało..^1.&Czuję jak się&rozpada./")
ds_map_add(global.text_data_en, "obj_mkid_battle_703", "Jakbym lada chwila..^1.&Rozpadła się na&a milion kawałków./")
ds_map_add(global.text_data_en, "obj_mkid_battle_704", "Ale.../")
ds_map_add(global.text_data_en, "obj_mkid_battle_705", "Głęboko^1, głęboko&w mojej duszy./")
ds_map_add(global.text_data_en, "obj_mkid_battle_706", "Jest pieczenie&którego nie&mogę opisać./")
ds_map_add(global.text_data_en, "obj_mkid_battle_707", "\E6Uczucie pieczenia&które NIE pozwoli&mi umrzeć./")
ds_map_add(global.text_data_en, "obj_mkid_battle_708", "\E5To już nie chodzi&tylko o potwórów^1,&czyż nie?/")
ds_map_add(global.text_data_en, "obj_mkid_battle_709", "Jeśli przejdziesz&przeze mnie^1, ty.../")
ds_map_add(global.text_data_en, "obj_mkid_battle_710", "Ty zniszczysz ich&wszystkich^1, prawda?/")
ds_map_add(global.text_data_en, "obj_mkid_battle_711", "Potworów..^1.&Ludzi..^1.&Wszystkich i&wszystko.../")
ds_map_add(global.text_data_en, "obj_mkid_battle_712", "Wszystkich nadzieje^1.&Wszystkich marzenia^1.&wyeliminowane w&mgnieniu oka./")
