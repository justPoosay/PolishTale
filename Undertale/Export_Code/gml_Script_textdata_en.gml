ds_map_add(global.text_data_en, "obj_migosp_228", "OBEY&THE&OVERMIND&..")
ds_map_add(global.text_data_en, "obj_migosp_229", "LEGION!&WE&ARE&LEGION")
ds_map_add(global.text_data_en, "obj_migosp_230", "HEED&THE&SWARM")
ds_map_add(global.text_data_en, "obj_migosp_231", "IN&UNISON,&NOW")
ds_map_add(global.text_data_en, "obj_migosp_234", "I&DON'T&CARE.")
ds_map_add(global.text_data_en, "obj_migosp_239", "Bein' me&is the&best!")
ds_map_add(global.text_data_en, "obj_migosp_240", "La la~&Just be&yourself~")
