ds_map_add(global.text_data_en, "item_desc_0_0", "* Jeśli to czytasz,&  Sans jest gejem./%")
ds_map_add(global.text_data_en, "item_desc_1_0", "* " + '"' + "Cukierek Potwór" + '"' + " - Leczy 10 HP&* Ma specyficzny,^1 &  bezlukrecjowy smak./%")
ds_map_add(global.text_data_en, "item_desc_2_0", "* " + '"' + "Croquet Roll" + '"' + " - Heals 15 HP&* Fried dough traditionally&  served with a mallet./%")
ds_map_add(global.text_data_en, "item_desc_3_0", "* " + '"' + "Patyk" + '"' + " - Broń AT 0&* Jego szczekanie jest&  słabsze od szczękogryzu./%")
ds_map_add(global.text_data_en, "item_desc_4_0", "* " + '"' + "Bandaż" + '"' + " - Leczy 10 HP&* Już zostało użyte&  wiele razy./%")
ds_map_add(global.text_data_en, "item_desc_5_0", "* " + '"' + "Rock Candy" + '"' + " - Heals 1 HP&* Here is a recipe to make&  this at home:/")
ds_map_add(global.text_data_en, "item_desc_5_1", "* 1. Find a rock/%")
ds_map_add(global.text_data_en, "item_desc_6_0", "* " + '"' + "Pumpkin Rings" + '"' + " - Heals 8 HP&* A small pumpkin cooked&  like onion rings./%")
ds_map_add(global.text_data_en, "item_desc_7_0", "* " + '"' + "Pajęczy Pączek" + '"' + " - Leczy 12 HP&* Pączek wypełniony&  frużeliną z pająków./%")
ds_map_add(global.text_data_en, "item_desc_8_0", "* " + '"' + "Stoic Onion" + '"' + " - Heals 5 HP&* Even eating it raw^1, the&  tears just won't come./%")
ds_map_add(global.text_data_en, "item_desc_9_0", "* " + '"' + "Ghost Fruit" + '"' + " - Heals 16 HP&* If eaten^1, it will never&  pass to the other side./%")
ds_map_add(global.text_data_en, "item_desc_10_0", "* " + '"' + "Wywar z Pająków" + '"' + " - Leczy 24 HP&* Zrobione z całych pająków^1,&  nie tylko soku./%")
ds_map_add(global.text_data_en, "item_desc_11_0", "* " + '"' + "Ciasto Toffi" + '"' + " - Leczy CAŁE HP&* Cynamonowo-karmelowe&  ciasto^1, jeden kawałek./%")
ds_map_add(global.text_data_en, "item_desc_12_0", "* " + '"' + "Wybl. Wstążka" + '"' + " - Zbroja DF 3&* Jeśli jesteś słodki^1, potwory&  nie będą cię tak mocno uderzać./%")
ds_map_add(global.text_data_en, "item_desc_13_0", "* " + '"' + "Zabawkowy Nóż" + '"' + " - Broń AT 3&* Zrobiony z plastiku.&* Rzadkość w tych czasach./%")
ds_map_add(global.text_data_en, "item_desc_14_0", "* " + '"' + "Twarda Rękawica" + '"' + " - Broń AT 5&* Noszona skórzana róż. rękawica^1.&* Dla pięciopalcowych ludzi./%")
ds_map_add(global.text_data_en, "item_desc_15_0", "* " + '"' + "Męska Bandana" + '"' + " - Zbroja DF 7&* Jest trochę zużyta.&  Ma narysowany sześciopak./%")
ds_map_add(global.text_data_en, "item_desc_16_0", "* " + '"' + "Kawałek Bałwana" + '"' + " - Leczy 45 HP&* Proszę zabierz to poza&  granice naszego świata./%")
ds_map_add(global.text_data_en, "item_desc_17_0", "* " + '"' + "Fajne Lody" + '"' + " - Leczy 15 HP&* Zamiast nieśmiesznego żartu,^1&  papierek mówi coś miłego./%")
ds_map_add(global.text_data_en, "item_desc_18_0", "* " + '"' + "Psie Lody" + '"' + "&* Leczy 28 HP^1.&* Zrobione przez młode psiunki./%")
ds_map_add(global.text_data_en, "item_desc_19_0", "* " + '"' + "Dwulód" + '"' + " - Leczy 11 HP&* To dwupatykowy lód^1, więc&  możesz go zjeść dwa razy./%")
ds_map_add(global.text_data_en, "item_desc_20_0", "* " + '"' + "Jednolód" + '"' + " - Leczy 11 HP&* To POJEDYNCZY lód na patyku^1.&* Chwila^1, to są zwykłe lody.../%")
ds_map_add(global.text_data_en, "item_desc_21_0", "* " + '"' + "Cynam. Królik" + '"' + " - Leczy 22 HP&* Cynamonowa bułka w&  kształcie królika./%%")
ds_map_add(global.text_data_en, "item_desc_22_0", "* " + '"' + "Temmie Flakes" + '"' + " - Leczy 2 HP&* To tylko podarte kawałki&  kolorowego papieru budowlanego./%%")
ds_map_add(global.text_data_en, "item_desc_23_0", "* " + '"' + "Porzucony Kisz" + '"' + " Leczy 34 HP&* Psychologicznie zmaltretowany&  placek szpinakowo-jajkowy./%%" + '"')
ds_map_add(global.text_data_en, "item_desc_24_0", "* " + '"' + "Stare Tutu" + '"' + " - Zbroja DF 10&* W końcu^1, jakaś funkcjonalna&  zbroja./%%")
ds_map_add(global.text_data_en, "item_desc_25_0", "* " + '"' + "Baletki" + '"' + " - Brń AT 7&* Te zużyte buty wydają się&  niezwykle niebezpieczne./%%")
ds_map_add(global.text_data_en, "item_desc_26_0", "* " + '"' + "Karta Dziurk." + '"' + " - Item do Walki&* Użyj, by umocnić ataki&  w ciągu jednej walki./")
ds_map_add(global.text_data_en, "item_desc_26_1", "* Użyj poza walką, by&  spojrzeć na kartę./%%")
ds_map_add(global.text_data_en, "item_desc_27_0", "* " + '"' + "Annoying Dog" + '"' + " - Pieseł&* Mały biały pieseł^1.&* Jest w głębokim śnie.../%%")
ds_map_add(global.text_data_en, "item_desc_28_0", "* " + '"' + "Sałatka Pieseła" + '"' + " - Leczy ?? HP&* Przywraca HP.&* (Pudle Ochronne.)/%%")
