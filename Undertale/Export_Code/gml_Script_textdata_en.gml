ds_map_add(global.text_data_en, "obj_aaron_243", "No chodź,&ta woda&jest&ciepła")
ds_map_add(global.text_data_en, "obj_aaron_244", "Nie ma&potrzeby&na strój&kąpielowy")
ds_map_add(global.text_data_en, "obj_aaron_245", "Edu-&kacja?&Hobby?&Talent?")
ds_map_add(global.text_data_en, "obj_aaron_246", "Whew,&zaczy-&nam się&pocić")
ds_map_add(global.text_data_en, "obj_aaron_249", "Nie&podchodź&zbyt&blisko")
ds_map_add(global.text_data_en, "obj_aaron_250", "To jest&trochę&straszne")
ds_map_add(global.text_data_en, "obj_aaron_251", "Kocham&mięśnie")
ds_map_add(global.text_data_en, "obj_aaron_252", "Whew,&zaczy-&nam się&pocić")
ds_map_add(global.text_data_en, "obj_aaron_257", "Flagrant&error&; )")
ds_map_add(global.text_data_en, "obj_aaron_258", "Kontest&flexu?&OK, flexuj&bardziejj")
ds_map_add(global.text_data_en, "obj_aaron_259", "Super!!&Ale nie&prze-&gram ; )")
ds_map_add(global.text_data_en, "obj_aaron_264", "Ego,&huh?&; )")
ds_map_add(global.text_data_en, "obj_aaron_265", "Wow!&Zadzi-&orny!&Kocham")
ds_map_add(global.text_data_en, "obj_aaron_267", "Zmienisz&zaraz&zdanie")
ds_map_add(global.text_data_en, "obj_aaron_272", "ZBADAJ&ile&chcesz&; )")
ds_map_add(global.text_data_en, "obj_aaron_273", "... ; )")
ds_map_add(global.text_data_en, "obj_aaron_276", "Ha, spoko.&To mój&humor&; )")
ds_map_add(global.text_data_en, "obj_aaron_278", "Tylko my&dwojga,&huh?&; )")
ds_map_add(global.text_data_en, "obj_aaron_279", "Hej?&; )")
ds_map_add(global.text_data_en, "obj_aaron_282", "%%%")
ds_map_add(global.text_data_en, "obj_aaron_478", "* Aaron radośnie pluska cię&  wodą^1.&* Udajesz^1, że to znosisz.")
ds_map_add(global.text_data_en, "obj_aaron_479", "* Aaron rozgląda sę wokół^1,&  bojąc się czegoś.")
ds_map_add(global.text_data_en, "obj_aaron_480", "* Aaron poci się jak ryba^3.&* Dosłownie.")
ds_map_add(global.text_data_en, "obj_aaron_481", "* Aaron podziwia swoje własne&  mięśnie.")
ds_map_add(global.text_data_en, "obj_aaron_482", "* Pachnie jak podwodna&  stajnia.")
ds_map_add(global.text_data_en, "obj_aaron_483", "* Pachnie jak farma małży.")
ds_map_add(global.text_data_en, "obj_aaron_484", "* Aaron jest gotowy na twój&  następny flex.")
ds_map_add(global.text_data_en, "obj_aaron_486", "* Mięśnie Aarona komicznie&  opadają.")
ds_map_add(global.text_data_en, "obj_aaron_502", "* AARON - ATK 24 DEF 12&* Ten konik morski ma dużo&  HP (Horsepower)./")
ds_map_add(global.text_data_en, "obj_aaron_503", "* Wszytkie jego ataki są&  trudniejsze do unikania na&  dole pola (kontenera)./^")
ds_map_add(global.text_data_en, "obj_aaron_512", "* Powiedziałeś Aaronowi^1, żeby&  spadał ztąd./^")
ds_map_add(global.text_data_en, "obj_aaron_514", "* Powiedziałeś Aaronowi^1, żeby&  spadał ztąd.&* On przytakuje./^")
ds_map_add(global.text_data_en, "obj_aaron_524", "* Flexujesz się^1.&* Aaron flexuje 2x mocniej^1.&* ATAK wam obojga się podwyższa./^")
ds_map_add(global.text_data_en, "obj_aaron_525", "* Flexujesz się mocniej^1.&* Aaron flexuje 3x mocniej^1.&* ATAK wam obojga się podwyższa./^")
ds_map_add(global.text_data_en, "obj_aaron_526", "* Flexujesz się^1.&* Aaron flexuje zbyt mocno.../")
ds_map_add(global.text_data_en, "obj_aaron_527", "* Wyflexowywuje się z&  pomieszczenia!/^")
ds_map_add(global.text_data_en, "obj_aaronnpc_70", "* Jako że flexowałeś mi&  się^1, przemyślałem sobie&  wiele rzeczy ; )/")
ds_map_add(global.text_data_en, "obj_aaronnpc_71", "* Typu..^1.&* Flexowanie ; )/%%")
ds_map_add(global.text_data_en, "obj_aaronnpc_75", "* I flexowanie ; )/%%")
ds_map_add(global.text_data_en, "obj_aaronnpc_80", "* Przeszedłeś całą tą&  drogę^1, by zobaczyć&  jak się flexuję ; )/")
ds_map_add(global.text_data_en, "obj_aaronnpc_81", "* To naprawdę wiele&  świadczy o tobie ; )/%%")
ds_map_add(global.text_data_en, "obj_aaronnpc_86", "* B..^1. boję się... ; )/")
ds_map_add(global.text_data_en, "obj_aaronnpc_87", "* Duchy nie są&  prawdziwe^1, co nie?&* ; )/")
ds_map_add(global.text_data_en, "obj_aaronnpc_88", "* Co^1? Są prawdziwe^1?&* O nieeeeeee ; )/%%")
ds_map_add(global.text_data_en, "obj_aaronnpc_92", "* Najpierw duchy są&  prawdziwe^1, teraz anime ; )&* Moje koszmary są prawdziwe ; )/%%")
ds_map_add(global.text_data_en, "obj_actiontable_63", "AH^1, TAK^1, MOJE&FIGURKI./")
ds_map_add(global.text_data_en, "obj_actiontable_64", "ŚWIETNE NARZĘDZIE&DO OBMYŚLANIA&PLANU BITWY./")
ds_map_add(global.text_data_en, "obj_actiontable_66", "\E3SKĄD ICH&TYLE MAM?/")
ds_map_add(global.text_data_en, "obj_actiontable_67", "\E2CÓŻ^1, POWIEDZMY&ŻE SĄ OD.../")
ds_map_add(global.text_data_en, "obj_actiontable_68", "\E0PUCHATEGO^1, RADOS-&NEGO PANA KTÓRY&KOCHA ZASKAKIWAĆ./")
ds_map_add(global.text_data_en, "obj_actiontable_69", "TAK^1!!&ZGADZA SIĘ!/")
ds_map_add(global.text_data_en, "obj_actiontable_70", "ŚWIĘTY&MIKOŁAJ!!!!/%%")
ds_map_add(global.text_data_en, "obj_actiontable_72", "* (Figurki wielu seksownych&  robotów.)/%%")
ds_map_add(global.text_data_en, "obj_actiontable_76", "* (Figurki wielu seksownych&  robotów.)/%%")
ds_map_add(global.text_data_en, "obj_adate_125", "      RANDKOWANIE^1  STAR^5T^2.^2.^2.^3?%%")
ds_map_add(global.text_data_en, "obj_adate_142", "Uhhh^1, sorki^2!&Jeszcze się&ubieram!/%%")
ds_map_add(global.text_data_en, "obj_adate_170", "H-how do I look?/")
ds_map_add(global.text_data_en, "obj_adate_171", "My friend helped me&pick out this&dress./")
ds_map_add(global.text_data_en, "obj_adate_172", "\E1S\M0he's got a great&sense of.../")
ds_map_add(global.text_data_en, "obj_adate_173", "\E0Um^1, anyway^1!&Let's do this thing!/%%")
ds_map_add(global.text_data_en, "obj_adate_186", "        DATING^3  START^3.%%")
ds_map_add(global.text_data_en, "obj_adate_199", "H-h-hey^1, w-w-wait!/")
ds_map_add(global.text_data_en, "obj_adate_200", "Actually^1, we still&can't start the&date yet!!!/%%")
ds_map_add(global.text_data_en, "obj_adate_209", "        DATING..^1.  STOP^4?%%")
ds_map_add(global.text_data_en, "obj_adate_221", "Umm^1, I've gotta give&you items to raise&your affection&statistic^1, first!/")
ds_map_add(global.text_data_en, "obj_adate_222", "That'll increase the&chance of a successful&outcome to the&date!/")
ds_map_add(global.text_data_en, "obj_adate_223", "\E6Right...?/")
ds_map_add(global.text_data_en, "obj_adate_224", "\E0Anyway^1, d-don't worry^1!&I'm prepared!/")
ds_map_add(global.text_data_en, "obj_adate_225", "\E5I-I've been&stockpiling gifts&in anticipation&for a date like this!/")
ds_map_add(global.text_data_en, "obj_adate_226", "\E7F\M6-first^1, I've got.../")
ds_map_add(global.text_data_en, "obj_adate_227", "\E5Some metal armor&polish!/")
ds_map_add(global.text_data_en, "obj_adate_228", "\E3.../")
ds_map_add(global.text_data_en, "obj_adate_229", "\E6Um^1, maybe you can't&use that./")
ds_map_add(global.text_data_en, "obj_adate_230", "\E5But!!!/")
ds_map_add(global.text_data_en, "obj_adate_231", "I also brought some&waterproof cream for&your scales!/")
ds_map_add(global.text_data_en, "obj_adate_232", "\E3Your^1, uh..^1.&Scales.../")
ds_map_add(global.text_data_en, "obj_adate_233", "\E6Uh^1, well^1, how about.../")
ds_map_add(global.text_data_en, "obj_adate_234", "This magical spear&repair kit^1, that I.../")
ds_map_add(global.text_data_en, "obj_adate_235", "\E7Um.../")
ds_map_add(global.text_data_en, "obj_adate_236", "\E5Hey^1, let's forget&about the items!/")
ds_map_add(global.text_data_en, "obj_adate_237", "\E0L\M0et's just start&the date!/%%")
ds_map_add(global.text_data_en, "obj_adate_301", "        DATING!^1!  START!^3!%%")
ds_map_add(global.text_data_en, "obj_adate_314", "Yeah!!^1!&Let's^1, uh^1, date!/%%")
ds_map_add(global.text_data_en, "obj_adate_352", "... uh.../")
ds_map_add(global.text_data_en, "obj_adate_353", "\E4Do you..^3. like..^3.&Anime...^2?/*")
ds_map_add(global.text_data_en, "obj_adate_367", "                              &   Yes             No       &                            ")
ds_map_add(global.text_data_en, "obj_adate_391", "H-hey^1!&Me too!!/%%")
ds_map_add(global.text_data_en, "obj_adate_396", "Oh./%%")
ds_map_add(global.text_data_en, "obj_adate_414", "Hey^1!&Let's!^1!&Go somewhere!!!/")
ds_map_add(global.text_data_en, "obj_adate_415", "\E7But where's a good&place to go on&a date...?/")
ds_map_add(global.text_data_en, "obj_adate_416", "\E2.../")
ds_map_add(global.text_data_en, "obj_adate_417", "\E0I've got it!!!/")
ds_map_add(global.text_data_en, "obj_adate_418", "\E5Let's go to the&garbage dump!!!/%%")
ds_map_add(global.text_data_en, "obj_adate_476", "Here we are!/")
ds_map_add(global.text_data_en, "obj_adate_477", "This is where Undyne&and I come all&the time.../")
ds_map_add(global.text_data_en, "obj_adate_478", "\E1We find all sorts&of great stuff&here./")
ds_map_add(global.text_data_en, "obj_adate_479", "\E5Heh^1, she's&really.../")
ds_map_add(global.text_data_en, "obj_adate_480", "\E6Uh.../%%")
ds_map_add(global.text_data_en, "obj_adate_503", "Oh no./")
ds_map_add(global.text_data_en, "obj_adate_504", "\E9That's her over&there./")
ds_map_add(global.text_data_en, "obj_adate_505", "\M4I c-can't let her&see me on a date&with you!/")
ds_map_add(global.text_data_en, "obj_adate_506", "\E6Why...?/")
ds_map_add(global.text_data_en, "obj_adate_507", "\M0Because^1, uh..^1.&Well.../")
ds_map_add(global.text_data_en, "obj_adate_508", "\E9Oh no^1, here she&comes!!/%%")
ds_map_add(global.text_data_en, "obj_adate_556", " Hey!^1!& There you are!!/")
ds_map_add(global.text_data_en, "obj_adate_557", "\F2 I^1, uh^1, realized^1,& if you deliver that&  thing.../")
ds_map_add(global.text_data_en, "obj_adate_558", "\F3 It might be a bad& idea./")
ds_map_add(global.text_data_en, "obj_adate_559", "\F4 So I'm gonna do& it!!^1!& Give it to me!!!/")
ds_map_add(global.text_data_en, "obj_adate_560", "\F3 Huh!^1?& You don't have it!?/")
ds_map_add(global.text_data_en, "obj_adate_561", "\F4 Ngggaaahhh!!/")
ds_map_add(global.text_data_en, "obj_adate_562", " Have you at least& seen her!?/*")
ds_map_add(global.text_data_en, "obj_adate_576", "                              &   Yeah            Nope     &                            ")
ds_map_add(global.text_data_en, "obj_adate_602", " Yes?/")
ds_map_add(global.text_data_en, "obj_adate_603", "\F6 So she's somewhere& around here.../")
ds_map_add(global.text_data_en, "obj_adate_604", "\F0 Thanks^1.& I'll keep looking./%%")
ds_map_add(global.text_data_en, "obj_adate_609", " No???/")
ds_map_add(global.text_data_en, "obj_adate_610", " But she wasn't& at home.../")
ds_map_add(global.text_data_en, "obj_adate_611", "\F3 Where the heck& could she be!?/%%")
ds_map_add(global.text_data_en, "obj_adate_669", "\E2Oh my god.../")
ds_map_add(global.text_data_en, "obj_adate_670", "\E6W... well^1, I guess&it's obvious^1, huh?/")
ds_map_add(global.text_data_en, "obj_adate_671", "\E7I...^1 uh..^1.&I really like her./")
ds_map_add(global.text_data_en, "obj_adate_672", "\E9I mean^1, more than&I like other people!/")
ds_map_add(global.text_data_en, "obj_adate_673", "\E7I'm sorry./")
ds_map_add(global.text_data_en, "obj_adate_674", "\E6I j-just figured^1,&y-you know.../")
ds_map_add(global.text_data_en, "obj_adate_675", "\E7It'd be f-fun to&go on like^1, a cute^1,&kind of.../")
ds_map_add(global.text_data_en, "obj_adate_676", "\E6P\M3retend date with you^1?&T-to make you feel&better?/")
ds_map_add(global.text_data_en, "obj_adate_677", "\E7.../")
ds_map_add(global.text_data_en, "obj_adate_678", "\E6Well^1, it sounds even&worse when I put it&like that./")
ds_map_add(global.text_data_en, "obj_adate_679", "\E8I\M0'm sorry^1.&I messed up again./")
ds_map_add(global.text_data_en, "obj_adate_680", "\E7Undyne's the person I..^1.&Um..^1. really want to&go on a date with./")
ds_map_add(global.text_data_en, "obj_adate_681", "But, I mean..^1.&She's way out of&my league./")
ds_map_add(global.text_data_en, "obj_adate_682", "\E9N-not that you&aren't^1, um^1, cool!/")
ds_map_add(global.text_data_en, "obj_adate_683", "\E7B-but..^1. Undyne.../")
ds_map_add(global.text_data_en, "obj_adate_684", "She's so confident..^1.&And strong..^1.&And funny.../")
ds_map_add(global.text_data_en, "obj_adate_685", "\E8And I'm just a&nobody./")
ds_map_add(global.text_data_en, "obj_adate_686", "\M3A fraud./")
ds_map_add(global.text_data_en, "obj_adate_687", "I'm the royal&scientist^1, but.../")
ds_map_add(global.text_data_en, "obj_adate_688", "\M0All I've ever done&is hurt people./")
ds_map_add(global.text_data_en, "obj_adate_689", "\E7I've told her so&many lies^1, she thinks&I'm.../")
ds_map_add(global.text_data_en, "obj_adate_690", "\E6She thinks I'm a&lot cooler than I&actually am./")
ds_map_add(global.text_data_en, "obj_adate_691", "\E7If she gets close&to me^1, she'll.../")
ds_map_add(global.text_data_en, "obj_adate_692", "\E8She'll find out the&truth about me./")
ds_map_add(global.text_data_en, "obj_adate_693", "\E7.../")
ds_map_add(global.text_data_en, "obj_adate_694", "\E7What should I do?/*")
ds_map_add(global.text_data_en, "obj_adate_708", "                              &   Tell her        Keep     &   the truth       lying    ")
ds_map_add(global.text_data_en, "obj_adate_732", "\E9The truth...?/")
ds_map_add(global.text_data_en, "obj_adate_733", "\M4But if I tell her&that^1, she'll hate&me./")
ds_map_add(global.text_data_en, "obj_adate_734", "\E6I\M0sn't it better&this way?/")
ds_map_add(global.text_data_en, "obj_adate_735", "To live a lie where&both people are&happy.../")
ds_map_add(global.text_data_en, "obj_adate_736", "\E7Or a truth where&neither of us&are?/")
ds_map_add(global.text_data_en, "obj_adate_737", "They say " + '"' + "be&yourself." + '"' + "/")
ds_map_add(global.text_data_en, "obj_adate_738", "\E8But I don't&really like who&" + '"' + "myself" + '"' + " is./")
ds_map_add(global.text_data_en, "obj_adate_739", "\E7I'd rather just&be whatever makes&people like me./")
ds_map_add(global.text_data_en, "obj_adate_740", "\E6Eheheh.../")
ds_map_add(global.text_data_en, "obj_adate_741", "\E7.../")
ds_map_add(global.text_data_en, "obj_adate_742", "\E8.../")
ds_map_add(global.text_data_en, "obj_adate_743", "No, you're right./")
ds_map_add(global.text_data_en, "obj_adate_744", "Every day I'm&scared.../")
ds_map_add(global.text_data_en, "obj_adate_745", "\E7Scared what will&happen if people&learn the truth&on their own./")
ds_map_add(global.text_data_en, "obj_adate_746", "\M3They'll all get&hurt because of&me.../")
ds_map_add(global.text_data_en, "obj_adate_747", "\E9B\M4ut how can I&tell UNDYNE the&tr..^1. truth?/")
ds_map_add(global.text_data_en, "obj_adate_748", "\E8I d-don't have the&confidence.../")
ds_map_add(global.text_data_en, "obj_adate_749", "\E9I'm going to mess&it up^1!&How can I&practice!?/%%")
ds_map_add(global.text_data_en, "obj_adate_755", "Yeah..^1. yeah^1, you're&right!/")
ds_map_add(global.text_data_en, "obj_adate_756", "\E6I\M0've come this far^1,&I c-can't tell&her now!/")
ds_map_add(global.text_data_en, "obj_adate_757", "\E7Sh-she'd be really&hurt if she found&out^1, right?/")
ds_map_add(global.text_data_en, "obj_adate_758", "\E5S-so it'll just&be^1, uh^1, a little&secret!/")
ds_map_add(global.text_data_en, "obj_adate_759", "\M1What people don't&know can't hurt&them!!/")
ds_map_add(global.text_data_en, "obj_adate_760", "\M0Th-thank God I've&got an honest&friend like you!!/")
ds_map_add(global.text_data_en, "obj_adate_761", ".../")
ds_map_add(global.text_data_en, "obj_adate_762", "\E3.../")
ds_map_add(global.text_data_en, "obj_adate_763", "\M1B..^1. but what if she&finds out on her&own^1, somehow?/")
ds_map_add(global.text_data_en, "obj_adate_764", "\E7O\M0r if I ever&m-mess up.../")
ds_map_add(global.text_data_en, "obj_adate_765", "\M4Sh-she'd find out&the truth^1, and.../")
ds_map_add(global.text_data_en, "obj_adate_766", "\E8Pr-probably be even&more hurt than if&I told her myself./")
ds_map_add(global.text_data_en, "obj_adate_767", "\E6N\M0-not to mention^1,&l-lying so far..^1.&h..^1. has.../")
ds_map_add(global.text_data_en, "obj_adate_768", "\E8Been really&stressful^1, and scary./")
ds_map_add(global.text_data_en, "obj_adate_769", "\E3.../")
ds_map_add(global.text_data_en, "obj_adate_770", "\E4I think I'm going&to have to tell&her the truth./")
ds_map_add(global.text_data_en, "obj_adate_771", "\E9B-but how!?/")
ds_map_add(global.text_data_en, "obj_adate_772", "\E8I..^1. I don't have&the confidence.../")
ds_map_add(global.text_data_en, "obj_adate_773", "\E7How am I supposed&to practice&something like that!?/%%")
ds_map_add(global.text_data_en, "obj_adate_794", "   Let's           Obviously&   Roleplay        Let's    &   It              Roleplay")
ds_map_add(global.text_data_en, "obj_adate_827", "\E4R..^1. roleplay?/")
ds_map_add(global.text_data_en, "obj_adate_828", "\E3.../")
ds_map_add(global.text_data_en, "obj_adate_829", "\E5.\M1.. That actually&sounds kind of&fun!/")
ds_map_add(global.text_data_en, "obj_adate_830", "\M0OK^1, which one of&us will be Undyne?/*")
ds_map_add(global.text_data_en, "obj_adate_844", "                              &   I'll be         You'll be&   Undyne          Undyne   ")
ds_map_add(global.text_data_en, "obj_adate_868", "Oh^1. Right^1.&Obviously^1.&Ehehe./")
ds_map_add(global.text_data_en, "obj_adate_869", "\E2A\M1hem./")
ds_map_add(global.text_data_en, "obj_adate_870", "\E0H-hi\M3 Undyne..^1.&H-how are you doing&today?/*")
ds_map_add(global.text_data_en, "obj_adate_884", "                              &   I'm fine.       YOur &                      cute, ")
ds_map_add(global.text_data_en, "obj_adate_907", "\E5Ha^1! Ha^1!&Glad to hear it!!/")
ds_map_add(global.text_data_en, "obj_adate_908", "\E3.../")
ds_map_add(global.text_data_en, "obj_adate_909", "\E4Uhhh^1, so I'd like&to^1, um^1, talk to&you about&something./%%")
ds_map_add(global.text_data_en, "obj_adate_913", "\E5Th..^1. thanks!/")
ds_map_add(global.text_data_en, "obj_adate_914", "\E6You say that to me&a lot^1, and I&never know what&to say!!/")
ds_map_add(global.text_data_en, "obj_adate_915", "\E6But I know^1, you just^1,&mean it platonically^1,&because we're just&friends!/")
ds_map_add(global.text_data_en, "obj_adate_916", "\M1Eheheh!!!/")
ds_map_add(global.text_data_en, "obj_adate_917", "\E3.../")
ds_map_add(global.text_data_en, "obj_adate_918", "\E4Uhhh^1, so I'd like&to^1, um^1, talk to&you about&something./%%")
ds_map_add(global.text_data_en, "obj_adate_941", "                              &   What is it,     THEN SHe&   Alphys.         Kisses YOu")
ds_map_add(global.text_data_en, "obj_adate_963", "\E3Umm, you see..^1.&I..^1. I.../")
ds_map_add(global.text_data_en, "obj_adate_964", "\M3I..^1. I h-haven't been&exactly truthful&w-w-with you.../")
ds_map_add(global.text_data_en, "obj_adate_965", "\E4Y\M4..^1. you see^1, I..^1. I.../")
ds_map_add(global.text_data_en, "obj_adate_966", "\E9Oh^1, forget it!/")
ds_map_add(global.text_data_en, "obj_adate_967", "\M0Undyne!!!/")
ds_map_add(global.text_data_en, "obj_adate_968", "I..^1. I want to&tell you how I&feel!/")
ds_map_add(global.text_data_en, "obj_adate_969", "\M4Y-you're so brave^1,&a-and s-strong..^1.&A-and nice.../")
ds_map_add(global.text_data_en, "obj_adate_970", "Y-you always listen&t-to me when I talk&about n-n-nerdy&stuff.../")
ds_map_add(global.text_data_en, "obj_adate_971", "\E0Y-you always d-d-do&your best to m-make&me f-f-feel&special.../")
ds_map_add(global.text_data_en, "obj_adate_972", "\E3L-like t-telling me&that y-you'll b-beat&up anyone that&g-gets in my way.../%%")
ds_map_add(global.text_data_en, "obj_adate_976", "\E9WH-WHAT!?/")
ds_map_add(global.text_data_en, "obj_adate_977", "\M1UNDYNE WOULD NEVER^1,&UH..../")
ds_map_add(global.text_data_en, "obj_adate_978", "\E3.../")
ds_map_add(global.text_data_en, "obj_adate_979", "\M0.../")
ds_map_add(global.text_data_en, "obj_adate_980", "\E4I kiss her back..^1.&S..^1. softly.../")
ds_map_add(global.text_data_en, "obj_adate_981", "\M4I..^1. l-look gently&into her eyes.../%%")
ds_map_add(global.text_data_en, "obj_adate_997", "UNDYNE!!!/")
ds_map_add(global.text_data_en, "obj_adate_998", "I CAN'T TAKE THIS&ANY LONGER!!!/")
ds_map_add(global.text_data_en, "obj_adate_999", "I'M MADLY IN LOVE&WITH YOU!!!/")
ds_map_add(global.text_data_en, "obj_adate_1000", "HOLD ME^1, UNDYNE!^1!&HOLD ME!!!/%%")
ds_map_add(global.text_data_en, "obj_adate_1006", "I START HOLLERING!!/")
ds_map_add(global.text_data_en, "obj_adate_1007", "UNDYNE!!!^1!&I LOVE YOU!!!/")
ds_map_add(global.text_data_en, "obj_adate_1008", "UNDYNE!!^1!&KISS ME AGAIN^1,&UNDYNE!!!/%%")
ds_map_add(global.text_data_en, "obj_adate_1023", "\E9M\M0-m-me^1?&Undyne???/")
ds_map_add(global.text_data_en, "obj_adate_1024", "\E7Uh^1, uh^1, uh^1, uh^1,&ok!/")
ds_map_add(global.text_data_en, "obj_adate_1025", "\E6I'll say what I&think she'd say^1,&and you..^1. ummm..../")
ds_map_add(global.text_data_en, "obj_adate_1026", "\E5You show me what&I'm supposed to do!/")
ds_map_add(global.text_data_en, "obj_adate_1027", "\E2*\M1ahem*/")
ds_map_add(global.text_data_en, "obj_adate_1028", "\E0N\M2gahhhh!!^1!&Hey^1, Alphys!&You look cute&today!/")
ds_map_add(global.text_data_en, "obj_adate_1029", "\E5Which I say often^1!&But platonically&because I would&NEVER like you./*")
ds_map_add(global.text_data_en, "obj_adate_1043", "   Hi Undyne!      Yo your&   Can we          one hot&   talk?           hotbaby")
ds_map_add(global.text_data_en, "obj_adate_1069", "Talk^1, to you^1?&Hmmm..^1.&I guess so./")
ds_map_add(global.text_data_en, "obj_adate_1070", "I often seem&excited to listen&to you for some&reason./")
ds_map_add(global.text_data_en, "obj_adate_1071", "\E4I will make intent&eye contact with you&so you sweat while&you talk./")
ds_map_add(global.text_data_en, "obj_adate_1072", "\E0So^1, what is it?/%%")
ds_map_add(global.text_data_en, "obj_adate_1078", "What!^1?&A... alphys!?/")
ds_map_add(global.text_data_en, "obj_adate_1079", "What's gotten into&you!?/")
ds_map_add(global.text_data_en, "obj_adate_1080", "\E9H\M2-hotbaby!^1?&How dare you call&me that!?/")
ds_map_add(global.text_data_en, "obj_adate_1081", "\E5First off^1, I'm a&baby KNIGHT!/")
ds_map_add(global.text_data_en, "obj_adate_1082", "Captain of the&babies!!!/")
ds_map_add(global.text_data_en, "obj_adate_1083", "Treat my position&with respect^1, or I&will strike you&down!/")
ds_map_add(global.text_data_en, "obj_adate_1084", "\M3Uh^1, now pretend&I'm suplexing a&boulder for no&reason./")
ds_map_add(global.text_data_en, "obj_adate_1085", "\E9U\M0m^1! Anyway^1!&What do you&want to say^1,&Alphys!?/%%")
ds_map_add(global.text_data_en, "obj_adate_1108", "   Let's tell      Alphys&   Undyne the      gives u&   truth           a kiss,")
ds_map_add(global.text_data_en, "obj_adate_1132", "What!?/")
ds_map_add(global.text_data_en, "obj_adate_1133", "So you've been&lying to me the&whole time.../")
ds_map_add(global.text_data_en, "obj_adate_1134", "\E7Alphys!!^1!&I can't believe you!/")
ds_map_add(global.text_data_en, "obj_adate_1135", "\E8You w-worthless&slime!/")
ds_map_add(global.text_data_en, "obj_adate_1136", "\E9How could you&betray our&friendship!!/")
ds_map_add(global.text_data_en, "obj_adate_1137", "\E8After how much I&trusted you!!!/%%")
ds_map_add(global.text_data_en, "obj_adate_1143", "WH-WHAT!^1?&I WOULD NEVER.../")
ds_map_add(global.text_data_en, "obj_adate_1144", "\M0Alphys^1!&What are you&d-doing!/")
ds_map_add(global.text_data_en, "obj_adate_1145", "I s-say^1, pushing&you away from&me.../")
ds_map_add(global.text_data_en, "obj_adate_1146", "\E3You sh-shouldn't&k-kiss me...!!/")
ds_map_add(global.text_data_en, "obj_adate_1147", "\E3.../")
ds_map_add(global.text_data_en, "obj_adate_1148", "\E4.../")
ds_map_add(global.text_data_en, "obj_adate_1149", "\E3B-but^1, y-you're so&good at it.../")
ds_map_add(global.text_data_en, "obj_adate_1150", "\E5B-b-b-because of what&you learned from&th-those d-d-dating&video games.../")
ds_map_add(global.text_data_en, "obj_adate_1151", "I...^1.&I c-c-can't help but&k-k-kiss you back.../%%")
ds_map_add(global.text_data_en, "obj_adate_1167", "ALPHYS^1!&I'LL NEVER LOVE YOU!/")
ds_map_add(global.text_data_en, "obj_adate_1168", "NEVER WILL YOU FEEL&MY PASSIONATE&EMBRACE!!!/")
ds_map_add(global.text_data_en, "obj_adate_1169", "I^1, UNDYNE^1, WILL&NEVER KISS YOU&WITH MY BEAUTIFUL&LIPS!!!/%%")
ds_map_add(global.text_data_en, "obj_adate_1176", "NGAHHHH!!^1!&NGAHHH!!!!/")
ds_map_add(global.text_data_en, "obj_adate_1177", "I'M UNDYNE AND I'M&PILING ON THE&SMOOCHES!!!/%%")
ds_map_add(global.text_data_en, "obj_adate_1236", "WHAT did you just&say?/%%")
ds_map_add(global.text_data_en, "obj_adate_1259", "\E1U..^1. Undyne^1!&I..^1. was..^1. just.../%%")
ds_map_add(global.text_data_en, "obj_adate_1271", "\F6Hey^1, woah^1, wait&a second!/")
ds_map_add(global.text_data_en, "obj_adate_1272", "Your outfit's really&cute^1!&What's the occasion?/")
ds_map_add(global.text_data_en, "obj_adate_1273", "\F0.\E0../")
ds_map_add(global.text_data_en, "obj_adate_1274", "\F2W\E1ait a second./")
ds_map_add(global.text_data_en, "obj_adate_1275", "\F1Are you two.../")
ds_map_add(global.text_data_en, "obj_adate_1276", "\F3On a date?/%%")
ds_map_add(global.text_data_en, "obj_adate_1287", "\E1UHHH^1, \F4YES!/")
ds_map_add(global.text_data_en, "obj_adate_1288", "\E7I mean^1, \F5UHHH NO!/")
ds_map_add(global.text_data_en, "obj_adate_1289", "\E3I mean^1, \F7we were^1,& bu^1t%")
ds_map_add(global.text_data_en, "obj_adate_1290", "\E1I mean^1, actually we&were \F3only romantically&roleplaying as you!/%%")
ds_map_add(global.text_data_en, "obj_adate_1300", "\F3WHAT???/%%")
ds_map_add(global.text_data_en, "obj_adate_1311", "\E8I MEAN!!!/")
ds_map_add(global.text_data_en, "obj_adate_1312", "\E3I mean.../")
ds_map_add(global.text_data_en, "obj_adate_1313", "Undyne..^1.&Ja.../%%")
ds_map_add(global.text_data_en, "obj_adate_1326", "\F4I've been lying to&you!/%%")
ds_map_add(global.text_data_en, "obj_adate_1336", "\F3WHAT??^1?&ABOUT WHAT???/%%")
ds_map_add(global.text_data_en, "obj_adate_1349", "About... well.../")
ds_map_add(global.text_data_en, "obj_adate_1350", "\E2Everything!/%%")
ds_map_add(global.text_data_en, "obj_adate_1366", "\E7I told you that&seaweed was like...&scientifically&important...%")
ds_map_add(global.text_data_en, "obj_adate_1367", "\F5Really, I just...&I just use it to&make ice cream^1!%%")
ds_map_add(global.text_data_en, "obj_adate_1383", "And those human&history books I&keep reading...%")
ds_map_add(global.text_data_en, "obj_adate_1384", "\F7Those are just&dorky comic books^1!%%")
ds_map_add(global.text_data_en, "obj_adate_1400", "And the history&movies..^1.&those..^2.%")
ds_map_add(global.text_data_en, "obj_adate_1401", "\F2Those are just^1, uh^1,&anime^2!&They aren't real^2!%%")
ds_map_add(global.text_data_en, "obj_adate_1417", "And that time I&told you I was&busy with work on&the phone..^1. I...%")
ds_map_add(global.text_data_en, "obj_adate_1418", "\F9Was just eating&frozen yogurt in&my pajamas!%")
ds_map_add(global.text_data_en, "obj_adate_1419", "\E3That time I...%%")
ds_map_add(global.text_data_en, "obj_adate_1433", "Alphys./%%")
ds_map_add(global.text_data_en, "obj_adate_1444", "\E5I..^1. I just wanted to&impress you!/")
ds_map_add(global.text_data_en, "obj_adate_1445", "I just wanted you&to think I was&smart and cool./")
ds_map_add(global.text_data_en, "obj_adate_1446", "That I wasn't&some..^1.&nerdy loser./%%")
ds_map_add(global.text_data_en, "obj_adate_1459", "Alphys./%%")
ds_map_add(global.text_data_en, "obj_adate_1470", "\E5Undyne^1, I..^1.&I really think you're&neat^1, OK.../%%")
ds_map_add(global.text_data_en, "obj_adate_1481", "Alphys./")
ds_map_add(global.text_data_en, "obj_adate_1482", "Shhhh./")
ds_map_add(global.text_data_en, "obj_adate_1483", "Shhhhhh./%%")
ds_map_add(global.text_data_en, "obj_adate_1522", "\F0Alphys!/")
ds_map_add(global.text_data_en, "obj_adate_1523", "I..^1. think you're&neat^1, too, I guess./")
ds_map_add(global.text_data_en, "obj_adate_1524", "\F1But, you've gotta&realize.../")
ds_map_add(global.text_data_en, "obj_adate_1525", "\F2Most of what you&said really doesn't&matter to me./")
ds_map_add(global.text_data_en, "obj_adate_1526", "I don't care if&you're watching kid&cartoons or reading&history books./")
ds_map_add(global.text_data_en, "obj_adate_1527", "\F3To me^1, ALL of&that stuff is&just NERDY CRAP!/")
ds_map_add(global.text_data_en, "obj_adate_1528", "What I like about&you is that you're&PASSIONATE^1!&You're ANALYTICAL!!/")
ds_map_add(global.text_data_en, "obj_adate_1529", "It doesn't matter&what it is^1!&YOU CARE ABOUT IT!!/")
ds_map_add(global.text_data_en, "obj_adate_1530", "\F4100-PERCENT!^1!&AT MAXIMUM POWER!!!/")
ds_map_add(global.text_data_en, "obj_adate_1531", "\F5... so^1, you don't&have to lie to me./")
ds_map_add(global.text_data_en, "obj_adate_1532", "\F0I don't want you&to have to lie to&anyone anymore./")
ds_map_add(global.text_data_en, "obj_adate_1533", "\F6Alphys..^1. I want to&help you become&happy with who&you are!/")
ds_map_add(global.text_data_en, "obj_adate_1534", "\F5And I know just&the training you&need to do that!/%%")
ds_map_add(global.text_data_en, "obj_adate_1566", "Undyne..^1.&You.../")
ds_map_add(global.text_data_en, "obj_adate_1567", "\E4Y-you're gonna train&me...?/%%")
ds_map_add(global.text_data_en, "obj_adate_1574", "\F2Pffft^1, what^1?&ME?/%%")
ds_map_add(global.text_data_en, "obj_adate_1594", "\F6Nah^1, I'm gonna&get Papyrus to&do it./%%")
ds_map_add(global.text_data_en, "obj_adate_1612", "GET THOSE BONES&SHAKIN'!!!/")
ds_map_add(global.text_data_en, "obj_adate_1613", "IT'S TIME TO JOG&100 LAPS^1, HOOTING&ABOUT HOW GREAT&WE ARE!!!/%%")
ds_map_add(global.text_data_en, "obj_adate_1622", "Ready^1?&I'm about to start&the timer!/%%")
ds_map_add(global.text_data_en, "obj_adate_1636", "\E5 & &    U-Undyne.../")
ds_map_add(global.text_data_en, "obj_adate_1637", "\E1 & &    I'll do my&    best...!/%%")
ds_map_add(global.text_data_en, "obj_adate_1659", "\F3OH MY GOD!!!/")
ds_map_add(global.text_data_en, "obj_adate_1660", "\F5She was kidding^1,&right!? /")
ds_map_add(global.text_data_en, "obj_adate_1661", "Those cartoons..^1.&those comics.../")
ds_map_add(global.text_data_en, "obj_adate_1662", "\F7Those are still&REAL^1, right!?/")
ds_map_add(global.text_data_en, "obj_adate_1663", "\F8ANIME'S REAL^1,&RIGHT?!?!/%%")
ds_map_add(global.text_data_en, "obj_adate_1688", "   Anime is        Anime &   Real            is not &                   real")
ds_map_add(global.text_data_en, "obj_adate_1708", "HA HA HA!!!/")
ds_map_add(global.text_data_en, "obj_adate_1709", "I KNEW IT!!!/")
ds_map_add(global.text_data_en, "obj_adate_1710", "GIGANTIC SWORDS!!^1!&MAGICAL PRINCESSES^1!&HERE I COME!!!/%%")
ds_map_add(global.text_data_en, "obj_adate_1714", "\F3No..^1. NO!!!!/")
ds_map_add(global.text_data_en, "obj_adate_1715", "I CAN FEEL MY&HEART BREAKING&INTO PIECES!!!/%%")
ds_map_add(global.text_data_en, "obj_adate_1736", "\F6.../")
ds_map_add(global.text_data_en, "obj_adate_1737", "Uhh^1, thanks for&taking care of&Alphys./")
ds_map_add(global.text_data_en, "obj_adate_1738", "\F9I didn't get to&say what I wanted&to^1, but.../")
ds_map_add(global.text_data_en, "obj_adate_1739", "\F0Things seem like&they're going to get&better for her./")
ds_map_add(global.text_data_en, "obj_adate_1740", "\F6Well^1, I gotta go&catch up with&them!/")
ds_map_add(global.text_data_en, "obj_adate_1741", "Later!/%%")
ds_map_add(global.text_data_en, "obj_adate_1745", "\F3.../")
ds_map_add(global.text_data_en, "obj_adate_1746", "\F5... no^1, I can&survive this.../")
ds_map_add(global.text_data_en, "obj_adate_1747", "\F3I have to be strong./")
ds_map_add(global.text_data_en, "obj_adate_1748", "\F9For Alphys./")
ds_map_add(global.text_data_en, "obj_adate_1749", "\F0Thank you^1, human^1,&for telling me&the truth./")
ds_map_add(global.text_data_en, "obj_adate_1750", "\F9I'll try my best to&live in this&world.../")
ds_map_add(global.text_data_en, "obj_adate_1751", "\F0See you later!/%%")
ds_map_add(global.text_data_en, "obj_alabdoor_l_153", "* (There's no response.)/%%")
ds_map_add(global.text_data_en, "obj_alabdoor_l_207", "* (...)/")
ds_map_add(global.text_data_en, "obj_alabdoor_l_208", "* (O^1-oh n^1-no^1, is that another&  letter...?)/")
ds_map_add(global.text_data_en, "obj_alabdoor_l_209", "* (I don't want to open it...^1)&* (C-^1can't I just slide it&  back out...?)/")
ds_map_add(global.text_data_en, "obj_alabdoor_l_210", "* (...)/")
ds_map_add(global.text_data_en, "obj_alabdoor_l_211", "* (N..^1. no..^1. I can't keep doing&  this.^1)&* (I'll read this one.)/")
ds_map_add(global.text_data_en, "obj_alabdoor_l_212", "* (...)/")
ds_map_add(global.text_data_en, "obj_alabdoor_l_213", "* (Um...^1)&* (I-it's shut k-kind of&  strongly^1, isn't it?)/")
ds_map_add(global.text_data_en, "obj_alabdoor_l_214", "* (Wait a second...)/%%")
ds_map_add(global.text_data_en, "obj_alabdoor_l_252", "* Hey^1, if this is a&  joke^1, it's.../")
ds_map_add(global.text_data_en, "obj_alabdoor_l_253", "\E1* .../")
ds_map_add(global.text_data_en, "obj_alabdoor_l_254", "\E3* Oh My God?/")
ds_map_add(global.text_data_en, "obj_alabdoor_l_255", "\E5* Did YOU write this&  letter?/")
ds_map_add(global.text_data_en, "obj_alabdoor_l_256", "\E6* It wasn't signed^1, so^1,&  I had no idea who&  could have.../")
ds_map_add(global.text_data_en, "obj_alabdoor_l_257", "\E8* Oh my god^1.&* Oh no./")
ds_map_add(global.text_data_en, "obj_alabdoor_l_258", "\E7* That's adorable.../")
ds_map_add(global.text_data_en, "obj_alabdoor_l_259", "\E5* And I h-had no idea&  you^1, um^1, wrote that way!/")
ds_map_add(global.text_data_en, "obj_alabdoor_l_260", "\E9* It's surprising^1, too..^1.&* After all the gross&  stuff I did.../")
ds_map_add(global.text_data_en, "obj_alabdoor_l_261", "\E8* I don't really deserve&  to be forgiven./")
ds_map_add(global.text_data_en, "obj_alabdoor_l_262", "\E4* Much less^1, um.../")
ds_map_add(global.text_data_en, "obj_alabdoor_l_263", "\E5* This?/")
ds_map_add(global.text_data_en, "obj_alabdoor_l_264", "\E1* And so passionately^1,&  too./")
ds_map_add(global.text_data_en, "obj_alabdoor_l_265", "\E2* .../")
ds_map_add(global.text_data_en, "obj_alabdoor_l_266", "\E0* You know what^1, okay^1!&* I'll do it!/")
ds_map_add(global.text_data_en, "obj_alabdoor_l_267", "\E5* It's the least I can&  do to make it up&  to you!/")
ds_map_add(global.text_data_en, "obj_alabdoor_l_268", "\W*\E7 Y-yeah^1!&* \WLet's \Rgo on a date\W!/%%")
ds_map_add(global.text_data_en, "obj_alphys_friendc_81", "\E0* On second thought^1,&  maybe I WON'T write&  fanfic of real people./")
ds_map_add(global.text_data_en, "obj_alphys_friendc_82", "\E7* I mean^1, isn't real life&  already the greatest&  fanfiction of all?/")
ds_map_add(global.text_data_en, "obj_alphys_friendc_83", "\E8* .../")
ds_map_add(global.text_data_en, "obj_alphys_friendc_84", "\E3* Uh^1, don't tell&  anyone I said that./")
ds_map_add(global.text_data_en, "obj_alphys_friendc_85", "\E1* Cause I'm gonna&  post it online!/%%")
ds_map_add(global.text_data_en, "obj_alphys_friendc_90", "\E0* I sure am excited&  to finally use the&  human internet./")
ds_map_add(global.text_data_en, "obj_alphys_friendc_91", "\E7* I bet they have all&  sorts of things Undyne&  and I can watch!/")
ds_map_add(global.text_data_en, "obj_alphys_friendc_93", "\E6* Oh man!!!/")
ds_map_add(global.text_data_en, "obj_alphys_friendc_94", "* We're gonna be&  able to watch&  anime online!?/")
ds_map_add(global.text_data_en, "obj_alphys_friendc_96", "\E7* Of course^1, Undyne!/")
ds_map_add(global.text_data_en, "obj_alphys_friendc_97", "\E2* What do you think&  we've been fighting&  for all along?/")
ds_map_add(global.text_data_en, "obj_alphys_friendc_99", "\E2* yeah^1, what do you.../")
ds_map_add(global.text_data_en, "obj_alphys_friendc_100", "\E1* whoops./")
ds_map_add(global.text_data_en, "obj_alphys_friendc_102", "\E1* Jinx^1!&* I knew you were&  gonna make that joke!/")
ds_map_add(global.text_data_en, "obj_alphys_friendc_104", "\E3WAIT^1, ALPHYS, I&DIDN'T KNOW YOU&KNEW SANS./")
ds_map_add(global.text_data_en, "obj_alphys_friendc_106", "\E5* Well..^1.&* I.../")
ds_map_add(global.text_data_en, "obj_alphys_friendc_108", "\E2* doesn't everybody?/")
ds_map_add(global.text_data_en, "obj_alphys_friendc_110", "\E0* Who the hell is Sans?/")
ds_map_add(global.text_data_en, "obj_alphys_friendc_111", "\E8* .../")
ds_map_add(global.text_data_en, "obj_alphys_friendc_112", "\E0* Who the HECK is Sans?/")
ds_map_add(global.text_data_en, "obj_alphys_friendc_114", "\E1* TORIEL!?!?!/%%")
ds_map_add(global.text_data_en, "obj_alphys_friendc_119", "\E0* Hey Frisk^1, why&  don't you go look&  for Mettaton?/")
ds_map_add(global.text_data_en, "obj_alphys_friendc_120", "\E8* He was here for&  a while^1, too.../")
ds_map_add(global.text_data_en, "obj_alphys_friendc_121", "\E0* But he said he&  had to go somewhere./%%")
ds_map_add(global.text_data_en, "obj_alphys_npc_76", "* Th-that last&  question.../")
ds_map_add(global.text_data_en, "obj_alphys_npc_77", "\E4* He wasn't s-supposed&  to ask that one.../%%")
ds_map_add(global.text_data_en, "obj_alphys_npc_82", "* (Yellow feet are tapping&  just behind the door.)/%%")
ds_map_add(global.text_data_en, "obj_alphys_npc_91", "* I..^1. I just need&  a moment./%%")
ds_map_add(global.text_data_en, "obj_alphys_npc_99", "* .../%%")
ds_map_add(global.text_data_en, "obj_alphysfollow_event_108", "* S..^1. Sorry about&  that!/")
ds_map_add(global.text_data_en, "obj_alphysfollow_event_109", "\E5* L-let's k-keep&  going!/%%")
ds_map_add(global.text_data_en, "obj_alphysfollow_event_148", "* S-so you're about&  to meet ASGORE^1,&  h-huh?/")
ds_map_add(global.text_data_en, "obj_alphysfollow_event_149", "\E6* You must be..^1.&* Y-you must be.../")
ds_map_add(global.text_data_en, "obj_alphysfollow_event_150", "\E5* Pr..^1. pretty&  excited about all&  that^1, huh?/%%")
ds_map_add(global.text_data_en, "obj_alphysfollow_event_175", "* You'll f-f-finally.../")
ds_map_add(global.text_data_en, "obj_alphysfollow_event_176", "\E7* You'll finally get&  to go home!/%%")
ds_map_add(global.text_data_en, "obj_alphysfollow_event_206", "* W..^1.&* Wait!/%%")
ds_map_add(global.text_data_en, "obj_alphysfollow_event_228", "* I mean^1, um..^1.&* I.../")
ds_map_add(global.text_data_en, "obj_alphysfollow_event_229", "\E1* I was just going&  to..^1.&* ...um.../")
ds_map_add(global.text_data_en, "obj_alphysfollow_event_230", "\E2* Say goodbye^1, and.../")
ds_map_add(global.text_data_en, "obj_alphysfollow_event_231", "* .../")
ds_map_add(global.text_data_en, "obj_alphysfollow_event_232", "\E3* .../")
ds_map_add(global.text_data_en, "obj_alphysfollow_event_233", "\E4* .../")
ds_map_add(global.text_data_en, "obj_alphysfollow_event_234", "* I can't take&  this anymore./%%")
ds_map_add(global.text_data_en, "obj_alphysfollow_event_262", "* I.../")
ds_map_add(global.text_data_en, "obj_alphysfollow_event_263", "\E5* I lied to you./")
ds_map_add(global.text_data_en, "obj_alphysfollow_event_264", "\E7* A human SOUL isn't&  strong enough to&  cross the barrier alone./")
ds_map_add(global.text_data_en, "obj_alphysfollow_event_265", "\E6* It takes at least&  a human soul.../")
ds_map_add(global.text_data_en, "obj_alphysfollow_event_266", "\E5* And a monster&  soul./")
ds_map_add(global.text_data_en, "obj_alphysfollow_event_267", "\E5* .../%%")
ds_map_add(global.text_data_en, "obj_alphysfollow_event_295", "* If you want to&  go home.../")
ds_map_add(global.text_data_en, "obj_alphysfollow_event_296", "\E5* You'll have to&  take his soul./")
ds_map_add(global.text_data_en, "obj_alphysfollow_event_297", "\E7* You'll have to&  kill ASGORE./%%")
ds_map_add(global.text_data_en, "obj_alphysfollow_event_345", "* I'm sorry./%%")
ds_map_add(global.text_data_en, "obj_alphystrigger1_166", "* Oh^1.&* My god./%%")
ds_map_add(global.text_data_en, "obj_alphystrigger1_175", "* I didn't expect you&  to show up so&  soon!/")
ds_map_add(global.text_data_en, "obj_alphystrigger1_176", "* I haven't showered^1, I'm&  barely dressed^1, it's&  all messy^1, and.../%%")
ds_map_add(global.text_data_en, "obj_alphystrigger1_224", "* Ummm.../")
ds_map_add(global.text_data_en, "obj_alphystrigger1_225", "* H-h-hiya!/")
ds_map_add(global.text_data_en, "obj_alphystrigger1_226", "* I'm Dr. Alphys^1.&* I'm ASGORE's royal&  scientist!/")
ds_map_add(global.text_data_en, "obj_alphystrigger1_227", "\E3* B-b-but^1, ahhhh^1,&  I'm not one of&  the " + '"' + "bad guys" + '"' + "!/")
ds_map_add(global.text_data_en, "obj_alphystrigger1_228", "\E0* Actually^1, since you&  stepped out of the&  RUINS^1, I've^1, um.../")
ds_map_add(global.text_data_en, "obj_alphystrigger1_229", "\E7* ... been " + '"' + "observing" + '"' + "&  your journey through&  my console./")
ds_map_add(global.text_data_en, "obj_alphystrigger1_230", "\E3* Your fights..^1.&* Your friendships..^1.&* Everything!/")
ds_map_add(global.text_data_en, "obj_alphystrigger1_231", "\E0* I was originally&  going to stop&  you^1, but.../")
ds_map_add(global.text_data_en, "obj_alphystrigger1_236", "\E7* Watching someone on&  a screen really makes&  you root for them./")
ds_map_add(global.text_data_en, "obj_alphystrigger1_237", "\E7* Watching you^1, I felt&  like..^1. like I was&  seeing an old friend./")
ds_map_add(global.text_data_en, "obj_alphystrigger1_238", "\E0* S-so^1, ahhh^1, now I&  want to help you!/")
ds_map_add(global.text_data_en, "obj_alphystrigger1_239", "\E6* Using my knowledge^1,&  I can easily guide&  you through Hotland!/")
ds_map_add(global.text_data_en, "obj_alphystrigger1_240", "\E0* I know a way right&  to ASGORE's castle^1,&  no problem!/")
ds_map_add(global.text_data_en, "obj_alphystrigger1_241", "\E2* .../")
ds_map_add(global.text_data_en, "obj_alphystrigger1_242", "\E7* Well^1, actually^1, umm^1,&  there's just a&  tiny issue./")
ds_map_add(global.text_data_en, "obj_alphystrigger1_243", "\E0* A long time ago^1, I&  made a robot named&  Mettaton./")
ds_map_add(global.text_data_en, "obj_alphystrigger1_244", "* Originally^1, I built&  him to be an&  entertainment robot./")
ds_map_add(global.text_data_en, "obj_alphystrigger1_245", "\E7* Uh^1, you know^1, like&  a robotic TV star&  or something./")
ds_map_add(global.text_data_en, "obj_alphystrigger1_246", "\E0* Anyway^1, recently I&  decided to make him&  more useful./")
ds_map_add(global.text_data_en, "obj_alphystrigger1_247", "\E7* You know^1, just some&  small practical&  adjustments./")
ds_map_add(global.text_data_en, "obj_alphystrigger1_248", "\E0* Like^1, um.../")
ds_map_add(global.text_data_en, "obj_alphystrigger1_249", "\E4* Anti..^1. anti-human&  combat features?/")
ds_map_add(global.text_data_en, "obj_alphystrigger1_250", "\E6* Of c-course^1, when I&  saw you coming^1, I&  immediately decided.../")
ds_map_add(global.text_data_en, "obj_alphystrigger1_251", "\E3* I have to remove&  those features!/")
ds_map_add(global.text_data_en, "obj_alphystrigger1_252", "\E4* Unfortunately^1, I may&  have made a teensy&  mistake while doing so./")
ds_map_add(global.text_data_en, "obj_alphystrigger1_253", "* And^1, um.../")
ds_map_add(global.text_data_en, "obj_alphystrigger1_254", "\E5* Now he's an unstoppable&  killing machine with a&  thirst for human blood?/")
ds_map_add(global.text_data_en, "obj_alphystrigger1_255", "* Ehehehehe.../")
ds_map_add(global.text_data_en, "obj_alphystrigger1_256", "\E8* Heh./")
ds_map_add(global.text_data_en, "obj_alphystrigger1_257", "\E0* But^1, ummm^1, hopefully&  we won't run into&  him!/%%")
ds_map_add(global.text_data_en, "obj_alphystrigger1_288", "* ...?/%%")
ds_map_add(global.text_data_en, "obj_alphystrigger1_312", "* Did you hear&  something?/%%")
ds_map_add(global.text_data_en, "obj_alphystrigger1_344", "* Oh no./%%")
ds_map_add(global.text_data_en, "obj_alphystrigger1_393", "* OHHHH YES!/")
ds_map_add(global.text_data_en, "obj_alphystrigger1_394", "* WELCOME^1, BEAUTIES.../%%")
ds_map_add(global.text_data_en, "obj_alphystrigger1_441", "\M1* ... TO TODAY'S QUIZ SHOW!!!/%%")
ds_map_add(global.text_data_en, "obj_alphystrigger1_468", "\M0* OH BOY^1!&* I CAN ALREADY TELL IT'S&  GONNA BE A GREAT SHOW!/")
ds_map_add(global.text_data_en, "obj_alphystrigger1_469", "\M2* EVERYONE GIVE A BIG&  HAND FOR OUR WONDERFUL&  CONTESTANT!/%%")
ds_map_add(global.text_data_en, "obj_alphystrigger1_493", "\M0* NEVER PLAYED BEFORE^1,&  GORGEOUS?/")
ds_map_add(global.text_data_en, "obj_alphystrigger1_494", "\M2* NO PROBLEM^1!&* IT'S SIMPLE!/")
ds_map_add(global.text_data_en, "obj_alphystrigger1_495", "\M4* THERE'S ONLY ONE&  RULE./")
ds_map_add(global.text_data_en, "obj_alphystrigger1_496", "* ANSWER CORRECTLY.../%%")
ds_map_add(global.text_data_en, "obj_alphystrigger1_514", "* OR YOU DIE!!!/%%")
ds_map_add(global.text_data_en, "obj_alphystrigger1_566", "* .../")
ds_map_add(global.text_data_en, "obj_alphystrigger1_567", "\E0* Well that was&  certainly something./%%")
ds_map_add(global.text_data_en, "obj_alphystrigger2_87", "* Wait^1, wait!/%%")
ds_map_add(global.text_data_en, "obj_alphystrigger2_146", "\E0* Let me give you my&  ph-phone number!/")
ds_map_add(global.text_data_en, "obj_alphystrigger2_147", "\E7* Th-then..^1. m-maybe..^1.&* If you need help^1,&  I could.../%%")
ds_map_add(global.text_data_en, "obj_alphystrigger2_169", "\E3* Wh..^1. where'd you get&  that phone!?&* It's ANCIENT!/")
ds_map_add(global.text_data_en, "obj_alphystrigger2_170", "\E1* It doesn't even have&  texting./")
ds_map_add(global.text_data_en, "obj_alphystrigger2_171", "\E3* W-wait a second^1,&  please!/%%")
ds_map_add(global.text_data_en, "obj_alphystrigger2_221", "\E0* Here^1, I upgraded it&  for you!/")
ds_map_add(global.text_data_en, "obj_alphystrigger2_222", "* It can do texting^1,&  items^1, it's got a&  key chain.../")
ds_map_add(global.text_data_en, "obj_alphystrigger2_223", "* I even signed you up&  for the underground's&  No. 1 social network!/")
ds_map_add(global.text_data_en, "obj_alphystrigger2_224", "\E7* Now we're officially&  friends^1!&* Ehehehe!/")
ds_map_add(global.text_data_en, "obj_alphystrigger2_225", "\E0* Heheh.../")
ds_map_add(global.text_data_en, "obj_alphystrigger2_226", "\E0* Heh.../")
ds_map_add(global.text_data_en, "obj_alphystrigger2_227", "\E0* .../")
ds_map_add(global.text_data_en, "obj_alphystrigger2_228", "\E1* .../")
ds_map_add(global.text_data_en, "obj_alphystrigger2_229", "\E2* .../")
ds_map_add(global.text_data_en, "obj_alphystrigger2_230", "\E1* .../")
ds_map_add(global.text_data_en, "obj_alphystrigger2_231", "\E2* .../")
ds_map_add(global.text_data_en, "obj_alphystrigger2_232", "\E4* I'm going to the&  bathroom./%%")
ds_map_add(global.text_data_en, "obj_amalgam_fridge_99", "* (It's a refrigerator.^1)&* (It's empty.)/%%")
ds_map_add(global.text_data_en, "obj_amalgam_fridge_103", "* (It's some sort of cold^1,&  rectangular object.)/%%")
ds_map_add(global.text_data_en, "obj_amalgam_fridge_107", "* (You found a blue key on&  the ground.^1)&* (You put it on your keychain.)/%%")
ds_map_add(global.text_data_en, "obj_artclass_sign_208", "* Art Club: Meet here!&* Next meeting:&* October 10th 8PM/%%")
ds_map_add(global.text_data_en, "obj_artclass_sign_213", "* (Art club is cancelled!)/%%")
ds_map_add(global.text_data_en, "obj_artclass_sign_218", "* (Art is dead.)/%%")
ds_map_add(global.text_data_en, "obj_artclass_sign_224", "* Let's meet again someday!/%%")
ds_map_add(global.text_data_en, "obj_artclass_sign_231", "* Who knows what lies in the&  future for Art Club!?/%%")
ds_map_add(global.text_data_en, "obj_artclass_sign_281", "* Ahhhh!!^1!&* I'm late!!^1!&* I'm late!!!/")
ds_map_add(global.text_data_en, "obj_artclass_sign_282", "* I'm so sorry!!!/%%")
ds_map_add(global.text_data_en, "obj_asgore_finalintro_178", "* (A strange light fills the&  room.^5)   %")
ds_map_add(global.text_data_en, "obj_asgore_finalintro_179", "* (Twilight is shining through&  the barrier.^3)   %")
ds_map_add(global.text_data_en, "obj_asgore_finalintro_180", "* (It seems your journey is&  finally over.^4)%")
ds_map_add(global.text_data_en, "obj_asgore_finalintro_181", "     * (You're filled with&          DETERMINATION.^5) %%")
ds_map_add(global.text_data_en, "obj_asgore_finalintro_213", "Human.../")
ds_map_add(global.text_data_en, "obj_asgore_finalintro_214", "\E1It was&nice to&meet&you./")
ds_map_add(global.text_data_en, "obj_asgore_finalintro_215", "\E0Goodbye./%%")
ds_map_add(global.text_data_en, "obj_asgore_finalintro_220", "\E1Now,&now./")
ds_map_add(global.text_data_en, "obj_asgore_finalintro_221", "There's&no need&to&fight./")
ds_map_add(global.text_data_en, "obj_asgore_finalintro_222", "Why not&settle&this.../")
ds_map_add(global.text_data_en, "obj_asgore_finalintro_223", "Over a&nice cup&of tea?/%%")
ds_map_add(global.text_data_en, "obj_asgore_finalintro_496", "* ASGORE attacks!")
ds_map_add(global.text_data_en, "obj_asgore_friendc_76", "\E0* Howdy^1, Frisk./")
ds_map_add(global.text_data_en, "obj_asgore_friendc_77", "\E3* Sorry about almost&  trying to take&  your SOUL./")
ds_map_add(global.text_data_en, "obj_asgore_friendc_78", "\E5* I feel very bad&  about it./")
ds_map_add(global.text_data_en, "obj_asgore_friendc_79", "\E0* I hope we can&  still be pals./")
ds_map_add(global.text_data_en, "obj_asgore_friendc_81", "\E0* Hey^1, don't worry&  about it^1, ASGORE./")
ds_map_add(global.text_data_en, "obj_asgore_friendc_82", "\E2* I think everybody's&  tried to kill Frisk&  at least once./")
ds_map_add(global.text_data_en, "obj_asgore_friendc_84", "\E2* Oh..^1. I see!/")
ds_map_add(global.text_data_en, "obj_asgore_friendc_85", "\E0* In that case^1, I'm&  not sorry^1, Frisk./")
ds_map_add(global.text_data_en, "obj_asgore_friendc_87", "\E6* ASGORE^1!&* That's not what I&  meant!/%%")
ds_map_add(global.text_data_en, "obj_asgore_friendc_97", "\E3* Oh^1, Frisk^1, if you're&  not busy.../")
ds_map_add(global.text_data_en, "obj_asgore_friendc_98", "\E0* On nice days^1, you&  should walk around and&  have a good time./")
ds_map_add(global.text_data_en, "obj_asgore_friendc_99", "\E0* That's important./%%")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_243", "Ah.../")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_244", ".../")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_245", "So that&is how&it is./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_246", ".../%%")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_251", "\E3Why..^1.&You.../%%")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_275", "I remember the day&after my son&died./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_276", "The entire underground&was devoid of hope./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_277", "The future had once&again been taken&from us by the&humans./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_278", "In a fit of anger,&I declared war./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_279", "I said that I would&destroy any human&that came here./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_280", "I would use their&souls to become&godlike.../")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_281", "... and free us from&this terrible prison./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_282", "Then, I would destroy&humanity.../")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_283", "And let monsters rule&the surface, in peace./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_284", "Soon, the people's&hopes returned./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_285", "My wife, however,&became disgusted with&my actions./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_286", "She left this place,&never to be seen&again./%%")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_294", "Truthfully.../")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_295", "I do not want power./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_296", "I do not want to&hurt anyone./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_297", "I just wanted everyone&to have hope.../")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_298", "Ale.../")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_299", "I cannot take this&any longer./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_300", "I just want to&see my wife./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_301", "I just want to&see my child./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_302", "Please..^1.&Young one.../")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_303", "This war has gone&on long enough./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_304", "You have the power.../")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_305", "Take my soul, and&leave this cursed&place./%%")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_340", ".../")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_341", "\E0After everything I&have done to&hurt you.../")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_342", "\E7You would rather&stay down here&and suffer.../")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_343", "\E9Than live happily&on the surface?/")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_344", "\E6.../%%")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_352", "\E1Human.../")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_353", "\E7I promise you.../")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_354", "\E7For as long as&you remain here.../")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_355", "\E1My wife and I will&take care of you&as best we can./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_356", "\E2We can sit in&the living room^1,&telling stories.../")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_357", "\E1Eating butterscotch&pie.../")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_358", "\E2We could be&like.../")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_359", "\E8Like a family.../%%")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_623", "You&IDIOT./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_627", "\[C]./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_628", "You&haven't&learned&a thing./%%")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_632", "Hee&hee&hee./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_633", "So you&finally&get it./%%")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_639", "\[C]./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_640", "So you&DO&recall./%%")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_651", "In&this&world.../%%")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_692", "It's KILL or BE killed^4.%%")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_769", "Hee hee hee^1.&Don't worry./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_770", "I know there's no&REAL point in&fighting you./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_771", "The human souls&would probably just&revolt again./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_772", "So...!/%%")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_778", "Hee hee hee^1./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_779", "Did you REALLY&think killing me&would make a&DIFFERENCE?/")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_780", "No./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_781", "Every time you&load your SAVE^1,&I'll come back./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_782", "And every time you&try to get a&happy ending.../")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_783", "I'll be there to&tear it away!/")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_784", "Ha ha ha!!!/%%")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_792", "Well^1, let's get&this over with./%%")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_796", ".../%%")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_831", "\E2.../")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_832", "\E0No^1.&That's just a&fantasy^1, isn't it?/")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_833", "\E1Young one^1, when I&look at you.../")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_834", "\E2I'm reminded of the&human that fell here&long ago.../")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_835", "\E8You have the same&feeling of hope in&your eyes./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_836", "\E7There is an ancient&prophecy among our&people.../")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_837", "One day^1, a savior&will come from the&heavens./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_838", "\E1... I believe the&one that was&prophecied was you./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_839", "Somewhere in the&world outside.../")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_840", "There must be a way&to free us from our&prison./")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_841", "\E0It pains me to&give you this&responsiblity^1, but.../")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_842", "\E0Please^1.&Take my soul..^1.&and seek the truth./%%")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_898", "\E0Ha... ha.../")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_899", "\E6I'm sorry.../")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_900", "I couldn't give you&a simple^1, happy&ending.../")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_901", "But I believe your&freedom.../")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_902", "... is what my son.../")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_903", "\E8... what ASRIEL would&have wanted./%%")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_979", "See^1?&I never betrayed&you^2! %")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_980", "It was all a&trick, see^2? %")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_981", "I was waiting to&kill him for you^2! %")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_982", "\E1After all it's me&your best friend^2! %")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_983", "\E2I'm helpful, I can&be useful to you^1 %")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_984", "\E1I promise I won't&get in your way^1 %%")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_995", "\E2I can help..^1.&I can..^1.&I can..^2. %%")
ds_map_add(global.text_data_en, "obj_asgore_lastcutscene_1006", "\E3Please don't&kill me./%%")
ds_map_add(global.text_data_en, "obj_asgore_prebarrier_event_78", "* How tense.../")
ds_map_add(global.text_data_en, "obj_asgore_prebarrier_event_79", "\E2* Just think of it like.../")
ds_map_add(global.text_data_en, "obj_asgore_prebarrier_event_80", "\E0* A visit to the dentist./%%")
ds_map_add(global.text_data_en, "obj_asgore_prebarrier_event_112", "* Are you ready?/")
ds_map_add(global.text_data_en, "obj_asgore_prebarrier_event_113", "\E3* If you are not^1, I&  understand./")
ds_map_add(global.text_data_en, "obj_asgore_prebarrier_event_114", "\E2* I am not ready either./%%")
ds_map_add(global.text_data_en, "obj_asgoreb_652", "* ...")
ds_map_add(global.text_data_en, "obj_asgoreb_658", "* Asgore has low HP.")
ds_map_add(global.text_data_en, "obj_asgoreb_692", "* ASGORE 80 ATK 80 DEF /^")
ds_map_add(global.text_data_en, "obj_asgoreb_705", "* But there was nothing to&  say./^")
ds_map_add(global.text_data_en, "obj_asgoreb_711", "* You quietly tell ASGORE&  you don't want to fight&  him./")
ds_map_add(global.text_data_en, "obj_asgoreb_712", "* His hands tremble for a&  moment./^")
ds_map_add(global.text_data_en, "obj_asgoreb_716", "* You tell ASGORE that you&  don't want to fight him./")
ds_map_add(global.text_data_en, "obj_asgoreb_717", "* His breathing gets funny&  for a moment./^")
ds_map_add(global.text_data_en, "obj_asgoreb_721", "* You firmly tell ASGORE to&  STOP fighting./")
ds_map_add(global.text_data_en, "obj_asgoreb_722", "* Recollection flashes in his&  eyes.../")
ds_map_add(global.text_data_en, "obj_asgoreb_723", "* ASGORE's ATTACK dropped^1!&* ASGORE's DEFENSE dropped!/^")
ds_map_add(global.text_data_en, "obj_asgoreb_729", "* Seems talking won't do any&  more good./^")
ds_map_add(global.text_data_en, "obj_asgoreb_731", "* All you can do is FIGHT./^")
ds_map_add(global.text_data_en, "obj_asgoreb_748", "* You tell ASGORE that he's&  killed you \[1]./")
ds_map_add(global.text_data_en, "obj_asgoreb_killcount_1", "once before")
ds_map_add(global.text_data_en, "obj_asgoreb_killcount_2", "twice before")
ds_map_add(global.text_data_en, "obj_asgoreb_killcount_3", "three times")
ds_map_add(global.text_data_en, "obj_asgoreb_killcount_4", "four times")
ds_map_add(global.text_data_en, "obj_asgoreb_killcount_5", "five times")
ds_map_add(global.text_data_en, "obj_asgoreb_killcount_6", "six times")
ds_map_add(global.text_data_en, "obj_asgoreb_killcount_7", "seven times")
ds_map_add(global.text_data_en, "obj_asgoreb_killcount_8", "eight times")
ds_map_add(global.text_data_en, "obj_asgoreb_killcount_9", "nine times")
ds_map_add(global.text_data_en, "obj_asgoreb_killcount_10", "too many times&  to count")
ds_map_add(global.text_data_en, "obj_asgoreb_749", "* He nods sadly./^")
ds_map_add(global.text_data_en, "obj_asgoreb_751", "* He nods grievously./^")
ds_map_add(global.text_data_en, "obj_asgoreb_753", "* He nods pitifully./^")
ds_map_add(global.text_data_en, "obj_asgoremeet_event_131", "* Dum dee dum.../")
ds_map_add(global.text_data_en, "obj_asgoremeet_event_132", "* Oh^1?&* Is someone there?/")
ds_map_add(global.text_data_en, "obj_asgoremeet_event_133", "* Just a moment!/")
ds_map_add(global.text_data_en, "obj_asgoremeet_event_134", "* I have almost finished watering&  these flowers./%%")
ds_map_add(global.text_data_en, "obj_asgoremeet_event_138", "* Curious^1.&* I've never seen a plant..^1.&* Cry before./%%")
ds_map_add(global.text_data_en, "obj_asgoremeet_event_162", "* ... Here we are!/%%")
ds_map_add(global.text_data_en, "obj_asgoremeet_event_193", "* Howdy^1!&* How can I.../%%")
ds_map_add(global.text_data_en, "obj_asgoremeet_event_224", "* Oh./%%")
ds_map_add(global.text_data_en, "obj_asgoremeet_event_247", "\E3* .../")
ds_map_add(global.text_data_en, "obj_asgoremeet_event_248", "\E2* I so badly want to&  say^1, " + '"' + "would you like&  a cup of tea?" + '"' + "/")
ds_map_add(global.text_data_en, "obj_asgoremeet_event_249", "* Ale.../")
ds_map_add(global.text_data_en, "obj_asgoremeet_event_250", "\E3* You know how it is./%%")
ds_map_add(global.text_data_en, "obj_asgoremeet_event_289", "* Nice day today^1, huh?/")
ds_map_add(global.text_data_en, "obj_asgoremeet_event_290", "* Birds are singing^1,&  flowers are blooming.../")
ds_map_add(global.text_data_en, "obj_asgoremeet_event_291", "* Perfect weather for a&  game of catch./%%")
ds_map_add(global.text_data_en, "obj_asgoremeet_event_313", "* .../")
ds_map_add(global.text_data_en, "obj_asgoremeet_event_314", "* You know what we must&  do./")
ds_map_add(global.text_data_en, "obj_asgoremeet_event_315", "* When you are ready^1,&  come into the next&  room./%%")
ds_map_add(global.text_data_en, "obj_asgoremeet_event_369", "\E3* ... huh?/")
ds_map_add(global.text_data_en, "obj_asgoremeet_event_370", "* You must be the one&  that flower just warned&  me about./")
ds_map_add(global.text_data_en, "obj_asgoremeet_event_371", "\E0* Howdy!/")
ds_map_add(global.text_data_en, "obj_asgoremeet_event_372", "* .../")
ds_map_add(global.text_data_en, "obj_asgoremeet_event_373", "\E3* Erm..^1.&* What kind of monster&  are you...?/")
ds_map_add(global.text_data_en, "obj_asgoremeet_event_374", "\E0* Sorry^1, I cannot tell./")
ds_map_add(global.text_data_en, "obj_asgoremeet_event_375", "* Well^1, we can always%%")
ds_map_add(global.text_data_en, "obj_asriel_overworldanim_174", "* I'm so sorry./%%")
ds_map_add(global.text_data_en, "obj_asriel_overworldanim_440", "* Ha..^1. ha.../")
ds_map_add(global.text_data_en, "obj_asriel_overworldanim_441", "* I don't want to let&  go.../%%")
ds_map_add(global.text_data_en, "obj_asriel_overworldanim_495", "\E7* Frisk.../")
ds_map_add(global.text_data_en, "obj_asriel_overworldanim_496", "* You're.../")
ds_map_add(global.text_data_en, "obj_asriel_overworldanim_497", "\E0* You're going to do&  a great job^1, OK?/")
ds_map_add(global.text_data_en, "obj_asriel_overworldanim_498", "* No matter what you&  do./")
ds_map_add(global.text_data_en, "obj_asriel_overworldanim_499", "* Everyone will be&  there for you^1,&  okay?/%%")
ds_map_add(global.text_data_en, "obj_asriel_overworldanim_533", "\E7* Well..^1.&* My time's running out./")
ds_map_add(global.text_data_en, "obj_asriel_overworldanim_534", "* Goodbye./%%")
ds_map_add(global.text_data_en, "obj_asriel_overworldanim_572", "* By the way.../")
ds_map_add(global.text_data_en, "obj_asriel_overworldanim_573", "* Frisk./")
ds_map_add(global.text_data_en, "obj_asriel_overworldanim_574", "\E6* ... take care of Mom&  and Dad for me^1, OK?/%%")
ds_map_add(global.text_data_en, "obj_asrielappear_110", "Finally./")
ds_map_add(global.text_data_en, "obj_asrielappear_111", "I was so&tired of&being a&flower./%%")
ds_map_add(global.text_data_en, "obj_asrielappear_147", "Howdy!/")
ds_map_add(global.text_data_en, "obj_asrielappear_148", "\[C]^1,&are you&there?/")
ds_map_add(global.text_data_en, "obj_asrielappear_149", "It's me^1,&your&best&friend./%%")
ds_map_add(global.text_data_en, "obj_FinalWriter_34", " ASRIEL   DREEMURR ")
ds_map_add(global.text_data_en, "obj_asrielb_245", "\E1You know.../")
ds_map_add(global.text_data_en, "obj_asrielb_246", "\M1I \E0don't care about&destroying this&world anymore./%%")
ds_map_add(global.text_data_en, "obj_asrielb_251", "\E1After I defeat you&and gain total&control over the&timeline.../")
ds_map_add(global.text_data_en, "obj_asrielb_252", "\E2I just want to reset&everything./%%")
ds_map_add(global.text_data_en, "obj_asrielb_257", "\E3All your progress..^1.&Everyone's memories./")
ds_map_add(global.text_data_en, "obj_asrielb_258", "\E2I'll bring them all&back to zero!/%%")
ds_map_add(global.text_data_en, "obj_asrielb_263", "\E2Then we can do&everything ALL over&again./%%")
ds_map_add(global.text_data_en, "obj_asrielb_268", "\E3And you know what&the best part of&all this is?/")
ds_map_add(global.text_data_en, "obj_asrielb_269", "\E2You'll DO it./%%")
ds_map_add(global.text_data_en, "obj_asrielb_274", "\E1And then you'll&lose to me again./%%")
ds_map_add(global.text_data_en, "obj_asrielb_279", "\E3And again./%%")
ds_map_add(global.text_data_en, "obj_asrielb_284", "\E3And again!!!/%%")
ds_map_add(global.text_data_en, "obj_asrielb_289", "\E1Because you want a&" + '"' + "happy ending." + '"' + "/%%")
ds_map_add(global.text_data_en, "obj_asrielb_294", "Because you " + '"' + "love&your friends." + '"' + "/%%")
ds_map_add(global.text_data_en, "obj_asrielb_299", "Because you " + '"' + "never&give up." + '"' + "/%%")
ds_map_add(global.text_data_en, "obj_asrielb_304", "\M1I\E1sn't that&delicious?/")
ds_map_add(global.text_data_en, "obj_asrielb_305", "\M0Your " + '"' + "determination.^1" + '"' + "&The power that let&you get this far.../")
ds_map_add(global.text_data_en, "obj_asrielb_306", "\E2It's gonna be your&downfall!/%%")
ds_map_add(global.text_data_en, "obj_asrielb_311", "\E2Now^1, ENOUGH messing&around!/")
ds_map_add(global.text_data_en, "obj_asrielb_312", "It's time to purge&this timeline once&and for all!/%%")
ds_map_add(global.text_data_en, "obj_asrielb_541", "* Asriel readies " + '"' + "STAR BLAZING." + '"')
ds_map_add(global.text_data_en, "obj_asrielb_542", "* Asriel charges " + '"' + "SHOCKER&  BREAKER." + '"')
ds_map_add(global.text_data_en, "obj_asrielb_543", "* Asriel calls on " + '"' + "CHAOS SABER." + '"')
ds_map_add(global.text_data_en, "obj_asrielb_544", "* Asriel readies " + '"' + "CHAOS BUSTER." + '"')
ds_map_add(global.text_data_en, "obj_asrielb_545", "* Asriel readies " + '"' + "GALACTA&  BLAZING." + '"')
ds_map_add(global.text_data_en, "obj_asrielb_546", "* Asriel calls on " + '"' + "CHAOS SLICER." + '"')
ds_map_add(global.text_data_en, "obj_asrielb_547", "* Asriel readies " + '"' + "SHOCKER&  BREAKER II." + '"')
ds_map_add(global.text_data_en, "obj_asrielb_548", "* Asriel readies " + '"' + "CHAOS&  BLASTER." + '"')
ds_map_add(global.text_data_en, "obj_asrielb_549", "* Asriel readies " + '"' + "HYPER GONER." + '"')
ds_map_add(global.text_data_en, "obj_asrielb_550", "* Asriel is glowing with a&  strange power.")
ds_map_add(global.text_data_en, "obj_asrielb_551", "* It's the end.")
ds_map_add(global.text_data_en, "obj_asrielb_585", "* ASRIEL DREEMURR \z4   ATK \z4   DEF&* Legendary being made of every&  SOUL in the underground./^")
ds_map_add(global.text_data_en, "obj_asrielb_587", "* ASRIEL DREEMURR \z4   ATK \z4   DEF&* The Absolute GOD of Hyperdeath!/^")
ds_map_add(global.text_data_en, "obj_asrielb_597", "* You held on to your hopes..^1.&* You reduced how much DAMAGE&  you'll take this turn!/^")
ds_map_add(global.text_data_en, "obj_asrielb_598", "* You kept holding on^1.&* DAMAGE reduced!/^")
ds_map_add(global.text_data_en, "obj_asrielb_614", "* You think about why you're&  here now.../")
ds_map_add(global.text_data_en, "obj_asrielb_615", "* You can feel the empty&  space in your inventory&  get smaller and smaller!/^")
ds_map_add(global.text_data_en, "obj_asrielb_618", "* Your items fill up with&  dreams./^")
ds_map_add(global.text_data_en, "obj_asrielb_669", "\E0... even after that&attack^1, you're still&standing in my way...?/")
ds_map_add(global.text_data_en, "obj_asrielb_670", "\M1W\E0ow..^1.&You really ARE&something special./")
ds_map_add(global.text_data_en, "obj_asrielb_671", "\M0B\E3ut don't get&cocky./")
ds_map_add(global.text_data_en, "obj_asrielb_672", "\E0Up until now^1, I've&only been using&a fraction of my&REAL power!/")
ds_map_add(global.text_data_en, "obj_asrielb_673", "\E2Let's see what good&your DETERMINATION&is against THIS!!/%%")
ds_map_add(global.text_data_en, "obj_asrielbed_87", "* \[C]^1, please.../")
ds_map_add(global.text_data_en, "obj_asrielbed_88", "* Wake up!/")
ds_map_add(global.text_data_en, "obj_asrielbed_89", "* You are the future&  of humans and&  monsters.../%%")
ds_map_add(global.text_data_en, "obj_asrielbed_93", "* (It felt strange to lie&  in the bed.)/")
ds_map_add(global.text_data_en, "obj_asrielbed_94", "* (It feels entirely too&  small for you now.)/%%")
ds_map_add(global.text_data_en, "obj_asrielfinal_58", "* You feel something faintly&  resonating within ASRIEL.")
ds_map_add(global.text_data_en, "obj_asrielfinal_59", "* You feel something&  resonating within ASRIEL.")
ds_map_add(global.text_data_en, "obj_asrielfinal_60", "* You feel something strongly&  resonating within ASRIEL.")
ds_map_add(global.text_data_en, "obj_asrielfinal_61", "* You feel your friends' SOULs&  resonating within ASRIEL!")
ds_map_add(global.text_data_en, "obj_asrielfinal_423", "* The whole world is ending.")
ds_map_add(global.text_data_en, "obj_asrielfinal_425", "* You feel something faintly&  resonating within ASRIEL.")
ds_map_add(global.text_data_en, "obj_asrielfinal_426", "* You feel something&  resonating within ASRIEL.")
ds_map_add(global.text_data_en, "obj_asrielfinal_427", "* You feel something strongly&  resonating within ASRIEL.")
ds_map_add(global.text_data_en, "obj_asrielfinal_428", "* You feel your friends' SOULs&  resonating within ASRIEL!")
ds_map_add(global.text_data_en, "obj_asrielfinal_429", "* ...")
ds_map_add(global.text_data_en, "obj_asrielfinal_468", "* Strangely^1, as your friends&  remembered you.../")
ds_map_add(global.text_data_en, "obj_asrielfinal_469", "* Something else began resonating&  within the SOUL^1, stronger&  and stronger./")
ds_map_add(global.text_data_en, "obj_asrielfinal_470", "* It seems that there's still&  one last person that needs&  to be saved./")
ds_map_add(global.text_data_en, "obj_asrielfinal_471", "* But who...?/")
ds_map_add(global.text_data_en, "obj_asrielfinal_472", "* .../")
ds_map_add(global.text_data_en, "obj_asrielfinal_473", "* Suddenly^1, you realize./")
ds_map_add(global.text_data_en, "obj_asrielfinal_474", "* You reach out and call&  their name./%%")
ds_map_add(global.text_data_en, "obj_asrielfinal_552", "* Can't move your body^1.&* Nothing happened./")
ds_map_add(global.text_data_en, "obj_asrielfinal_553", "* You struggle..^1.&* Nothing happened./")
ds_map_add(global.text_data_en, "obj_asrielfinal_554", "* You tried to reach your&  SAVE file^1.&* Nothing happened./")
ds_map_add(global.text_data_en, "obj_asrielfinal_555", "* You tried again to reach&  your SAVE file^1.&* Nothing happened./")
ds_map_add(global.text_data_en, "obj_asrielfinal_556", "* Seems SAVING the game really&  is impossible./")
ds_map_add(global.text_data_en, "obj_asrielfinal_559", "* SAVING over ASRIEL's file&  seems like the only way to&  defeat him.../")
ds_map_add(global.text_data_en, "obj_asrielfinal_560", "* But^1, having never SAVED&  before^1, you lack the power&  to do it./")
ds_map_add(global.text_data_en, "obj_asrielfinal_561", "* Seems SAVING the game really&  is impossible./")
ds_map_add(global.text_data_en, "obj_asrielfinal_563", "* .../")
ds_map_add(global.text_data_en, "obj_asrielfinal_564", "* Ale.../")
ds_map_add(global.text_data_en, "obj_asrielfinal_565", "* Maybe^1, with what little&  power you have.../")
ds_map_add(global.text_data_en, "obj_asrielfinal_566", "* You can SAVE something else./%%")
ds_map_add(global.text_data_en, "obj_asrielfinal_577", "* Can't move your body./^")
ds_map_add(global.text_data_en, "obj_asrielfinal_648", "* !?!?")
ds_map_add(global.text_data_en, "obj_asrielfinal_674", "Huh^1? What are you&doing...!?")
ds_map_add(global.text_data_en, "obj_asrielfinal_723", "")
ds_map_add(global.text_data_en, "obj_asrielfinal_724", "")
ds_map_add(global.text_data_en, "obj_asrielfinal_725", "")
ds_map_add(global.text_data_en, "obj_asrielfinal_726", "")
ds_map_add(global.text_data_en, "obj_asrielfinal_732", "")
ds_map_add(global.text_data_en, "obj_asrielfinal_737", "")
ds_map_add(global.text_data_en, "obj_asrielfinal_741", "")
ds_map_add(global.text_data_en, "obj_asrielfinal_746", "%%%")
ds_map_add(global.text_data_en, "obj_asrielfinal_767", "Urah ha ha ha...&Behold my TRUE power!/%%")
ds_map_add(global.text_data_en, "obj_asrielfinal_771", "I can feel it.../")
ds_map_add(global.text_data_en, "obj_asrielfinal_772", "Every time you die^1,&your grip on this&world slips away./")
ds_map_add(global.text_data_en, "obj_asrielfinal_773", "Every time you die^1,&your friends forget&you a little more./")
ds_map_add(global.text_data_en, "obj_asrielfinal_774", "Your life will end&here^1, in a world&where no one&remembers you.../%%")
ds_map_add(global.text_data_en, "obj_asrielfinal_779", "Still^1, you're&hanging on...?/")
ds_map_add(global.text_data_en, "obj_asrielfinal_780", "That's fine./")
ds_map_add(global.text_data_en, "obj_asrielfinal_781", "In a few moments^1,&you'll forget&everything^1, too./")
ds_map_add(global.text_data_en, "obj_asrielfinal_782", "That attitude will&serve you well in&your next life!/%%")
ds_map_add(global.text_data_en, "obj_asrielfinal_787", "Ura ha ha.../")
ds_map_add(global.text_data_en, "obj_asrielfinal_788", "Still!?/")
ds_map_add(global.text_data_en, "obj_asrielfinal_789", "Come on.../")
ds_map_add(global.text_data_en, "obj_asrielfinal_790", "Show me what good&your DETERMINATION&is now!/%%")
ds_map_add(global.text_data_en, "obj_asrielfinal_796", "Ultimate bepis/%%")
ds_map_add(global.text_data_en, "obj_asrielfinal_819", "\E1Wh..^1.&what did you do...?/")
ds_map_add(global.text_data_en, "obj_asrielfinal_820", "\E3What's this&feeling...^1?&What's happening&to me?/")
ds_map_add(global.text_data_en, "obj_asrielfinal_821", "\E2No^1! NO^1!&I don't need&ANYONE!/%%")
ds_map_add(global.text_data_en, "obj_asrielfinal_826", "\E6STOP IT^1!&Get away from me!/")
ds_map_add(global.text_data_en, "obj_asrielfinal_827", "Do you hear me!?/")
ds_map_add(global.text_data_en, "obj_asrielfinal_828", "\E2I'll tear you&apart!/%%")
ds_map_add(global.text_data_en, "obj_asrielfinal_833", "\E3.../")
ds_map_add(global.text_data_en, "obj_asrielfinal_834", "\E3.../")
ds_map_add(global.text_data_en, "obj_asrielfinal_835", "\[C]..^1.&Do you know why&I'm doing this...?/")
ds_map_add(global.text_data_en, "obj_asrielfinal_836", "Why I keep fighting&to keep you&around...?/%%")
ds_map_add(global.text_data_en, "obj_asrielfinal_841", "\E4I'm doing this.../")
ds_map_add(global.text_data_en, "obj_asrielfinal_842", "\E6Because you're&special^1, \[C]./")
ds_map_add(global.text_data_en, "obj_asrielfinal_843", "You're the only one&that understands&me./")
ds_map_add(global.text_data_en, "obj_asrielfinal_844", "You're the only one&who's any fun to&play with anymore./%%")
ds_map_add(global.text_data_en, "obj_asrielfinal_849", "\E4.../")
ds_map_add(global.text_data_en, "obj_asrielfinal_850", "No.../")
ds_map_add(global.text_data_en, "obj_asrielfinal_851", "\E1That's not JUST&it./")
ds_map_add(global.text_data_en, "obj_asrielfinal_852", "I..^1. I.../")
ds_map_add(global.text_data_en, "obj_asrielfinal_853", "\E4I'm doing this&because I care&about you^1, \[C]!/")
ds_map_add(global.text_data_en, "obj_asrielfinal_854", "\E4I care about you&more than anybody&else!/%%")
ds_map_add(global.text_data_en, "obj_asrielfinal_859", "\E4I'm not ready for&this to end./")
ds_map_add(global.text_data_en, "obj_asrielfinal_860", "I'm not ready for&you to leave./")
ds_map_add(global.text_data_en, "obj_asrielfinal_861", "I'm not ready to&say goodbye to&someone like&you again.../%%")
ds_map_add(global.text_data_en, "obj_asrielfinal_868", "\E7So, please..^1.&STOP doing this.../")
ds_map_add(global.text_data_en, "obj_asrielfinal_869", "AND JUST LET ME&WIN!!!/%%")
ds_map_add(global.text_data_en, "obj_asrielfinal_877", "\E5.../")
ds_map_add(global.text_data_en, "obj_asrielfinal_878", "\[C].../%%")
ds_map_add(global.text_data_en, "obj_asrielfinal_886", "\E5I'm so alone^1,&\[C].../%%")
ds_map_add(global.text_data_en, "obj_asrielfinal_894", "\E5I'm so afraid^1,&\[C].../%%")
ds_map_add(global.text_data_en, "obj_asrielfinal_903", "\[C]^1, I.../%%")
ds_map_add(global.text_data_en, "obj_asrielfinal_911", "I...")
ds_map_add(global.text_data_en, "obj_asrielfinal_976", "* You called out to your&  friends with all your&  heart./")
ds_map_add(global.text_data_en, "obj_asrielfinal_977", "* From somewhere^1, you felt&  their support.../^")
ds_map_add(global.text_data_en, "obj_asrielfinal_1007", "* You reached out to ASRIEL's&  SOUL and called out to your&  friends./")
ds_map_add(global.text_data_en, "obj_asrielfinal_1008", "* They're in there somewhere^1,&  aren't they?/")
ds_map_add(global.text_data_en, "obj_asrielfinal_1009", "* .../")
ds_map_add(global.text_data_en, "obj_asrielfinal_1010", "* Within the depths of ASRIEL's&  SOUL^1, something's resonating..!/%%")
ds_map_add(global.text_data_en, "obj_asrielfinal_1014", "* Within the depths of ASRIEL's&  SOUL^1, something's resonating..!/%%")
ds_map_add(global.text_data_en, "obj_assortedtrash_79", "* (Kładziesz rękę na&  zardzewiałym rowerze.^1)/")
ds_map_add(global.text_data_en, "obj_assortedtrash_80", "* (Jego trąbka wydusza z siebie&  dźwięk desperacji.)/%%")
ds_map_add(global.text_data_en, "obj_assortedtrash_86", "* (Podbity komputer.^1)&* (Jest pusty w środku.)/%%")
ds_map_add(global.text_data_en, "obj_assortedtrash_91", "* (To opakowanie po płycie DVD&  z anime.)/")
ds_map_add(global.text_data_en, "obj_assortedtrash_92", "* (Zdesperowane ślady pazurów&  pokrywają krawędzie.)/%%")
ds_map_add(global.text_data_en, "obj_astigmatism_210", "...&...")
ds_map_add(global.text_data_en, "obj_astigmatism_211", "You've&seen&enough.")
ds_map_add(global.text_data_en, "obj_astigmatism_212", "Take&your&last&look.")
ds_map_add(global.text_data_en, "obj_astigmatism_213", "...")
ds_map_add(global.text_data_en, "obj_astigmatism_220", "What are&you so&afraid&of?")
ds_map_add(global.text_data_en, "obj_astigmatism_222", "Finally,&someone&gets it.")
ds_map_add(global.text_data_en, "obj_astigmatism_228", "How&dare&you.")
ds_map_add(global.text_data_en, "obj_astigmatism_230", "That's&right!")
ds_map_add(global.text_data_en, "obj_astigmatism_236", "You&dare&defy me?")
ds_map_add(global.text_data_en, "obj_astigmatism_238", "You've&pushed&your&luck.")
ds_map_add(global.text_data_en, "obj_astigmatism_242", "That&takes&guts.")
ds_map_add(global.text_data_en, "obj_astigmatism_248", "...&Don't&pick on&me.")
ds_map_add(global.text_data_en, "obj_astigmatism_249", "...&Pick on&me.")
ds_map_add(global.text_data_en, "obj_astigmatism_254", "%%%")
ds_map_add(global.text_data_en, "obj_astigmatism_456", "* Astigmatism gazes through&  your soul.")
ds_map_add(global.text_data_en, "obj_astigmatism_457", "* Astigmatism gives you a&  hypnotizing glare.")
ds_map_add(global.text_data_en, "obj_astigmatism_458", "* Astigmatism clicks its teeth.")
ds_map_add(global.text_data_en, "obj_astigmatism_459", "* Smells like glasses.")
ds_map_add(global.text_data_en, "obj_astigmatism_460", "* Astigmatism has gone&  bloodshot.")
ds_map_add(global.text_data_en, "obj_astigmatism_461", "* Astigmatism doesn't care&  about fighting anymore.")
ds_map_add(global.text_data_en, "obj_astigmatism_462", "* Astigmatism is watering.")
ds_map_add(global.text_data_en, "obj_astigmatism_495", "* ASTIGMATISM - ATK 32 DEF 26&* This relentless bully ALWAYS&  gets its way./^")
ds_map_add(global.text_data_en, "obj_astigmatism_504", "* You pick on Astigmatism./^")
ds_map_add(global.text_data_en, "obj_astigmatism_518", "* You don't pick on Astigmatism./^")
ds_map_add(global.text_data_en, "obj_astigmatism_533", "* You stand up to Astigmatism./^")
ds_map_add(global.text_data_en, "obj_astigmatism_534", "* You stand up to Astigmatism^1.&* The other monsters are&  impressed./^")
ds_map_add(global.text_data_en, "obj_autowater_81", "* (The cup of water returned&  to the water cooler.)/%%")
ds_map_add(global.text_data_en, "obj_autowater_85", "* (The cup of water was erased&  by a mysterious force.)/%%")
ds_map_add(global.text_data_en, "obj_autowater_89", "* (The water evaporated from&  the heat.)/")
ds_map_add(global.text_data_en, "obj_autowater_90", "* (The cup evaporated^1, too.)/%%")
ds_map_add(global.text_data_en, "obj_bara01_252", "Like,&give us&the soul&brah.")
ds_map_add(global.text_data_en, "obj_bara01_253", "Like,&" + '"' + "you're&dead" + '"' + "&and all.")
ds_map_add(global.text_data_en, "obj_bara01_254", "Like,&prepare&to die,&right?")
ds_map_add(global.text_data_en, "obj_bara01_255", "Like,&perish&and&stuff.")
ds_map_add(global.text_data_en, "obj_bara01_259", "D...&Dude...")
ds_map_add(global.text_data_en, "obj_bara01_262", "Like,&team&attack!")
ds_map_add(global.text_data_en, "obj_bara01_266", "Like...&what?&I don't&get it.")
ds_map_add(global.text_data_en, "obj_bara01_267", "I...&I...")
ds_map_add(global.text_data_en, "obj_bara01_272", "Like,&hands&off the&merch.")
ds_map_add(global.text_data_en, "obj_bara01_278", "H-HEY,&STOP&THAT!!")
ds_map_add(global.text_data_en, "obj_bara01_285", "02...&this is,&like,&for you.")
ds_map_add(global.text_data_en, "obj_bara01_286", "Like,&02...")
ds_map_add(global.text_data_en, "obj_bara01_287", "02...&are you&really..")
ds_map_add(global.text_data_en, "obj_bara01_288", "...")
ds_map_add(global.text_data_en, "obj_bara01_291", "02...&I never&told&him...")
ds_map_add(global.text_data_en, "obj_bara01_293", "02!?&B-but&why!?")
ds_map_add(global.text_data_en, "obj_bara01_300", "%%%")
ds_map_add(global.text_data_en, "obj_bara01_524", "* 02 seems to be bothered by&  his outfit.")
ds_map_add(global.text_data_en, "obj_bara01_525", "* 01 is polishing his face.")
ds_map_add(global.text_data_en, "obj_bara01_526", "* 01 stands guard.")
ds_map_add(global.text_data_en, "obj_bara01_527", "* 02 watches your movements.")
ds_map_add(global.text_data_en, "obj_bara01_528", "* Smells like a military zoo.")
ds_map_add(global.text_data_en, "obj_bara01_535", "* 01 holds his head in his&  hands.")
ds_map_add(global.text_data_en, "obj_bara01_536", "* Anguished noises come from&  inside 01's armor.")
ds_map_add(global.text_data_en, "obj_bara01_537", "* 01 stands still.")
ds_map_add(global.text_data_en, "obj_bara01_538", "* 01 doesn't know what to do.")
ds_map_add(global.text_data_en, "obj_bara01_542", "* 01's breathing intensifies.")
ds_map_add(global.text_data_en, "obj_bara01_558", "* RG 01 - ATK 30 DEF 20&* Royal Guard member with&  shining^1, polished armor./^")
ds_map_add(global.text_data_en, "obj_bara01_561", "* I see two lovers staring over&  the edge of the cauldron of&  hell./^")
ds_map_add(global.text_data_en, "obj_bara01_571", "* You attempt to touch RG 01's&  armor^1.&* Your hands slip off./^")
ds_map_add(global.text_data_en, "obj_bara01_581", "* You tell RG 01 to be honest&  with his feelings./^")
ds_map_add(global.text_data_en, "obj_bara01_615", "D-dude&.../")
ds_map_add(global.text_data_en, "obj_bara01_616", "I can't&.../")
ds_map_add(global.text_data_en, "obj_bara01_617", "I can't&take&this&anymore!/")
ds_map_add(global.text_data_en, "obj_bara01_618", "Not like&this!!/%%")
ds_map_add(global.text_data_en, "obj_bara01_632", "Like^1, 02!&I like.../")
ds_map_add(global.text_data_en, "obj_bara01_633", "I like^1, LIKE you^1,&bro!/")
ds_map_add(global.text_data_en, "obj_bara01_634", "The way you fight..^1.&The way you talk.../")
ds_map_add(global.text_data_en, "obj_bara01_635", "I love doing team&attacks with you./")
ds_map_add(global.text_data_en, "obj_bara01_636", "I love standing here&with you^1, bouncing&and waving our&weapons in sync.../")
ds_map_add(global.text_data_en, "obj_bara01_637", "02..^1.&I^1, like^1, want to stay&like this forever.../%%")
ds_map_add(global.text_data_en, "obj_bara01_650", "^1.^1../")
ds_map_add(global.text_data_en, "obj_bara01_651", "^1.^1.^1.^1./%%")
ds_map_add(global.text_data_en, "obj_bara01_663", "Uh.../")
ds_map_add(global.text_data_en, "obj_bara01_664", "I mean,&uh.../")
ds_map_add(global.text_data_en, "obj_bara01_665", "Psyche!&Gotcha,&bro!!!&Haha!/%%")
ds_map_add(global.text_data_en, "obj_bara01_668", "Whew,&bro!&That&human,/")
ds_map_add(global.text_data_en, "obj_bara01_669", "Put me&under,&uh, mind&control!/")
ds_map_add(global.text_data_en, "obj_bara01_670", "What was&I just&saying?/")
ds_map_add(global.text_data_en, "obj_bara01_671", "It's all&a blur,&dude!!&Whoops!/%%")
ds_map_add(global.text_data_en, "obj_bara01_687", "... 01./%%")
ds_map_add(global.text_data_en, "obj_bara01_699", "Y-yeah,&bro??/%%")
ds_map_add(global.text_data_en, "obj_bara01_716", ".../")
ds_map_add(global.text_data_en, "obj_bara01_717", "... do&you want&to.../")
ds_map_add(global.text_data_en, "obj_bara01_718", "... get&some ice&cream.../")
ds_map_add(global.text_data_en, "obj_bara01_719", "...&after&this?/%%")
ds_map_add(global.text_data_en, "obj_bara01_731", "Like.../")
ds_map_add(global.text_data_en, "obj_bara01_732", "Sure,&dude!&Haha!/%%")
ds_map_add(global.text_data_en, "obj_bara01_751", "* 01 and 02 are looking at&  each other happily.")
ds_map_add(global.text_data_en, "obj_bara02_256", "...&...&...&sigh.")
ds_map_add(global.text_data_en, "obj_bara02_257", "...&...&heh.")
ds_map_add(global.text_data_en, "obj_bara02_258", "...&...&what?")
ds_map_add(global.text_data_en, "obj_bara02_259", "...&...&hmph.")
ds_map_add(global.text_data_en, "obj_bara02_262", "...&team&attack.")
ds_map_add(global.text_data_en, "obj_bara02_266", "...&i&won't&tell.")
