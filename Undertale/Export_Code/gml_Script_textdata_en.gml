ds_map_add(global.text_data_en, "item_desc_30_0", "* " + '"' + "Pozostałości Piesa" + '"' + " - Pieseł&* Łuska w kształcie psa zrzucana&  przez skorupę piesa/%%")
ds_map_add(global.text_data_en, "item_desc_31_0", "* " + '"' + "Pozostałości Piesa" + '"' + " - Pieseł&* Brudne naczynia pozostawione&  nieumyte przez piesa./%%")
ds_map_add(global.text_data_en, "item_desc_32_0", "* " + '"' + "Pozostałości Piesa" + '"' + " - Pieseł&* Świecące kryształy wydzielane&  przez piesa./%%")
ds_map_add(global.text_data_en, "item_desc_33_0", "* " + '"' + "Pozostałości Piesa" + '"' + " - Pieseł&* Puzzle pozostawione&  niedokończone przez piesa./%%")
ds_map_add(global.text_data_en, "item_desc_34_0", "* " + '"' + "Pozostałości Piesa" + '"' + " - Pieseł&* Sieć utkana przez piesa w celu&  oplątania ofiary./%%")
ds_map_add(global.text_data_en, "item_desc_35_0", "* " + '"' + "Jedzenie Kosmosu" + '"' + " Leczy 21 HP&* Do karmienia kosmicznego&  zwierzaka./%%")
ds_map_add(global.text_data_en, "item_desc_36_0", "* " + '"' + "Kluski Instant" + '"' + " Leczy HP&* Wszystko, czego potrzebujesz&  do szybkiego posiłku!/%%")
ds_map_add(global.text_data_en, "item_desc_37_0", "* " + '"' + "Krabie Japko" + '"' + " Leczy 18 HP&* Wodny owoc, który&  przypomina skorupiaka./%%")
ds_map_add(global.text_data_en, "item_desc_38_0", "* " + '"' + "Hot Dog...?" + '"' + " Leczy 20 HP&* " + '"' + "Mięso" + '"' + " jest zrobione z czegoś&  o nazwie " + '"' + "Wodna Parówka." + '"' + "/%%")
ds_map_add(global.text_data_en, "item_desc_39_0", "* " + '"' + "Hot Cat" + '"' + " Leczy 21 HP&* Jak hot dog^1, ale z&  małymi kocimi uszami na końcu./%%")
ds_map_add(global.text_data_en, "item_desc_40_0", "* " + '"' + "Glamburger" + '"' + " Leczy 27 HP&* Hamburger zrobiony z jadalnego&  brokatu i cekin./%%")
ds_map_add(global.text_data_en, "item_desc_41_0", "* " + '"' + "Oceanowa Herbata" + '"' + " Leczy 10 HP&* Zrobiona ze świecącej wody.&* Podwyższa PRĘDKOŚĆ na jedną walkę./%%")
ds_map_add(global.text_data_en, "item_desc_42_0", "* " + '"' + "Starfait" + '"' + " Leczy 14 HP&* Słodki poczęstunek zrobiony z&  błyskotliwych gwiazdek./%%")
ds_map_add(global.text_data_en, "item_desc_43_0", "* " + '"' + "Legend. Bohater" + '"' + " Leczy 40 HP&* Kanapka w kształcie miecza.&* Podwyższa ATAK kiedy zjedzona./%%")
ds_map_add(global.text_data_en, "item_desc_44_0", "* " + '"' + "Zadym. Okulary" + '"' + " - Zbroja DF 6&* Okulary ze śladami użytkowania.&* Podwyższa INV o 9./")
ds_map_add(global.text_data_en, "item_desc_44_1", "* (Kiedy zostajesz obrażony po&  ataku^1, zostajesz nietykalny&  na dłużej.)/%%")
ds_map_add(global.text_data_en, "item_desc_45_0", "* " + '"' + "Zeszyt Toma" + '"' + " - Broń AT 2&* Zabiera nieczytelne bazgroły.&* Podwyższa INV o 6./%")
ds_map_add(global.text_data_en, "item_desc_45_1", "* (Kiedy zostajesz obrażony po&  ataku^1, zostajesz nietykalny&  na dłużej.)/%%")
ds_map_add(global.text_data_en, "item_desc_46_0", "* " + '"' + "Poplam.Fartuch" + '"' + " - Zbroja DF 11&* Leczy 1 HP co drugą kolejkę./%")
ds_map_add(global.text_data_en, "item_desc_47_0", "* " + '"' + "Spalona Patelnia" + '"' + " - Broń AT 10&* Obrażenia są raczej niezmienne.&* Jedzenie leczy 4 HP więcej./%")
ds_map_add(global.text_data_en, "item_desc_48_0", "* " + '"' + "Czapka Kowboja" + '"' + " - Zbroja DF 12&* Ta powojenna czapka&  chce zapuścić brodę./")
ds_map_add(global.text_data_en, "item_desc_48_1", "* Również podwyższa ATAK o 5./%")
ds_map_add(global.text_data_en, "item_desc_49_0", "* " + '"' + "Pusty Rewolwer" + '"' + " - Broń AT 12&* Antyczny rewolwer^1.&* Nie ma amunicji (ale działa)./")
ds_map_add(global.text_data_en, "item_desc_49_1", "* Musi być użyte precyzyjnie,&  albo obrażenia będą słabe./%")
