ds_map_add(global.text_data_en, "obj_papyrus8_184", "CZŁOWIEKU./")
ds_map_add(global.text_data_en, "obj_papyrus8_185", "POZWÓL MI SIĘ PRZYZNAĆ&DO NIECO KOMPLEK-&SOWYCH UCZUĆ./")
ds_map_add(global.text_data_en, "obj_papyrus8_188", "ODZIWO^1, CZUJĘ^1, JAKBYŚ&BYŁ DAWNYM ZNAJOMYM.../")
ds_map_add(global.text_data_en, "obj_papyrus8_189", "CHOCIAŻ JESZCZE NIGDY&NIE MIELIŚMY NAWET&OKAZJI SIĘ POZNAĆ!!/")
ds_map_add(global.text_data_en, "obj_papyrus8_190", "NIE UMIEM OKREŚLIĆ&POWODU DLA KTÓREGO&TAK SIĘ CZUJĘ.../")
ds_map_add(global.text_data_en, "obj_papyrus8_191", "CZYŻBYM CIĘ POZNAŁ&ONLINE???/")
ds_map_add(global.text_data_en, "obj_papyrus8_192", "MAM WIELE POŁĄCZEŃ W&" + '"' + "MEDIACH SPOŁECZ-&NOŚCIOWYCH." + '"' + "/")
ds_map_add(global.text_data_en, "obj_papyrus8_193", "CIĘŻKO JEST NADĄŻAĆ&NAD WSZYSTKIM./")
ds_map_add(global.text_data_en, "obj_papyrus8_194", "JESZCZE DZIESIĘĆ^1, A.../")
ds_map_add(global.text_data_en, "obj_papyrus8_195", "W KOŃCU OSIĄGNĘ&DWIE CYFRY!!!/")
ds_map_add(global.text_data_en, "obj_papyrus8_196", "... HEJ^1, CHWILA MOMENT!/")
ds_map_add(global.text_data_en, "obj_papyrus8_197", "NIE MOŻESZ BYĆ&PRZYJACIELEM!!^1!&JESTEŚ CZŁOWIEKIEM!/")
ds_map_add(global.text_data_en, "obj_papyrus8_198", "NIE WIERZĘ^1, ŻE PRAWIE&MNIE OSZUKAŁEŚ DO&NIEPOKONYWANIA CIĘ!!!/")
ds_map_add(global.text_data_en, "obj_papyrus8_199", "WHOOPSIE DOOPSIE!/%%")
ds_map_add(global.text_data_en, "obj_papyrus8_202", "TAKIE UCZUCIA JAK.../")
ds_map_add(global.text_data_en, "obj_papyrus8_203", "RADOŚĆ W ZNALEZIENIU&KOLEJNEGO MIŁOŚNIKA&MAKARONU./")
ds_map_add(global.text_data_en, "obj_papyrus8_204", "PODZIW CZYJEJŚ&UMIEJĘTNOŚCI&ROZWIĄZYWANIA PUZZLI./")
ds_map_add(global.text_data_en, "obj_papyrus8_205", "PRAGNIENIE BY MIEĆ FAJNĄ^1,&MĄDRĄ OSOBĘ MYŚLĄCĄ ŻE&TEŻ JESTEŚ FAJNY./")
ds_map_add(global.text_data_en, "obj_papyrus8_206", "TE UCZUCIA.../")
ds_map_add(global.text_data_en, "obj_papyrus8_207", "TO MUSI BYĆ TO^1,&CO CZUJESZ WŁAŚNIE&W TYM MOMENCIE!!!/")
ds_map_add(global.text_data_en, "obj_papyrus8_208", "MOGĘ SOBIE WYOBRAZIĆ&JAK TO JEST SIĘ CZUĆ&W TEN SPOSÓB./")
ds_map_add(global.text_data_en, "obj_papyrus8_209", "W KOŃCU^1, JESTEM SUPER./")
ds_map_add(global.text_data_en, "obj_papyrus8_210", "NIGDY SOBIE NIE MYŚLĘ&JAK TO JEST MIEĆ&WIELE PRZYJACIÓŁ./")
ds_map_add(global.text_data_en, "obj_papyrus8_211", "ŻALĘ SIĘ NAD TOBĄ..^1.&SAMOTNY CZŁOWIEKU.../")
ds_map_add(global.text_data_en, "obj_papyrus8_212", "NATOMIAST NIE OBA-&WIAJ SIĘ!!^1! JUŻ NIGDY&NIE BĘDZISZ SAMOTNY!/")
ds_map_add(global.text_data_en, "obj_papyrus8_213", "BO JA^1, WIELKI&PAPYRUS^1, BĘDĘ&TWOIM.../")
ds_map_add(global.text_data_en, "obj_papyrus8_214", " ^2.^2../")
ds_map_add(global.text_data_en, "obj_papyrus8_215", "NIE.../")
ds_map_add(global.text_data_en, "obj_papyrus8_216", "NIE^1, TO WSZYSTKO&NIE TAK!/")
ds_map_add(global.text_data_en, "obj_papyrus8_217", "NIE MOGĘ BYĆ TWYM&PRZYJACIELEM!!!/")
ds_map_add(global.text_data_en, "obj_papyrus8_218", "JESTEŚ CZŁOWIEKIEM!/")
ds_map_add(global.text_data_en, "obj_papyrus8_219", "MUSZĘ CIĘ&PORWAĆ!!!/")
ds_map_add(global.text_data_en, "obj_papyrus8_220", "WTEDY^1, BĘDĘ MÓGŁ&SPEŁNIĆ MOJEŻYCIOWE&MARZENIE!!!/")
ds_map_add(global.text_data_en, "obj_papyrus8_221", "POTĘŻNY^1!&POPULARNY^1!&PRESTIŻOWY!!!/")
ds_map_add(global.text_data_en, "obj_papyrus8_222", "TO JEST PAPYRUS!!!/")
ds_map_add(global.text_data_en, "obj_papyrus8_223", "NAJNOWSZY CZŁONEK.../")
ds_map_add(global.text_data_en, "obj_papyrus8_224", "KRÓLEWSKIEJ GWARII!/%%")
ds_map_add(global.text_data_en, "obj_papyrus8_227", "OH..^1.&GDZIEŻ MÓGŁ SIĘ TEN&CZŁOWIEK POCZĄŚĆ./")
ds_map_add(global.text_data_en, "obj_papyrus8_228", "... CHWILA..^1.&JEST TUŻ&PRZEDE MNĄ!!!/")
ds_map_add(global.text_data_en, "obj_papyrus8_229", "HALO^1!&MARTWIŁEM SIĘ ŻE&SIĘ ZAGUBIŁEŚ!/")
ds_map_add(global.text_data_en, "obj_papyrus8_230", "TO WIELKA ULGA&WIEDZIEĆ ŻE JESTEŚ&TUTAJ.../")
ds_map_add(global.text_data_en, "obj_papyrus8_231", "... CHWILA MOMENT!!!/")
ds_map_add(global.text_data_en, "obj_papyrus8_232", "NIE POWINIENEŚ BYĆ&W STANIE UWOLNIĆ&SIĘ!!!/")
ds_map_add(global.text_data_en, "obj_papyrus8_233", "WRACAJ TU!!!/%%")
ds_map_add(global.text_data_en, "obj_papyrus8_237", "NAJWYRAŹNIEJ TO&UDOWADNIA&MÓJ PUNKT./")
ds_map_add(global.text_data_en, "obj_papyrus8_238", "NAPRAWDĘ JESTEŚMY&DO SIEBIE&PRZYWIĄZANI./")
ds_map_add(global.text_data_en, "obj_papyrus8_239", "DWIE KOŚCI W&KOŚĆCOWEJ&ANATOMII LOSU!!!/")
ds_map_add(global.text_data_en, "obj_papyrus8_240", "TO UDOWADNIA&TWÓJ POWRÓT.../")
ds_map_add(global.text_data_en, "obj_papyrus8_241", "POMIMO TEGO ŻE TO&NIEMOŻLIWE BYŚ SIĘ&UWOLNIŁ./")
ds_map_add(global.text_data_en, "obj_papyrus8_242", "WSPANIAŁE!!!/")
ds_map_add(global.text_data_en, "obj_papyrus8_243", "CZUJĘ SZCZERĄ.../")
ds_map_add(global.text_data_en, "obj_papyrus8_244", "CHWIIIIIIILA MOMENT!!/")
ds_map_add(global.text_data_en, "obj_papyrus8_245", "DALEJ MUSZĘ CIĘ&PORWAĆ!!!/")
ds_map_add(global.text_data_en, "obj_papyrus8_246", "WHOOPSIE-DOOPSIE!!/%%")
ds_map_add(global.text_data_en, "obj_papyrus8_252", "ZNÓW POWRACASZ^1,&EH?/")
ds_map_add(global.text_data_en, "obj_papyrus8_253", "MYŚLĘ^1, ŻE TO&MOJA WINA.../")
ds_map_add(global.text_data_en, "obj_papyrus8_254", "MÓWIŁEM CI JUŻ ŻE&UGOTUJĘ CI&SPAGHETTI./")
ds_map_add(global.text_data_en, "obj_papyrus8_255", "TO ZROZUMIAŁE ŻE&CHCIAŁEŚ MNIE&ZOBACZYĆ.../")
ds_map_add(global.text_data_en, "obj_papyrus8_256", "W LITOSNEJ NADZIEI^1,&ŻE CI TROCHĘ ZROBIĘ./")
ds_map_add(global.text_data_en, "obj_papyrus8_257", "CÓŻ..^1. ROZUMIEM./")
ds_map_add(global.text_data_en, "obj_papyrus8_258", "PAPYRUS TEŻ JEST^1,&GŁODNY!/")
ds_map_add(global.text_data_en, "obj_papyrus8_259", "GŁODNY NA&WYMIERZENIE&SPRAWIEDLIWOŚCI!/%%")
ds_map_add(global.text_data_en, "obj_papyrus8_271", "HALT^1, CZŁOWIEKU!/%%")
ds_map_add(global.text_data_en, "obj_papyrus8_386", "I WAS NEVER ONE&  TO BEPIS./%%")
ds_map_add(global.text_data_en, "obj_papyrus8_414", "\E1OH^1, PRAWIE&ZAPOMNIAŁEM CI&POWIEDZIEĆ.../")
ds_map_add(global.text_data_en, "obj_papyrus8_415", "ABY DOJŚĆ DO&WYJŚCIA^1, BĘDZIESZ&MUSIAŁ OBEJŚĆ.../")
ds_map_add(global.text_data_en, "obj_papyrus8_416", "\WPRZEZ ZAMEK&\YKRÓLA\W./")
ds_map_add(global.text_data_en, "obj_papyrus8_419", "ABY DOJŚĆ DO&WYJŚCIA^1, BĘDZIESZ&MUSIAŁ SPOTKAĆ.../")
ds_map_add(global.text_data_en, "obj_papyrus8_420", "KRÓLA./")
ds_map_add(global.text_data_en, "obj_papyrus8_422", "\YKRÓLA WSZYSTKICH&POTWORÓW.../")
ds_map_add(global.text_data_en, "obj_papyrus8_423", "ON JEST.../")
ds_map_add(global.text_data_en, "obj_papyrus8_424", "... CÓŻ.../%%")
ds_map_add(global.text_data_en, "obj_papyrus8_441", "\E0JEST PUCHATYM&MISIEM!!!/")
ds_map_add(global.text_data_en, "obj_papyrus8_442", "KAŻDY GO KOCHA./")
ds_map_add(global.text_data_en, "obj_papyrus8_443", "JESTEM PEWIEN^1, ŻE&JEŚLI POWIESZ.../")
ds_map_add(global.text_data_en, "obj_papyrus8_444", '"' + "PRZEPRASZAM^1, PANIE&DREEMURR..^1. CZY MOGĘ&PROSZĘ IŚĆ DO DOMU?" + '"' + "/")
ds_map_add(global.text_data_en, "obj_papyrus8_445", "TO POKIERUJE CIĘ&OSOBIŚCIE PROSTO&DO BARIERY!/")
ds_map_add(global.text_data_en, "obj_papyrus8_446", "W KAŻDYM RAZIE!!^1!&WYSTARCZY&GADANIA!!!/")
ds_map_add(global.text_data_en, "obj_papyrus8_447", "BĘDĘ W DOMU&BĘDĄC CZADOWYM&ZIOMEM!!!/")
ds_map_add(global.text_data_en, "obj_papyrus8_448", "NIE KRĘPUJ SIĘ^1, BY&PRZYJŚĆ I CHILLOWAĆ!!!/")
ds_map_add(global.text_data_en, "obj_papyrus8_449", "NIE KRĘPUJ SIĘ^1, BY&PRZYJŚĆ I MIEĆ TĄ&RANDKĘ!/")
ds_map_add(global.text_data_en, "obj_papyrus8_450", "NYEH HEH HEH&HEH HEH HEH!!!/%%")
ds_map_add(global.text_data_en, "obj_papyrus8_515", "HEJ^1, PRZESTAŃ SIĘ&RUSZAĆ KIEDY Z&TOBĄ ROZMAWIAM!/")
ds_map_add(global.text_data_en, "obj_papyrus8_516", "JA^1, WIELKI PAPYRUS^1,&MAM PARĘ RZECZY&DO POWIEDZENIA./")
ds_map_add(global.text_data_en, "obj_papyrus8_517", "PIERWSZA^1: JESTEŚ&JAKIMŚ OBŁĘDNYM&PSYCHOLEM!/")
ds_map_add(global.text_data_en, "obj_papyrus8_518", "NIE TYLKO NIE&LUBISZ PUZZLI./")
ds_map_add(global.text_data_en, "obj_papyrus8_519", "ALE SAM SPOSÓB W&JAKI PRZEMIESZCZASZ&SIĘ PRZEZ SNOWDIN.../")
ds_map_add(global.text_data_en, "obj_papyrus8_520", "SAM FAKT^1, ŻE TWOJE&RĘCE SĄ ZAWSZE&POKRYTE W PROCHU./")
ds_map_add(global.text_data_en, "obj_papyrus8_521", "WYDAJE SIĘ.../")
ds_map_add(global.text_data_en, "obj_papyrus8_522", "ŻE TWOJE ŻYCIE&TOCZY SIĘ BARDZO&TOKSYCZNĄ ŚCIEŻKĄ./")
ds_map_add(global.text_data_en, "obj_papyrus8_523", "JEDNAK!/")
ds_map_add(global.text_data_en, "obj_papyrus8_524", "JA^1, PAPYRUS^1, WIDZĘ&W TOBIE WIELKI&POTENCJAŁ!/")
ds_map_add(global.text_data_en, "obj_papyrus8_525", "KAŻDY MOŻE BYĆ&DOBRĄ OSOBĄ JEŚLI&SIĘ POSTARA!/")
ds_map_add(global.text_data_en, "obj_papyrus8_526", "A JA^1, JA LEDWO&MUSZĘ SIĘ STARAĆ&WOGULE!!!/")
ds_map_add(global.text_data_en, "obj_papyrus8_527", "NYEH HEH HEH&HEH HEH HEH!!! /%%")
ds_map_add(global.text_data_en, "obj_papyrus8_555", "HEJ^1, PRZESTAŃ&SIĘ RUSZAĆ!/")
ds_map_add(global.text_data_en, "obj_papyrus8_556", "WŁAŚNIE DOKŁADNIE&O TYM MÓWIĘ!/")
ds_map_add(global.text_data_en, "obj_papyrus8_557", "CZŁOWIEKU^1!&MYŚLĘ^1, ŻE POTRZE-&BUJESZ POMOCY!/")
ds_map_add(global.text_data_en, "obj_papyrus8_558", "KTOŚ CIĘ MUSI&SPROSTOWAĆ NA&DOBRĄ ŚCIEŻKĘ!/")
ds_map_add(global.text_data_en, "obj_papyrus8_559", "ALE NIE MARTW SIĘ!&JA^1, PAPYRUS.../")
ds_map_add(global.text_data_en, "obj_papyrus8_560", "Z CHĘCIĄ BĘDĘ&TWOIM PRZYJACIELEM&I KOREPETYTOREM!/")
ds_map_add(global.text_data_en, "obj_papyrus8_561", "PRZEMIENIĘ TWOJE&ŻYCIE NA LEPSZE!!!/%%")
ds_map_add(global.text_data_en, "obj_papyrus8_590", "WIDZĘ, ŻE&PODCHODZISZ./")
ds_map_add(global.text_data_en, "obj_papyrus8_591", "OFERUJESZ MI&PRZYTULASA&AKCEPTACJI?/")
ds_map_add(global.text_data_en, "obj_papyrus8_592", "WOWIE!^1! MOJE LEKCJE&JUŻ ZACZYNAJĄ&DZIAŁAĆ!!/")
ds_map_add(global.text_data_en, "obj_papyrus8_593", "JA^1, PAPYRUS^1,&WITAM CIĘ Z OTWAR-&TYMI RAMIONAMI!/%%")
ds_map_add(global.text_data_en, "obj_papyrus_friendc_76", "\E3SO^1, ASGORE.../")
ds_map_add(global.text_data_en, "obj_papyrus_friendc_77", "\E0HOW ABOUT MAKING&ME A MEMBER OF&THE ROYAL GUARD?/")
ds_map_add(global.text_data_en, "obj_papyrus_friendc_79", "\E2* Well^1, Papyrus^1, now&  that the war is&  over.../")
ds_map_add(global.text_data_en, "obj_papyrus_friendc_80", "\E0* We might not need&  the Royal Guard&  anymore./")
ds_map_add(global.text_data_en, "obj_papyrus_friendc_82", "\E7WHAT!?/")
ds_map_add(global.text_data_en, "obj_papyrus_friendc_83", "\E1THEN WHAT WAS&THE POINT OF THE&HUMAN'S QUEST!?/")
ds_map_add(global.text_data_en, "obj_papyrus_friendc_84", "\E3THEY JOURNEYED&ALL THAT WAY.../")
ds_map_add(global.text_data_en, "obj_papyrus_friendc_85", "\E4AND I'M STILL&NOT A MEMBER OF&THE ROYAL GUARD!?/")
ds_map_add(global.text_data_en, "obj_papyrus_friendc_86", "\E0TRULY^1, THIS IS&THE WORST&POSSIBLE ENDING./%%")
ds_map_add(global.text_data_en, "obj_papyrus_friendc_91", "\E3IT SEEMS LIKE YOU&REALLY BOTCHED&YOUR QUEST^1, FRISK./")
ds_map_add(global.text_data_en, "obj_papyrus_friendc_92", "\E0BUT^1, I^1, THE&GREAT PAPYRUS.../")
ds_map_add(global.text_data_en, "obj_papyrus_friendc_93", "WILL ALWAYS BE&YOUR FRIEND!!!/")
ds_map_add(global.text_data_en, "obj_papyrus_friendc_95", "\E1* no matter how hard&  you try to get&  rid of him./")
ds_map_add(global.text_data_en, "obj_papyrus_friendc_97", "\E1HEY!/")
ds_map_add(global.text_data_en, "obj_papyrus_friendc_98", "\E0THAT'S TRUE./%%")
ds_map_add(global.text_data_en, "obj_papyrus_friendc_103", "\E3FRISK^1, WHY DON'T&YOU TAKE A WALK&AROUND?/")
ds_map_add(global.text_data_en, "obj_papyrus_friendc_105", "\E1* frisk^1, why don't you&  fly^1?&* it's faster./")
ds_map_add(global.text_data_en, "obj_papyrus_friendc_107", "\E0YEAH^1, FRISK^1, WHY&DON'T YOU FLY?/")
ds_map_add(global.text_data_en, "obj_papyrus_friendc_109", "\E1* Hmmm..^1. Flying sounds&  a little dangerous./")
ds_map_add(global.text_data_en, "obj_papyrus_friendc_111", "\E3* But they CAN'T fly./")
ds_map_add(global.text_data_en, "obj_papyrus_friendc_113", "\E2* Not with THAT&  attitude!/%%")
ds_map_add(global.text_data_en, "obj_papyrus_friendc_118", "\E3FRISK..^1.&TAKE A HIKE./")
ds_map_add(global.text_data_en, "obj_papyrus_friendc_119", "\E0HIKING IS GOOD&FOR YOUR BONES./%%")
ds_map_add(global.text_data_en, "obj_papyrus_guide_82", "WITAJ W MOIM&SCENICZNYM DOMU!/")
ds_map_add(global.text_data_en, "obj_papyrus_guide_83", "BAW SIĘ&DOBRZE!!!/%%")
ds_map_add(global.text_data_en, "obj_papyrus_guide_84", "WOW! BYCIE DOBRYM&GOSPODARZEM TO&WIELKI WYSIŁEK!/%%")
ds_map_add(global.text_data_en, "obj_papyrus_guide_88", "\E3NIE CZUJĘ MOICH&NÓG.../")
ds_map_add(global.text_data_en, "obj_papyrus_guide_89", "\E0TO MUSI ZNACZYĆ ŻE&JESTEM ŚWIETNYM&GOSPODARZEM!!!!/%%")
ds_map_add(global.text_data_en, "obj_papyrus_hisroom_86", "POZWIEDZAJ&SOBIE!/%%")
ds_map_add(global.text_data_en, "obj_papyrus_houseoutside_109", "A WIĘC WRÓCIŁEŚ^1,&ABY PÓJŚĆ ZE MNĄ&NA RANDKĘ!/")
ds_map_add(global.text_data_en, "obj_papyrus_houseoutside_110", "A WIĘC WROCIŁEŚ^1,&BY MNIE ZOBACZYĆ!/")
ds_map_add(global.text_data_en, "obj_papyrus_houseoutside_111", "\E3MUSISZ BRAĆ TO&CAŁKIEM POWAŻNIE.../")
ds_map_add(global.text_data_en, "obj_papyrus_houseoutside_112", "\E2MUSZĘ ZABRAĆ CIĘ&DO SPECJALNEGO&MIEJSCA....../")
ds_map_add(global.text_data_en, "obj_papyrus_houseoutside_113", "\E0DO MIEJSCA W&KTÓRYM LUBIE SPĘ-&DZAĆ DUŻO CZASU!!!/%%")
ds_map_add(global.text_data_en, "obj_papyrus_houseoutside_303", "MÓJ DOM!!!/%%")
ds_map_add(global.text_data_en, "obj_papyrus_room_119", "MÓJ BRAT ZACZĄŁ&OSTATNIO KOLEK-&CJONOWAĆ SKARPETY./")
ds_map_add(global.text_data_en, "obj_papyrus_room_120", "\E3JAK SMUTNE.../")
ds_map_add(global.text_data_en, "obj_papyrus_room_121", "\E0CZASAMI SIĘ&ZASTANAWIAM&CO BY ZROBIŁ.../")
ds_map_add(global.text_data_en, "obj_papyrus_room_122", "BEZ TAKIEGO CZADO-&WEGO SZKIELETA&JAK JA???/")
ds_map_add(global.text_data_en, "obj_papyrus_room_123", "NYEH HEH HEH!/%%")
ds_map_add(global.text_data_en, "obj_papyrus_room_129", "A WIĘC^1, CHCESZ&WSKAZÓWKĘ^1, HUH?/")
ds_map_add(global.text_data_en, "obj_papyrus_room_130", "\E3CÓŻ..^1.&PATRZYŁEM NA&TĄ ŁAMIGÓWKĘ.../")
ds_map_add(global.text_data_en, "obj_papyrus_room_131", "I MYŚLĘ ŻE&ROZWIĄZANIEM.../")
ds_map_add(global.text_data_en, "obj_papyrus_room_132", "\E0JEST ZAMIENIĆ&WSZYSTKIE X NA O!/")
ds_map_add(global.text_data_en, "obj_papyrus_room_133", "POWINIENEŚ TO&WYPRÓBOWAĆ!/")
ds_map_add(global.text_data_en, "obj_papyrus_room_134", "ZAGADAJ POTEM&PO WIĘCEJ TAKICH&PORAD!/%%")
ds_map_add(global.text_data_en, "obj_papyrus_room_135", "\WMOŻE ROZWIĄZANIE&\YOSTATNIEGO PUZZLA\W &JESZCZE RAZ POMOŻE./")
ds_map_add(global.text_data_en, "obj_papyrus_room_136", "SPYTAJ ZNÓW PO&WIĘCEJ WSPANIAŁYCH&WSKAZÓWEK!!/%%")
ds_map_add(global.text_data_en, "obj_papyrus_room_157", "Error, Pepibs./%%")
ds_map_add(global.text_data_en, "obj_papyrus_room_161", "SPYTAŁEM UNDYNE&CZY WSZYSCY BYŚMY&MOGLI SIĘ SPOTKAĆ.../")
ds_map_add(global.text_data_en, "obj_papyrus_room_162", "\E3ALE POWIEDZIAŁA&COŚ DZIWNEGO./")
ds_map_add(global.text_data_en, "obj_papyrus_room_163", "\E0POWIEDZIAŁA, ŻE NIE&BĘDZIE SPĘDZAĆ&CZASU Z MORDERCĄ./")
ds_map_add(global.text_data_en, "obj_papyrus_room_164", "\E3ALE..^1. HMM.../")
ds_map_add(global.text_data_en, "obj_papyrus_room_165", "\E5NIE PRZYPOMINAM&SOBIE^1, ŻEBYM&KOGOŚ ZABIJAŁ.../")
ds_map_add(global.text_data_en, "obj_papyrus_room_166", "\E3CHOCIAŻ JESTEM&CAŁKIEM BRUTALNYM&TYPEM SZKIELETEM./")
ds_map_add(global.text_data_en, "obj_papyrus_room_167", "\E3WTEDY POWIEDZIAŁA&COŚ O OCHOCIE.../")
ds_map_add(global.text_data_en, "obj_papyrus_room_168", "\E1BITWY Z KIMŚ ZŁYM./")
ds_map_add(global.text_data_en, "obj_papyrus_room_169", "\E3ALE ONA WYDAJE SIĘ&BARDZO..^1. OSŁA-&BIONA OD CZEGOŚ./")
ds_map_add(global.text_data_en, "obj_papyrus_room_170", "\E5POSTAWIŁA KROK I&UPADŁA W PRZEJŚCIU./")
ds_map_add(global.text_data_en, "obj_papyrus_room_171", "\E0WIĘC JA TU POPROSTU&CZEKAM^1, GDYBY MNIE&POTRZEBOWAŁA./")
ds_map_add(global.text_data_en, "obj_papyrus_room_172", "\E3OD WTEDY NIENAWIDZI&BYCIA CZEKANYM NA&KOGOŚ./")
ds_map_add(global.text_data_en, "obj_papyrus_room_173", "\E5CHYBA BĘDZIEMY&MUSIELI PRZEŁOŻYĆ&SPOTKANIE.../%%")
ds_map_add(global.text_data_en, "obj_papyrus_room_176", "HEJ^1, JA.../")
ds_map_add(global.text_data_en, "obj_papyrus_room_177", "\E5NAPRAWDĘ NIE SĄDZĘ&ŻE BĘDZIEMY MOGLI&SPĘDZIĆ CZAS./")
ds_map_add(global.text_data_en, "obj_papyrus_room_178", "\E3CIĘŻKO TO SOBIE&WYOBRAZIĆ^1, ALE.../")
ds_map_add(global.text_data_en, "obj_papyrus_room_179", "\E0BĘDZIESZ MUSIAŁ&SPĘDZIĆ CZAS BEZE&MNIE./%%")
ds_map_add(global.text_data_en, "obj_papyrus_room_185", "HEJ^1! GOTOWY&NA SPOTKANIE&Z UNDYNE???/")
ds_map_add(global.text_data_en, "obj_papyrus_room_186", "SUPER!!^1!&JA TEŻ!!!/")
ds_map_add(global.text_data_en, "obj_papyrus_room_187", "\E3JEDNAK^1, NIE MA&JEJ W DOMU./")
ds_map_add(global.text_data_en, "obj_papyrus_room_188", "\E0ZAZWYCZAJ ONA&POWRACA MNIEJ&WIĘCEJ TERAZ./")
ds_map_add(global.text_data_en, "obj_papyrus_room_189", "\E3ALE SIĘ&COŚ SPÓŹNIA.../")
ds_map_add(global.text_data_en, "obj_papyrus_room_190", "\E3I NIE ODBIERA&SWOJEGO&TELEFONU./")
ds_map_add(global.text_data_en, "obj_papyrus_room_191", "\E2TROCHĘ&NIEPOKOJĄCE./")
ds_map_add(global.text_data_en, "obj_papyrus_room_192", "\E0PO PROSTU TU&POCZEKAM DOPÓKI&SIĘ NIE ZJAWI./")
ds_map_add(global.text_data_en, "obj_papyrus_room_193", "ZADZWONIĘ DO CIEBIE&KIEDY ONA PRZYJDZIE&TU^1, OKEJ!?/%%")
ds_map_add(global.text_data_en, "obj_papyrus_room_196", "NOPE!^1!&JESZCZE JEJ TU&NIE MA!!!/%%")
ds_map_add(global.text_data_en, "obj_papyrus_room_202", "UNDYNE JEST W&DOMU^1, \E2ALE NIE&CZUJE SIĘ NAJLEPIEJ./")
ds_map_add(global.text_data_en, "obj_papyrus_room_203", "\E5NIE WYDAJE MI SIĘ^1,&ŻE BĘDZIEMY MOGLI&SIĘ SPOTKAĆ./")
ds_map_add(global.text_data_en, "obj_papyrus_room_204", "\E3WYDAJE SIĘ^1, ŻE ONA&ZŁAPAŁA GORĄCZKĘ&CZY COŚ./")
ds_map_add(global.text_data_en, "obj_papyrus_room_205", "KTOS JĄ MUSIAŁ&PRZENIEŚĆ SPOWRO-&TEM DO DOMU.../")
ds_map_add(global.text_data_en, "obj_papyrus_room_206", "\E5BO LEDWO MOŻE&SIĘ RUSZAĆ./")
ds_map_add(global.text_data_en, "obj_papyrus_room_207", "\E0ALE CAŁY CZAS&GADA O ZNISZCZENIU&CIEBIE./")
ds_map_add(global.text_data_en, "obj_papyrus_room_208", "WIĘC TO JEST DOBRY&ZNAK ŻYCIOWY./")
ds_map_add(global.text_data_en, "obj_papyrus_room_209", "\E3W KAŻDYM RAZIE^1, NIE&WYDAJE MI SIĘ ŻE&SIĘ SPOTKAMY./")
ds_map_add(global.text_data_en, "obj_papyrus_room_210", "\E0JA TU SOBIE&POCZEKAM GDYBY&COŚ POTRZEBOWAŁA./")
ds_map_add(global.text_data_en, "obj_papyrus_room_211", "WIĘC^1, CHYBA MOŻESZ&SOBIE PO PROSTU&PÓJŚĆ./%%")
ds_map_add(global.text_data_en, "obj_papyrus_room_214", "UNDYNE JEST CHORA^1,&WIĘC NIE MOŻE SIĘ&DZISIAJ POBAWIĆ./%%")
ds_map_add(global.text_data_en, "obj_papyrus_room_220", "HEJ^1! GOTOWY&NA SPOTKANIE&Z UNDYNE???/")
ds_map_add(global.text_data_en, "obj_papyrus_room_221", "SUPER!!^1!&BO NAWET JEJ&TU NIE MA./")
ds_map_add(global.text_data_en, "obj_papyrus_room_222", "PRZYGOTOWAŁEŚ SIĘ^1!&TO POKAZUJE JAK&BARDZO CI ZALEŻY!!/")
ds_map_add(global.text_data_en, "obj_papyrus_room_223", "\E3NAWET JEŚLI JEJ&TU NIE MA^1, BY TO&ZOBACZYĆ./%%")
ds_map_add(global.text_data_en, "obj_papyrus_room_226", "NOPE!^1!&JESZCZE JEJ TU&NIE MA!!!/%%")
ds_map_add(global.text_data_en, "obj_papyrus_room_244", "WITAJ^1, PRZYJACIELU./")
ds_map_add(global.text_data_en, "obj_papyrus_room_245", "CO CIĘ PRZYNOSI&DO MIASTA PAPYRUSA?/%%")
ds_map_add(global.text_data_en, "obj_papyrus_room_248", "WITAJ..^1.&J-JAK SIĘ TRZYMASZ^1,&P-PRZYJACIELU?/")
ds_map_add(global.text_data_en, "obj_papyrus_room_249", "\E5CZUJĘ SIĘ TOTALNIE&NIEPODEJRZLIWIE&DZISIAJ./%%")
ds_map_add(global.text_data_en, "obj_papyrus_room_253", "HEJ^1, MAM&SUPER POMYSŁ./")
ds_map_add(global.text_data_en, "obj_papyrus_room_254", "SPOTKAJMY SIĘ&PÓŹNIEJ Z UNDYNE./")
ds_map_add(global.text_data_en, "obj_papyrus_room_255", "ZADZWONIĘ DO CIEBIE&GDY BĘDE GOTOWY!/%%")
ds_map_add(global.text_data_en, "obj_papyrus_room_259", "TAK SIĘ CIESZĘ ŻE&TY I UNDYNE SIĘ JUŻ&PRZYJAŹNICIE./")
ds_map_add(global.text_data_en, "obj_papyrus_room_260", "WY DWAJ PASUJECIE&DO SIEBIE JAK MAKA-&RON I PRZYPALENIE!/%%")
ds_map_add(global.text_data_en, "obj_papyrus_room_263", "OH^1, HEJ.../")
ds_map_add(global.text_data_en, "obj_papyrus_room_264", "\E3NIEDŁUGO NAS&OPUSZCZASZ^1,&PRAWDA!?/")
ds_map_add(global.text_data_en, "obj_papyrus_room_265", "\E1NIE WRACAJ ŻEBY&SIĘ POŻEGNAĆ!!/")
ds_map_add(global.text_data_en, "obj_papyrus_room_266", "\E3POŻEGNANIA NIE SĄ&DOZWOLONE W&MOIM MIEŚCIE./")
ds_map_add(global.text_data_en, "obj_papyrus_room_267", "\E0TYLKO WIDZIMY-SIĘ-&PÓŹNIEJ./%%")
ds_map_add(global.text_data_en, "obj_papyrus_room_272", "CHYBA UNDYNE MA&COŚ DLA CIEBIE./")
ds_map_add(global.text_data_en, "obj_papyrus_room_273", "TO ONA JEST OSOBĄ&KTÓRA NIE JEST MNĄ./%%")
ds_map_add(global.text_data_en, "obj_papyrus_room_278", "UNDYNE PISZE&WIELE LISTÓW./")
ds_map_add(global.text_data_en, "obj_papyrus_room_279", "\E3ALE^1, NIGDY NIE&MOŻE ZNALEŹĆ&WŁAŚCIWYCH SŁÓW./")
ds_map_add(global.text_data_en, "obj_papyrus_room_280", "WIĘC KIEDY IDZIE&JE OSOBIŚCIE&WRĘCZYĆ.../")
ds_map_add(global.text_data_en, "obj_papyrus_room_281", "ZAWSZE SIĘ WRACA I&PISZE CAŁY LIST&OD NOWA./")
ds_map_add(global.text_data_en, "obj_papyrus_room_282", "\E0TO DLATEGO SIĘ&CIEBIE SPYTAŁA!!/")
ds_map_add(global.text_data_en, "obj_papyrus_room_283", "BO TY NIE MASZ&ŻADNYCH&STANDARDÓW!!!/%%")
ds_map_add(global.text_data_en, "obj_papyrus_room_287", "ALPHYS WYDAJE SIĘ&ZNIKNĄĆ./")
ds_map_add(global.text_data_en, "obj_papyrus_room_288", "NIE MARTW SIĘ^1, &TO NORMALKA./")
ds_map_add(global.text_data_en, "obj_papyrus_room_289", "POWINIENEŚ&IŚĆ DO JEJ&LABORATORIUM./")
ds_map_add(global.text_data_en, "obj_papyrus_room_290", "POWINIENEM&POŁĄCZYĆTE&CYFRY./%%")
ds_map_add(global.text_data_en, "obj_papyrusboss_270", " ALAS^1, BIEDNY& PAPYRUS!/%%")
ds_map_add(global.text_data_en, "obj_papyrusboss_272", " C-CÓŻ^1, NIE& TEGO SIĘ& SPODZEWAŁEM.../%%")
ds_map_add(global.text_data_en, "obj_papyrusboss_282", " UM^1, PRZYNAJMNIEJ& JESZCZE MAM& MOJĄ GŁOWĘ!/%%")
ds_map_add(global.text_data_en, "obj_papyrusboss_285", "ALE.../")
ds_map_add(global.text_data_en, "obj_papyrusboss_286", " JE-..^1. JEDNAK^1!& WIERZĘ W& CIEBIE!/")
ds_map_add(global.text_data_en, "obj_papyrusboss_287", " MOŻESZ ZROBIĆ& TROSZKĘ LEPIEJ!/")
ds_map_add(global.text_data_en, "obj_papyrusboss_288", " NAWET JEŚLI& TAK NIE MYŚLISZ!/")
ds_map_add(global.text_data_en, "obj_papyrusboss_289", " JA..^1.& OBIECUJĘ.../%%")
ds_map_add(global.text_data_en, "obj_papyrusboss_402", " CÓŻ...! *HUFF^1*& WIDAĆ... *HUFF^1*& ŻE NIE MOŻESZ^1!& MNIE POKONAĆ!!!/")
ds_map_add(global.text_data_en, "obj_papyrusboss_403", " TAK!!!& WIDZĘ JAK SIĘ& TRZĘSIESZ W & BUTACH!!!/")
ds_map_add(global.text_data_en, "obj_papyrusboss_404", " W TAKIM RAZIE JA^1,& WIELKI PAPYRUS^1,& WYBIERAM LITOŚĆ!!/")
ds_map_add(global.text_data_en, "obj_papyrusboss_405", "\X JA CIĘ \ROSZCZĘDZĘ\X,& CZŁOWIEKU!!!/")
ds_map_add(global.text_data_en, "obj_papyrusboss_406", " \XTERAZ MASZ SZANSĘ& ZAAKCEPTOWAĆ MOJĄ& \RLITOŚĆ\X./%%")
ds_map_add(global.text_data_en, "obj_papyrusboss_423", "* Papyrus cię oszczędza.")
ds_map_add(global.text_data_en, "obj_papyrusboss_456", " CO DO CHOLERY!/")
ds_map_add(global.text_data_en, "obj_papyrusboss_457", " TO MÓJ& SPECJALNY ATAK!/%%")
ds_map_add(global.text_data_en, "obj_papyrusboss_466", " HEJ^1!& TY GŁUPI PSIE!/%%")
ds_map_add(global.text_data_en, "obj_papyrusboss_477", " SŁYSZYSZ& MNIE!?/")
ds_map_add(global.text_data_en, "obj_papyrusboss_478", " PRZESTAŃ GRYŹĆ& TĄ KOŚĆ!!!/%%")
ds_map_add(global.text_data_en, "obj_papyrusboss_487", " HEJ!!!& CO TY& ROBISZ!!!/")
ds_map_add(global.text_data_en, "obj_papyrusboss_488", " WRACAJ TU Z& MOIM SPECJALNYM& ATAKIEM!!!/%%")
ds_map_add(global.text_data_en, "obj_papyrusboss_502", " .../")
ds_map_add(global.text_data_en, "obj_papyrusboss_503", " NO CÓŻ./")
ds_map_add(global.text_data_en, "obj_papyrusboss_504", " PO PROSTU UŻYJĘ& BARDZO CZADOWY& ZWYCZAJNY ATAK./%%")
ds_map_add(global.text_data_en, "obj_papyrusboss_514", "* Papyrus się przygotowuje na&  regularny atak.")
ds_map_add(global.text_data_en, "obj_papyrusboss_548", "  ...")
ds_map_add(global.text_data_en, "obj_papyrusboss_552", " OH^1, POWINIENEM& BYŁ PRZYNIEŚĆ& JEDEN Z TAKICH.")
ds_map_add(global.text_data_en, "obj_papyrusboss_558", " WIĘC MOWISZ& POWAŻNIE.../")
ds_map_add(global.text_data_en, "obj_papyrusboss_559", " WIĘC& ODMAWIASZ& WALKI.../")
ds_map_add(global.text_data_en, "obj_papyrusboss_560", " W TAKIM RAZIE^1,& ZOBACZMY CZY& UDŹWIGNIESZ MÓJ& SŁYNNY 'NIEBIESKI& ATAK!'/%%")
ds_map_add(global.text_data_en, "obj_papyrusboss_561", "%%%")
ds_map_add(global.text_data_en, "obj_papyrusboss_570", " OTO TO!")
ds_map_add(global.text_data_en, "obj_papyrusboss_571", " HMMM... I WONDER& WHAT I SHOULD& WEAR...")
ds_map_add(global.text_data_en, "obj_papyrusboss_572", " HOW HIGH CAN YOU& JUMP?")
ds_map_add(global.text_data_en, "obj_papyrusboss_573", " WHAT!? I'M NOT& THINKING ABOUT& THAT DATE THING!!")
ds_map_add(global.text_data_en, "obj_papyrusboss_574", " TRY HOLDING THE& 'UP' BUTTON TO& JUMP!!!")
ds_map_add(global.text_data_en, "obj_papyrusboss_575", "\X YEAH!& DON'T MAKE ME& USE MY \RSPECIAL& ATTACK\X!")
ds_map_add(global.text_data_en, "obj_papyrusboss_576", " HOLD 'UP' LONGER& TO JUMP HIGHER!& JEEZ!!!")
ds_map_add(global.text_data_en, "obj_papyrusboss_577", " I CAN ALMOST& TASTE MY FUTURE& POPULARITY!!!")
ds_map_add(global.text_data_en, "obj_papyrusboss_578", " PAPYRUS:& HEAD OF THE& ROYAL GUARD!")
ds_map_add(global.text_data_en, "obj_papyrusboss_579", " PAPYRUS:& UNPARALLELED& SPAGHETTORE!")
ds_map_add(global.text_data_en, "obj_papyrusboss_580", " UNDYNE WILL BE& REALLY PROUD& OF ME!!")
ds_map_add(global.text_data_en, "obj_papyrusboss_581", " THE KING WILL& TRIM A HEDGE& IN THE SHAPE& OF MY SMILE!!!")
ds_map_add(global.text_data_en, "obj_papyrusboss_582", " MY BROTHER WILL& ... WELL, HE& WON'T CHANGE& VERY MUCH.")
ds_map_add(global.text_data_en, "obj_papyrusboss_583", " I'LL HAVE LOTS& OF ADMIRERS!!& BUT...")
ds_map_add(global.text_data_en, "obj_papyrusboss_584", " HOW WILL I& KNOW IF PEOPLE& SINCERELY LIKE& ME???")
ds_map_add(global.text_data_en, "obj_papyrusboss_585", " WILL ANYONE LIKE& ME AS SINCERELY& AS YOU?")
ds_map_add(global.text_data_en, "obj_papyrusboss_586", " SOMEONE LIKE& YOU IS REALLY& RARE...")
ds_map_add(global.text_data_en, "obj_papyrusboss_587", " I DON'T THINK& THEY'LL LET YOU& GO...")
ds_map_add(global.text_data_en, "obj_papyrusboss_588", " AND DATING MIGHT& BE KIND OF& HARD...")
ds_map_add(global.text_data_en, "obj_papyrusboss_589", " AFTER YOU'RE& CAPTURED AND& SENT AWAY.")
ds_map_add(global.text_data_en, "obj_papyrusboss_590", " URGH...& WHO CARES!& GIVE UP!!")
ds_map_add(global.text_data_en, "obj_papyrusboss_591", "\X GIVE UP OR& FACE MY...& \RSPECIAL ATTACK\X!!!")
ds_map_add(global.text_data_en, "obj_papyrusboss_592", "\X YEAH!!!& VERY SOON I WILL& USE MY& \RSPECIAL ATTACK\X! ")
ds_map_add(global.text_data_en, "obj_papyrusboss_593", "\X NOT TOO LONG& AND I WILL& USE THAT& \RSPECIAL ATTACK\X!!!")
ds_map_add(global.text_data_en, "obj_papyrusboss_594", "\X THIS IS YOUR& LAST CHANCE...& BEFORE MY& \RSPECIAL ATTACK\X!!")
ds_map_add(global.text_data_en, "obj_papyrusboss_595", "\X BEHOLD...!& MY \RSPECIAL& ATTACK\X!")
ds_map_add(global.text_data_en, "obj_papyrusboss_596", " *SIGH* HERE'S AN& ABSOLUTELY& NORMAL ATTACK.")
ds_map_add(global.text_data_en, "obj_papyrusboss_604", " NYEH HEH HEH!")
ds_map_add(global.text_data_en, "obj_papyrusboss_605", " I DON'T DESERVE& SUCH HOSPITALITY& FROM YOU ...")
ds_map_add(global.text_data_en, "obj_papyrusboss_606", " YOUR BARBS HIDE A& HIDDEN AFFECTION^1!& YOU EMOTIONAL& CACTUS!")
ds_map_add(global.text_data_en, "obj_papyrusboss_607", " DON'T WASTE YOUR& WORDS ON ME!")
ds_map_add(global.text_data_en, "obj_papyrusboss_608", " LET'S DATE& L-LATER!^1!& AFTER I CAPTURE& YOU!")
ds_map_add(global.text_data_en, "obj_papyrusboss_612", "  ...")
ds_map_add(global.text_data_en, "obj_papyrusboss_1584", "* Papyrus is preparing a bone&  attack.")
ds_map_add(global.text_data_en, "obj_papyrusboss_1585", "* Papyrus prepares a non-bone&  attack then spends a minute&  fixing his mistake.")
ds_map_add(global.text_data_en, "obj_papyrusboss_1586", "* Papyrus is cackling.")
ds_map_add(global.text_data_en, "obj_papyrusboss_1587", "* Papyrus whispers " + '"' + "Nyeh heh&  heh!" + '"')
ds_map_add(global.text_data_en, "obj_papyrusboss_1588", "* Papyrus is rattling his bones.")
ds_map_add(global.text_data_en, "obj_papyrusboss_1589", "* Papyrus is trying hard to play&  it cool.")
ds_map_add(global.text_data_en, "obj_papyrusboss_1590", "* Papyrus is considering his&  options.")
ds_map_add(global.text_data_en, "obj_papyrusboss_1591", "* Smells like bones.")
ds_map_add(global.text_data_en, "obj_papyrusboss_1592", "* Papyrus remembered a bad joke&  Sans told and is frowning.")
ds_map_add(global.text_data_en, "obj_papyrusboss_1596", "* Papyrus is thinking about&  what to wear for his date.")
ds_map_add(global.text_data_en, "obj_papyrusboss_1597", "* Papyrus is thinking about&  what to cook for his date.")
ds_map_add(global.text_data_en, "obj_papyrusboss_1598", "* Papyrus dabs some Bone&  Cologne behind his ear.")
ds_map_add(global.text_data_en, "obj_papyrusboss_1599", "* Papyrus dabs marinara sauce&  behind his ear.")
ds_map_add(global.text_data_en, "obj_papyrusboss_1600", "* Papyrus dabs MTT-Brand Bishie&  Cream behind his ear.")
ds_map_add(global.text_data_en, "obj_papyrusboss_1601", "* Papyrus dabs MTT-Brand Anime&  Powder behind his ear.")
ds_map_add(global.text_data_en, "obj_papyrusboss_1602", "* Papyrus dabs MTT-Brand Cute&  Juice behind his ear.")
ds_map_add(global.text_data_en, "obj_papyrusboss_1603", "* Papyrus dabs MTT-Brand&  Attraction Slime behind his&  ear.")
ds_map_add(global.text_data_en, "obj_papyrusboss_1604", "* Papyrus dabs MTT-Brand&  Beauty Yogurt behind his&  ear.")
ds_map_add(global.text_data_en, "obj_papyrusboss_1605", "* Papyrus realizes he doesn't&  have ears.")
ds_map_add(global.text_data_en, "obj_papyrusboss_1609", "* Papyrus is at the edge of&  defeat.")
ds_map_add(global.text_data_en, "obj_papyrusboss_1611", "* Papyrus cię oszczędza.")
ds_map_add(global.text_data_en, "obj_papyrusboss_1613", "* Papyrus cię oszczędza.")
ds_map_add(global.text_data_en, "obj_papyrusboss_1645", "* PAPYRUS - ATK 20 DEF 20&* He likes to say:&  " + '"' + "Nyeh heh heh!" + '"' + "/^")
ds_map_add(global.text_data_en, "obj_papyrusboss_1647", "* PAPYRUS - ATK 3 DEF 3&* Forgettable./^")
ds_map_add(global.text_data_en, "obj_papyrusboss_1661", " HOW SELFLESS.../")
ds_map_add(global.text_data_en, "obj_papyrusboss_1662", " YOU WANT ME TO& FEEL BETTER& ABOUT FIGHTING& YOU.../%%")
ds_map_add(global.text_data_en, "obj_papyrusboss_1663", " THERE'S NO NEED& TO LIE TO& YOURSELF!!!/%%")
ds_map_add(global.text_data_en, "obj_papyrusboss_1664", " DON'T...!/%%")
ds_map_add(global.text_data_en, "obj_papyrusboss_1678", "* You INSULT^1, but to no avail^1.&* Seems ACTing won't escalate&  this battle.../^")
ds_map_add(global.text_data_en, "obj_papyrusboss_1680", "* Papyrus is too busy FIGHTing&  to accept your insult./^")
ds_map_add(global.text_data_en, "obj_papyrusboss_1696", " WHAT!^1?& FL-FLIRTING!?/")
ds_map_add(global.text_data_en, "obj_papyrusboss_1697", "\X SO YOU FINALLY& REVEAL YOUR\R & ULTIMATE FEELINGS\X!/")
ds_map_add(global.text_data_en, "obj_papyrusboss_1698", " W-WELL^1!& I'M A SKELETON& WITH VERY HIGH& STANDARDS!!!/%%")
ds_map_add(global.text_data_en, "obj_papyrusboss_1700", " OH NO!!!/%%")
ds_map_add(global.text_data_en, "obj_papyrusboss_1713", "* You FLIRT^1, but to no avail^1.&* Seems ACTing won't escalate&  this battle.../^")
ds_map_add(global.text_data_en, "obj_papyrusboss_1715", "* Papyrus is too busy FIGHTing&  to flirt back./^")
ds_map_add(global.text_data_en, "obj_papyrusboss_1754", " OH NO!!^1! YOU'RE& MEETING ALL MY& STANDARDS!!!/")
ds_map_add(global.text_data_en, "obj_papyrusboss_1755", " I GUESS THIS MEANS& I HAVE TO GO ON A& DATE WITH YOU...?/%%")
ds_map_add(global.text_data_en, "obj_papyrusboss_1769", " OH NO!!^1!& THAT HUMILITY..^1.& IT REMINDS ME OF,/")
ds_map_add(global.text_data_en, "obj_papyrusboss_1770", " MYSELF!!!/")
ds_map_add(global.text_data_en, "obj_papyrusboss_1771", " YOU'RE MEETING ALL&  MY STANDARDS!!!/%%")
ds_map_add(global.text_data_en, "obj_papyrusboss_1804", "   I can           I have zero&   make            redeeming&   spaghetti       qualities\C")
ds_map_add(global.text_data_en, "obj_papyrussnowman_98", "* (To śnieżny Papyrus.)/%%")
ds_map_add(global.text_data_en, "obj_parsnik_205", "Hisssss")
ds_map_add(global.text_data_en, "obj_parsnik_206", "Hisssss")
ds_map_add(global.text_data_en, "obj_parsnik_207", "Hisssss")
ds_map_add(global.text_data_en, "obj_parsnik_208", "Herssss")
ds_map_add(global.text_data_en, "obj_parsnik_211", "Ate&Your&Green&Snakes")
ds_map_add(global.text_data_en, "obj_parsnik_215", "Don't&Be Rude")
ds_map_add(global.text_data_en, "obj_parsnik_219", "Jedz&Warzywa&Smaczne&Węże")
ds_map_add(global.text_data_en, "obj_parsnik_225", "%%%")
ds_map_add(global.text_data_en, "obj_parsnik_431", "* Parsnik has a hissy fit.")
ds_map_add(global.text_data_en, "obj_parsnik_432", "* Parsnik's snakes shift to&  change hairstyles^1.&* Mohawk^1. Ponytail^1. Undercut.")
ds_map_add(global.text_data_en, "obj_parsnik_433", "* Parsnik completely closes its&  mouth^1.&* It looks short and weird.")
ds_map_add(global.text_data_en, "obj_parsnik_434", "* Snakes play with a beach ball.")
ds_map_add(global.text_data_en, "obj_parsnik_435", "* Smells like tasty snakes.")
ds_map_add(global.text_data_en, "obj_parsnik_436", "* Parsnik seems satisfied.")
ds_map_add(global.text_data_en, "obj_parsnik_437", "* The snakes are wilting.")
ds_map_add(global.text_data_en, "obj_parsnik_478", "* PARSNIK - ATK 30 DEF 28&* This cobrafied carrot has&  a headful of tasty snakes./^")
ds_map_add(global.text_data_en, "obj_parsnik_495", "* You tried to eat Parsnik^1,&  but it wasn't weakened&  enough./^")
ds_map_add(global.text_data_en, "obj_parsnik_498", "* You start eating snakes like&  they're spaghetti.&* You recovered 5 HP!/^")
ds_map_add(global.text_data_en, "obj_parsnik_512", "* Parsnik mishears you and fires&  a series of tasty snakes./^")
ds_map_add(global.text_data_en, "obj_phonecall_room_161", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_162", "\TS \E6 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_phonecall_room_163", "* OK^1!&* Y-you should..^1.&* You should.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_164", "* Head to the..^1.&* Head to the.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_165", "\E9* I..^1. I.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_166", "\E9* I don't know?/")
ds_map_add(global.text_data_en, "obj_phonecall_room_167", "\E8* This doesn't look&  like my map&  at all.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_168", "\E9* I'm sorry..^1.&* I..^1. I.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_169", "\E8* I have to go./")
ds_map_add(global.text_data_en, "obj_phonecall_room_170", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_phonecall_room_171", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_phonecall_room_190", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_191", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_phonecall_room_192", "* W-wait^1!&* No^1, I think you&  should h-head up!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_193", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_phonecall_room_194", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_phonecall_room_202", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_203", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_phonecall_room_204", "* A crossroads..^1.&* Uhh.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_205", "* Uhhh.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_206", "\E6* Tr..^1.&* Try heading to the&  right!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_207", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_phonecall_room_208", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_phonecall_room_218", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_219", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_phonecall_room_220", "* Looks like you can't&  proceed until you&  hit the switch./")
ds_map_add(global.text_data_en, "obj_phonecall_room_221", "* B-but^1, those lasers&  will activate when&  you do./")
ds_map_add(global.text_data_en, "obj_phonecall_room_222", "\E6* Ummm..^1.&* Looks like they'll&  come in this order:/")
ds_map_add(global.text_data_en, "obj_phonecall_room_223", "\W* \OOrange\W. \OOrange\W. \LBlue\W./")
ds_map_add(global.text_data_en, "obj_phonecall_room_224", "* G-got it^1?&* Move until the&  third one!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_225", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_phonecall_room_226", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_phonecall_room_234", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_235", "\TS \E6 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_phonecall_room_236", "* Alright^1, now just&  keep heading&  up!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_237", "\E6* .../")
ds_map_add(global.text_data_en, "obj_phonecall_room_238", "\E3* ..^1.&* That pit..^1.&* Isn't on my map./")
ds_map_add(global.text_data_en, "obj_phonecall_room_239", "\E6* Forget it^1!&* Let's try the&  left side!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_240", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_phonecall_room_241", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_phonecall_room_245", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_246", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_phonecall_room_247", "* H-hey^1, aren't&  you gonna use&  the elevator?/")
ds_map_add(global.text_data_en, "obj_phonecall_room_248", "\E6* I guess you can&  go this way!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_249", "\E3* .../")
ds_map_add(global.text_data_en, "obj_phonecall_room_250", "* If there wasn't&  a huge pit in&  the way...?/")
ds_map_add(global.text_data_en, "obj_phonecall_room_251", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_phonecall_room_252", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_phonecall_room_259", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_260", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_phonecall_room_261", "* Wh..^1. where'd this&  pit come from?/")
ds_map_add(global.text_data_en, "obj_phonecall_room_262", "\E8* You should be able&  to walk across&  here.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_263", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_phonecall_room_264", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_phonecall_room_275", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_276", "\TS \E6 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_phonecall_room_277", "* Ready^1?&* This is it!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_278", "* Take the elevator&  up to the top&  of the CORE!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_279", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_phonecall_room_280", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_phonecall_room_290", "* Dzyn.../%%")
ds_map_add(global.text_data_en, "obj_phonecall_room_302", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_303", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_phonecall_room_304", "* Hi^1, Alphys here!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_305", "* This room is like&  the room we saw&  before./")
ds_map_add(global.text_data_en, "obj_phonecall_room_306", "* There are two puzzles&  to the north and&  south.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_307", "* You'll have to solve&  them both to proceed!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_308", "\E2* .../")
ds_map_add(global.text_data_en, "obj_phonecall_room_309", "\E0* A-also... I'd like&  to say!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_310", "\E3* I don't really...&* Like giving away&  puzzle solutions./")
ds_map_add(global.text_data_en, "obj_phonecall_room_311", "\E6* But if you need&  help^1, just call&  me^1, ok?/")
ds_map_add(global.text_data_en, "obj_phonecall_room_312", "\E3* Actually^1, wait^1, I&  have an idea!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_313", "\E0* Let's be friends&  on UnderNet!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_314", "\E7* Then you can just&  ping me when you&  need help!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_315", "\E0* .../")
ds_map_add(global.text_data_en, "obj_phonecall_room_316", "\E4* Wait^1, we're already&  friends^1, aren't we?/")
ds_map_add(global.text_data_en, "obj_phonecall_room_317", "\E5* I signed you up^1,&  didn't I?/")
ds_map_add(global.text_data_en, "obj_phonecall_room_318", "\E5* You've been reading&  my posts the whole&  time.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_319", "\E6* Well^1! I hope^1!&  You agree with me^1!&* About Mew Mew 2!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_320", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_phonecall_room_321", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_phonecall_room_353", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_354", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_phonecall_room_355", "* Uh^1, h-h-hey!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_356", "\E0* I'm going to the&  bathroom^1, so I'll&  be MIA for a bit./")
ds_map_add(global.text_data_en, "obj_phonecall_room_357", "* I'm..^1. I'm sure you&  can handle this&  puzzle yourself!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_358", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_phonecall_room_359", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_phonecall_room_372", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_373", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_phonecall_room_374", "* S-see that building in&  the distance?/")
ds_map_add(global.text_data_en, "obj_phonecall_room_375", "\E0* That's the CORE^1.&* The source of all power&  for the underground./")
ds_map_add(global.text_data_en, "obj_phonecall_room_376", "\E6* It converts geothermal&  energy into magical&  electricity^1, by.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_377", "\E3* Uhh^1, anyway^1, that's&  where we're going to&  go./")
ds_map_add(global.text_data_en, "obj_phonecall_room_378", "\E0* In the CORE is an&  elevator directly to&  ASGORE's castle./")
ds_map_add(global.text_data_en, "obj_phonecall_room_379", "\E0* And from there..^1.&* You can go home./")
ds_map_add(global.text_data_en, "obj_phonecall_room_380", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_phonecall_room_381", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_phonecall_room_397", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_398", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_phonecall_room_399", "* Uuuh^1, I think...&* Umm.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_400", "\E6* Hey^1!&* About the puzzles on&  the left and right...!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_401", "\E6* They're a bit difficult&  to explain^1, but.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_402", "\E4* ... uhhh^1, you already&  s-solved them?/")
ds_map_add(global.text_data_en, "obj_phonecall_room_403", "\E5* Awesome!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_404", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_phonecall_room_405", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_phonecall_room_411", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_412", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_phonecall_room_413", "* Alphys^1! Here!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_414", "\E6* Th-that blue laser&  seems totally&  impassable!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_415", "\E3* B-b-but!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_416", "\E6* As the Royal Scientist^1,&  I h-have some tricks&  up my sleeve!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_417", "* I'll h-hack into th-the&  Hotland laser database&  and take it out!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_418", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_phonecall_room_419", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_phonecall_room_423", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_424", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_phonecall_room_425", "* A-another laser^1,&  huh?/")
ds_map_add(global.text_data_en, "obj_phonecall_room_426", "\E8* I'm sorry^1, I won't&  play around this&  time./")
ds_map_add(global.text_data_en, "obj_phonecall_room_427", "\E6* Hold on a second!!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_428", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_phonecall_room_429", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_phonecall_room_464", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_465", "\TS \E6 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_phonecall_room_466", "\E6* A-A-Alphys here!!!!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_467", "\E3* Th..^1. the northern door&  will stay locked until&  you.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_468", "* S-solve the puzzles on&  the right and left!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_469", "\E0* I..^1. I think you&  sh-should g-g-go to the&  right first!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_470", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_phonecall_room_471", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_phonecall_room_498", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_499", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_phonecall_room_500", "* Uhh^1!&* H-hi^1, so^1, the blue&  lasers.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_501", "\E4* Uhh^1!&* I mean^1, Alphys here^1!&* Hi!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_502", "\W*\E6 The \Lblue lasers\W won't&  hurt you if you don't&  move!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_503", "\W*\E3 \OO-orange\W ones^1, um..^1.&* Y-you have to be&  moving^1, and they.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_504", "\E4* Um^1, they won't^1, um.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_505", "\E6* Move through those&  ones!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_506", "\E1* .../")
ds_map_add(global.text_data_en, "obj_phonecall_room_507", "\E5* Uhh^1, bye!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_508", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_phonecall_room_509", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_phonecall_room_521", "* Dzyn..^1. Dzyn.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_522", "* Click...?/")
ds_map_add(global.text_data_en, "obj_phonecall_room_523", "* (Whoever was calling hung up&  before you answered it.)/%%")
ds_map_add(global.text_data_en, "obj_phonecall_room_569", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_571", "HOWDY!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_572", "IF IT ISN'T MY&GOOD FRIEND^1,&WHO TRUSTS ME./")
ds_map_add(global.text_data_en, "obj_phonecall_room_573", "THIS IS PAPYRUS^1.&YOUR ALSO&MUTUAL FRIEND./")
ds_map_add(global.text_data_en, "obj_phonecall_room_574", "\E3ALPHYS AND I&FINISHED OUR&TRAINING EARLY./")
ds_map_add(global.text_data_en, "obj_phonecall_room_575", "\E5VERY EARLY./")
ds_map_add(global.text_data_en, "obj_phonecall_room_576", "\E3SO I SENT HER&HOME./")
ds_map_add(global.text_data_en, "obj_phonecall_room_577", "\E5VERY HOME./")
ds_map_add(global.text_data_en, "obj_phonecall_room_578", "\E3UH... NOW./")
ds_map_add(global.text_data_en, "obj_phonecall_room_579", "\E0I FEEL STRONGLY&AND FOR NO&APPARENT REASON./")
ds_map_add(global.text_data_en, "obj_phonecall_room_580", "\E3YOU SHOULD ALSO&GO..^1. THERE./")
ds_map_add(global.text_data_en, "obj_phonecall_room_581", "\E0TO HER^1.&LAB..^1. HOUSE./")
ds_map_add(global.text_data_en, "obj_phonecall_room_582", "I HAVE ONLY&GOOD FEELINGS&ABOUT THIS./")
ds_map_add(global.text_data_en, "obj_phonecall_room_583", "\E5GOODBYE./")
ds_map_add(global.text_data_en, "obj_phonecall_room_584", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_phonecall_room_585", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_phonecall_room_593", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_phonecall_room_594", "\TS \E4 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_phonecall_room_595", "\E3* H..^1. hi...^1!&* It's Dr. Alphys./")
ds_map_add(global.text_data_en, "obj_phonecall_room_596", "\E0* This p-puzzle is&  kinda..^1. um..^1. timing-&  based./")
ds_map_add(global.text_data_en, "obj_phonecall_room_597", "\E3* Y-you see those&  switches over there?/")
ds_map_add(global.text_data_en, "obj_phonecall_room_598", "\E0* Y-you'll have to press&  all three of them&  within 3 seconds./")
ds_map_add(global.text_data_en, "obj_phonecall_room_599", "\E6* I'll t-try to help&  you with the&  rhythm!/")
ds_map_add(global.text_data_en, "obj_phonecall_room_600", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_phonecall_room_601", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_piano_68", "* Come on! What are you doing!/%%")
ds_map_add(global.text_data_en, "obj_playmovement_206", "* OH^1?&* THAT HUMAN.../%%")
ds_map_add(global.text_data_en, "obj_playmovement_348", "* COULD IT BE...?/%%")
ds_map_add(global.text_data_en, "obj_playmovement_375", "* ... MY ONE TRUE LOVE?/%%")
ds_map_add(global.text_data_en, "obj_playmovement_791", "* SO SAD./")
ds_map_add(global.text_data_en, "obj_playmovement_792", "* SO SAD THAT YOU ARE&  GOING TO THE DUNGEON./%%")
ds_map_add(global.text_data_en, "obj_playmovement_795", "* OOMPH!&* I AM SO OVERWHELMED WITH&  TRAGEDIES./")
ds_map_add(global.text_data_en, "obj_playmovement_796", "* THE KING HAS ORDERED YOU&  TO WASTE AWAY IN THE CASTLE&  BASEMENT./")
ds_map_add(global.text_data_en, "obj_playmovement_797", "* AND BEFORE WE EVEN HAD&  TIME TO SING A SWEET&  SONG ABOUT IT./")
ds_map_add(global.text_data_en, "obj_playmovement_798", "* MY DEAR HEART^1!&* I CAN BARELY LOOK UPON YOU^1,&  KNOWING WHAT COMES NEXT.../%%")
ds_map_add(global.text_data_en, "obj_playmovement_821", "* WELL^1, TOODLES!/%%")
ds_map_add(global.text_data_en, "obj_potheat_73", "* Hold \*D to turn up the heat!")
ds_map_add(global.text_data_en, "obj_potheat_108", "* Left^1? You fool^2!%")
ds_map_add(global.text_data_en, "obj_potheat_109", "\E6* THIS BURNER ONLY&  GOES ONE WAY!!^2!%%")
ds_map_add(global.text_data_en, "obj_potheat_132", "* Hotter^2!%%")
