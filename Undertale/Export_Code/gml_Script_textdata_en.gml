ds_map_add(global.text_data_en, "scr_papcall_7", "* Dzyn..^1. Dzyn.../")
ds_map_add(global.text_data_en, "scr_papcall_8", "* (Brak odpowiedzi...)/%%")
ds_map_add(global.text_data_en, "scr_papcall_17", "HMMMM..^1.&DZIWNE DRZWI&W LESIE./")
ds_map_add(global.text_data_en, "scr_papcall_18", "\E0W SUMIE^1, MÓJ&BRAT SPĘDZA TAM&DOŚĆ SPORO CZASU./")
ds_map_add(global.text_data_en, "scr_papcall_19", "\E3CO ON TAM ROBI...?/")
ds_map_add(global.text_data_en, "scr_papcall_20", "\E1MUSZĘ GO TRZYMAĆ&NA SMYCZY!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_24", "ARE YOU STILL&AROUND THAT DOOR?/")
ds_map_add(global.text_data_en, "scr_papcall_25", "\E1OH NO!!^1!&MY BROTHER'S A&BAD INFLUENCE!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_31", "THIS IS WHERE MY&BROTHER IS SUPPOSED&TO PATROL.../")
ds_map_add(global.text_data_en, "scr_papcall_32", "\E3BUT^1, EVERY TIME I&SHOW UP^1, HE'S&SLACKING OFF./")
ds_map_add(global.text_data_en, "scr_papcall_33", "\E0IT'S A GOOD THING&I SPOTTED YOU&FIRST!/")
ds_map_add(global.text_data_en, "scr_papcall_34", "\E3I'M SURE HE WOULD&HAVE MADE A WEIRD&FIRST IMPRESSION./%%")
ds_map_add(global.text_data_en, "scr_papcall_39", "IF HE'S NOT AROUND^1,&HE WON'T COME&BACK.../")
ds_map_add(global.text_data_en, "scr_papcall_40", "\E3THAT'S JUST THE&WAY HE FUNCTIONS./%%")
ds_map_add(global.text_data_en, "scr_papcall_46", "WHAT??^1?&ARE YOU LOST???/")
ds_map_add(global.text_data_en, "scr_papcall_47", "\E0HMMM..^1. YOU SHOULD&TRY CALLING&SOMEONE FOR HELP!/%%")
ds_map_add(global.text_data_en, "scr_papcall_52", "HUH??^1?&WHY ARE YOU&CALLING ME??/%%")
ds_map_add(global.text_data_en, "scr_papcall_58", "IT'S TOO COLD&TO SWIM IN THE&RIVER./")
ds_map_add(global.text_data_en, "scr_papcall_59", "UNLESS YOU HAVE A&WATERPROOF&SWEATER!/%%")
ds_map_add(global.text_data_en, "scr_papcall_65", "IT'S JUST A&RIVER./%%")
ds_map_add(global.text_data_en, "scr_papcall_71", "NYEH HEH HEH!^1!&IMPRESSED!?!/")
ds_map_add(global.text_data_en, "scr_papcall_72", "NOT ONLY AM I&GREAT AT PUZZLES.../")
ds_map_add(global.text_data_en, "scr_papcall_73", "BUT I'M ALSO&AN ESTEEMED&ARCHITECT!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_79", "MY BROTHER HELPED&ME FIND THE BOX!/%%")
ds_map_add(global.text_data_en, "scr_papcall_85", "THE STATION OF&DOGGO./")
ds_map_add(global.text_data_en, "scr_papcall_86", "HE HAS THE AMAZING&POWER TO SEE THINGS&WHEN THEY MOVE./")
ds_map_add(global.text_data_en, "scr_papcall_87", "\E3OKAY^1, MAYBE IT'S&NOT AN AMAZING&POWER./%%")
ds_map_add(global.text_data_en, "scr_papcall_93", "DOGGO'S NOT HOME./%%")
ds_map_add(global.text_data_en, "scr_papcall_100", "CAREFUL!^1!&THE ICE IS&SLPPERY./")
ds_map_add(global.text_data_en, "scr_papcall_101", "\E0BUT IF YOU SLIDE&ON THE ICE^1, NO ONE&WILL ATTACK YOU./")
ds_map_add(global.text_data_en, "scr_papcall_102", "\E3NO ONE WANTS TO&PRATFALL DURING A&COOL TECHNIQUE./%%")
ds_map_add(global.text_data_en, "scr_papcall_108", "I'M COLD OUT OF&THINGS TO SAY./%%")
ds_map_add(global.text_data_en, "scr_papcall_114", "IT MUST BE TOUGH&BEING A SNOWMAN./")
ds_map_add(global.text_data_en, "scr_papcall_115", "\E2TRY TO BE NICE&TO PEOPLE MADE OF&STRANGE MATERIALS./%%")
ds_map_add(global.text_data_en, "scr_papcall_121", "IS THAT SNOWMAN&STILL THERE?/%%")
ds_map_add(global.text_data_en, "scr_papcall_127", "OH HO^1!&THE ELECTRIC MAZE^1!&THAT SURE WAS FUN!/")
ds_map_add(global.text_data_en, "scr_papcall_128", "\E3EXCEPT FOR WHEN&I GOT SHOCKED./%%")
ds_map_add(global.text_data_en, "scr_papcall_133", "OH HO^1!&THE ELECTRIC MAZE^1!&A GREAT PUZZLE!/")
ds_map_add(global.text_data_en, "scr_papcall_134", "\E3EXCEPT FOR THE&PART WHERE WE&DIDN'T EVEN DO IT./")
ds_map_add(global.text_data_en, "scr_papcall_135", "\E0MINUS THAT ONE&TINY FLAW^1, IT'S AN&EASY 10 OUT OF 10!/%%")
ds_map_add(global.text_data_en, "scr_papcall_141", "DISAPPOINTING^1, BUT&I TURNED OFF THE&ELECTRICITY./%%")
ds_map_add(global.text_data_en, "scr_papcall_149", "THE FAMOUS SNOWDIN&SNOWBALL GAME./")
ds_map_add(global.text_data_en, "scr_papcall_150", "FASTER COMPLETION&GIVES DIFFERENT&PRIZES./")
ds_map_add(global.text_data_en, "scr_papcall_151", "\E3WHERE DOES THE&MONEY COME FROM?/")
ds_map_add(global.text_data_en, "scr_papcall_152", "\E0THE SNOWBALL TAX^1,&OF COURSE!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_157", "WHAT^1?&YOU'VE NEVER HEARD&OF A SNOWBALL TAX?/")
ds_map_add(global.text_data_en, "scr_papcall_158", "\E2THE SURFACE WORLD&MUST BE PARADISE.../%%")
ds_map_add(global.text_data_en, "scr_papcall_166", "THE STATION OF THE&MARRIED DOGS.../")
ds_map_add(global.text_data_en, "scr_papcall_167", "\E3HMMM^1. DO YOU EVER&THINK ABOUT DOING&THAT SOMEDAY?/")
ds_map_add(global.text_data_en, "scr_papcall_168", "\E0MARRYING A DOG?/%%")
ds_map_add(global.text_data_en, "scr_papcall_173", "NAH..^1.&THAT'S WEIRD./")
ds_map_add(global.text_data_en, "scr_papcall_174", "\E0THERE ARE WAY&BETTER ANIMALS TO&MARRY./")
ds_map_add(global.text_data_en, "scr_papcall_175", "LIKE SKELETONS!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_182", "HMM... CROSSWORD^1.&I GUESS IT'S AN&APT NAME./")
ds_map_add(global.text_data_en, "scr_papcall_183", "\E4THOSE WORDS MAKE&ME CROSS!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_188", "ARE YOU STILL&LOOKING AT THAT&WORD SEARCH?/%%")
ds_map_add(global.text_data_en, "scr_papcall_195", "AH^1, THE SPAGHETTI&TRAP ROOM.../")
ds_map_add(global.text_data_en, "scr_papcall_196", "ERROR????/%%")
ds_map_add(global.text_data_en, "scr_papcall_199", "\E3I STILL HAVE TO&GO VISIT IT.../")
ds_map_add(global.text_data_en, "scr_papcall_200", "\E2THE SPAGHETTI YOU&LEFT ME IS STILL&THERE!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_204", "\E3WELL^1, I GUESS IT'S&NOT MUCH OF A&TRAP ANYMORE.../")
ds_map_add(global.text_data_en, "scr_papcall_205", "\E0SINCE YOU ATE THE&WHOLE THING^1,&RIGHT!?/%%")
ds_map_add(global.text_data_en, "scr_papcall_211", "NOTHING LIKE A&HOT BUCKET OF&SPAGH.../%%")
ds_map_add(global.text_data_en, "scr_papcall_218", "THIS ROOM IS&NORMALLY BLOCKED&BY THOSE SPIKES./")
ds_map_add(global.text_data_en, "scr_papcall_219", "\E3BUT WE'RE THINKING&OF GETTING RID&OF THEM.../")
ds_map_add(global.text_data_en, "scr_papcall_220", "\E0THE KING RELEASED&A MANDATE ON&PUZZLES RECENTLY./")
ds_map_add(global.text_data_en, "scr_papcall_221", "\E3HE THINKS SPIKES&ARE INEFFECTIVE AND&HAZARDOUS TO KIDS./")
ds_map_add(global.text_data_en, "scr_papcall_222", "\E4BUT I THINK HE'S&WRONG!!!/")
ds_map_add(global.text_data_en, "scr_papcall_223", "\E0KIDS LOVE DEADLY&SPIKES!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_228", "IF YOU KNOW ANY&KIDS^1, YOU SHOULD&ASK THEM!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_234", "HMMM..^1.&THE SOLUTION TO&THIS ONE...?/")
ds_map_add(global.text_data_en, "scr_papcall_235", "\E5I ACTUALLY JUST&STEPPED OVER THE&SPIKES./")
ds_map_add(global.text_data_en, "scr_papcall_236", "\E0SO THE SOLUTION&IS TO BE VERY&TALL AND HANDSOME./%%")
ds_map_add(global.text_data_en, "scr_papcall_241", "I'M SOLVING IT&AS WE SPEAK.../%%")
ds_map_add(global.text_data_en, "scr_papcall_248", "OH-HO!!^1! &THIS PUZZLE^1!/")
ds_map_add(global.text_data_en, "scr_papcall_249", "YOU FIGURED IT OUT&SO EASILY!!/")
ds_map_add(global.text_data_en, "scr_papcall_250", "\E2THAT WAS VERY&PAPYRUS OF YOU./%%")
ds_map_add(global.text_data_en, "scr_papcall_255", "TALKING ON THE&PHONE..^1. HOW&PAPYRUS OF YOU./%%")
ds_map_add(global.text_data_en, "scr_papcall_262", "OH-HO!!^1!&THE PUZZLE THAT&DR. ALPHYS MADE!/")
ds_map_add(global.text_data_en, "scr_papcall_263", "I HAD TO ASK&UNDYNE TO ASK&HER TO MAKE ONE./")
ds_map_add(global.text_data_en, "scr_papcall_264", "\E3I ONLY FOLLOW&HER ONLINE.../")
ds_map_add(global.text_data_en, "scr_papcall_265", "\E3I'M NOT REALLY&FRIENDS WITH HER.../")
ds_map_add(global.text_data_en, "scr_papcall_266", "\E0YET!!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_271", "SOMEDAY I'LL&IMPRESS HER WITH&MY HUGE BICEPS.../")
ds_map_add(global.text_data_en, "scr_papcall_272", "\E0THAT'S A GOOD&WAY TO MAKE&FRIENDS!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_278", "THE STATION OF&LESSERDOG./")
ds_map_add(global.text_data_en, "scr_papcall_279", "THIS DOG LOVES&TO BE PET./")
ds_map_add(global.text_data_en, "scr_papcall_280", "THAT'S ITS DEFINING&PERSONALITY&TRAIT./")
ds_map_add(global.text_data_en, "scr_papcall_281", "\E3WAIT^1, WHY ARE THEY&A ROYAL GUARD&AND NOT ME!?/")
ds_map_add(global.text_data_en, "scr_papcall_282", "\E0I LOVE TO BE&PET TOO!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_287", "SIGH..^1.&IT'S ALL JUST A&PUPULARITY CONTEST./%%")
ds_map_add(global.text_data_en, "scr_papcall_293", "WE WERE GETTING&BORED WAITING&FOR YOU.../")
ds_map_add(global.text_data_en, "scr_papcall_294", "\E0SO I BUILT A&SNOW-PAPYRUS!/")
ds_map_add(global.text_data_en, "scr_papcall_295", "\E3AND SANS...&DID HIS THING./%%")
ds_map_add(global.text_data_en, "scr_papcall_300", "ACTUALLY^1, IT'S ONE&OF HIS BETTER&LUMPS./%%")
ds_map_add(global.text_data_en, "scr_papcall_306", "I ALWAYS JUMP OVER&THE GAP INSTEAD OF&SOLVING THE PUZZLE./")
ds_map_add(global.text_data_en, "scr_papcall_307", "SANS NEVER SOLVES&IT EITHER./")
ds_map_add(global.text_data_en, "scr_papcall_308", "\E3HE ALWAYS JUST..^1.&UM.../")
ds_map_add(global.text_data_en, "scr_papcall_309", "GETS ACROSS./%%")
ds_map_add(global.text_data_en, "scr_papcall_314", "I THINK HE HAS&A SHORTCUT OR&SOMETHING./%%")
ds_map_add(global.text_data_en, "scr_papcall_321", "GYFTROT LIVES NEAR&THERE^1.&THEY LIKE GIFTS./")
ds_map_add(global.text_data_en, "scr_papcall_322", "\E3DON'T WORRY IF&YOU CAN'T AFFORD&SOMETHING NICE./")
ds_map_add(global.text_data_en, "scr_papcall_323", "\E0IT'S THE THOUGHT&THAT COUNTS./")
ds_map_add(global.text_data_en, "scr_papcall_324", "SO IMAGINE YOU&HAVE A LOT OF&MONEY.../%%")
ds_map_add(global.text_data_en, "scr_papcall_329", "DID YOU MEET&GYFTROT?/%%")
ds_map_add(global.text_data_en, "scr_papcall_336", "MY SIGNAL IS&GETTING WEAK./")
ds_map_add(global.text_data_en, "scr_papcall_337", "\E3LOOKS LIKE THE&PHONE WON'T WORK&PAST HERE./")
ds_map_add(global.text_data_en, "scr_papcall_338", "\E0SO THERE'S NO&REASON TO GO&FURTHER./%%")
ds_map_add(global.text_data_en, "scr_papcall_343", "HELLO./%%")
ds_map_add(global.text_data_en, "scr_papcall_349", "THE STATION OF&GREATERDOG./")
ds_map_add(global.text_data_en, "scr_papcall_350", "\E3HE LOOKS A BIT&LIKE A CERTAIN DOG&I DON'T LIKE./")
ds_map_add(global.text_data_en, "scr_papcall_351", "\E0BUT GREATERDOG&DOESN'T COLLECT&ANYTHING./")
ds_map_add(global.text_data_en, "scr_papcall_352", "\E2HE'S ONLY A&KLEPTOMANIAC&FOR AFFECTION!/%%")
ds_map_add(global.text_data_en, "scr_papcall_357", "HE'S AMASSED A&LARGE COLLECTION&OF HUGS AND PETS./%%")
ds_map_add(global.text_data_en, "scr_papcall_363", "THIS BRIDGE LOOKS&DANGEROUS^1, BUT&IT'S VERY STABLE./")
ds_map_add(global.text_data_en, "scr_papcall_364", "IN FACT^1, IT'S JUST&A ROCK FORMATION&I PAINTED OVER./")
ds_map_add(global.text_data_en, "scr_papcall_365", "I THINK IT LOOKS&MORE DRAMATIC&THAT WAY./%%")
ds_map_add(global.text_data_en, "scr_papcall_370", "I ADDED THE ROPE^1,&TOO./%%")
ds_map_add(global.text_data_en, "scr_papcall_376", "SNOWDIN..^1.&HOME OF PAPYRUS!/")
ds_map_add(global.text_data_en, "scr_papcall_377", "\E3THAT'S THE SLOGAN^1,&RIGHT???/%%")
ds_map_add(global.text_data_en, "scr_papcall_382", "I'M PETITIONING TO&CHANGE THE SLOGAN./%%")
ds_map_add(global.text_data_en, "scr_papcall_389", "THAT FURRY PERSON&THROWS ICE ALL&DAY./")
ds_map_add(global.text_data_en, "scr_papcall_390", "NOBODY KNOWS&WHERE IT GOES./%%")
ds_map_add(global.text_data_en, "scr_papcall_394", "THAT FURRY PERSON&THROWS ICE ALL&DAY./")
ds_map_add(global.text_data_en, "scr_papcall_395", "NOBODY KNOWS&WHERE IT GOES./")
ds_map_add(global.text_data_en, "scr_papcall_397", "* Hey^1, I know^1!&* Alphys told me.../")
ds_map_add(global.text_data_en, "scr_papcall_398", "* It goes to Hotland&  to cool down the&  CORE!/")
ds_map_add(global.text_data_en, "scr_papcall_400", "WOW^1, UNDYNE!^1!&I DIDN'T KNOW YOU&LIKED NERDY STUFF!/")
ds_map_add(global.text_data_en, "scr_papcall_401", "\E3JUST STRENGTH&AND FIGHTING.../")
ds_map_add(global.text_data_en, "scr_papcall_403", "\E0* Are you kidding!?&* Why wouldn't I!?/")
ds_map_add(global.text_data_en, "scr_papcall_404", "\E6* The brain's the&  biggest muscle of&  all!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_410", "HYPNOTIZING^1, ISN'T&IT???/%%")
ds_map_add(global.text_data_en, "scr_papcall_416", "THE INN'S A&GREAT PLACE&TO STAY./")
ds_map_add(global.text_data_en, "scr_papcall_417", "THE LADY WHO&RUNS IT IS&REALLY NICE./")
ds_map_add(global.text_data_en, "scr_papcall_418", "\E2SHE ALWAYS GIVES&ME A LOLLIPOP AND&A PAT ON THE HEAD./%%")
ds_map_add(global.text_data_en, "scr_papcall_423", "WHY ARE YOU&CALLING ME?/")
ds_map_add(global.text_data_en, "scr_papcall_424", "\E0ARE YOU TRYING&TO MAKE A&RESERVATION???/%%")
ds_map_add(global.text_data_en, "scr_papcall_430", "* Hey^1, I always stay&  there when I come&  to Snowdin!/")
ds_map_add(global.text_data_en, "scr_papcall_431", "\E4* I used to stay&  at Papyrus's^1, but.../")
ds_map_add(global.text_data_en, "scr_papcall_432", "\E1* His couch is like^1,&  lumpy and jangly?/")
ds_map_add(global.text_data_en, "scr_papcall_433", "\E5* And his brother&  kept making 100's&  of midnight snacks./%%")
ds_map_add(global.text_data_en, "scr_papcall_434", "\E2* And Papyrus himself&  doesn't??^1?&* Know how to sleep?/%%")
ds_map_add(global.text_data_en, "scr_papcall_439", "* Yeah^1, just sleep&  here./%%")
ds_map_add(global.text_data_en, "scr_papcall_448", "GRILLBY'S...&IT'S DARK AND FULL&OF GREASE./")
ds_map_add(global.text_data_en, "scr_papcall_449", "PURGATORY OF&FRIES..^1.&HAMBURGER ABYSS.../")
ds_map_add(global.text_data_en, "scr_papcall_450", "ANYWAY^1, MY BROTHER&PRACTICALLY LIVES&HERE./%%")
ds_map_add(global.text_data_en, "scr_papcall_455", "I'M NOT COMING&TO GRILLBY'S./%%")
ds_map_add(global.text_data_en, "scr_papcall_461", "GRILLBY'S^1? WE'RE TOO&REFINED FOR THAT&GREASEHOLE./")
ds_map_add(global.text_data_en, "scr_papcall_463", "* WOAH^1, if you go^1,&  you HAVE to try&  the cheese fries./")
ds_map_add(global.text_data_en, "scr_papcall_464", "\E6* They're AMAZINGLY&  bad for you!!/")
ds_map_add(global.text_data_en, "scr_papcall_465", "\E9* Oh^1, sorry^1, Papyrus^1,&  were you saying&  something?/")
ds_map_add(global.text_data_en, "scr_papcall_467", "JUST MONOLOGUING&ABOUT MY LOVE&FOR GREASE!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_472", "OUR FEELINGS FOR&GREASE RUN DEEP&LIKE A RIVER./")
ds_map_add(global.text_data_en, "scr_papcall_474", "* Grease^1, I.../")
ds_map_add(global.text_data_en, "scr_papcall_475", "\E8* I..^1.&* .../")
ds_map_add(global.text_data_en, "scr_papcall_476", "\E6* I want you in&  all my food!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_487", "I LOVE THE LIBRARY^1.&THE BOOKS ARE ALL&ARRANGED BY COLOR../")
ds_map_add(global.text_data_en, "scr_papcall_488", "\E4THIS SENSE OF&ORDER!!^1! IT FILLS&ME WITH POWER!/%%")
ds_map_add(global.text_data_en, "scr_papcall_493", "WHAT'S A LIBRARY&CARD?/%%")
ds_map_add(global.text_data_en, "scr_papcall_499", "* I couldn't get enough&  books when I was&  a kid./")
ds_map_add(global.text_data_en, "scr_papcall_500", "\E9* I tore through all&  sorts of 'em!/")
ds_map_add(global.text_data_en, "scr_papcall_501", "\E1* I ripped through&  tons of 'em!/")
ds_map_add(global.text_data_en, "scr_papcall_502", "\E6* I kicked 'em into&  shreds!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_507", "* But now I think&  reading's cool./%%")
ds_map_add(global.text_data_en, "scr_papcall_516", "WOW^1! IT ONLY TOOK&YOU FOUR SECONDS&TO CALL ME!!/")
ds_map_add(global.text_data_en, "scr_papcall_517", "YOU MUST BE VERY&DESPERATE FOR MY&HELP!!!/")
ds_map_add(global.text_data_en, "scr_papcall_518", "WELL^1! DO NOT FEAR^1!&THIS IS PAPYRUS'S&HOTFUL HELPLINE!/")
ds_map_add(global.text_data_en, "scr_papcall_519", "JUST DESCRIBE YOUR&LOCATION^1, AND...!/")
ds_map_add(global.text_data_en, "scr_papcall_520", "I WILL DESCRIBE&SOME HOT TIPS!/")
ds_map_add(global.text_data_en, "scr_papcall_521", "\E0SO^1, WHERE ARE&YOU?/")
ds_map_add(global.text_data_en, "scr_papcall_522", "\E3.../")
ds_map_add(global.text_data_en, "scr_papcall_523", "\E5... YOU'RE STILL&IN MY ROOM??/")
ds_map_add(global.text_data_en, "scr_papcall_524", "\E3.../")
ds_map_add(global.text_data_en, "scr_papcall_525", "\E3HAVE YOU HEARD OF&SOMETHING CALLED&A..^1. DOOR?/")
ds_map_add(global.text_data_en, "scr_papcall_526", "\E0WAIT^1! DON'T WORRY^1!&I'LL DRAW A&DIAGRAM FOR YOU!/%%")
ds_map_add(global.text_data_en, "scr_papcall_531", "HOLD UP^1!&I'M STILL DRAWING!/%%")
ds_map_add(global.text_data_en, "scr_papcall_537", "WHAT^1? I THOUGHT&YOU HAD GOTTEN OUT&OF MY ROOM./")
ds_map_add(global.text_data_en, "scr_papcall_538", "\E1WE'RE GOING TO&HAVE TO START OVER&FROM SQUARE ONE!/")
ds_map_add(global.text_data_en, "scr_papcall_539", "\E0FIRST: DO YOU&KNOW WHO PAPYRUS&IS!?/%%")
ds_map_add(global.text_data_en, "scr_papcall_544", "DO I KNOW WHO&PAPYRUS IS!?/%%")
ds_map_add(global.text_data_en, "scr_papcall_554", "YOU'RE IN MY&HOUSE^1.&GOOD CHOICE!/")
ds_map_add(global.text_data_en, "scr_papcall_555", "\E3THOUGH I GUESS&IT'S TECHNICALLY&SANS'S HOUSE TOO./")
ds_map_add(global.text_data_en, "scr_papcall_556", "\E1BUT I PREFER NOT&TO DISCUSS HIS&PART OF IT./")
ds_map_add(global.text_data_en, "scr_papcall_557", "\E3HIS ROOM IS..^1.&IT'S LIKE ANOTHER&WORLD!/")
ds_map_add(global.text_data_en, "scr_papcall_558", "\E2A WORLD WHERE&THEY DON'T KNOW&HOW TO VACUUM./%%")
ds_map_add(global.text_data_en, "scr_papcall_563", "YOU'RE BEST&STAYING AWAY FROM&THAT STRANGE PLACE./%%")
ds_map_add(global.text_data_en, "scr_papcall_572", "THIS IS WHERE&I TRIED TO&CAPTURE YOU!/")
ds_map_add(global.text_data_en, "scr_papcall_573", "WHAT A TERRIBLE&MEMORY!/%%")
ds_map_add(global.text_data_en, "scr_papcall_578", ".../%%")
ds_map_add(global.text_data_en, "scr_papcall_584", "* Yeah!^1! This is the&  best room for&  snow-wrestling!!/")
ds_map_add(global.text_data_en, "scr_papcall_586", "SNOW WRESTLING IS&WHEN SHE SNEAKS UP&ON YOU FROM BEHIND,/")
ds_map_add(global.text_data_en, "scr_papcall_587", "THEN TACKLES YOU&AND YELLS&" + '"' + "SNOW-WRESTLING!" + '"' + "/")
ds_map_add(global.text_data_en, "scr_papcall_588", "\E5IT'S..^1.&NOT THE BEST&GAME./")
ds_map_add(global.text_data_en, "scr_papcall_590", "\E9* Well^1, you know&  what I think?/")
ds_map_add(global.text_data_en, "scr_papcall_592", "WHAT?/")
ds_map_add(global.text_data_en, "scr_papcall_594", "* Snow-wrestling!!/")
ds_map_add(global.text_data_en, "scr_papcall_596", "NOOOOOOOOO!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_601", "* We'll have to play&  sometime!/%%")
ds_map_add(global.text_data_en, "scr_papcall_610", "WATERFALL..^1.&I BARELY KNOW&ANYTHING ABOUT IT./")
ds_map_add(global.text_data_en, "scr_papcall_611", "\E0BUT I'LL DO MY&BEST TO INFORM&YOU!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_616", "UH^1, I DON'T HAVE&ANY FACTS ABOUT&THIS ROOM./%%")
ds_map_add(global.text_data_en, "scr_papcall_622", "* If you're going to&  Snowdin^1, I won't&  have much to say./")
ds_map_add(global.text_data_en, "scr_papcall_624", "BUT I WILL!!/")
ds_map_add(global.text_data_en, "scr_papcall_626", "* There's the rub^1,&  right?/")
ds_map_add(global.text_data_en, "scr_papcall_628", "WHAT!^1?&THERE'S A RUB^1?&WHERE!?!?/")
ds_map_add(global.text_data_en, "scr_papcall_630", "* In Snowdin^1, duh!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_635", "I'LL DO MY&BEST TO FIND&THE RUB./")
ds_map_add(global.text_data_en, "scr_papcall_637", "* Hey^1, I think I&  found something!/")
ds_map_add(global.text_data_en, "scr_papcall_639", "OOH^1, WHERE?/")
ds_map_add(global.text_data_en, "scr_papcall_640", "\E5AND WHAT'S THIS&HORRIBLE NOOGIE?/")
ds_map_add(global.text_data_en, "scr_papcall_642", "* It's the rub!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_660", "MY BROTHER HAS&A STATION HERE./")
ds_map_add(global.text_data_en, "scr_papcall_661", "\E3YES^1, HE MANS&TWO STATIONS AT&ONCE./")
ds_map_add(global.text_data_en, "scr_papcall_662", "\E0AMAZING^1, ISN'T&HE?/")
ds_map_add(global.text_data_en, "scr_papcall_663", "HE SLACKS OFF&TWICE AS MUCH&AS NORMAL!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_668", "NORMAL FOLKS CAN&ONLY DREAM OF&SUCH SLOTH.../%%")
ds_map_add(global.text_data_en, "scr_papcall_674", "* This is Papyrus's&  brother's station./")
ds_map_add(global.text_data_en, "scr_papcall_675", "\E4* I'm always catching&  him slacking off^1,&  or sleeping.../")
ds_map_add(global.text_data_en, "scr_papcall_676", "\E2* But his results are&  JUST good enough&  to not fire him./")
ds_map_add(global.text_data_en, "scr_papcall_677", "\E4* Well^1, except today./")
ds_map_add(global.text_data_en, "scr_papcall_678", "\E2* He didn't tell me&  ANYTHING about you./%%")
ds_map_add(global.text_data_en, "scr_papcall_683", "\E4* JUST scraping by&  the bare minimum&  every time.../")
ds_map_add(global.text_data_en, "scr_papcall_684", "\E9* I guess it's kind&  of impressive...?/%%")
ds_map_add(global.text_data_en, "scr_papcall_693", "ROCKS?/")
ds_map_add(global.text_data_en, "scr_papcall_694", "\E0IT MUST BE ONE&OF UNDYNE'S&INGENIOUS PUZZLES./")
ds_map_add(global.text_data_en, "scr_papcall_695", "\E0YOU'D BETTER BE&CAREFUL!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_700", "BE WARY OF ROCKS./%%")
ds_map_add(global.text_data_en, "scr_papcall_706", "* God^1, I was supposed&  to build a puzzle&  for this room.../")
ds_map_add(global.text_data_en, "scr_papcall_707", "\E2* But I HATE puzzles./")
ds_map_add(global.text_data_en, "scr_papcall_708", "\E6* So I just put a&  huge pile of&  rocks upstream./%%")
ds_map_add(global.text_data_en, "scr_papcall_714", "* What??^1?&* Don't judge me!!!/")
ds_map_add(global.text_data_en, "scr_papcall_715", "\E6* My lack of&  creativity's making&  your life easier!/%%")
ds_map_add(global.text_data_en, "scr_papcall_722", "* Dzyn..^1. Dzyn.../")
ds_map_add(global.text_data_en, "scr_papcall_723", "* (Brak odpowiedzi...)/%%")
ds_map_add(global.text_data_en, "scr_papcall_731", "WHERE'D YOU GO!?&I CAN'T SEE&YOU!!!/")
ds_map_add(global.text_data_en, "scr_papcall_732", "\E0OH WAIT^1, THAT'S&BECAUSE YOU'RE&ON THE PHONE./%%")
ds_map_add(global.text_data_en, "scr_papcall_737", "ARE YOU STILL&ON THE PHONE?/%%")
ds_map_add(global.text_data_en, "scr_papcall_743", "* So you found the&  room behind the&  waterfall.../")
ds_map_add(global.text_data_en, "scr_papcall_744", "\E0* When I feel like&  relaxing^1, I always&  take a break there./")
ds_map_add(global.text_data_en, "scr_papcall_745", "\E1* That means NEVER!^1!&* I HATE RELAXING!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_750", "* I LOVE being&  ANGRY and STRESSED&  OUT!!!/")
ds_map_add(global.text_data_en, "scr_papcall_751", "\E0* Nah^1, I'm joking./%%")
ds_map_add(global.text_data_en, "scr_papcall_757", "* Dzyn..^1. Dzyn.../")
ds_map_add(global.text_data_en, "scr_papcall_758", "* (Brak odpowiedzi...)/%%")
ds_map_add(global.text_data_en, "scr_papcall_766", "WOWIE^1, I HAD AN&AWKWARD TIME IN&THIS ROOM EARLIER./")
ds_map_add(global.text_data_en, "scr_papcall_767", "\E0GOOD HEAVENS&YOU WEREN'T AROUND&TO SEE IT!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_772", "YOU REALLY&DIDN'T SEE IT!/")
ds_map_add(global.text_data_en, "scr_papcall_773", "I LOVE THAT&FACT^1, AND&REPEATING IT!/%%")
ds_map_add(global.text_data_en, "scr_papcall_779", "* This is the room&  where I first&  spotted you./")
ds_map_add(global.text_data_en, "scr_papcall_780", "\E2* You have NO idea&  how many spears I&  wanted to throw!!!/")
ds_map_add(global.text_data_en, "scr_papcall_781", "\E9* But^1, um^1, that sea-&  grass is under&  scientific protection./%%")
ds_map_add(global.text_data_en, "scr_papcall_786", "* What!!!!^1!&* That's a real thing!/%%")
ds_map_add(global.text_data_en, "scr_papcall_792", "* Dzyn..^1. Dzyn.../")
ds_map_add(global.text_data_en, "scr_papcall_793", "* (Brak odpowiedzi...)/%%")
ds_map_add(global.text_data_en, "scr_papcall_801", "A BRIDGE GROWS&IF YOU ALIGN&FOUR BRIDGE SEEDS./")
ds_map_add(global.text_data_en, "scr_papcall_802", "\E3BUT THAT'S SORT&OF LIMITED IN&USEFULNESS./")
ds_map_add(global.text_data_en, "scr_papcall_803", "\E2WHY DON'T WE&HAVE AIRPLANE&SEEDS???/%%")
ds_map_add(global.text_data_en, "scr_papcall_808", "OR^1, PHONES THAT&CAN TURN INTO&JETPACKS???/%%")
ds_map_add(global.text_data_en, "scr_papcall_814", "* Wait^1, did you actually&  DO the puzzle!?/")
ds_map_add(global.text_data_en, "scr_papcall_815", "\E2* You can't just jump&  across!?/")
ds_map_add(global.text_data_en, "scr_papcall_816", "\E6* You can't do the&  jimpity jumpity&  joodle!?/%%")
ds_map_add(global.text_data_en, "scr_papcall_821", "* The limpity loppity&  leap!?/%%")
ds_map_add(global.text_data_en, "scr_papcall_830", "HMMM..^1. THIS PUZZLE.../")
ds_map_add(global.text_data_en, "scr_papcall_831", "\E0I'VE GOT IT!!!/")
ds_map_add(global.text_data_en, "scr_papcall_832", "TRY TO BUILD A&BRIDGE WITH THE&BRIDGE SEEDS!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_837", "I'M HELPING./%%")
ds_map_add(global.text_data_en, "scr_papcall_843", "* Alphys helped measure&  out the mud tiles&  for this puzzle./")
ds_map_add(global.text_data_en, "scr_papcall_844", "* It was a lot of work^1,&  but we got to make&  sand castles after./")
ds_map_add(global.text_data_en, "scr_papcall_845", "\E9* We're a good team^1.&* She's great at&  building them.../")
ds_map_add(global.text_data_en, "scr_papcall_846", "\E6* And I'm great at&  wrecking them!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_851", "* There's barely even&  a trace of 'em&  now.../%%")
ds_map_add(global.text_data_en, "scr_papcall_861", "WHAT'S BETTER&THAN A BENCHFUL&OF QUICHE?/%%")
ds_map_add(global.text_data_en, "scr_papcall_866", "* What's better than&  a benchful of&  quiche?/%%")
ds_map_add(global.text_data_en, "scr_papcall_876", "\E3THE WISHING ROOM^1.&DO YOU HAVE&A WISH...?/")
ds_map_add(global.text_data_en, "scr_papcall_877", "\E0NYEH HEH HEH!^1!&I HAVE ONE!!!/")
ds_map_add(global.text_data_en, "scr_papcall_878", "\E2I WISH I WAS&TALKING TO MY&COOL FRIEND!!!/")
ds_map_add(global.text_data_en, "scr_papcall_879", "\E0LOOK!!^1!&IT'S COMING TRUE!/%%")
ds_map_add(global.text_data_en, "scr_papcall_885", "WHAT WILL YOU&WISH FOR?/%%")
ds_map_add(global.text_data_en, "scr_papcall_891", "* Every day^1, people&  come here and wish&  to the stars.../")
ds_map_add(global.text_data_en, "scr_papcall_892", "\E1* I won't let them&  down!!!/")
ds_map_add(global.text_data_en, "scr_papcall_893", "* I'll make everyone's&  wishes come true!!/")
ds_map_add(global.text_data_en, "scr_papcall_895", "I WISH I HAD&EIGHT LEGS.../")
ds_map_add(global.text_data_en, "scr_papcall_896", "\E0SO I COULD WEAR&FOUR PAIRS OF&HOTPANTS./")
ds_map_add(global.text_data_en, "scr_papcall_898", "* I'll make most&  people's wishes&  come true!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_903", "* What^1, you have a&  wish?/")
ds_map_add(global.text_data_en, "scr_papcall_904", "\E3* Add it to the pile^1,&  punk./%%")
ds_map_add(global.text_data_en, "scr_papcall_915", "THERE ARE MANY&ANCIENT PLAQUES&HERE./")
ds_map_add(global.text_data_en, "scr_papcall_916", "WATERFALL IS&PRACTICALLY A&HISTORY MUSEUM./")
ds_map_add(global.text_data_en, "scr_papcall_917", "\E3EXCEPT WITH&MUSCULAR&SEAHORSES./%%")
ds_map_add(global.text_data_en, "scr_papcall_922", "HI?/%%")
ds_map_add(global.text_data_en, "scr_papcall_928", "* Along these walls&  lies our tragic&  history.../")
ds_map_add(global.text_data_en, "scr_papcall_929", "\E1* Tragically BORING!/")
ds_map_add(global.text_data_en, "scr_papcall_930", "\E2* Why can't our history&  be COOL ANIMATIONS&  like the humans'!?/")
ds_map_add(global.text_data_en, "scr_papcall_931", "\E6* Someone at LEAST&  engrave a plaque with&  swords and kissing!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_936", "* Come on^1, don't act&  like your history's&  not COOL!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_942", "* Dzyn..^1. Dzyn.../")
ds_map_add(global.text_data_en, "scr_papcall_943", "* (Brak odpowiedzi...)/%%")
ds_map_add(global.text_data_en, "scr_papcall_950", "ANOTHER HARMLESS&AND VERY SAFE&CORRIDOR.../")
ds_map_add(global.text_data_en, "scr_papcall_951", "\E0ALL THANKS TO&ME!!^1!&NYEH HEH HEH!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_956", "HEH!!!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_962", "* This is where I&  threw all those&  spears at you.../")
ds_map_add(global.text_data_en, "scr_papcall_963", "\E6* That was fun!!^1!&* Let's do that&  again sometime!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_968", "* Come on^1!&* Don't fear the spear!/%%")
ds_map_add(global.text_data_en, "scr_papcall_974", "* Dzyn..^1. Dzyn.../")
ds_map_add(global.text_data_en, "scr_papcall_975", "* (Brak odpowiedzi...)/%%")
ds_map_add(global.text_data_en, "scr_papcall_982", "WATCH YOUR STEP!/")
ds_map_add(global.text_data_en, "scr_papcall_983", "\E3UNDYNE REALLY CARES&ABOUT THIS GRASS&FOR SOME REASON./%%")
ds_map_add(global.text_data_en, "scr_papcall_988", "ARE YOU WATCHING?/%%")
ds_map_add(global.text_data_en, "scr_papcall_994", "* If it wasn't for&  that grass^1, I'd&  have kicked your.../")
ds_map_add(global.text_data_en, "scr_papcall_995", "\E9* Uh^1, if not for&  that grooty^1, I'd have&  kicked your booty./%%")
ds_map_add(global.text_data_en, "scr_papcall_1000", "* Don't ask me what&  a grooty is!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1006", "* Dzyn..^1. Dzyn.../")
ds_map_add(global.text_data_en, "scr_papcall_1007", "* (Brak odpowiedzi...)/%%")
ds_map_add(global.text_data_en, "scr_papcall_1014", "WHY ARE THERE SO&MANY TABLES LYING&AROUND HERE?/%%")
ds_map_add(global.text_data_en, "scr_papcall_1019", "* Where are all&  these tables coming&  from?/%%")
ds_map_add(global.text_data_en, "scr_papcall_1029", "HUH^1? SANS ISN'T&PLAYING WITH HIS&TELESCOPE?/")
ds_map_add(global.text_data_en, "scr_papcall_1030", "\E0WOWIE!!^1! MAYBE HE&WENT TO WORK!!!/")
ds_map_add(global.text_data_en, "scr_papcall_1031", "\E2WOW!!^1! AM I&ALLOWED TO BE&PROUD???/%%")
ds_map_add(global.text_data_en, "scr_papcall_1036", "HUH^1? MY BROTHER^1?&OF COURSE HE HAS&A TELESCOPE./")
ds_map_add(global.text_data_en, "scr_papcall_1037", "\E0SANS LOVES&OUTER SPACEY&SCI-FI STUFF./")
ds_map_add(global.text_data_en, "scr_papcall_1038", "\E3HMM^1?&HE NEVER TOLD&YOU??/")
ds_map_add(global.text_data_en, "scr_papcall_1039", "\E0YEAH^1, SANS NEVER&TELLS ANYBODY&ANYTHING!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1046", "THANKS FOR CALLING./%%")
ds_map_add(global.text_data_en, "scr_papcall_1052", "* Hey^1, here's a&  neat party trick./")
ds_map_add(global.text_data_en, "scr_papcall_1053", "\E0* Try talking to&  the southern&  wall!/")
ds_map_add(global.text_data_en, "scr_papcall_1054", "\E4* First you have to&  throw a party&  though.../")
ds_map_add(global.text_data_en, "scr_papcall_1055", "\E0* Hey^1, you should&  make it a costume&  party!/")
ds_map_add(global.text_data_en, "scr_papcall_1056", "\E6* Then Papyrus can&  have someplace he&  seems normal!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1062", "* Oh^1!&* I should invite&  Alphys^1, too!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1071", "ICE CREAM^1?&THANKS^1, BUT I&LIVE IN SNOWDIN!/")
ds_map_add(global.text_data_en, "scr_papcall_1072", "\E0THERE'S ICE CREAM&ALL OVER THE&GROUND!!!/")
ds_map_add(global.text_data_en, "scr_papcall_1074", "* that's called snow./")
ds_map_add(global.text_data_en, "scr_papcall_1076", "SANS!!^1! I DIDN'T&ASK YOUR OPINION!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1081", "I'M FLATTERED HOW&MUCH YOU WANT TO&GIVE ME ICE CREAM./")
ds_map_add(global.text_data_en, "scr_papcall_1083", "* me too./")
ds_map_add(global.text_data_en, "scr_papcall_1085", "NO YOU AREN'T!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1097", "\E1* Ugh^1, ice cream!^1?&* Sugary... COLD..^1.&* Talk about GROSS./")
ds_map_add(global.text_data_en, "scr_papcall_1098", "\E3* Now this chilly&  pink stuff that&  Alphys makes me.../")
ds_map_add(global.text_data_en, "scr_papcall_1099", "\E6* THAT rules!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1104", "* I'll also drink it&  if it's heated up./%%")
ds_map_add(global.text_data_en, "scr_papcall_1113", "SOMETIMES^1, PRIZES&ARE HIDDEN UNDER&THE GRASS./")
ds_map_add(global.text_data_en, "scr_papcall_1114", "TREASURES LIKE&MUD^1, OR DIRT./%%")
ds_map_add(global.text_data_en, "scr_papcall_1120", "DID YOU FIND&THE TREASURE?/%%")
ds_map_add(global.text_data_en, "scr_papcall_1126", "* There's normally a&  pair of old shoes&  in that seagrass./")
ds_map_add(global.text_data_en, "scr_papcall_1127", "\E4* Strangely^1, they're made&  for someone without&  fins or claws./")
ds_map_add(global.text_data_en, "scr_papcall_1128", "\E7* What kind of monster&  is like that...?/")
ds_map_add(global.text_data_en, "scr_papcall_1129", "\E2* Oh^1, wait!^1?&* What about a slime&  monster!?/")
ds_map_add(global.text_data_en, "scr_papcall_1130", "\E6* Wait^1, those don't&  have feet at all!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1136", "* Well^1, if they fit&  you^1, you might as&  well take them./")
ds_map_add(global.text_data_en, "scr_papcall_1137", "\E6* Whoever wore them&  isn't coming back!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1146", "\E3A BIRD MONSTER?^1?&TRY TALKING TO&IT!!!/")
ds_map_add(global.text_data_en, "scr_papcall_1147", "\E0OR YOU COULD&PUT ME ON THE&LINE!/")
ds_map_add(global.text_data_en, "scr_papcall_1148", "\E2I'VE GOT SOME&PRETTY GOOD&TWEETS./")
ds_map_add(global.text_data_en, "scr_papcall_1149", "\E0(HORRIBLE&  BIRD IMITATIONS)/%%")
ds_map_add(global.text_data_en, "scr_papcall_1155", "DID THE BIRD LIKE&MY TWEETS???/%%")
ds_map_add(global.text_data_en, "scr_papcall_1161", "* That bird will carry&  anyone past the gap^1.&* It NEVER says no./")
ds_map_add(global.text_data_en, "scr_papcall_1162", "\E7* When I was younger^1,&  it gave me a lift^1.&* It took an hour.../")
ds_map_add(global.text_data_en, "scr_papcall_1163", "\E2* But this bird NEVER&  once thought of&  giving up!!!/")
ds_map_add(global.text_data_en, "scr_papcall_1164", "\E7* Cherish this bird./%%")
ds_map_add(global.text_data_en, "scr_papcall_1170", "* Well??^1?&* Are you CHERISHING???/")
ds_map_add(global.text_data_en, "scr_papcall_1171", "\E1* CHERISH HARDER!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1180", "ONION?/%%")
ds_map_add(global.text_data_en, "scr_papcall_1186", "HUM HUM HUM.../%%")
ds_map_add(global.text_data_en, "scr_papcall_1192", "* Onion...?/%%")
ds_map_add(global.text_data_en, "scr_papcall_1198", "* ...?/%%")
ds_map_add(global.text_data_en, "scr_papcall_1206", "I'VE HEARD A SHY&MONSTER LIVES&AROUND HERE./")
ds_map_add(global.text_data_en, "scr_papcall_1207", "\E3WELL^1, IF YOU WANT&TO GET SOMEONE&TO OPEN UP.../")
ds_map_add(global.text_data_en, "scr_papcall_1208", "\E0YOU SHOULD ENGAGE&THEM IN COMBAT!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1214", "HUM HUM HUM.../%%")
ds_map_add(global.text_data_en, "scr_papcall_1220", "* Oh yeah^1, Shyren&  lives around here./")
ds_map_add(global.text_data_en, "scr_papcall_1221", "* I used to give her&  piano lessons./")
ds_map_add(global.text_data_en, "scr_papcall_1222", "\E4* She was really&  talented..^1. \E9for someone&  with no fingers./")
ds_map_add(global.text_data_en, "scr_papcall_1223", "\E4* One day^1, she stopped&  coming to her lessons^1,&  though.../%%")
ds_map_add(global.text_data_en, "scr_papcall_1229", "\E7* How did her song&  go again...?/%%")
ds_map_add(global.text_data_en, "scr_papcall_1239", "HUH!^1?&ARE YOU SERENADING&ME!?/")
ds_map_add(global.text_data_en, "scr_papcall_1240", "\E2OH NO!!^1!&YOU'RE MAKING ME&BLUSH!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1246", "LET'S WRITE A&MUSICAL ABOUT&OUR ADVENTURES!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1252", "\E6* Yeah!^1! YEAH!!^1!&* I made this puzzle!!/")
ds_map_add(global.text_data_en, "scr_papcall_1253", "\E0* Really^1, it was just&  an excuse to put&  a piano here./")
ds_map_add(global.text_data_en, "scr_papcall_1254", "\E2* I love FIGHTING THE&  IVORIES!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1259", "\E9* Maybe I'll play you&  something sometime!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1269", "\E3HMMM.../")
ds_map_add(global.text_data_en, "scr_papcall_1270", "THERE'S SOMETHING&ANNOYING ABOUT&THIS ROOM./%%")
ds_map_add(global.text_data_en, "scr_papcall_1276", "BUT I CAN'T&QUITE PLACE MY&FINGER ON IT.../")
ds_map_add(global.text_data_en, "scr_papcall_1277", "THEN PLACE MY&WHOLE HAND ON&IT.../")
ds_map_add(global.text_data_en, "scr_papcall_1278", "THEN PET IT&AFFECTIONATELY.../%%")
ds_map_add(global.text_data_en, "scr_papcall_1291", "\E1* Huh!^1?&* Did you solve the&  puzzle!?/")
ds_map_add(global.text_data_en, "scr_papcall_1292", "\E6* No one has ever..^1.&* I've been waiting so&  long for someone to.../")
ds_map_add(global.text_data_en, "scr_papcall_1293", "\E2* I mean^1, uhhh^1, big deal^1!&* Whatever!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1298", "* Guess I've gotta&  find a new mystic&  artifact./%%")
ds_map_add(global.text_data_en, "scr_papcall_1308", "\E3A MYSTERIOUS&STATUE.../%%")
ds_map_add(global.text_data_en, "scr_papcall_1313", "\E3WHAT'S THAT MUSIC?/")
ds_map_add(global.text_data_en, "scr_papcall_1314", "AM I ON HOLD???/%%")
ds_map_add(global.text_data_en, "scr_papcall_1320", "\E0* That statue's been&  here forever.../")
ds_map_add(global.text_data_en, "scr_papcall_1321", "* No one knows where&  it came from./%%")
ds_map_add(global.text_data_en, "scr_papcall_1326", "* Hey^1, you figured out&  how to get the&  music to play...?/")
ds_map_add(global.text_data_en, "scr_papcall_1327", "\E9* Nice^1, isn't it?/%%")
ds_map_add(global.text_data_en, "scr_papcall_1336", "ALWAYS CARRY AN&UMBRELLA IN CASE&IT RAINS!/")
ds_map_add(global.text_data_en, "scr_papcall_1337", "YOU KNOW^1.&JUST KEEP A FEW&IN YOUR POCKETS./%%")
ds_map_add(global.text_data_en, "scr_papcall_1342", "NOTHING LIKE A&HOT BUCKET OF&'BRELLAS.../%%")
ds_map_add(global.text_data_en, "scr_papcall_1348", "* Those umbrellas were&  ASGORE's idea./")
ds_map_add(global.text_data_en, "scr_papcall_1349", "\E9* He says he doesn't&  want anyone to&  catch a cold./")
ds_map_add(global.text_data_en, "scr_papcall_1350", "\E0* Waterfall's underwater&  citizens couldn't care&  less^1, though./%%")
ds_map_add(global.text_data_en, "scr_papcall_1355", "* Did you get a 'brella?/%%")
ds_map_add(global.text_data_en, "scr_papcall_1365", "YOU CAN SEE YOUR&REFLECTION IN A&PUDDLE^1, BUT.../")
ds_map_add(global.text_data_en, "scr_papcall_1366", "\E1DON'T LET A BODY&OF WATER DETERMINE&YOUR SELF-WORTH!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1372", "HMMM^1? YOU'RE&HANGING OUT&WITH A FRIEND?/")
ds_map_add(global.text_data_en, "scr_papcall_1373", "THEN MAYBE YOU&SHOULDN'T TALK&TO ME.../")
ds_map_add(global.text_data_en, "scr_papcall_1374", "\E0YOU'LL MAKE THEM&JEALOUS!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1380", "CALLING AGAIN...?/%%")
ds_map_add(global.text_data_en, "scr_papcall_1386", "* What!^1?&* You're at my&  FAVORITE SPOT!?!?/")
ds_map_add(global.text_data_en, "scr_papcall_1387", "\E2* You'd better jump in&  at least 1000 puddles&  for me!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1392", "* Have you reached&  triple digits yet!?/%%")
ds_map_add(global.text_data_en, "scr_papcall_1402", "WHERE ARE YOU^1?&I HEAR WATER./")
ds_map_add(global.text_data_en, "scr_papcall_1403", "ARE YOU IN THE&TOILET?/%%")
ds_map_add(global.text_data_en, "scr_papcall_1409", "ALSO^1, WHAT'S A&TOILET?/%%")
ds_map_add(global.text_data_en, "scr_papcall_1415", "* This whole area's&  like a little&  nature trail./")
ds_map_add(global.text_data_en, "scr_papcall_1416", "* It's nice to have&  a rainy spot away&  from civilization.../")
ds_map_add(global.text_data_en, "scr_papcall_1417", "\E7* Though^1, with the city&  filling up^1, who knows&  how long that'll last./%%")
ds_map_add(global.text_data_en, "scr_papcall_1422", "* Well?^1!&* Are you enjoying&  nature!?/%%")
ds_map_add(global.text_data_en, "scr_papcall_1431", "THAT'S THE KING'S&CASTLE.../%%")
ds_map_add(global.text_data_en, "scr_papcall_1436", "SEEMS YOU CAN&FINALLY SEE THE&END./%%")
ds_map_add(global.text_data_en, "scr_papcall_1442", "* ASGORE's castle.../")
ds_map_add(global.text_data_en, "scr_papcall_1443", "\E7* Guess there's no&  stopping you^1, huh?/%%")
ds_map_add(global.text_data_en, "scr_papcall_1448", "* .../%%")
ds_map_add(global.text_data_en, "scr_papcall_1458", "SEEMS LIKE THE&PHONE CONNECTION'S&GETTING WEAK.../%%")
ds_map_add(global.text_data_en, "scr_papcall_1463", "BETTER NOT GO&PAST THAT POINT./%%")
ds_map_add(global.text_data_en, "scr_papcall_1469", "* The trail dead-ends&  here^1, unless you can&  jump./")
ds_map_add(global.text_data_en, "scr_papcall_1470", "\E4* Honestly^1, I can't&  believe I expected&  you to go this way./")
ds_map_add(global.text_data_en, "scr_papcall_1471", "\E6* What was I thinking???/")
ds_map_add(global.text_data_en, "scr_papcall_1472", "\E1* ... and how was I&  right???/%%")
ds_map_add(global.text_data_en, "scr_papcall_1477", "* Don't explain it!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1488", "FLOWERS...?/")
ds_map_add(global.text_data_en, "scr_papcall_1489", "\E0DO ANY OF THEM&TALK!^1?&SAY HI FOR ME!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1494", "FLOWERS ARE OUR&BEST FRIENDS!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1500", "* Those flowers.../")
ds_map_add(global.text_data_en, "scr_papcall_1501", "* One day^1, they just&  started to grow&  there./")
ds_map_add(global.text_data_en, "scr_papcall_1502", "* I swear^1, it's like&  they have a mind&  of their own./%%")
ds_map_add(global.text_data_en, "scr_papcall_1507", "* That's ridiculous&  though!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1513", "* Dzyn..^1. Dzyn.../")
ds_map_add(global.text_data_en, "scr_papcall_1514", "* (Brak odpowiedzi...)/%%")
ds_map_add(global.text_data_en, "scr_papcall_1522", "GARBAGE^1, HUH^1?&BOY^1, DO I KNOW&GARBAGE!!/")
ds_map_add(global.text_data_en, "scr_papcall_1523", "\E4AFTER ALL^1, I'M&HOUSEMATES WITH A&LAZY BAG OF TRASH!/")
ds_map_add(global.text_data_en, "scr_papcall_1524", "\E0HIS NAME'S TRASHY^1.&HE LIVES IN THE&GARBAGE CAN./%%")
ds_map_add(global.text_data_en, "scr_papcall_1529", "YOU DIDN'T THINK I&DIDN'T NAME MY&GARBAGE^1, DID YOU?/%%")
ds_map_add(global.text_data_en, "scr_papcall_1535", "\E1* That's where I&  met Alphys for the&  first time!!/")
ds_map_add(global.text_data_en, "scr_papcall_1536", "\E0* I was looking for&  cool swords^1, when&  I saw her.../")
ds_map_add(global.text_data_en, "scr_papcall_1537", "\E1* Uh^1, standing there^1,&  staring into the&  abyss./")
ds_map_add(global.text_data_en, "scr_papcall_1538", "\E4* She looked pretty..^1.&* Um..^1.&* ... contemplative./")
ds_map_add(global.text_data_en, "scr_papcall_1539", "\E9* So I asked her&  where she thought&  the abyss led to!/")
ds_map_add(global.text_data_en, "scr_papcall_1540", "\E2* She looked up at&  me^1, shocked^1, and went&  red in the face./")
ds_map_add(global.text_data_en, "scr_papcall_1541", "\E6* But I'm scary^1,&  so I'm used to&  that kinda stuff!/")
ds_map_add(global.text_data_en, "scr_papcall_1542", "\E1* Then she kept&  explaining all her&  different theories./")
ds_map_add(global.text_data_en, "scr_papcall_1543", "\E9* She went on for&  hours^1!&* I was so captivated!/")
ds_map_add(global.text_data_en, "scr_papcall_1544", "\E1* After that^1, I kept&  running into her&  here./")
ds_map_add(global.text_data_en, "scr_papcall_1545", "\E6* And now we're&  friends^1!&* Yeeee hawww!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1550", "* Oh my GOD^1!&* Don't make me tell&  this story AGAIN!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1557", "* Dzyn..^1. Dzyn.../")
ds_map_add(global.text_data_en, "scr_papcall_1558", "* (Brak odpowiedzi...)/%%")
ds_map_add(global.text_data_en, "scr_papcall_1566", "I KNOW WHY YOU&CALLED ME./")
ds_map_add(global.text_data_en, "scr_papcall_1567", "\E0I ALWAYS MAKE&PEOPLE FEEL&BETTER.../")
ds_map_add(global.text_data_en, "scr_papcall_1568", "\E2WHEN THEY'RE DOWN&IN THE DUMPS!!!/")
ds_map_add(global.text_data_en, "scr_papcall_1569", "\E0.../")
ds_map_add(global.text_data_en, "scr_papcall_1570", "\E3I'VE SPENT TOO&LONG WITH MY&BROTHER TODAY./%%")
ds_map_add(global.text_data_en, "scr_papcall_1575", "FORGET I SAID&THAT./%%")
ds_map_add(global.text_data_en, "scr_papcall_1581", "* The garbage dump!^1!&* So many great things&  come from there!!/")
ds_map_add(global.text_data_en, "scr_papcall_1582", "\E0* The only reason we&  have modern&  technology.../")
ds_map_add(global.text_data_en, "scr_papcall_1583", "* Is 'cause of all the&  human junk that flows&  from the surface!/")
ds_map_add(global.text_data_en, "scr_papcall_1584", "\E9* Plus^1, it's a GREAT&  place to meet&  girls./%%")
ds_map_add(global.text_data_en, "scr_papcall_1590", "* Wait^1!&* Don't quote me on&  that one!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1596", "* Dzyn..^1. Dzyn.../")
ds_map_add(global.text_data_en, "scr_papcall_1597", "* (Brak odpowiedzi...)/%%")
ds_map_add(global.text_data_en, "scr_papcall_1604", "HEY^1!&YOU'RE NEAR&UNDYNE'S HOUSE!/")
ds_map_add(global.text_data_en, "scr_papcall_1605", "THAT'S TO THE&LEFT-UPWARDS^1.&LUPWARDS./")
ds_map_add(global.text_data_en, "scr_papcall_1606", "\E3ALL THE OTHER&DIRECTIONS GO TO&THE WRONG HOUSE./")
ds_map_add(global.text_data_en, "scr_papcall_1607", "\E0NORTH:&GHOST HOUSE./")
ds_map_add(global.text_data_en, "scr_papcall_1608", "EAST: TURTLE HOUSE./")
ds_map_add(global.text_data_en, "scr_papcall_1609", "SOUTH:&TRASH HOUSE./%%")
ds_map_add(global.text_data_en, "scr_papcall_1614", "WEST: BIRD HOUSE./%%")
ds_map_add(global.text_data_en, "scr_papcall_1620", "SOUNDS LIKE YOU'RE&NEAR UNDYNE'S&HOUSE./")
ds_map_add(global.text_data_en, "scr_papcall_1621", "HEY^1!&WE SHOULD GO&VISIT UNDYNE!/")
ds_map_add(global.text_data_en, "scr_papcall_1623", "* I'm right here!/")
ds_map_add(global.text_data_en, "scr_papcall_1625", "I LOVE WHEN A PLAN&COMES TOGETHER^1!&NYEH HEH HEH!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1632", "* Well^1, I think we&  should hang out&  with Papyrus./")
ds_map_add(global.text_data_en, "scr_papcall_1634", "REALLY??^1?&CAN WE???/%%")
ds_map_add(global.text_data_en, "scr_papcall_1641", "THAT'S UNDYNE'S&HOUSE./")
ds_map_add(global.text_data_en, "scr_papcall_1642", "LET'S GO THERE&AND HANG OUT&SOME DAY!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1647", "STILL WAITING&OUTSIDE HER&HOUSE...?/")
ds_map_add(global.text_data_en, "scr_papcall_1648", "\E0YEAH^1, I DO THAT&SOMETIMES^1, TOO!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1653", "THAT'S UNDYNE'S&HOUSE./")
ds_map_add(global.text_data_en, "scr_papcall_1654", "YOU KNOW^1, THE&ONE WITH THE&SKELETON IN FRONT./%%")
ds_map_add(global.text_data_en, "scr_papcall_1662", "THAT'S UNDYNE'S&HOUSE./")
ds_map_add(global.text_data_en, "scr_papcall_1663", "IT'S A GREAT&PLACE TO.../")
ds_map_add(global.text_data_en, "scr_papcall_1664", "\E5UHHH?/")
ds_map_add(global.text_data_en, "scr_papcall_1666", "* Huff..^1. puff...!/")
ds_map_add(global.text_data_en, "scr_papcall_1667", "\E6* YEAH!!^1!&* That's MY HOUSE!!!/")
ds_map_add(global.text_data_en, "scr_papcall_1669", "HI UNDYNE^1!&HOW'D YOU GET&HERE SO FAST?/")
ds_map_add(global.text_data_en, "scr_papcall_1671", "\E9* I ran./")
ds_map_add(global.text_data_en, "scr_papcall_1673", "WOWIE!!^1!&UNDYNE!!!/")
ds_map_add(global.text_data_en, "scr_papcall_1674", "SOMEDAY I WANT&TO BE AS STRONG&AND SWEATY AS YOU./%%")
ds_map_add(global.text_data_en, "scr_papcall_1680", "SO YOU RAN HERE&JUST TO BE ON&THE PHONE???/")
ds_map_add(global.text_data_en, "scr_papcall_1682", "* Yep!/")
ds_map_add(global.text_data_en, "scr_papcall_1684", "THEN YOU MUST&HAVE SOMETHING.../")
ds_map_add(global.text_data_en, "scr_papcall_1685", "EXTREMELY COOL&TO SAY ABOUT&YOUR HOUSE!!!/")
ds_map_add(global.text_data_en, "scr_papcall_1687", "* Nope!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1694", "* That's my house./")
ds_map_add(global.text_data_en, "scr_papcall_1695", "\E1* Or^1, it WAS my&  house^1, until we&  set it on fire./")
ds_map_add(global.text_data_en, "scr_papcall_1696", "\E6* But hey^1, can't say&  I've never done&  that before!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1701", "* Hey^1, if you find&  any cool swords in&  the wreckage.../")
ds_map_add(global.text_data_en, "scr_papcall_1702", "* You know where to&  find me./%%")
ds_map_add(global.text_data_en, "scr_papcall_1714", "OH^1, THAT'S THE&HOUSE OF... UM..^1.&UNDYNE'S NEIGHBOR./")
ds_map_add(global.text_data_en, "scr_papcall_1715", "\E3WHAT WAS THEIR&NAME AGAIN?/")
ds_map_add(global.text_data_en, "scr_papcall_1716", "\E0SPOOKY BLOO BLOO?/%%")
ds_map_add(global.text_data_en, "scr_papcall_1721", "NAPPER HOG...?/%%")
ds_map_add(global.text_data_en, "scr_papcall_1727", "* That's Napstablook's&  house./")
ds_map_add(global.text_data_en, "scr_papcall_1728", "\E9* They kind of keep&  to theirself^1, but...&* That's a good ghost./")
ds_map_add(global.text_data_en, "scr_papcall_1729", "\E4* I try to be a good&  neighbor^1, but I think&  they're scared of me./")
ds_map_add(global.text_data_en, "scr_papcall_1730", "\E2* C'mon^1, what's scary&  about a good-natured&  invite to wrestle!!?/%%")
ds_map_add(global.text_data_en, "scr_papcall_1736", "* They're incorporeal&  anyway!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1745", "SO YOU'RE FRIENDS&WITH A GHOST.../")
ds_map_add(global.text_data_en, "scr_papcall_1746", "\E5ISN'T THAT KIND&OF SPOOKY?/")
ds_map_add(global.text_data_en, "scr_papcall_1747", "\E3I'D THINK YOU'D&LIKE YOUR FRIENDS&WARM AND CUDDLY.../")
ds_map_add(global.text_data_en, "scr_papcall_1748", "\E0LIKE SKELETONS!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1754", "VERY SOFT^1, AND&FULL OF CALCIUM./%%")
ds_map_add(global.text_data_en, "scr_papcall_1760", "* Oh^1, you're hanging&  out with Napstablook!^1?&* That's great!!!/")
ds_map_add(global.text_data_en, "scr_papcall_1761", "\E9* I haven't seen them&  hanging out with&  anyone since.../")
ds_map_add(global.text_data_en, "scr_papcall_1762", "\E4* Well^1, their cousin./")
ds_map_add(global.text_data_en, "scr_papcall_1763", "\E9* They would both watch&  TV at all hours of&  the day.../")
ds_map_add(global.text_data_en, "scr_papcall_1764", "\E0* Then they would&  practice these&  weird performances./")
ds_map_add(global.text_data_en, "scr_papcall_1765", "\E4* Where'd they go...?/%%")
ds_map_add(global.text_data_en, "scr_papcall_1771", "* Don't feel like you&  have to live up&  to their cousin!/")
ds_map_add(global.text_data_en, "scr_papcall_1772", "\E6* Just be your lovable&  old garbage self!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1781", "THAT HOUSE USED&TO BE HAUNTED./")
ds_map_add(global.text_data_en, "scr_papcall_1782", "BECAUSE A GHOST&LIVED THERE./")
ds_map_add(global.text_data_en, "scr_papcall_1783", "BUT THE GHOST&MOVED AWAY./")
ds_map_add(global.text_data_en, "scr_papcall_1784", "IT'S AN&UN-HAUNTED HOUSE./%%")
ds_map_add(global.text_data_en, "scr_papcall_1791", "BY THE BY^1,&BREAKING INTO&A HOUSE.../")
ds_map_add(global.text_data_en, "scr_papcall_1792", "\E3THAT'S ILLEGAL^1,&RIGHT???/")
ds_map_add(global.text_data_en, "scr_papcall_1793", "\E5PLEASE STOP&COMMITTING GHOST&CRIMES./%%")
ds_map_add(global.text_data_en, "scr_papcall_1799", "* WHAT?/")
ds_map_add(global.text_data_en, "scr_papcall_1800", "* You broke into&  Napstablook's&  cousin's house!?/")
ds_map_add(global.text_data_en, "scr_papcall_1801", "\E2* That's..^1.&* That's...!/")
ds_map_add(global.text_data_en, "scr_papcall_1802", "\E9* Hey^1, what was&  their name^1, anyway?/")
ds_map_add(global.text_data_en, "scr_papcall_1804", "HAPPSTABLOOK^1,&THE HAPPY&GHOST./")
ds_map_add(global.text_data_en, "scr_papcall_1806", "* Okay^1, that's&  DEFINITELY wrong./")
ds_map_add(global.text_data_en, "scr_papcall_1808", "IT'S NOT WRONG^1.&IT'S JUST MY&HEADCANON./%%")
ds_map_add(global.text_data_en, "scr_papcall_1815", "* Seriously^1, though^1,&  stop committing&  ghost crimes./%%")
ds_map_add(global.text_data_en, "scr_papcall_1825", "THESE SNAILS ARE&JUST LIKE MY&BROTHER./")
ds_map_add(global.text_data_en, "scr_papcall_1826", "ROUND^1, SLOW.../")
ds_map_add(global.text_data_en, "scr_papcall_1827", "\E3AND CONSTANTLY&EMITTING SLIME???/%%")
ds_map_add(global.text_data_en, "scr_papcall_1832", "EMITTING SLIME..^1.&THAT'S JUST WHAT&BROTHERS DO./%%")
ds_map_add(global.text_data_en, "scr_papcall_1838", "* Napstablook's family&  used to run this&  farm^1, but.../")
ds_map_add(global.text_data_en, "scr_papcall_1839", "\E7* They've all..^1.&* Passed on.../")
ds_map_add(global.text_data_en, "scr_papcall_1840", "\E9* ... to different jobs^1,&  since there's not&  much business here./")
ds_map_add(global.text_data_en, "scr_papcall_1841", "\E0* Them and their cousin&  stayed behind to run&  the family farm./")
ds_map_add(global.text_data_en, "scr_papcall_1842", "\E4* But no one's seen&  their cousin for a&  long time./")
ds_map_add(global.text_data_en, "scr_papcall_1843", "\E7* Now Napstablook's&  all alone.../")
ds_map_add(global.text_data_en, "scr_papcall_1844", "\E1* Be nice to them^1,&  okay!?/%%")
ds_map_add(global.text_data_en, "scr_papcall_1850", "* Cherish this ghost!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1859", "IF YOU SEE A&SHOP^1, YOU SHOULD&STOP.../")
ds_map_add(global.text_data_en, "scr_papcall_1860", "DROP^1, AND&ROLL.../")
ds_map_add(global.text_data_en, "scr_papcall_1861", "INTO SOME&GREAT DEALS!!/")
ds_map_add(global.text_data_en, "scr_papcall_1862", "BECAUSE WE'RE&HAVING A FIRE&SALE!!/")
ds_map_add(global.text_data_en, "scr_papcall_1863", "AT MY IMAGINARY&STORE^1, WHICH&SELLS FLAMES./%%")
ds_map_add(global.text_data_en, "scr_papcall_1868", "YET ANOTHER DREAM&OF MINE./%%")
ds_map_add(global.text_data_en, "scr_papcall_1874", "\E1* Hey!/")
ds_map_add(global.text_data_en, "scr_papcall_1875", "* That's the store of&  Gerson^1, the Hammer of&  Justice!/")
ds_map_add(global.text_data_en, "scr_papcall_1876", "\E9* The toughest monster&  that ever lived...!/")
ds_map_add(global.text_data_en, "scr_papcall_1877", "\E4* He fought in the&  war between humans&  and monsters.../")
ds_map_add(global.text_data_en, "scr_papcall_1878", "\E6* And he survived^1!&* He's a real hero!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1883", "* Are you gonna buy&  something?/%%")
ds_map_add(global.text_data_en, "scr_papcall_1892", "IS THE RIVER&PERSON THERE&TODAY?/%%")
ds_map_add(global.text_data_en, "scr_papcall_1897", "ARE THEY?/%%")
ds_map_add(global.text_data_en, "scr_papcall_1903", "* That river connects&  to Snowdin and&  Hotland./")
ds_map_add(global.text_data_en, "scr_papcall_1904", "* If you need to get&  from one place to&  another^1, jump in!/")
ds_map_add(global.text_data_en, "scr_papcall_1905", "\E2* Look^1, that's all we&  got for public&  transport^1, OK!?/%%")
ds_map_add(global.text_data_en, "scr_papcall_1910", "* So what?/%%")
ds_map_add(global.text_data_en, "scr_papcall_1919", "WHAT'S THAT&STRANGE WHISPER?/")
ds_map_add(global.text_data_en, "scr_papcall_1920", "\E5I MIGHT HAVE&TO HANG UP./%%")
ds_map_add(global.text_data_en, "scr_papcall_1925", "PAPYRUS ISN'T&HOME RIGHT NOW!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1931", "* A field of echo&  flowers.../")
ds_map_add(global.text_data_en, "scr_papcall_1932", "\E4* They babble back and&  forth to each other.../")
ds_map_add(global.text_data_en, "scr_papcall_1933", "* ... until their words&  become meaningless&  noise./")
ds_map_add(global.text_data_en, "scr_papcall_1934", "\E5* Creepy^1, huh?/%%")
ds_map_add(global.text_data_en, "scr_papcall_1939", "* Stop calling me&  from that creepy&  room!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_1948", "WHAT^1?&MUSHROOMS^1?&CAN YOU EAT THEM?/")
ds_map_add(global.text_data_en, "scr_papcall_1949", "\E3ARE YOU SURE&YOU CAN'T EAT&THEM???/%%")
ds_map_add(global.text_data_en, "scr_papcall_1954", "I'D TRY EATING&THEM./%%")
ds_map_add(global.text_data_en, "scr_papcall_1960", "* Once you get familiar&  with this room.../")
ds_map_add(global.text_data_en, "scr_papcall_1961", "\E9* You don't even need&  to light up the&  mushrooms!/")
ds_map_add(global.text_data_en, "scr_papcall_1962", "\E0* I mean^1, the path&  to Temmie Village is&  never lit up here./")
ds_map_add(global.text_data_en, "scr_papcall_1963", "\E6* But why would you&  wanna go there!?/%%")
ds_map_add(global.text_data_en, "scr_papcall_1968", "* It's down south if&  you want to avoid&  it./%%")
ds_map_add(global.text_data_en, "scr_papcall_1977", "LANTERNS^1?&UM^1, OKAY.../")
ds_map_add(global.text_data_en, "scr_papcall_1978", "\E0CAN YOU EAT&THEM???/")
ds_map_add(global.text_data_en, "scr_papcall_1979", "\E3I'M SERIOUSLY OUT&OF IDEAS HERE./%%")
ds_map_add(global.text_data_en, "scr_papcall_1984", "I'D TRY EATING&THEM./%%")
ds_map_add(global.text_data_en, "scr_papcall_1990", "* Once you get familiar&  with this room.../")
ds_map_add(global.text_data_en, "scr_papcall_1991", "\E9* You don't even need&  to light up the&  lanterns!/")
ds_map_add(global.text_data_en, "scr_papcall_1992", "\E0* ... yeah./%%")
ds_map_add(global.text_data_en, "scr_papcall_1997", "* Whatever./%%")
ds_map_add(global.text_data_en, "scr_papcall_2007", "HMMM..^1.&A CORRIDOR FILLED&WITH WATER./")
ds_map_add(global.text_data_en, "scr_papcall_2008", "\E0THAT'S JUST A&GUESS./%%")
ds_map_add(global.text_data_en, "scr_papcall_2013", "I HAVE NOTHING&TO SAY./%%")
ds_map_add(global.text_data_en, "scr_papcall_2019", "* That's where I first&  talked to you!/")
ds_map_add(global.text_data_en, "scr_papcall_2020", "\E3* Weren't you SUPER&  terrified?/")
ds_map_add(global.text_data_en, "scr_papcall_2021", "\E2* I practice that&  monologue ALL the&  time in the mirror!/")
ds_map_add(global.text_data_en, "scr_papcall_2023", "UNDYNE???/")
ds_map_add(global.text_data_en, "scr_papcall_2025", "* I mean!!^1!&* Uh!!^1!&* No I don't!!!/")
ds_map_add(global.text_data_en, "scr_papcall_2027", "OH^1.&I WAS JUST GOING&TO ASK./")
ds_map_add(global.text_data_en, "scr_papcall_2028", "\E0DO YOU WANT TO&PRACTICE MONOLOGUES&TOGETHER...?!!/")
ds_map_add(global.text_data_en, "scr_papcall_2030", "* UH!!^1!&* NO!!^1!&* I DON'T!!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2035", "ATTENTION EVERYONE^1!&I AM GOING TO&OPEN THE FRIDGE!/")
ds_map_add(global.text_data_en, "scr_papcall_2037", "* Do you have a&  monologue for&  EVERYTHING?/%%")
ds_map_add(global.text_data_en, "scr_papcall_2051", "ECHO FLOWERS.../")
ds_map_add(global.text_data_en, "scr_papcall_2052", "\E0THERE'S ONLY ONE&TALKING FLOWER&FOR ME!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2058", "* Fields of flowers^1,&  whispering everybody's&  hopes and dreams.../")
ds_map_add(global.text_data_en, "scr_papcall_2059", "\E1* NGAHHHH!!^1!&* IT FILLS ME WITH&  POWER!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2064", "* NGAHHHH!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2078", "EACH AREA HAS TO&HAVE A PRECARIOUS&BRIDGE./")
ds_map_add(global.text_data_en, "scr_papcall_2079", "IT'S MANDATED BY&THE GOVERNMENT./")
ds_map_add(global.text_data_en, "scr_papcall_2080", "OF COURSE^1, KING&FLUFFYBOY WANTS TO&UNMANDATE IT SAFER./")
ds_map_add(global.text_data_en, "scr_papcall_2081", "\E1WHY!!^1? WON'T HE&THINK OF THE&CHILDREN!?/%%")
ds_map_add(global.text_data_en, "scr_papcall_2088", "SPIKES^1. DANGER&BRIDGES^1. THE&PILLARS OF YOUTH./%%")
ds_map_add(global.text_data_en, "scr_papcall_2094", "* This room...!/")
ds_map_add(global.text_data_en, "scr_papcall_2095", "* Error?/%%")
ds_map_add(global.text_data_en, "scr_papcall_2098", "\E7* That sure was a&  tense scenario./")
ds_map_add(global.text_data_en, "scr_papcall_2099", "\E4* I just wanted to&  help that poor kid^1,&  but.../")
ds_map_add(global.text_data_en, "scr_papcall_2100", "\E1* I thought if I tried^1,&  you'd attack me!/")
ds_map_add(global.text_data_en, "scr_papcall_2101", "\E9* Thankfully^1, you&  ended up saving&  them./%%")
ds_map_add(global.text_data_en, "scr_papcall_2105", "\E7* I'd actually..^1.&* Forgotten what had&  happened here./")
ds_map_add(global.text_data_en, "scr_papcall_2106", "\E4* You just let that&  poor kid drop to&  the floor./")
ds_map_add(global.text_data_en, "scr_papcall_2107", "* Maybe you were just&  afraid./")
ds_map_add(global.text_data_en, "scr_papcall_2108", "\E7* But if I hadn't&  been around^1, then...?/%%")
ds_map_add(global.text_data_en, "scr_papcall_2112", "\E2* That's when you ran&  away when your friend&  asked for help!!!/")
ds_map_add(global.text_data_en, "scr_papcall_2113", "\E9* Though^1, who can blame&  you for fleeing from&  certain death...?/")
ds_map_add(global.text_data_en, "scr_papcall_2114", "\E6* ME!!!^1!&* I'm still TOTALLY&  disappointed!/")
ds_map_add(global.text_data_en, "scr_papcall_2115", "\E1* That's the WIMPIEST&  thing you've EVER&  done!/")
ds_map_add(global.text_data_en, "scr_papcall_2116", "* Apologize to your&  poor friend^1, OK^1,&  buster!?/%%")
ds_map_add(global.text_data_en, "scr_papcall_2122", "* .../%%")
ds_map_add(global.text_data_en, "scr_papcall_2136", "THIS IS WHERE&ELDER PUZZLER&LIKES TO STAND./")
ds_map_add(global.text_data_en, "scr_papcall_2137", "BLOCK-PUSHING^1.&KEY-GATHERING^1.&TEDIOUS AGONY./")
ds_map_add(global.text_data_en, "scr_papcall_2138", "IT'S IMPORTANT TO&RESPECT OUR ROOTS!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2144", "THIS IS WHERE&ELDER PUZZLER&LIKES TO STAND./")
ds_map_add(global.text_data_en, "scr_papcall_2145", "IT'S IMPORTANT TO&RESPECT OUR&PUZZLING ROOTS./")
ds_map_add(global.text_data_en, "scr_papcall_2147", "* Yeah^1, someone else&  has to care so I&  don't have to!/")
ds_map_add(global.text_data_en, "scr_papcall_2149", "BUT UNDYNE^1, DON'T&YOU LIKE TRADITION?/")
ds_map_add(global.text_data_en, "scr_papcall_2151", "* I worked in an office&  pushing blocks for&  a month!/")
ds_map_add(global.text_data_en, "scr_papcall_2152", "\E9* My respect for block&  puzzles was depleted&  by corporate life./")
ds_map_add(global.text_data_en, "scr_papcall_2154", "WHAT!^1? YOU THREW&AWAY MY DREAM&LIFE!!!/")
ds_map_add(global.text_data_en, "scr_papcall_2155", "\E2THE LIFE OF A&SIMPLE SALARYMAN.../")
ds_map_add(global.text_data_en, "scr_papcall_2156", "COMMUTING EVERY&DAY ON A TRAIN&FULL OF SPIKES.../")
ds_map_add(global.text_data_en, "scr_papcall_2158", "* (I won't tell him&  that's not how it&  works...)/%%")
ds_map_add(global.text_data_en, "scr_papcall_2163", "UNDYNE^1, DID YOU&REALLY HAVE AN&OFFICE JOB?/")
ds_map_add(global.text_data_en, "scr_papcall_2165", "* Well^1, it was more&  of a^1, uh^1, community&  service thing./")
ds_map_add(global.text_data_en, "scr_papcall_2167", "THAT'S UNDYNE!^1!&ALWAYS HELPING OUT&THE COMMUNITY!/")
ds_map_add(global.text_data_en, "scr_papcall_2169", "* Uh^1, yep^1!&* Totally of my own&  volition there!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2185", "THAT'S UNDYNE'S&DRAMATIC CRAG./")
ds_map_add(global.text_data_en, "scr_papcall_2186", "\E0SHE'S ALWAYS&POSING ATOP IT./")
ds_map_add(global.text_data_en, "scr_papcall_2187", "\E3MUMBLING SOMETHING&TO HERSELF.../%%")
ds_map_add(global.text_data_en, "scr_papcall_2191", "I THINK IT'S&SOMETHING SHE&HAS TO MEMORIZE./%%")
ds_map_add(global.text_data_en, "scr_papcall_2198", "* Oh my GOD!!^1!&* Wasn't this room&  the BEST!?/")
ds_map_add(global.text_data_en, "scr_papcall_2199", "\E3* Like when I decided&  to NOT do that&  BORING monologue.../")
ds_map_add(global.text_data_en, "scr_papcall_2200", "\E6* And then went TOTALLY&  off-the-cuff!?/")
ds_map_add(global.text_data_en, "scr_papcall_2201", "\E2* Or when I almost&  killed you with&  spears???/")
ds_map_add(global.text_data_en, "scr_papcall_2202", "\E3* Or when I almost&  killed you with&  MORE spears???/")
ds_map_add(global.text_data_en, "scr_papcall_2203", "\E9* Aw man^1.&* I should have taken&  photos./")
ds_map_add(global.text_data_en, "scr_papcall_2204", "\E8* Think about how cute&  a little scrapbook&  would be.../")
ds_map_add(global.text_data_en, "scr_papcall_2206", "NOW I WANT A&SCRAPBOOK OF&MY FIGHT TOO!!!/")
ds_map_add(global.text_data_en, "scr_papcall_2208", "* Let's start a photo&  company for boss&  fights!/")
ds_map_add(global.text_data_en, "scr_papcall_2210", "ONE WEEK LATER^1,&SAMPLE GLOSSIES&IN THE MAIL./")
ds_map_add(global.text_data_en, "scr_papcall_2212", "* Relive the memories.../%%")
ds_map_add(global.text_data_en, "scr_papcall_2217", "* Going off-the-cuff..^1.&* It helped that I...&* Uh./")
ds_map_add(global.text_data_en, "scr_papcall_2218", "\E9* Completely forgot the&  words to my monologue^1,&  anyway.../%%")
ds_map_add(global.text_data_en, "scr_papcall_2234", "HEY..^1. ISN'T THIS&WHERE I CALLED&YOU?/")
ds_map_add(global.text_data_en, "scr_papcall_2235", "\E2I HAVE A PHOTO-&GRAPHIC MEMORY&FOR PHONE CALLS./")
ds_map_add(global.text_data_en, "scr_papcall_2236", "\E3.../")
ds_map_add(global.text_data_en, "scr_papcall_2237", "\E5HEY^1, WHEN ARE&WE GONNA HANG&WITH UNDYNE?/%%")
ds_map_add(global.text_data_en, "scr_papcall_2241", "\E0HEY^1, WHEN ARE&WE GONNA HANG&WITH UNDYNE?/%%")
ds_map_add(global.text_data_en, "scr_papcall_2248", "* This is where I&  was chasing you.../")
ds_map_add(global.text_data_en, "scr_papcall_2249", "\E1* But you got a phone&  call^1, so I had to&  wait./")
ds_map_add(global.text_data_en, "scr_papcall_2251", "OH^1!&THAT WAS ME!/")
ds_map_add(global.text_data_en, "scr_papcall_2253", "* What!^1?&* What were you even&  calling about!?/")
ds_map_add(global.text_data_en, "scr_papcall_2255", "I WAS JUST&SAYING WE SHOULD&ALL HANG OUT./")
ds_map_add(global.text_data_en, "scr_papcall_2257", "* As I was trying&  to kill them!?/")
ds_map_add(global.text_data_en, "scr_papcall_2259", "WELL!^1!&NOBODY STARTS AS&GREAT FRIENDS!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2265", "* Nobody starts as&  great friends^1, huh?/")
ds_map_add(global.text_data_en, "scr_papcall_2267", "THAT'S THE RULE./")
ds_map_add(global.text_data_en, "scr_papcall_2269", "* Well^1, you're gonna&  END as my great&  friend!!/")
ds_map_add(global.text_data_en, "scr_papcall_2271", "N... NO!!^1!&NOT THE FLATTERY&SUPLEX!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2285", "OH!!!&YOU'RE IN HOTLAND&NOW!!!/")
ds_map_add(global.text_data_en, "scr_papcall_2286", "\E4... HEY SANS^1,&AREN'T YOU SUPPOSED&TO BE THERE?/")
ds_map_add(global.text_data_en, "scr_papcall_2288", "* don't worry^1.&* i am./")
ds_map_add(global.text_data_en, "scr_papcall_2290", "UF!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2295", "FINALLY^1, SANS IS&DOING HIS JOB./%%")
ds_map_add(global.text_data_en, "scr_papcall_2302", "\E1* I can't believe&  Papyrus's brother was&  sleeping!!/")
ds_map_add(global.text_data_en, "scr_papcall_2303", "\E2* I was counting on&  him to stop you!^1!&* UrrrrgHHHH!!!/")
ds_map_add(global.text_data_en, "scr_papcall_2305", "HE'S GOTTEN REALLY&OUT OF SHAPE^1.&HE TIRES EASILY./")
ds_map_add(global.text_data_en, "scr_papcall_2306", "LATELY HE'S BEEN&NAPPING OVER 7&HOURS A NIGHT.../")
ds_map_add(global.text_data_en, "scr_papcall_2307", "\E1HE'S NAPPING&HIMSELF INTO AN&EARLY GRAVE!!/")
ds_map_add(global.text_data_en, "scr_papcall_2309", "* I agree!^1!&* Your brother needs&  to...!/")
ds_map_add(global.text_data_en, "scr_papcall_2310", "\E9* ... wait^1, isn't that&  just called sleeping?/")
ds_map_add(global.text_data_en, "scr_papcall_2312", "UNDYNE!^1! NO!!^1!&NOT YOU TOO!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2319", "* Wait^1. Papyrus..^1.&* When do YOU sleep?/")
ds_map_add(global.text_data_en, "scr_papcall_2321", "\E3I'M USUALLY TOO&BUSY TO SLEEP^1.&WHY???/")
ds_map_add(global.text_data_en, "scr_papcall_2323", "* Well^1, I was just&  thinking.../")
ds_map_add(global.text_data_en, "scr_papcall_2324", "\E6* If you're not using&  that cool car bed^1,&  can I have it!?/%%")
ds_map_add(global.text_data_en, "scr_papcall_2339", "A WATER COOLER...^1?&IN HOTLAND???&THAT'S WEIRD./")
ds_map_add(global.text_data_en, "scr_papcall_2340", "\E0SHOULDN'T IT BE&A FIRE COOLER&INSTEAD?/%%")
ds_map_add(global.text_data_en, "scr_papcall_2345", "\E3WHAT'S A WATER&COOLER DO^1,&ANYWAY?/")
ds_map_add(global.text_data_en, "scr_papcall_2346", "\E3MAKE WATER..^1.&COOLER?/")
ds_map_add(global.text_data_en, "scr_papcall_2347", "\E0SO IT GIVES IT&SPIKES AND MAKES&IT GLOW?/%%")
ds_map_add(global.text_data_en, "scr_papcall_2354", "* Thank God for that&  water cooler^1, huh?/")
ds_map_add(global.text_data_en, "scr_papcall_2355", "\E4* Actually^1, you can&  thank Alphys.../")
ds_map_add(global.text_data_en, "scr_papcall_2356", "\E9* She put it there&  just for me./")
ds_map_add(global.text_data_en, "scr_papcall_2357", "\E0* Now I can take a&  drink on the way&  to her lab./")
ds_map_add(global.text_data_en, "scr_papcall_2358", "\E1* Though^1, usually I'm&  not wearing 100&  pounds of armor...!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2363", "* Thanks for giving me&  that water^1, I guess./%%")
ds_map_add(global.text_data_en, "scr_papcall_2377", "A LAB??^1?&MY BROTHER&WOULD LOVE THAT!/")
ds_map_add(global.text_data_en, "scr_papcall_2378", "HE LOVES SCIENCE&FICTION!!/")
ds_map_add(global.text_data_en, "scr_papcall_2379", "ESPECIALLY&WHEN IT'S&REAL./%%")
ds_map_add(global.text_data_en, "scr_papcall_2384", "WAIT^1, THAT BAG OF&DOG FOOD LOOKS&FAMILIAR.../")
ds_map_add(global.text_data_en, "scr_papcall_2385", "I REMEMBER SEEING&IT..^1.&IN SANS'S ROOM?/")
ds_map_add(global.text_data_en, "scr_papcall_2386", "\E1YEAH^1! I ASKED HIM&WHY HE HAD IT!/")
ds_map_add(global.text_data_en, "scr_papcall_2387", "\E0HE TOLD ME HE&WAS TRYING TO&EAT HEALTHIER./%%")
ds_map_add(global.text_data_en, "scr_papcall_2393", "* You're at Alphys's&  lab^1?&* Is she there...?/")
ds_map_add(global.text_data_en, "scr_papcall_2394", "\E1* Hey^1, tell her I&  said hi^1, okay!?/")
ds_map_add(global.text_data_en, "scr_papcall_2395", "\E2* And^1, tell me how&  she's doing!/")
ds_map_add(global.text_data_en, "scr_papcall_2396", "\E9* And tell me if&  she needs anything^1,&  and.../")
ds_map_add(global.text_data_en, "scr_papcall_2397", "\E1* Wait^1! No^1!&* Don't ask any of&  that!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2402", "* But she's fine^1,&  right!?/%%")
ds_map_add(global.text_data_en, "scr_papcall_2408", "* (There's some strange&  interference...)/%%")
ds_map_add(global.text_data_en, "scr_papcall_2416", "\E2YOU'RE IN HER&ROOM^1, UNINVITED^1?&WOWIE.../")
ds_map_add(global.text_data_en, "scr_papcall_2417", "\E3THAT'S EXTREMELY&CREEPY./%%")
ds_map_add(global.text_data_en, "scr_papcall_2422", "MAYBE DON'T DO&THAT./%%")
ds_map_add(global.text_data_en, "scr_papcall_2428", "* What!^1?&* You're in her room!?/")
ds_map_add(global.text_data_en, "scr_papcall_2429", "\E2* Get out of there!/")
ds_map_add(global.text_data_en, "scr_papcall_2430", "\E9* Unless^1, um^1, she&  invited you.../")
ds_map_add(global.text_data_en, "scr_papcall_2431", "\E2* No wayyyy!!^1!&* That did NOT happen!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2436", "* Stop that!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2445", "HOTLAND^1, HUH.../")
ds_map_add(global.text_data_en, "scr_papcall_2446", "\E2I KNOW IT LIKE&THE BACK OF&MY HAND.../")
ds_map_add(global.text_data_en, "scr_papcall_2447", "\E3WHICH^1, SINCE I'M&ALWAYS WEARING&GLOVES.../")
ds_map_add(global.text_data_en, "scr_papcall_2448", "\E0I DON'T KNOW&ANYTHING&ABOUT!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2453", "MY KNOWLEDGE&QUANTITY IS&STAGNANT./%%")
ds_map_add(global.text_data_en, "scr_papcall_2459", "NEITHER OF US&KNOW ANYTHING&ABOUT HOTLAND./")
ds_map_add(global.text_data_en, "scr_papcall_2461", "* So we'll just have&  to COMBINE OUR&  POWER!!!/")
ds_map_add(global.text_data_en, "scr_papcall_2463", "ZERO PLUS ZERO&IS STILL ZERO./")
ds_map_add(global.text_data_en, "scr_papcall_2465", "* Yeah^1, but it's a&  BIG zero!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2470", "* THE BIGGEST ZERO!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2479", "HEY^1, YOU SHOULD&COME TO SNOWDIN&AND VISIT ME!/")
ds_map_add(global.text_data_en, "scr_papcall_2480", "\E2I'VE BEEN WORKING&ON A FEW THINGS./")
ds_map_add(global.text_data_en, "scr_papcall_2481", "\E0A FEW SENTENCES&TO STAND AROUND&AND REPEAT./%%")
ds_map_add(global.text_data_en, "scr_papcall_2486", "A FEW SENTENCES&TO STAND AROUND&AND REPEAT./%%")
ds_map_add(global.text_data_en, "scr_papcall_2492", "HEY^1, YOU SHOULD&COME TO SNOWDIN&AND VISIT ME!/")
ds_map_add(global.text_data_en, "scr_papcall_2494", "* No WAY!!^1!&* Come to Snowdin&  and visit ME!!!/")
ds_map_add(global.text_data_en, "scr_papcall_2496", "WHAT??^1?&WE'RE IN THE&SAME LOCATION!!/")
ds_map_add(global.text_data_en, "scr_papcall_2498", "* Wrong^1! I'm standing&  slightly to the&  right!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2503", "* Come on!!^1!&* Make your choice!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2512", "CONVEYOR BELTS&EVERYWHERE?^1?&ARE YOU SERIOUS?/")
ds_map_add(global.text_data_en, "scr_papcall_2513", "\E3IMAGINE RIDING&ONE TO GET TO&WORK OR SCHOOL./")
ds_map_add(global.text_data_en, "scr_papcall_2514", "RIDICULOUS./")
ds_map_add(global.text_data_en, "scr_papcall_2515", "\E0NOW ICE AND&SPIKES^1, THERE'S&CONVENIENCE!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2520", "GLAD I DON'T&LIVE IN HOTLAND./%%")
ds_map_add(global.text_data_en, "scr_papcall_2526", "* I rode on a&  conveyor belt&  once./")
ds_map_add(global.text_data_en, "scr_papcall_2527", "\E1* I learned pretty&  fast that they&  make me sick./")
ds_map_add(global.text_data_en, "scr_papcall_2529", "DID YOU HURL??/")
ds_map_add(global.text_data_en, "scr_papcall_2531", "* Yeah^1, like 9000&  times!^1!&* It was awesome!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2536", "STOP CALLING AND&MAKING HER SAY&GROSS THINGS./%%")
ds_map_add(global.text_data_en, "scr_papcall_2546", "STEAM VENTS^1?&WOW..^1. THAT&SOUNDS AWFUL./")
ds_map_add(global.text_data_en, "scr_papcall_2547", "\E1WHAT IF YOU'RE&WEARING A&DRESS?/%%")
ds_map_add(global.text_data_en, "scr_papcall_2552", "GLAD I DON'T&LIVE IN HOTLAND!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2558", "* Steam vents^1?&* I think Alphys told&  me about those./")
ds_map_add(global.text_data_en, "scr_papcall_2559", "* The CORE cools off&  by releasing steam&  through those.../")
ds_map_add(global.text_data_en, "scr_papcall_2560", "\E9* And at the same&  time^1, it doubles&  as transport!/")
ds_map_add(global.text_data_en, "scr_papcall_2561", "\E6* Pretty cool^1, if&  you aren't wearing&  a dress!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2566", "* Huh!^1?&* Did you put on&  a dress?/%%")
ds_map_add(global.text_data_en, "scr_papcall_2576", "ORANGE AND BLUE&LASERS^1, HUH?/")
ds_map_add(global.text_data_en, "scr_papcall_2577", "\E3JUST KEEP IN&MIND WHAT THE&COLORS MEAN./")
ds_map_add(global.text_data_en, "scr_papcall_2578", "\E0BLUE MEANS&JUMP.../")
ds_map_add(global.text_data_en, "scr_papcall_2579", "\E3AND ORANGE MEANS&YOU'LL..^1. SMELL&LIKE ORANGES./")
ds_map_add(global.text_data_en, "scr_papcall_2580", "\E0THAT'S WHAT I&REMEMBER./%%")
ds_map_add(global.text_data_en, "scr_papcall_2585", "HAVE FUN!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2591", "* What!^1?&* Why'd I call Alphys&  about the weather?/")
ds_map_add(global.text_data_en, "scr_papcall_2592", "\E3* Who CARES!?!^1?&* Isn't it natural&  to love meteorology!?/")
ds_map_add(global.text_data_en, "scr_papcall_2594", "ZOINKS!!!/")
ds_map_add(global.text_data_en, "scr_papcall_2595", "\E3I THOUGHT THAT WAS&JUST AN EXCUSE&TO TALK TO HER./")
ds_map_add(global.text_data_en, "scr_papcall_2596", "I DIDN'T KNOW&THERE WAS WEATHER&DOWN HERE!!!/")
ds_map_add(global.text_data_en, "scr_papcall_2598", "\E1* YEAH!?!^1!&* THERE IS?!!?!/")
ds_map_add(global.text_data_en, "scr_papcall_2599", "\E2* And I'm forecasting&  an incoming front&  of SHUT UP!!!/")
ds_map_add(global.text_data_en, "scr_papcall_2601", "WOWIE!!^1!&WILL I NEED&AN UMBRELLA?/%%")
ds_map_add(global.text_data_en, "scr_papcall_2607", "* What!^1?&* What ABOUT this&  room!?/%%")
ds_map_add(global.text_data_en, "scr_papcall_2614", "* Oh^1, Papyrus^1.&* I can't stay mad&  at you./")
ds_map_add(global.text_data_en, "scr_papcall_2616", "IT'S OKAY^1, I&FORGIVE YOU!/")
ds_map_add(global.text_data_en, "scr_papcall_2617", "\E3(PSST^1, WHEN WAS&SHE MAD AT ME?)/%%")
ds_map_add(global.text_data_en, "scr_papcall_2637", "IT'S IMPORTANT TO&STAY IN SCHOOL./")
ds_map_add(global.text_data_en, "scr_papcall_2638", "\E3A REAL TEACHER.../")
ds_map_add(global.text_data_en, "scr_papcall_2639", "\E0WOULD NEVER ACCEPT&DEADLY LASERS AS&AN EXCUSE!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2645", "GLAD!&I DON'T&LIVE IN HOTLAND!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2651", "* Huh^1?&* Those kids are&  skipping school?/")
ds_map_add(global.text_data_en, "scr_papcall_2652", "* .../")
ds_map_add(global.text_data_en, "scr_papcall_2653", "\E6* ... well^1, I can't&  blame them^1, school&  sucks!/")
ds_map_add(global.text_data_en, "scr_papcall_2654", "\E4* We need to find&  some way to make&  it cooler.../")
ds_map_add(global.text_data_en, "scr_papcall_2655", "\E2* Hey^1, what if I&  visited their&  school!?/")
ds_map_add(global.text_data_en, "scr_papcall_2656", "\E6* Then I could beat&  up ALL the teachers!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2661", "* Okay^1, maybe I&  wouldn't beat up&  a teacher.../%%")
ds_map_add(global.text_data_en, "scr_papcall_2671", "OH NO^1!&THE PUZZLES&REACTIVATING.../")
ds_map_add(global.text_data_en, "scr_papcall_2672", "\E3CAUSED THOSE&PEOPLE TO MISS&THEIR WORK!?/")
ds_map_add(global.text_data_en, "scr_papcall_2674", "* yep./")
ds_map_add(global.text_data_en, "scr_papcall_2675", "\E1* that's why i'm&  missing work^1, too./")
ds_map_add(global.text_data_en, "scr_papcall_2677", "OH MY GOD!!^1!&SANS^1, GO DO YOUR&JOB(S)!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2682", "GLAD^1,&I DON'T&LIVE IN HOTLAND./")
ds_map_add(global.text_data_en, "scr_papcall_2684", "* me too./")
ds_map_add(global.text_data_en, "scr_papcall_2686", "THEN WHY ARE&YOU SKIPPING&WORK!?!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2697", "I HEARD YOU GOT&TO MEET METTATON!!/")
ds_map_add(global.text_data_en, "scr_papcall_2698", "\E0IS THAT TRUE!^1?&CAN YOU GET ME&AN AUTOGRAPH!?/")
ds_map_add(global.text_data_en, "scr_papcall_2699", "\E2HE'S MY FAVORITE&SEXY RECTANGLE!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2704", "I WISH I LIVED&IN HOTLAND!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2710", "I HEARD YOU GOT&TO MEET METTATON!!/")
ds_map_add(global.text_data_en, "scr_papcall_2712", "* Really^1? Careful^1, that&  dude gives me bad&  vibes./")
ds_map_add(global.text_data_en, "scr_papcall_2714", "WH-WHAT^1?&BUT HE'S SO&POPULAR.../")
ds_map_add(global.text_data_en, "scr_papcall_2716", "* I don't care about&  people just because&  they're popular./")
ds_map_add(global.text_data_en, "scr_papcall_2718", "WELL^1, YOU CAN&SAY THAT BECAUSE&YOU'RE POPULAR./")
ds_map_add(global.text_data_en, "scr_papcall_2720", "* Pssshhht^1, what!^1?&* Popular with WHO?/")
ds_map_add(global.text_data_en, "scr_papcall_2722", "YOU'RE POPULAR&WITH ME!!!/")
ds_map_add(global.text_data_en, "scr_papcall_2724", "* Awww..^1.&* Papyrus^1, you're popular&  with me^1, too./")
ds_map_add(global.text_data_en, "scr_papcall_2726", "AWW^1, WOWIE!^1!&WAIT.../")
ds_map_add(global.text_data_en, "scr_papcall_2727", "\E3DOES THAT MEAN&YOU DON'T CARE&ABOUT ME...?/%%")
ds_map_add(global.text_data_en, "scr_papcall_2732", "* Let's not discuss&  this anymore./%%")
ds_map_add(global.text_data_en, "scr_papcall_2742", "WHAT^1? MY BROTHER'S&ACTUALLY AT HIS&STATION?/")
ds_map_add(global.text_data_en, "scr_papcall_2743", "\E1BUT SOMEHOW^1, HE'S&SELLING HOTDOGS&INSTEAD?/")
ds_map_add(global.text_data_en, "scr_papcall_2744", "\E3SLACKING OFF BY&DOING WORK.../")
ds_map_add(global.text_data_en, "scr_papcall_2745", "TRULY MY BROTHER&IS A MASTER./%%")
ds_map_add(global.text_data_en, "scr_papcall_2750", "NO FURTHER&COMMENT./%%")
ds_map_add(global.text_data_en, "scr_papcall_2756", "WHAT^1? MY BROTHER'S&ACTUALLY AT HIS&STATION?/")
ds_map_add(global.text_data_en, "scr_papcall_2758", "* What^1?&* I thought he only&  had three stations./")
ds_map_add(global.text_data_en, "scr_papcall_2760", "NO^1, HE HAS..^1.&AT LEAST FOUR?/")
ds_map_add(global.text_data_en, "scr_papcall_2762", "* Who the heck keeps&  hiring this guy!?/%%")
ds_map_add(global.text_data_en, "scr_papcall_2767", "* Seriously!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2774", "MY BROTHER ISN'T&EVEN THERE???/")
ds_map_add(global.text_data_en, "scr_papcall_2775", "\E1WASN'T HE SLACKING&OFF BY SELLING&HOTDOGS?/")
ds_map_add(global.text_data_en, "scr_papcall_2776", "\E3NOW HE'S SLACKING&OFF FROM SLACKING&OFF.../")
ds_map_add(global.text_data_en, "scr_papcall_2777", "TRULY MY BROTHER&IS A MASTER./%%")
ds_map_add(global.text_data_en, "scr_papcall_2782", "NO FURTHER&COMMENT./%%")
ds_map_add(global.text_data_en, "scr_papcall_2796", "WHAT^1? YOU HAVE TO&SOLVE A PUZZLE&ON THE CONVEYORS?/")
ds_map_add(global.text_data_en, "scr_papcall_2797", "\E3THAT GOES AGAINST&PUZZLE DESIGN&101.../")
ds_map_add(global.text_data_en, "scr_papcall_2798", "\E4CONVEYORS ARE&AWFUL AND SHOULD&NEVER BE USED!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2803", "GLAD I DON'T&LIVE ON CONVEYOR&PLANET!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2809", "WHAT^1? YOU HAVE TO&SOLVE A PUZZLE&ON THE CONVEYORS?/")
ds_map_add(global.text_data_en, "scr_papcall_2811", "* Oh MAN^1, did I ever&  tell you MY conveyor&  puzzle idea?/")
ds_map_add(global.text_data_en, "scr_papcall_2813", "WHAT... IS IT?/")
ds_map_add(global.text_data_en, "scr_papcall_2815", "* Imagine four basketball&  hoops on the sides&  of a conveyor loop./")
ds_map_add(global.text_data_en, "scr_papcall_2816", "\E2* The conveyor keeps&  speeding up^1, until&  you get sick.../")
ds_map_add(global.text_data_en, "scr_papcall_2817", "\E6* Then you have to&  puke in all four&  hoops in a row!!!/")
ds_map_add(global.text_data_en, "scr_papcall_2819", "I HATE THIS./")
ds_map_add(global.text_data_en, "scr_papcall_2821", "* You have to time&  the pukes!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2826", "* Oh man!!^1!&* You wanna hear more&  of my great idea!?/")
ds_map_add(global.text_data_en, "scr_papcall_2828", "I'M GONNA HANG&UP NOW!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2836", "SO THE ARROWS&FLIP WHEN YOU&DO WHAT?/")
ds_map_add(global.text_data_en, "scr_papcall_2837", "I CAN'T VISUALIZE&THIS PUZZLE AT&ALL./")
ds_map_add(global.text_data_en, "scr_papcall_2838", "\E0CAN YOU DRAW&A PICTURE???/")
ds_map_add(global.text_data_en, "scr_papcall_2839", "\E3THEN HOLD IT UP&TO THE RECEIVER??/%%")
ds_map_add(global.text_data_en, "scr_papcall_2844", "DID YOU DRAW IT&YET?/%%")
ds_map_add(global.text_data_en, "scr_papcall_2850", "WHAT^1? HOW'S THIS&PUZZLE WORK^1?&UMMM.../")
ds_map_add(global.text_data_en, "scr_papcall_2851", "\E0WHOOPS^1, I THINK&IT'S UNDYNE'S TURN&TO TALK!!!/")
ds_map_add(global.text_data_en, "scr_papcall_2853", "\E1* What!^1?&* No^1, I HATE puzzles^1!&* Papyrus^1, YOU do it!/")
ds_map_add(global.text_data_en, "scr_papcall_2855", "WELL^1, ALPHYS MADE&THE PUZZLE^1,&RIGHT?/")
ds_map_add(global.text_data_en, "scr_papcall_2856", "\E0YOU SHOULD JUST&CALL HER UP.../")
ds_map_add(global.text_data_en, "scr_papcall_2857", "\E2AND SAY IN A&HOT VOICE.../")
ds_map_add(global.text_data_en, "scr_papcall_2858", "ALPHYS..^1.&I NEED HELP WITH&A.../")
ds_map_add(global.text_data_en, "scr_papcall_2859", "(AUDIBLE WINK)/")
ds_map_add(global.text_data_en, "scr_papcall_2860", "\E2PUZZLE.../")
ds_map_add(global.text_data_en, "scr_papcall_2862", "* Oh my GOD^1!&* NO^1!&* Shut up!!!/")
ds_map_add(global.text_data_en, "scr_papcall_2864", "FINE!!^1!&GIVE ME HER&NUMBER!!!/")
ds_map_add(global.text_data_en, "scr_papcall_2865", "\E0I'LL DO THE HOT&VOICE!!!/")
ds_map_add(global.text_data_en, "scr_papcall_2867", "* NO!!!^1!&* THAT'S EVEN WORSE!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2872", "(AUDIBLE WINK).../")
ds_map_add(global.text_data_en, "scr_papcall_2873", "\E3WAIT^1, WHOSE NUMBER&IS THIS???/%%")
ds_map_add(global.text_data_en, "scr_papcall_2883", "THE ROYAL GUARD&PATROLS THAT&AREA./")
ds_map_add(global.text_data_en, "scr_papcall_2884", "YES^1, LIKE SNOWDIN^1,&HOTLAND HAS ROYAL&GUARD MEMBERS./")
ds_map_add(global.text_data_en, "scr_papcall_2885", "WATERFALL DOESN'T&NEED THEM BECAUSE&IT'S GOT UNDYNE!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2890", "DID YOU SEE&THEM?/%%")
ds_map_add(global.text_data_en, "scr_papcall_2896", "* Careful^1, the Royal&  Guard patrols that&  area./")
ds_map_add(global.text_data_en, "scr_papcall_2897", "\E4* I think it's RG01&  and RG02 today.../")
ds_map_add(global.text_data_en, "scr_papcall_2898", "\E0* It's funny^1, the bunny&  actually requested to be&  with the dragon guy./")
ds_map_add(global.text_data_en, "scr_papcall_2899", "* It's nice when people&  are platonic friends&  like that!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2904", "* It's nice when people&  are platonic friends&  like that!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2912", "I LOVE THE NEWS^1!&IT'S SO&INFORMATIVE.../")
ds_map_add(global.text_data_en, "scr_papcall_2913", "AND FULL OF CUT-&THROAT^1, EXPLOSIVE&ACTION!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2918", "KA-WOWIE!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2924", "* Yeah^1! You totally&  kicked his butt&  on the news!!!/")
ds_map_add(global.text_data_en, "scr_papcall_2925", "\E9* And I bet Alphys&  was helping you^1,&  wasn't she?/")
ds_map_add(global.text_data_en, "scr_papcall_2926", "\E6* Oh my god!!^1!&* You guys becoming&  friends.../")
ds_map_add(global.text_data_en, "scr_papcall_2927", "\E8* It's kinda cute.../")
ds_map_add(global.text_data_en, "scr_papcall_2928", "\E1* ... I mean^1, uh.../")
ds_map_add(global.text_data_en, "scr_papcall_2929", "\E2* I'm tough!!^1!&* I love to eat rocks!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_2934", "* What!?!?/%%")
ds_map_add(global.text_data_en, "scr_papcall_2940", "* (There's some strange&  interference...)/%%")
ds_map_add(global.text_data_en, "scr_papcall_2948", "THE CORE..^1.&YOU'RE GETTING&CLOSE^1, HUH...?/")
ds_map_add(global.text_data_en, "scr_papcall_2949", "\E6.../%%")
ds_map_add(global.text_data_en, "scr_papcall_2954", ".../%%")
ds_map_add(global.text_data_en, "scr_papcall_2960", "THE CORE..^1.&YOU'RE GETTING&CLOSE^1, HUH...?/")
ds_map_add(global.text_data_en, "scr_papcall_2962", "* What!^1?&* No^1, we just&  became friends!!/")
ds_map_add(global.text_data_en, "scr_papcall_2963", "\E4* You can't already&  be that close.../%%")
ds_map_add(global.text_data_en, "scr_papcall_2968", "* What?/%%")
ds_map_add(global.text_data_en, "scr_papcall_2980", "IT MIGHT SOUND&WEIRD THAT SPIDERS&NEED DONATIONS./")
ds_map_add(global.text_data_en, "scr_papcall_2981", "\E0BUT THINK ABOUT&IT^1, THEY HAVE&EIGHT FEET./")
ds_map_add(global.text_data_en, "scr_papcall_2982", "\E3THAT'S FOUR PAIRS&OF SHOES./")
ds_map_add(global.text_data_en, "scr_papcall_2983", "\E0A SPIDER WEARING&FOUR PAIRS OF&PINK BOOTIES./")
ds_map_add(global.text_data_en, "scr_papcall_2984", "MEDITATE ON&THIS IMAGE./%%")
ds_map_add(global.text_data_en, "scr_papcall_2989", "OM.../%%")
ds_map_add(global.text_data_en, "scr_papcall_2997", "THE ENTIRE ROOM&IS COVERED IN&STEAM THINGIES?/")
ds_map_add(global.text_data_en, "scr_papcall_2998", "\E1OH MY GOD^1, CAN'T&YOU JUST TAKE&A BUS!?!?/")
ds_map_add(global.text_data_en, "scr_papcall_2999", "\E3HOTLAND STINKS.../%%")
ds_map_add(global.text_data_en, "scr_papcall_3004", "DON'T TELL ME&MORE OF THIS&GARBAGE./%%")
ds_map_add(global.text_data_en, "scr_papcall_3010", "A WHOLE ROOM&COVERED IN VENTS^1?&OH NO.../")
ds_map_add(global.text_data_en, "scr_papcall_3012", "* Hey^1, did I ever&  tell you about my&  puzzle idea?/")
ds_map_add(global.text_data_en, "scr_papcall_3013", "* It's a maze full&  of steam vents.../")
ds_map_add(global.text_data_en, "scr_papcall_3014", "\E2* But the steam vents&  are on conveyor&  belts^1, and.../")
ds_map_add(global.text_data_en, "scr_papcall_3016", "OH MY GOD!!^1!&I HATE THIS!?!?/%%")
ds_map_add(global.text_data_en, "scr_papcall_3021", "ITS BEST IF YOU&DON'T ENCOURAGE&HER./%%")
ds_map_add(global.text_data_en, "scr_papcall_3030", "LASERS ON&CONVEYORS^1?&NO THANKS./")
ds_map_add(global.text_data_en, "scr_papcall_3031", "SOUNDS LIKE MY&LEAST FAVORITE&NIGHTMARE./%%")
ds_map_add(global.text_data_en, "scr_papcall_3036", "DON'T TELL ME&MORE OF THIS&GARBAGE./%%")
ds_map_add(global.text_data_en, "scr_papcall_3042", "LASERS ON&CONVEYORS^1? ARE&YOU SERIOUS???/")
ds_map_add(global.text_data_en, "scr_papcall_3044", "* Hey^1, this reminds&  me of a puzzle&  idea./")
ds_map_add(global.text_data_en, "scr_papcall_3046", "OH MY GOD??^1?&NO??^1?&WHY????/")
ds_map_add(global.text_data_en, "scr_papcall_3047", "I THOUGHT YOU&HATED MAKING&UP PUZZLES!!/")
ds_map_add(global.text_data_en, "scr_papcall_3049", "* Yeah^1, but I love&  driving you crazy!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3054", "PLEASE STOP&ENCOURAGING&HER./%%")
ds_map_add(global.text_data_en, "scr_papcall_3063", "WHERE DID THAT&TABLE COME FROM?/")
ds_map_add(global.text_data_en, "scr_papcall_3064", "\E0DOES IT BELONG&TO THE MOUSE??/%%")
ds_map_add(global.text_data_en, "scr_papcall_3069", "EH???/%%")
ds_map_add(global.text_data_en, "scr_papcall_3075", "* Where are all these&  tables coming from?/")
ds_map_add(global.text_data_en, "scr_papcall_3077", "MAYBE THEY BELONG&TO THE MOUSE./")
ds_map_add(global.text_data_en, "scr_papcall_3079", "* What would a mouse&  need a table for?/")
ds_map_add(global.text_data_en, "scr_papcall_3081", "TO PUT THE&CHEESE ON./")
ds_map_add(global.text_data_en, "scr_papcall_3083", "* But where's the&  cheese come from!?/")
ds_map_add(global.text_data_en, "scr_papcall_3085", "* doesn't it come&  from milk?/")
ds_map_add(global.text_data_en, "scr_papcall_3087", "OH MY GOD!!^1!&GET OUT OF&HERE!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3092", "WAIT^1, DOES IT&COME FROM MILK??/%%")
ds_map_add(global.text_data_en, "scr_papcall_3102", "WOW!!^1!&THAT CHOREOGRAPHY!/")
ds_map_add(global.text_data_en, "scr_papcall_3103", "\E2I CAN'T BELIEVE&I'M FRIENDS.../")
ds_map_add(global.text_data_en, "scr_papcall_3104", "\E0WITH A BONE-A-&FIDE OPERA&STAR!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3109", "WOWIE!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3115", "I CAN'T BELIEVE&YOU GOT TO DANCE&WITH METTATON!/")
ds_map_add(global.text_data_en, "scr_papcall_3117", "* Big deal.../")
ds_map_add(global.text_data_en, "scr_papcall_3118", "\E2* Earlier^1, the human&  and I danced with&  DEATH!!!/")
ds_map_add(global.text_data_en, "scr_papcall_3120", "WOW!!/")
ds_map_add(global.text_data_en, "scr_papcall_3121", "IS DEATH COOL?/")
ds_map_add(global.text_data_en, "scr_papcall_3123", "* Yeah^1, she's like&  super hot./%%")
ds_map_add(global.text_data_en, "scr_papcall_3128", "I WANT TO MEET&DEATH.../%%")
ds_map_add(global.text_data_en, "scr_papcall_3135", "* (There's some strange&  interference...)/%%")
ds_map_add(global.text_data_en, "scr_papcall_3144", "WHAT?&I^1? SCREAM?/")
ds_map_add(global.text_data_en, "scr_papcall_3145", "\E0SURE^1!&I'LL TRY./")
ds_map_add(global.text_data_en, "scr_papcall_3146", "A^1. A^1. A^1. A^1. A./")
ds_map_add(global.text_data_en, "scr_papcall_3147", "I'M SCREAMING VERY&SLOWLY./%%")
ds_map_add(global.text_data_en, "scr_papcall_3152", "A./%%")
ds_map_add(global.text_data_en, "scr_papcall_3160", "* WHAT!^1?&* RG01 and RG02 are&  slacking off?!/")
ds_map_add(global.text_data_en, "scr_papcall_3161", "\E2* Come ON^1!&* They should be KILLING&  you right now!/")
ds_map_add(global.text_data_en, "scr_papcall_3162", "\E9* Not that I want&  them to^1, I mean./")
ds_map_add(global.text_data_en, "scr_papcall_3163", "\E6* But they could at&  least TRY^1, y'know!?/%%")
ds_map_add(global.text_data_en, "scr_papcall_3169", "* Oh yeah^1, that&  reminds me./")
ds_map_add(global.text_data_en, "scr_papcall_3170", "* I told RG01 and RG02&  that if they managed&  to nab you.../")
ds_map_add(global.text_data_en, "scr_papcall_3171", "\E9* I'd take them both&  out for ice cream./")
ds_map_add(global.text_data_en, "scr_papcall_3172", "\E0* I hope you were able&  to avoid them./")
ds_map_add(global.text_data_en, "scr_papcall_3173", "\E6* Cause I HATE ice&  cream!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3179", "I ALMOST CAPTURED&YOU.../")
ds_map_add(global.text_data_en, "scr_papcall_3180", "WHERE'S MY ICE&CREAM./%%")
ds_map_add(global.text_data_en, "scr_papcall_3187", "A HOT-L.../")
ds_map_add(global.text_data_en, "scr_papcall_3188", "\E0THAT'S SHORT FOR&HOTLAND^1, RIGHT?/%%")
ds_map_add(global.text_data_en, "scr_papcall_3194", "WOWIE!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3200", "* A hotel?^1? Cool!^1!&* I've never stayed&  at a fancy hotel!/")
ds_map_add(global.text_data_en, "scr_papcall_3202", "REALLY?^1?&ME NEITHER./")
ds_map_add(global.text_data_en, "scr_papcall_3204", "* Papyrus^1, we should&  go on vacation&  sometime!/")
ds_map_add(global.text_data_en, "scr_papcall_3206", "YEAH!^1!&LET'S VACATION TO&A HOTEL!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3211", "* Well^1, maybe we would&  go someplace besides&  the hotel^1, too.../")
ds_map_add(global.text_data_en, "scr_papcall_3213", "OH^1, I WAS BEING&SARCASTIC./")
ds_map_add(global.text_data_en, "scr_papcall_3214", "\E0I WOULD NEVER&TAKE A VACATION&FOR ANY REASON./%%")
ds_map_add(global.text_data_en, "scr_papcall_3224", "A FANCY&SCHMANCY&RESTAURANT!?!?/")
ds_map_add(global.text_data_en, "scr_papcall_3225", "\E2AFTER TASTING MY&COOKING^1, THAT SEEMS&POINTLESS^1, RIGHT?/%%")
ds_map_add(global.text_data_en, "scr_papcall_3231", "I BET THEY CAN'T&EVEN MAKE&SPAGHETTI!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3237", "* Woah!^1!&* A fancy restaurant!?/")
ds_map_add(global.text_data_en, "scr_papcall_3238", "\E6* Are you treating us^1?&* Do they have steak?/")
ds_map_add(global.text_data_en, "scr_papcall_3240", "PSHHHHHHT./")
ds_map_add(global.text_data_en, "scr_papcall_3241", "\E0WHO NEEDS THAT!&YOUR FRIENDS ARE&GREAT CHEFS!/")
ds_map_add(global.text_data_en, "scr_papcall_3243", "* Well^1, maybe our cooking&  abilities aren't&  exactly perfect./")
ds_map_add(global.text_data_en, "scr_papcall_3244", "\E6* Nah!!^1!&* They totally are!^1!&* Eat up^1, punk!!/")
ds_map_add(global.text_data_en, "scr_papcall_3245", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "scr_papcall_3246", "* (You hear spaghetti thwap&  against the receiver.)/%%")
ds_map_add(global.text_data_en, "scr_papcall_3251", "ISN'T FRIENDSHIP&DELICIOUS?/%%")
ds_map_add(global.text_data_en, "scr_papcall_3261", "CAREFUL^1.&LOTS OF HOTELS ARE&INFESTED NOWADAYS./")
ds_map_add(global.text_data_en, "scr_papcall_3262", "THEY CAN SLIDE&UNDER CLOSED DOOR&HOLES 1 INCH HIGH./")
ds_map_add(global.text_data_en, "scr_papcall_3263", "WHAT DO I MEAN^1?&YOU'LL KNOW IT&IF YOU SEE IT./")
ds_map_add(global.text_data_en, "scr_papcall_3264", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "scr_papcall_3265", "* (You hear a muffled bark&  behind one of the doors.)/%%")
ds_map_add(global.text_data_en, "scr_papcall_3270", "WHAT WAS THAT???/%%")
ds_map_add(global.text_data_en, "scr_papcall_3276", "CAREFUL^1. I'VE HEARD&THAT HOTEL HAS A&DOG PROBLEM./")
ds_map_add(global.text_data_en, "scr_papcall_3278", "* Oh^1?&* No pets allowed^1, huh?/")
ds_map_add(global.text_data_en, "scr_papcall_3280", "I'M NOT TALKING&ABOUT PETS./")
ds_map_add(global.text_data_en, "scr_papcall_3282", "* What's the problem?/")
ds_map_add(global.text_data_en, "scr_papcall_3284", "THE PROBLEM IS..^1.&DOG./")
ds_map_add(global.text_data_en, "scr_papcall_3286", "* What's wrong with&  dogs!?/")
ds_map_add(global.text_data_en, "scr_papcall_3288", "NOT ALL DOGS^1.&JUST THAT ONE./")
ds_map_add(global.text_data_en, "scr_papcall_3290", "* What's WRONG with it!?/")
ds_map_add(global.text_data_en, "scr_papcall_3292", "EVERYTHING./%%")
ds_map_add(global.text_data_en, "scr_papcall_3297", "* So you hate this dog^1,&  but like weird&  talking flowers?/")
ds_map_add(global.text_data_en, "scr_papcall_3299", "THE FLOWER IS MY&FRIEND!/")
ds_map_add(global.text_data_en, "scr_papcall_3301", "* I mean^1, if having&  an imaginary friend&  makes you happy.../")
ds_map_add(global.text_data_en, "scr_papcall_3303", "OH MY GOD!^1!&HE'S NOT IMAGINARY^1!&HE HAS A NAME!/")
ds_map_add(global.text_data_en, "scr_papcall_3305", "* What's his name./")
ds_map_add(global.text_data_en, "scr_papcall_3307", "FL.../")
ds_map_add(global.text_data_en, "scr_papcall_3308", "\E3FLOWERY?/")
ds_map_add(global.text_data_en, "scr_papcall_3310", "* Oh my GOD!!^1!&* You just made that&  up!!/")
ds_map_add(global.text_data_en, "scr_papcall_3312", "OK^1, I DID!^1!&BUT HE'S REAL!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3320", "YOU HAVE YOUR OWN&HOTEL ROOM!?/")
ds_map_add(global.text_data_en, "scr_papcall_3321", "\E3... WHY?/")
ds_map_add(global.text_data_en, "scr_papcall_3322", "\E0MY GARAGE IS&ALWAYS OPEN TO&YOU!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3327", "THE PRICE IS&RIGHT!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3333", "YOU HAVE YOUR OWN&HOTEL ROOM!?/")
ds_map_add(global.text_data_en, "scr_papcall_3335", "* Heyyy!^1!&* Let's throw a room&  party!/")
ds_map_add(global.text_data_en, "scr_papcall_3336", "\E9* We can order a pizza&  and stay up all night&  playing games!/")
ds_map_add(global.text_data_en, "scr_papcall_3338", "PARTY " + '"' + "GAMES" + '"' + "^1?&LIKE THE SIX-&LEGGED RACE?/")
ds_map_add(global.text_data_en, "scr_papcall_3340", "* Nah^1, like " + '"' + "pillow&  fight the skeleton!" + '"' + "/")
ds_map_add(global.text_data_en, "scr_papcall_3342", "H-HEY!!^1!&NO PILLOWS FROM&THE COUCH!/")
ds_map_add(global.text_data_en, "scr_papcall_3344", "* Aww^1, okay./")
ds_map_add(global.text_data_en, "scr_papcall_3346", "HEY!!^1!&NO ENTIRE COUCH!!/")
ds_map_add(global.text_data_en, "scr_papcall_3348", "* Too late!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3353", "HEY^1, YOU DIDN'T&HIT ME WITH MY&ENTIRE COUCH./")
ds_map_add(global.text_data_en, "scr_papcall_3355", "* Nah^1, why would I&  do that?/")
ds_map_add(global.text_data_en, "scr_papcall_3356", "\E6* I'm saving it for&  the party!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3364", "THE ELEVATOR&SAYS L1./")
ds_map_add(global.text_data_en, "scr_papcall_3365", "\E3BUT WHAT DOES THE&L STAND FOR^1?&LINGUINE?/")
ds_map_add(global.text_data_en, "scr_papcall_3366", "\E0LINGUINE^1.&THE FLAT PASTA./")
ds_map_add(global.text_data_en, "scr_papcall_3367", "IT CAN ALSO BE&USED TO TIE UP&PRESENTS./%%")
ds_map_add(global.text_data_en, "scr_papcall_3372", "THE FLATNESS&MAKES A NICE&RIBBON./%%")
ds_map_add(global.text_data_en, "scr_papcall_3378", "\E0THE ELEVATOR&SAYS L1./")
ds_map_add(global.text_data_en, "scr_papcall_3379", "\E3BUT WHAT DOES THE&L STAND FOR?/")
ds_map_add(global.text_data_en, "scr_papcall_3381", "\E0* C'mon^1, Papyrus^1.&* Think about it./")
ds_map_add(global.text_data_en, "scr_papcall_3383", "\E3HMMM.../")
ds_map_add(global.text_data_en, "scr_papcall_3385", "\E6* It stands for&  L-evator^1, duh!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3390", "IS ELEVATOR&REALLY SPELLED&THAT WAY?/")
ds_map_add(global.text_data_en, "scr_papcall_3392", "* Probably?/%%")
ds_map_add(global.text_data_en, "scr_papcall_3401", "THE ELEVATOR&SAYS R1./")
ds_map_add(global.text_data_en, "scr_papcall_3402", "\E3BUT WHAT DOES THE&R STAND FOR^1?&RAVIOLI?/")
ds_map_add(global.text_data_en, "scr_papcall_3403", "\E0RAVIOLI..^1.&THE DUMPLING-TYPE&PASTA./")
ds_map_add(global.text_data_en, "scr_papcall_3404", "THE TREASURE CHEST&OF THE CULINARY&WORLD./%%")
ds_map_add(global.text_data_en, "scr_papcall_3409", "YOU CAN PUT GEMS&OR GOLD INSIDE./%%")
ds_map_add(global.text_data_en, "scr_papcall_3415", "\E0THE ELEVATOR&SAYS R1./")
ds_map_add(global.text_data_en, "scr_papcall_3416", "\E3BUT WHAT DOES THE&R STAND FOR?/")
ds_map_add(global.text_data_en, "scr_papcall_3418", "\E0* C'mon^1, Papyrus^1.&* Think about it./")
ds_map_add(global.text_data_en, "scr_papcall_3420", "\E3HMMM.../")
ds_map_add(global.text_data_en, "scr_papcall_3422", "\E6* It stands for RED^1,&  'cause that's the&  color of the lights!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3427", "I GUESS THAT&MAKES SENSE!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3434", "* (The phone won't turn on.)/%%")
ds_map_add(global.text_data_en, "scr_papcall_3441", "THE ELEVATOR&SAYS R2./")
ds_map_add(global.text_data_en, "scr_papcall_3442", "\E3BUT WHAT DOES THE&R STAND FOR^1?&RIGATONI?/")
ds_map_add(global.text_data_en, "scr_papcall_3443", "\E0THE TUBE-SHAPED&PASTA./")
ds_map_add(global.text_data_en, "scr_papcall_3444", "IN A PINCH^1, IT&CAN BE USED AS&A STRAW./%%")
ds_map_add(global.text_data_en, "scr_papcall_3449", "IF YOU NEED TO&DRINK A CUP OF&SAUCE./%%")
ds_map_add(global.text_data_en, "scr_papcall_3455", "\E3WAIT^1, UNDYNE^1.&IF THE R STANDS&FOR RED.../")
ds_map_add(global.text_data_en, "scr_papcall_3456", "\E5WHAT COLOR DOES&THE L STAND FOR?/")
ds_map_add(global.text_data_en, "scr_papcall_3458", "* Uhhhh.../")
ds_map_add(global.text_data_en, "scr_papcall_3459", "\E9* Light green./")
ds_map_add(global.text_data_en, "scr_papcall_3461", "OH^1! OF COURSE!/")
ds_map_add(global.text_data_en, "scr_papcall_3462", "WAIT^1.&ISN'T THAT TWO&WORDS?/")
ds_map_add(global.text_data_en, "scr_papcall_3464", "* light sea green./")
ds_map_add(global.text_data_en, "scr_papcall_3466", "THREE DOESN'T&FIX THE ISSUE!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3471", "* light sea foam&  green./")
ds_map_add(global.text_data_en, "scr_papcall_3473", "AREN'T YOU WORKING&IN THE VERY NEXT&ROOM!?/%%")
ds_map_add(global.text_data_en, "scr_papcall_3482", "THE ELEVATOR&SAYS L2./")
ds_map_add(global.text_data_en, "scr_papcall_3483", "\E3BUT WHAT DOES THE&L STAND FOR^1?&LASAGNA?/")
ds_map_add(global.text_data_en, "scr_papcall_3484", "\E3I HOPE NOT^1.&I DON'T MAKE&LASAGNA ANYMORE./")
ds_map_add(global.text_data_en, "scr_papcall_3485", "\E1THAT GLUTTONOUS&DOG ALWAYS EATS&IT FIRST!/")
ds_map_add(global.text_data_en, "scr_papcall_3486", "\E3FIRST MY BONES^1,&AND NOW THIS.../%%")
ds_map_add(global.text_data_en, "scr_papcall_3491", "THEN IT RETREATS&INTO A SHALLOW&BLUE BOX./")
ds_map_add(global.text_data_en, "scr_papcall_3492", "COVERS ITSELF&WITH A BLANKET^1,&AND SLEEPS.../%%")
ds_map_add(global.text_data_en, "scr_papcall_3499", "\E2* OK^1, OK^1.&* I've got it./")
ds_map_add(global.text_data_en, "scr_papcall_3500", "\E9* The L stands for&  the color " + '"' + "Lime." + '"' + "/")
ds_map_add(global.text_data_en, "scr_papcall_3502", "\E0REALLY!?/")
ds_map_add(global.text_data_en, "scr_papcall_3503", "\E3I HATE LIMES./")
ds_map_add(global.text_data_en, "scr_papcall_3505", "\E1* What!^1? Limes rule!^1!&* I eat them whole&  all the time!!/")
ds_map_add(global.text_data_en, "scr_papcall_3507", "\E3WELL^1, ONE TIME I&WAS GIVING MYSELF&THE SPA TREATMENT./")
ds_map_add(global.text_data_en, "scr_papcall_3508", "\E0I PUT THE LIME&SLICES IN MY&EYES^1, LIKE ON TV./")
ds_map_add(global.text_data_en, "scr_papcall_3509", "\E1BUT IT STINGS!^1!&HOW DO THEY DO&IT!?/")
ds_map_add(global.text_data_en, "scr_papcall_3511", "\E6* Oh my god^1!&* Those aren't LIMES^1!&* Those are CUCUMBERS!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3516", "\E3I THOUGHT IT WAS&SUPPOSED TO BE&REJUVENATING./")
ds_map_add(global.text_data_en, "scr_papcall_3517", "\E1BUT IT WASN'T&WORKING!/")
ds_map_add(global.text_data_en, "scr_papcall_3518", "\E5SO I JUST STUCK&MORE LIMES INTO&MY EYES./")
ds_map_add(global.text_data_en, "scr_papcall_3520", "\E1* Gross!^1!&* Why did you even&  do that!?/")
ds_map_add(global.text_data_en, "scr_papcall_3522", "\E2I JUST WANT TO&HAVE HANDSOME^1,&BISHONEN EYES./")
ds_map_add(global.text_data_en, "scr_papcall_3523", "LIKE METTATON..^1.&SIGH.../")
ds_map_add(global.text_data_en, "scr_papcall_3525", "* (He doesn't even&  HAVE eyes!!!)/%%")
ds_map_add(global.text_data_en, "scr_papcall_3533", "* (The phone won't turn on.)/%%")
ds_map_add(global.text_data_en, "scr_papcall_3540", "THE ELEVATOR&SAYS L3./")
ds_map_add(global.text_data_en, "scr_papcall_3541", "\E3BUT WHAT DOES THE&L STAND FOR^1?&LUMACONI?/")
ds_map_add(global.text_data_en, "scr_papcall_3542", "\E0THAT'S THE SNAIL-&SHAPED PASTA!/")
ds_map_add(global.text_data_en, "scr_papcall_3543", "\E3SANS BOUGHT SOME&RECENTLY./")
ds_map_add(global.text_data_en, "scr_papcall_3544", "\E2HE'LL PROBABLY&FILL THEM WITH&HOTDOGS AND SLIME./%%")
ds_map_add(global.text_data_en, "scr_papcall_3549", "HEY!^1!&MAYBE HE'LL SHARE&SOME WITH YOU!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3555", "\E0MAYBE WE NEED TO&THINK MORE&ABSTRACTLY./")
ds_map_add(global.text_data_en, "scr_papcall_3556", "\E3MAYBE THE L&STANDS FOR.../")
ds_map_add(global.text_data_en, "scr_papcall_3557", "\E2LOVE./")
ds_map_add(global.text_data_en, "scr_papcall_3559", "\E2* But isn't love&  supposed to be&  FIERY RED!?/")
ds_map_add(global.text_data_en, "scr_papcall_3560", "\E9* Like a cartoony&  human-heart?/")
ds_map_add(global.text_data_en, "scr_papcall_3562", "\E3BUT UNDYNE^1, DON'T&YOU TURN PEOPLE'S&HEARTS GREEN?/")
ds_map_add(global.text_data_en, "scr_papcall_3564", "\E9* You make it sound&  like I give people&  nausea./")
ds_map_add(global.text_data_en, "scr_papcall_3566", "\E0WELL^1, IT WOULD BE&AN AFFECTIONATE&NAUSEA./")
ds_map_add(global.text_data_en, "scr_papcall_3568", "\E6* Okay^1, yeah^1!&That's me!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3573", "IT'S DECIDED!^1!&L STANDS FOR!!/")
ds_map_add(global.text_data_en, "scr_papcall_3574", "\E3A HEART THAT&UNDYNE HAS MADE&NAUSEOUS?/%%")
ds_map_add(global.text_data_en, "scr_papcall_3582", "* (The phone won't turn on.)/%%")
ds_map_add(global.text_data_en, "scr_papcall_3589", "THE ELEVATOR&SAYS R3./")
ds_map_add(global.text_data_en, "scr_papcall_3590", "\E3BUT WHAT DOES THE&R STAND FOR^1?&ROTINI?/")
ds_map_add(global.text_data_en, "scr_papcall_3591", "THE SCREW-SHAPED&PASTA./")
ds_map_add(global.text_data_en, "scr_papcall_3592", "I USED IT TO HOLD&MY SENTRY STATION&TOGETHER./%%")
ds_map_add(global.text_data_en, "scr_papcall_3597", "MY WHOLE STATION&IS MADE OUT OF&CARDBOARDHYDRATES!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3603", "\E3WAIT^1.&WHAT IF R AND L./")
ds_map_add(global.text_data_en, "scr_papcall_3604", "\E0STAND FOR RIGHT&AND LEFT???/")
ds_map_add(global.text_data_en, "scr_papcall_3606", "\E9* No WAY!&* That makes NO sense./")
ds_map_add(global.text_data_en, "scr_papcall_3607", "\E6* Cause if you face&  the opposite way^1,&  they'd be wrong!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3612", "BUT IF YOU FACE&THE OTHER WAY.../")
ds_map_add(global.text_data_en, "scr_papcall_3613", "HOW CAN YOU KNOW&THEY ARE REALLY&STILL WRONG?/")
ds_map_add(global.text_data_en, "scr_papcall_3615", "* Let's not get&  philosophical&  over the alphabet./%%")
ds_map_add(global.text_data_en, "scr_papcall_3625", "\E9PAPYRUS^1?&WHO IS THAT?/")
ds_map_add(global.text_data_en, "scr_papcall_3626", "THIS IS..^1.&COOLSKELETON95./")
ds_map_add(global.text_data_en, "scr_papcall_3627", "SORRY^1. CAN'T TALK^1.&I'M BUSY BEING&POPULAR ON-LINE./")
ds_map_add(global.text_data_en, "scr_papcall_3628", "\E0NYEH HEH HEH^1!&ONLY KIDDING^1!&YOU HAVE BEEN HAD!/")
ds_map_add(global.text_data_en, "scr_papcall_3629", "IT WAS PAPYRUS&PLAYING A SIMPLE&GENTLEMAN'S RUSE!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3634", "WINK!/")
ds_map_add(global.text_data_en, "scr_papcall_3635", "YOU CAN SEE&ME WINKING^1,&RIGHT./%%")
ds_map_add(global.text_data_en, "scr_papcall_3641", "\E9* Papyrus..^1.&* Why are you&  wearing those?/")
ds_map_add(global.text_data_en, "scr_papcall_3643", "\E9PAPYRUS?/")
ds_map_add(global.text_data_en, "scr_papcall_3644", "EXCUSE ME^1?&I AM THE VERY&COOL ONLINE GUY,/")
ds_map_add(global.text_data_en, "scr_papcall_3645", "COOLSKELETON95./")
ds_map_add(global.text_data_en, "scr_papcall_3647", "* What^1?&* No^1!&* You're Papyrus!/")
ds_map_add(global.text_data_en, "scr_papcall_3649", "(UNDYNE!!!^1)&(SHHH!!!)/")
ds_map_add(global.text_data_en, "scr_papcall_3650", "(YOU'RE GOING TO&REVEAL MY SECRET&ONLINE PERSONA!)/%%")
ds_map_add(global.text_data_en, "scr_papcall_3655", "* FINE then^1!&* I'm not Undyne!/")
ds_map_add(global.text_data_en, "scr_papcall_3656", "\E2* The name's...&* StrongFish91!/")
ds_map_add(global.text_data_en, "scr_papcall_3658", "WHAT!^1?&REALLY!^1?&OH NO!!!/")
ds_map_add(global.text_data_en, "scr_papcall_3659", "STRONGFISH!^1!&PLEASE BRING BACK&MY FRIEND UNDYNE!/")
ds_map_add(global.text_data_en, "scr_papcall_3661", "* Uh^1, OK./%%")
ds_map_add(global.text_data_en, "scr_papcall_3671", "AN APRON LYING&IN HOTLAND^1?&THAT MAKES SENSE./")
ds_map_add(global.text_data_en, "scr_papcall_3672", "COOKING IS&DEFINITELY&FIRE-ELEMENTAL./%%")
ds_map_add(global.text_data_en, "scr_papcall_3677", "UNLESS YOU COOK&A POPSICLE./%%")
ds_map_add(global.text_data_en, "scr_papcall_3683", "AN APRON LYING&IN HOTLAND^1?&THAT MAKES SENSE./")
ds_map_add(global.text_data_en, "scr_papcall_3685", "\E3* Yeah^1, cooking is&  definitely fire-&  elemental!/")
ds_map_add(global.text_data_en, "scr_papcall_3687", "\E3UNLESS YOU COOK&A POPSICLE./")
ds_map_add(global.text_data_en, "scr_papcall_3689", "\E9* Would you really&  call it " + '"' + "cooking" + '"' + "&  a popsicle...?/")
ds_map_add(global.text_data_en, "scr_papcall_3691", "\E5THAT'S WHAT YOU&CALLED IT LAST&TIME WE^1, UH.../")
ds_map_add(global.text_data_en, "scr_papcall_3693", "* Oh MAN^1, I almost&  forgot about that^1!&* What a mess!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3700", "* It took forever to&  hose everything off./%%")
ds_map_add(global.text_data_en, "scr_papcall_3710", "\E0WOW^1! I SAW IT^1!&THE MULTICOLOR&TILE PUZZLE!/")
ds_map_add(global.text_data_en, "scr_papcall_3713", "\E2YOU DID IT!^1!&MY DIRECTIONS&HELPED YOU!!/")
ds_map_add(global.text_data_en, "scr_papcall_3714", "I'M A GOOD&EXPLAINER!/")
ds_map_add(global.text_data_en, "scr_papcall_3715", "NYEH HEH HEH!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3719", "\E3SEEMS LIKE YOU&WEREN'T ABLE TO&COMPLETE IT./")
ds_map_add(global.text_data_en, "scr_papcall_3720", "\E0YOU'VE GOT TO&BE PREPARED NEXT&TIME!/")
ds_map_add(global.text_data_en, "scr_papcall_3721", "I'LL HAVE TO&EXPLAIN IT ALL&AGAIN!/")
ds_map_add(global.text_data_en, "scr_papcall_3722", "YOU SEE^1, RED&TILES ARE&IMPASSIBLE./")
ds_map_add(global.text_data_en, "scr_papcall_3723", "PINK TILES&DON'T DO&ANYTHING./")
ds_map_add(global.text_data_en, "scr_papcall_3724", "GREEN TILES&ARE.../%%")
ds_map_add(global.text_data_en, "scr_papcall_3730", "PLAID TILES&ARE.../%%")
ds_map_add(global.text_data_en, "scr_papcall_3731", "NYEH HEH HEH!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3738", "\E3HEADING INTO&THE CORE...^1?&HMMM./")
ds_map_add(global.text_data_en, "scr_papcall_3739", "YOU MIGHT NOT&BE ABLE TO&CALL PAST THERE./")
ds_map_add(global.text_data_en, "scr_papcall_3740", "\E1I KNOW^1!&IT SOUNDS AWFUL!/")
ds_map_add(global.text_data_en, "scr_papcall_3741", "\E3HOW WILL YOU&GET BY WITHOUT&ME?/")
ds_map_add(global.text_data_en, "scr_papcall_3742", "\E0WELL^1, I HAVE&CONFIDENCE YOU&WILL FIND A WAY!/")
ds_map_add(global.text_data_en, "scr_papcall_3743", "I WILL TALK TO&YOU AGAIN^1, SO&DO NOT WORRY!/")
ds_map_add(global.text_data_en, "scr_papcall_3744", "GOOD LUCK OUT&THERE!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3749", "QUIT IT^1!&YOU DON'T HAVE&TO SAY GOODBYE!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3755", "\E3HEADING INTO&THE CORE...^1?&HMMM./")
ds_map_add(global.text_data_en, "scr_papcall_3757", "\E4* The CORE is a huge&  tower of electric&  energy./")
ds_map_add(global.text_data_en, "scr_papcall_3758", "* So I don't think&  your phone will&  work through it.../")
ds_map_add(global.text_data_en, "scr_papcall_3760", "\E1OH NO!/")
ds_map_add(global.text_data_en, "scr_papcall_3761", "\E3WHAT WILL YOU DO&WITHOUT US...?/")
ds_map_add(global.text_data_en, "scr_papcall_3763", "* You have something&  you have to do^1,&  right...?/")
ds_map_add(global.text_data_en, "scr_papcall_3764", "* Well.../")
ds_map_add(global.text_data_en, "scr_papcall_3765", "\E9* Even without words^1,&  we'll be with you&  in spirit^1, OK!?/")
ds_map_add(global.text_data_en, "scr_papcall_3767", "\E0YEAH^1! YOU CAN'T&GET RID OF US!/")
ds_map_add(global.text_data_en, "scr_papcall_3769", "\E9* We're counting on&  you^1, so don't mess&  it up!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3775", "* We're not going to&  say goodbye to you&  just yet!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3785", "\E0A POSTER FOR&METTATON'S SHOW?/")
ds_map_add(global.text_data_en, "scr_papcall_3786", "THAT'S NEATO^1.&I WANT A POSTER&FOR MY PUZZLES!/")
ds_map_add(global.text_data_en, "scr_papcall_3787", "\E3AND MAYBE A FEW&OPENING BANDS./%%")
ds_map_add(global.text_data_en, "scr_papcall_3792", "THEY COULD PLAY&MY THEME SONG!/")
ds_map_add(global.text_data_en, "scr_papcall_3793", "\E3I JUST NEED TO&GET A THEME SONG./%%")
ds_map_add(global.text_data_en, "scr_papcall_3799", "\E0A POSTER FOR&METTATON'S SHOW?/")
ds_map_add(global.text_data_en, "scr_papcall_3800", "THAT'S NEATO^1.&I WANT A POSTER&FOR MY PUZZLES!/")
ds_map_add(global.text_data_en, "scr_papcall_3802", "\E1* Oh^1! And I want a&  poster for all of&  my big fights!/")
ds_map_add(global.text_data_en, "scr_papcall_3804", "A REAL EVENT^1!&WE COULD HAVE A&LIVE BAND!/")
ds_map_add(global.text_data_en, "scr_papcall_3806", "* And a barbeque!/")
ds_map_add(global.text_data_en, "scr_papcall_3808", "AND FIREWORKS!/")
ds_map_add(global.text_data_en, "scr_papcall_3810", "* And a second&  barbeque!/")
ds_map_add(global.text_data_en, "scr_papcall_3812", "WON'T YOU JUST&EAT BBQ INSTEAD&OF FIGHTING?/")
ds_map_add(global.text_data_en, "scr_papcall_3814", "\E6* Let's do it!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3820", "\E2* We could use the&  spears as kabob&  skewers!/")
ds_map_add(global.text_data_en, "scr_papcall_3822", "AND BONES AS&KABONE SKEWERS!/")
ds_map_add(global.text_data_en, "scr_papcall_3824", "* What's a kabone?/")
ds_map_add(global.text_data_en, "scr_papcall_3826", "LIKE A KABOB BUT&WITH ONLY BONES./%%")
ds_map_add(global.text_data_en, "scr_papcall_3836", "\E0DO SPIDERS HAVE&WEBBED FEET?/")
ds_map_add(global.text_data_en, "scr_papcall_3837", "\E3WAIT^1.&SPIDERS DON'T HAVE&FEET./")
ds_map_add(global.text_data_en, "scr_papcall_3838", "\E0DO SPIDERS HAVE&WEBBED FINGERS?/%%")
ds_map_add(global.text_data_en, "scr_papcall_3844", "JUST CURIOUS./%%")
ds_map_add(global.text_data_en, "scr_papcall_3850", "\E0HEY^1, UNDYNE^1.&DO SPIDERS HAVE&WEBBED FEET?/")
ds_map_add(global.text_data_en, "scr_papcall_3852", "\E9* No^1, ducks have&  webbed feet./")
ds_map_add(global.text_data_en, "scr_papcall_3854", "DUCKS CAN SPIN&WEBS!?/")
ds_map_add(global.text_data_en, "scr_papcall_3856", "* Yeah^1, haven't you&  seen a duck wrap&  up a loaf of bread?/")
ds_map_add(global.text_data_en, "scr_papcall_3857", "\E3* Then suck all of&  its guts out with&  its fangs?/")
ds_map_add(global.text_data_en, "scr_papcall_3859", "BREAD HAS GUTS?/")
ds_map_add(global.text_data_en, "scr_papcall_3861", "* Yeah^1. They just take&  'em all out before&  they sell it./")
ds_map_add(global.text_data_en, "scr_papcall_3863", "\E0WOW!^1!&YOU'RE REALLY&SMART^1, UNDYNE!/")
ds_map_add(global.text_data_en, "scr_papcall_3865", "* (I thought he knew&  I was joking...)/%%")
ds_map_add(global.text_data_en, "scr_papcall_3872", "\E9* Papyrus^1, wait^1, you&  know I'm joking^1,&  right...?/")
ds_map_add(global.text_data_en, "scr_papcall_3874", "OF COURSE!/")
ds_map_add(global.text_data_en, "scr_papcall_3875", "\E2EVERYONE KNOWS&SPIDERS HAVE&WEBBED FEET./%%")
ds_map_add(global.text_data_en, "scr_papcall_3880", "* (The signal is clogged with&  cobwebs...)/%%")
ds_map_add(global.text_data_en, "scr_papcall_3887", "I'VE HEARD THERE&ARE TWO GROUPS&OF SPIDERS./")
ds_map_add(global.text_data_en, "scr_papcall_3888", "ONE IN HOTLAND^1,&AND ONE IN THE&RUINS./")
ds_map_add(global.text_data_en, "scr_papcall_3889", "\E3SINCE THE SPIDERS&CAN'T CROSS THE&COLD OF SNOWDIN./")
ds_map_add(global.text_data_en, "scr_papcall_3890", "THEY NEED SOME&KIND OF TRANSPORT./")
ds_map_add(global.text_data_en, "scr_papcall_3891", "\E0LIKE A TANDEM&MOTORCYCLE WITH&EIGHT WHEELS./%%")
ds_map_add(global.text_data_en, "scr_papcall_3897", "OR A UNICYCLE&WITH EIGHT&WHEELS!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3903", "I WONDER IF ANY&OF MY ONLINE&FANS ARE SPIDERS./")
ds_map_add(global.text_data_en, "scr_papcall_3905", "* Do spiders even&  use the internet?/")
ds_map_add(global.text_data_en, "scr_papcall_3907", "* are you kidding^1?&* spiders love to surf&  the web./")
ds_map_add(global.text_data_en, "scr_papcall_3909", "SANS!/")
ds_map_add(global.text_data_en, "scr_papcall_3910", "\E0YOU'RE RIGHT&ABOUT SOMETHING./%%")
ds_map_add(global.text_data_en, "scr_papcall_3918", "\E3FANGS FOR VISITING&MY WEB-SITE./")
ds_map_add(global.text_data_en, "scr_papcall_3919", "\E0THAT'S WHAT SPIDERS&LIKE TO POST./%%")
ds_map_add(global.text_data_en, "scr_papcall_3924", "* (The signal is clogged with&  cobwebs...)/%%")
ds_map_add(global.text_data_en, "scr_papcall_3931", "HMMM..^1.&A MYSTERIOUS&SCIENCE HOUSE./")
ds_map_add(global.text_data_en, "scr_papcall_3933", "* the sign outside&  says " + '"' + "lab." + '"' + "/")
ds_map_add(global.text_data_en, "scr_papcall_3935", "LAB?/")
ds_map_add(global.text_data_en, "scr_papcall_3937", "* like..^1. laboratory./")
ds_map_add(global.text_data_en, "scr_papcall_3939", "LABRADOR..^1. Y?/")
ds_map_add(global.text_data_en, "scr_papcall_3940", "DOES THAT MEAN&THERE ARE DOGS&INSIDE?/")
ds_map_add(global.text_data_en, "scr_papcall_3942", "* w sensie./")
ds_map_add(global.text_data_en, "scr_papcall_3943", "\E2* i wouldn't rule it&  out./%%")
ds_map_add(global.text_data_en, "scr_papcall_3948", "STRANGE DOG'S&HOUSE.../%%")
ds_map_add(global.text_data_en, "scr_papcall_3956", "* That's Alphys's house./")
ds_map_add(global.text_data_en, "scr_papcall_3957", "\E9* Hey^1, why don't we&  all go over and&  watch anime?/")
ds_map_add(global.text_data_en, "scr_papcall_3959", "ANIME?/")
ds_map_add(global.text_data_en, "scr_papcall_3960", "ISN'T THAT A KIND&OF CARTOON FOR&SMALL CHILDREN?/")
ds_map_add(global.text_data_en, "scr_papcall_3962", "* Oh my GOD!!!/")
ds_map_add(global.text_data_en, "scr_papcall_3963", "\E6* Anime isn't just for&  kids^1! It's deep^1!&* It's EMOTIONAL!!!/")
ds_map_add(global.text_data_en, "scr_papcall_3965", "IS (THE SOUND A&BABY MAKES) AN&EMOTION?/")
ds_map_add(global.text_data_en, "scr_papcall_3967", "* YEah CAUSE It'S HoW&  I'M FEElinG RIGHT&  NOW!!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3972", "WAIT.../")
ds_map_add(global.text_data_en, "scr_papcall_3973", "\E5UNDYNE^1, DO YOU&LIKE ANIME?/")
ds_map_add(global.text_data_en, "scr_papcall_3975", "* .../")
ds_map_add(global.text_data_en, "scr_papcall_3977", "UH OH!!!/")
ds_map_add(global.text_data_en, "scr_papcall_3978", "\E3I MEAN^1, I'VE&NEVER SEEN ANY./")
ds_map_add(global.text_data_en, "scr_papcall_3979", "\E0MAYBE I ACTUALLY&DO LIKE ANIME!/")
ds_map_add(global.text_data_en, "scr_papcall_3981", "* You don't have to&  say that^1, Papyrus./")
ds_map_add(global.text_data_en, "scr_papcall_3983", "MAYBE I'M A BABY&WHO LOVES CARTOONS&FOR CHILDREN!/")
ds_map_add(global.text_data_en, "scr_papcall_3985", "* YOU DON'T HAVE TO&  SAY THAT^1, PAPYRUS!!/%%")
ds_map_add(global.text_data_en, "scr_papcall_3993", "* What!^1?&* Royal Guards are&  blocking the way!?/")
ds_map_add(global.text_data_en, "scr_papcall_3994", "\E2* Then I'll tell them&  to...!/")
ds_map_add(global.text_data_en, "scr_papcall_3995", "\E4* Well^1, nothing^1, I&  guess./")
ds_map_add(global.text_data_en, "scr_papcall_3996", "\E2* I already told them&  to seek out and&  destroy you!/")
ds_map_add(global.text_data_en, "scr_papcall_3997", "\E1* And I can't just&  tell them I've&  changed my mind./")
ds_map_add(global.text_data_en, "scr_papcall_3998", "\E2* You see^1, Alphys&  showed me these&  animations about.../")
ds_map_add(global.text_data_en, "scr_papcall_3999", "\E1* Uhhh^1, humans?&* So I can learn&  their weaknesses?/")
ds_map_add(global.text_data_en, "scr_papcall_4000", "\E2* And one of them&  is about this human&  that^1, uh.../")
ds_map_add(global.text_data_en, "scr_papcall_4001", "\E6* Well^1, suffice to say^1,&  they can control&  people's minds!!!/")
ds_map_add(global.text_data_en, "scr_papcall_4002", "\E3* Surprised^1?&* I know your kind's&  hidden power!/")
ds_map_add(global.text_data_en, "scr_papcall_4003", "\E1* Anyway^1, I told my&  crew that if I ever&  defended a human.../")
ds_map_add(global.text_data_en, "scr_papcall_4004", "\E2* I must be under&  some kind of mind&  control!/")
ds_map_add(global.text_data_en, "scr_papcall_4005", "\E6* And to disregard&  EVERYTHING that I&  tell them!/")
ds_map_add(global.text_data_en, "scr_papcall_4006", "\E7* So^1, sorry..^1.&* But my hands are&  tied./")
ds_map_add(global.text_data_en, "scr_papcall_4007", "\E9* By the way^1, that&  animation is&  really good!/%%")
ds_map_add(global.text_data_en, "scr_papcall_4013", "\E6* I'm not going to&  tell them to let&  you by!/%%")
ds_map_add(global.text_data_en, "scr_papcall_4019", "* (No response.)/%%")
ds_map_add(global.text_data_en, "scr_papcall_4026", "* Dzyn..^1. Dzyn.../")
ds_map_add(global.text_data_en, "scr_papcall_4033", "* Dzyn..^1. Dzyn.../")
ds_map_add(global.text_data_en, "scr_papcall_4034", "* (Brak odpowiedzi...)/%%")
ds_map_add(global.text_data_en, "scr_papcall_4040", "I DON'T HAVE&ANYTHING ELSE TO&SAY./%%")
ds_map_add(global.text_data_en, "scr_torcall_7", "* (Noticed you received a&  text from Toriel.)/")
ds_map_add(global.text_data_en, "scr_torcall_8", "* Dear Frisk,/")
ds_map_add(global.text_data_en, "scr_torcall_9", "* Sans and Alphys are teaching&  me how to text^1.&* I am learning so much./")
ds_map_add(global.text_data_en, "scr_torcall_10", "* For example:&* Do you know what a&  " + '"' + "smiley" + '"' + " is?/")
ds_map_add(global.text_data_en, "scr_torcall_11", "* Please look at this:/")
ds_map_add(global.text_data_en, "scr_torcall_12", "  ]:3/")
ds_map_add(global.text_data_en, "scr_torcall_13", "* Now turn your head to the&  left./")
ds_map_add(global.text_data_en, "scr_torcall_14", "* It is a picture of me&  smiling at you^1!&* Can you see it?/")
ds_map_add(global.text_data_en, "scr_torcall_15", "* L-O-L^1!&* (That stands for Lots of&  Laughter.)/")
ds_map_add(global.text_data_en, "scr_torcall_16", "* Sincerely^1, Toriel/")
ds_map_add(global.text_data_en, "scr_torcall_17", "* (That's all for now.^1)&* (Maybe in the next room^1, you&  will receive another.)/%%")
ds_map_add(global.text_data_en, "scr_torcall_22", "* (TORIEL sent you a message.)&* Dear Frisk,/")
ds_map_add(global.text_data_en, "scr_torcall_23", "* How are you^1? You have been&  wandering around for&  quite some time now./")
ds_map_add(global.text_data_en, "scr_torcall_24", "* I hope you are not getting&  into trouble./")
ds_map_add(global.text_data_en, "scr_torcall_25", "* Only kidding^1.&* L-O-L!/")
ds_map_add(global.text_data_en, "scr_torcall_26", "* Sincerly^1, Toriel/")
ds_map_add(global.text_data_en, "scr_torcall_27", "* PS - Do not get into trouble./%%")
ds_map_add(global.text_data_en, "scr_torcall_32", "* (TORIEL sent you a message.)&* Excuse me,/")
ds_map_add(global.text_data_en, "scr_torcall_33", "* I did not mean to write&  " + '"' + "sincerly." + '"' + "&* I meant to say " + '"' + "sincerely." + '"' + "/")
ds_map_add(global.text_data_en, "scr_torcall_34", "* It is difficult to use this&  with large hands./")
ds_map_add(global.text_data_en, "scr_torcall_35", "* Perhaps I should ask Sans&  to transcribe for me./%%")
ds_map_add(global.text_data_en, "scr_torcall_40", "* (TORIEL sent you a message.^1)&* Sans will be typing from&  now on./%%")
ds_map_add(global.text_data_en, "scr_torcall_45", "* (TORIEL sent you a message.)/")
ds_map_add(global.text_data_en, "scr_torcall_46", "* hey frisk^1.&* it's torrrrrieellll/")
ds_map_add(global.text_data_en, "scr_torcall_47", "* i just baked 1000000 pies.&* do you want any?/")
ds_map_add(global.text_data_en, "scr_torcall_48", "* make sure to brush your&  teeth before crossing&  the street^1, frisk/%%")
ds_map_add(global.text_data_en, "scr_torcall_53", "* (TORIEL sent you a message.)/")
ds_map_add(global.text_data_en, "scr_torcall_54", "* I did not say any of that./%%")
ds_map_add(global.text_data_en, "scr_torcall_59", "* (TORIEL sent you a message.)/")
ds_map_add(global.text_data_en, "scr_torcall_60", "* Greetings^1.&* This is Sans^1.&* I love my brother very much./")
ds_map_add(global.text_data_en, "scr_torcall_61", "* help im being slandered/%%")
ds_map_add(global.text_data_en, "scr_torcall_66", "* (TORIEL sent you a message.)/")
ds_map_add(global.text_data_en, "scr_torcall_67", "* This is Sans^1.&* Frisk^1, did you know that I&  love to " + '"' + "get owned?" + '"' + "/")
ds_map_add(global.text_data_en, "scr_torcall_68", "* I also think Toriel is very&  good and fhfjkehfeaufsisf/")
ds_map_add(global.text_data_en, "scr_torcall_69", "* Excuse me/")
ds_map_add(global.text_data_en, "scr_torcall_70", "* ./%%")
ds_map_add(global.text_data_en, "scr_torcall_75", "* (TORIEL sent you a message&  titled " + '"' + "Cat Video." + '"' + ")/")
ds_map_add(global.text_data_en, "scr_torcall_76", "* (Inside^1, she meticulously&  describes a video she saw&  of a small^1, white animal.)/")
ds_map_add(global.text_data_en, "scr_torcall_77", "* (There is no link or&  attachment to watch it.)/%%")
ds_map_add(global.text_data_en, "scr_torcall_82", "* (TORIEL sent you a message.)/")
ds_map_add(global.text_data_en, "scr_torcall_83", "* Fwd: send this 2 some1 u&  care about... or a skeleton&  will rattle his bones at u/%%")
ds_map_add(global.text_data_en, "scr_torcall_88", "* (TORIEL sent you a message.)&* Dear Frisk,/")
ds_map_add(global.text_data_en, "scr_torcall_89", "* Thought you might enjoy this^1.&* ]: )/")
ds_map_add(global.text_data_en, "scr_torcall_90", "* (It's ASCII art of a snail.)/%%")
ds_map_add(global.text_data_en, "scr_torcall_95", "* (TORIEL sent you a message.)&* Dear Frisk,/")
ds_map_add(global.text_data_en, "scr_torcall_96", "* Undyne and Papyrus want to&  cook something together&  with me./")
ds_map_add(global.text_data_en, "scr_torcall_97", "* Sans is telling me that they&  are excellent chefs./")
ds_map_add(global.text_data_en, "scr_torcall_98", "* I am excited. ]: )&* Maybe if you are lucky^1, you&  can have some!/%%")
ds_map_add(global.text_data_en, "scr_torcall_103", "* (TORIEL sent you a message.)&* Dear Frisk,/")
ds_map_add(global.text_data_en, "scr_torcall_104", "* If Sans and I started a&  band^1, do you know what&  we could call it?/")
ds_map_add(global.text_data_en, "scr_torcall_105", "* " + '"' + "Dreemurr" + '"' + " and " + '"' + "Femur.^1" + '"' + "&* L-O-L!/")
ds_map_add(global.text_data_en, "scr_torcall_106", "* PS - That is only a joke^1.&* Do not refer to me as&  Dreemurr./%%")
ds_map_add(global.text_data_en, "scr_torcall_111", "* (TORIEL sent you a message.)&* Dear Frisk,/")
ds_map_add(global.text_data_en, "scr_torcall_112", "* Undyne is very strong./")
ds_map_add(global.text_data_en, "scr_torcall_113", "* Papyrus made a bet with her&  that she could not lift&  everyone here up./")
ds_map_add(global.text_data_en, "scr_torcall_114", "* She could./")
ds_map_add(global.text_data_en, "scr_torcall_115", "* The only trouble is that&  she did not know how to&  put everyone down./%%")
ds_map_add(global.text_data_en, "scr_torcall_120", "* (TORIEL sent you a message.)&* Dear Frisk,/")
ds_map_add(global.text_data_en, "scr_torcall_121", "* Alphys is telling me many&  interesting facts about&  the human world./")
ds_map_add(global.text_data_en, "scr_torcall_122", "* Quite a few of them are&  wrong^1, though./")
ds_map_add(global.text_data_en, "scr_torcall_123", "* Frisk^1, you did not tell&  her anything funny^1, did you^1?&* ]: )/%%")
ds_map_add(global.text_data_en, "scr_torcall_128", "* (TORIEL sent you a message.)&* Dear Frisk,/")
ds_map_add(global.text_data_en, "scr_torcall_129", "* I heard that using the&  computer for too long&  is bad for you./")
ds_map_add(global.text_data_en, "scr_torcall_130", "* However^1, I have not seen&  you use the computer at all./")
ds_map_add(global.text_data_en, "scr_torcall_129_console", "* I heard that playing&  video games for too long&  is bad for you./")
ds_map_add(global.text_data_en, "scr_torcall_130_console", "* However^1, I have not seen&  you playing video games&  at all./")
ds_map_add(global.text_data_en, "scr_torcall_131", "* You must be very healthy^1!&* How nice./%%")
ds_map_add(global.text_data_en, "scr_torcall_136", "* (TORIEL sent you a message.)&* Dear Frisk,/")
ds_map_add(global.text_data_en, "scr_torcall_137", "* I think I may have to turn&  off the phone for now./")
ds_map_add(global.text_data_en, "scr_torcall_138", "* Your friends are all very&  lovely people!/")
ds_map_add(global.text_data_en, "scr_torcall_139", "* I think I will spend this&  time getting to know&  them better./")
ds_map_add(global.text_data_en, "scr_torcall_140", "* Bądź grzeczny^1,&  w porządku?/")
ds_map_add(global.text_data_en, "scr_torcall_141", "* Pozdrawiam^1, Toriel./%%")
ds_map_add(global.text_data_en, "scr_torcall_144", "* (Toriel nie wysłała&  nowych wiadomości.)/%%")
ds_map_add(global.text_data_en, "scr_torcall_146", "* (Toriel nie wysłała&  nowych wiadomości.)/%%")
