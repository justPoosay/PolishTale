ds_map_add(global.text_data_en, "SCR_TEXT_1096", "* (Karty w skrzynce: \[1])/")
ds_map_add(global.text_data_en, "SCR_TEXT_1097", "* (Dwa robaczki w pudle&  grają w \[1]-karcianą grę.)/")
