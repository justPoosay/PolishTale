ds_map_add(global.text_data_en, "obj_triswitchevent_213", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_triswitchevent_214", "\TS \E4 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_triswitchevent_215", "\E3* H-h-hej^1!&* Udało ci się!!/")
ds_map_add(global.text_data_en, "obj_triswitchevent_216", "\E4* Bałam się, że&  coś zwaliłam.../")
ds_map_add(global.text_data_en, "obj_triswitchevent_217", "\E0* Ale wygląda na to^1, że&  niezłe z nas duo!/%%")
