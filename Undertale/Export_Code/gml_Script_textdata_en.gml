ds_map_add(global.text_data_en, "obj_smallfrog_63", "\W* (Jeśli wybierzesz odpowiednią&  \YCZYNNOŚĆ\W lub \YWALKĘ\W aż do&  granicy ich życia...)/")
ds_map_add(global.text_data_en, "obj_smallfrog_64", "* (Mogą przestać chcieć toczyć&  z tobą pojedynku.)/")
