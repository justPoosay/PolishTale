ds_map_add(global.text_data_en, "SCR_TEXT_55", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_61", "\Y ")
ds_map_add(global.text_data_en, "SCR_TEXT_62", "\p ")
ds_map_add(global.text_data_en, "SCR_TEXT_99", "* Łagodnie pożegnałeś&   \[I].")
ds_map_add(global.text_data_en, "SCR_TEXT_100", "* Położyłeś \[I]&  na ziemi i pogłaskałeś&  łagodnie.")
ds_map_add(global.text_data_en, "SCR_TEXT_102", "* Rzuciłeś \[I]&  na ziemię jak kupę śmieci&  którym jest.")
ds_map_add(global.text_data_en, "SCR_TEXT_103", "* Porzuciłeś &  \[I].")
ds_map_add(global.text_data_en, "SCR_TEXT_104", "* \[I] zostało&  wyrzucone.")
ds_map_add(global.text_data_en, "SCR_TEXT_111", "   * Spadam ztąd.")
ds_map_add(global.text_data_en, "SCR_TEXT_112", "   * Mam lepsze rzeczy &     do robienia.")
ds_map_add(global.text_data_en, "SCR_TEXT_113", "   * Wstaję, wychodzę")
ds_map_add(global.text_data_en, "SCR_TEXT_114", "   * Nie spowalniaj mnie.")
ds_map_add(global.text_data_en, "SCR_TEXT_121", "   * Uciekłeś z \[1] EXP&     i \[2] GOLD.")
ds_map_add(global.text_data_en, "SCR_TEXT_127", "* (Cienie ruin unoszą się&  w powietrzu^1, wypełniając cię&  determinacją.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_128", "* (HP w pełni przywrócone.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_129", "* (Zabawa liśćmi&  wypełnia cię&  determinacją.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_130", "* (HP w pełni przywrócone.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_131", "* (Wiedząc, że pewnego dnia&  mysz opuści swoją norę, by&  odzyskać ser...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_132", "* (Napełniasz się&  determinacją.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_133", "* (Widok przytulnego^1, czystego&  domku w RUINACH przynosi&  ci determinację.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_134", "* Determinacja./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_135", "* (Chłodna atmosfera&  nowego terenu... wypełnia cię&  determinacją.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_136", "* (Fartowne umiejscowienie&  lampy wypełnia cię&  determinacją.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_137", "* (Wiedząc, że pewnego dnia&  mysz znajdzie sposób na&  podgrzanie spaghetti...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_138", "* (Napełniasz się&  determinacją.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_140", "* (Wiedząc, że psiunka&  nie podda się w lepieniu&  idealnego psiobałwana ...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_141", "* (Napełniasz się&  determinacją.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_142", "* (Śnieg można zawsze rozbić&  i ulepić coś bardziej&  użytecznego.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_143", "* (Ten prosty fakt wypełnia&  cię determinacją.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_144", "* (Widok tak sympatycznego&  miasta wypełnia cię&  determinacją.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_145", "* (Dźwięk pływającego&  strumyczka wypełnia cię&  determinacją.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_146", "* (Czujesz dreszcze spływające&   po twoim ciele...^1)&* (Ale zostajesz zdeterminowany.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_147", "* (Wiedząc, że pewnego dnia&  mysz wyjmie ser z &  mitycznego kryształu...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_148", "* (Napełniasz się&  determinacją.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_150", "* (Dźwięk przytłumionego&  deszczu stukającego o &  sufit jaskini ...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_151", "* (W oddali słychać granie&  spokojnej melodii&  ze starej katarynki...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_152", "* (Napełniasz się&  determinacją.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_153", "* (Uczucie twoich skarpet&  zgniatających się w butach&  przynosi ci determinację.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_156", "* (Wodospad tutaj wyjade się&  lać z sufitu jaskinii...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_157", "* (Okazjonalnie^1, różne śmieci&  spływają z wodą...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_158", "* (... i spadają do&  bezdennej przepaści&  poniżej.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_159", "* (Widząc ten niekończący się&  cykl wezwartościowych&  odpadów...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_160", "* (Napełniasz się&  determinacją.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_161", "* (Stając się jednością ze& śmieciami^1. wypełniasz się&  determinacją.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_164", "* (Czujesz ukojenie i spokój^1.&  Napełniasz się&  determinacją...)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_165", "* (Wyczuwasz..^1. coś.)&* (Napełniasz się&  determinacją.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_168", "* (Wiatr wieje kojąco^1.&* Napełniasz się&  determinacją...)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_169", "* (Kojący wiatr staje się zimny^1.&  To ci daje&  determinację...)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_170", "* (Przestało wiać^1.&* Napełniasz się&  determinacją...)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_174", "* (Widząc laboratorium w&  miejscu takim jak tu...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_175", "* (Napełniasz się&  determinacją.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_180", "* (Dźwięk pary i skomplikowanych&  mechanizmów..^1. napełnia cię&  determinacją.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_184", "* (Złowieszcza struktura&  wyłania się w oddali...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_185", "* (Napełniasz się&  determinacją.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_187", "* (Wiedząc, że pewnego dnia &  mysz zhackuje się do&  sejfu i odzyska ser...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_188", "* (Napełniasz się&  determinacją.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_191", "* (Wyłania się ogromna struktura)&* (Napełniasz się&  determinacją.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_195", "* (Relaksująca atmosfera&  tego hotelu..^1. napełnia cię&  determinacją.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_199", "* (W powietrzu ulatnia się&  zapach ozonu..^1. napełniasz&  się determinacją.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_203", "* (Za drzwiami musi być&  winda do zamku&  Króla.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_204", "* (Napełniasz się&  determinacją.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_208", "* (Zapach pajęczyn ulatnia&  się w powietrzu...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_209", "* (Napełniasz się&  determinacją.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_242", "* Zostawiasz kisz na&  ziemi i mówisz, że&  zaraz przyjdziesz./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_246", "* Użyć skrzyni?& &         Tak         Nie      \C ")
ds_map_add(global.text_data_en, "SCR_TEXT_247", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_248", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_270", "  %%")
ds_map_add(global.text_data_en, "SCR_TEXT_275", "* Nie masz żadnych rzeczy^1.&* Wkładasz trochę czasu do&  skrzyni./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_276", "* Nie masz żadnych rzeczy^1.&* Wkładasz trochę wysiłku do&  skrzyni./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_277", "* Nie masz żadnych rzeczy^1.&* Wkładasz trochę uczucia do&  skrzyni./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_282", "  %%")
ds_map_add(global.text_data_en, "SCR_TEXT_291", "\W* Heja^2!&* Jestem\Y FLOWEY\W.^2 &* \YFLOWEY\W \YKWIATEK\W!/")
ds_map_add(global.text_data_en, "SCR_TEXT_292", "* Hmm.../")
ds_map_add(global.text_data_en, "SCR_TEXT_293", "* Jesteś nowy w&  PODZIEMIACH^2, czyż nie?/")
ds_map_add(global.text_data_en, "SCR_TEXT_294", "* Rany^1, musisz być&  bardzo zdziwiony./")
ds_map_add(global.text_data_en, "SCR_TEXT_295", "* Ktoś cię musi nauczyć&  jak wyglądają sprawy&  u nas!/")
ds_map_add(global.text_data_en, "SCR_TEXT_296", "* Najwyraźniej mały ja&  musi to zrobić./")
ds_map_add(global.text_data_en, "SCR_TEXT_297", "* Gotowy^2?&* No to lecimy!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_301", "\E2* Chodź za mną./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_302", "%%%")
ds_map_add(global.text_data_en, "SCR_TEXT_306", "\E2* Witaj w twoim nowym&  domu^1, drogie dziecię./")
ds_map_add(global.text_data_en, "SCR_TEXT_307", "* Pozwól mi pokierować cię&  przez RUINY./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_311", "\E2* RUINY są pełne&  łamigówek./")
ds_map_add(global.text_data_en, "SCR_TEXT_312", "* starożytnego systemu&  dywersji i przejść./")
ds_map_add(global.text_data_en, "SCR_TEXT_313", "* Jeden musi je rozwiązać,&  by przemieszczać się&  między pomieszczeniami./")
ds_map_add(global.text_data_en, "SCR_TEXT_314", "* Proszę, przypatrz się&  im./%")
ds_map_add(global.text_data_en, "SCR_TEXT_318", "\E2* Aby progresować dalej,^1 &  będziesz musiał&  włączać wiele dźwigni./")
ds_map_add(global.text_data_en, "SCR_TEXT_319", "* Nie obawiaj się,&  zetykietowałam  te,&  które należy uruchomić./%")
ds_map_add(global.text_data_en, "SCR_TEXT_322", "* Nie obawiaj się,^1&  zetykietowałam  te, które&  należy uruchomić./")
ds_map_add(global.text_data_en, "SCR_TEXT_323", "* ... eh^1?&* Wygląda na to, że&  etykiety się starły./")
ds_map_add(global.text_data_en, "SCR_TEXT_324", "* Ojejku./")
ds_map_add(global.text_data_en, "SCR_TEXT_325", "* To może być znacznie&  trudniejsze niż&  zakładałam.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_330", "\E2* Pierwsza dźwignia jest&  tam na ścianie./%")
ds_map_add(global.text_data_en, "SCR_TEXT_334", "\E1* Potrzebujesz pomocy..^1?&* Uruchom dźwignię na&  ścianie./")
ds_map_add(global.text_data_en, "SCR_TEXT_335", "\E0* Dawaj^1, wierzę w ciebie!/%")
ds_map_add(global.text_data_en, "SCR_TEXT_339", "\E2* No już^1, przełącz&  dźwignię po lewej./%")
ds_map_add(global.text_data_en, "SCR_TEXT_342", "\E2* Obawiam się, że to miała&  być dźwignia po lewej./%")
ds_map_add(global.text_data_en, "SCR_TEXT_347", "\E1* Wiesz, w którą stronę&  jest lewo^1, czyż nie?/")
ds_map_add(global.text_data_en, "SCR_TEXT_348", "\E0* Naciśnij przełącznik, który &  ci oznaczyłam./%")
ds_map_add(global.text_data_en, "SCR_TEXT_352", "\E1* Wiesz, w którą stronę&  jest lewo^1, czyż nie?/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_357", "\E1* Jesteś bardzo ciekawski,^1 &  czyż nie?/")
ds_map_add(global.text_data_en, "SCR_TEXT_358", "\E1* Proszę, zrozum.^2 & \E0 Ja tylko chcę&  cię chronić./%")
ds_map_add(global.text_data_en, "SCR_TEXT_362", "\E0* Wyśmienicie!^2 &* Jestem z ciebie dumna,^1 &  malutki./")
ds_map_add(global.text_data_en, "SCR_TEXT_363", "* Pozwól, że przejdziemy&  do następnego&  pomieszczenia./%")
ds_map_add(global.text_data_en, "SCR_TEXT_367", "\E1* Jako człowiek żyjący w&  PODZIEMIACH,^1 potwory&  mogą cię atakować./")
ds_map_add(global.text_data_en, "SCR_TEXT_368", "\E2* Będziesz musiał się&  przygotować na&  taką sytuację./")
ds_map_add(global.text_data_en, "SCR_TEXT_369", "\E0* Jednakże, nie&  obawiaj się!^2 &* Proces jest łatwy./")
ds_map_add(global.text_data_en, "SCR_TEXT_370", "\E2* Kiedy napotkasz &  potwora,^1 wkroczysz&  w WALKĘ./")
ds_map_add(global.text_data_en, "SCR_TEXT_371", "* Kiedy jesteś w WALCE^1,&  zacznij przyjacielską&  konwersację./")
ds_map_add(global.text_data_en, "SCR_TEXT_372", "\E2* Nie spiesz się.&  Ja przyjdę i&  rozwiążę konflikt./")
ds_map_add(global.text_data_en, "SCR_TEXT_373", "\E2* Przećwicz rozmowę&  z manekinem./%")
ds_map_add(global.text_data_en, "SCR_TEXT_379", "\E1* Ahh,^1 manekiny nie&  służą do walki!^2 &* One są do rozmowy!/")
ds_map_add(global.text_data_en, "SCR_TEXT_380", "* Nie chcemy przecież&  nikogo skrzywdzić,&  prawda...?^2 \E0/%")
ds_map_add(global.text_data_en, "SCR_TEXT_384", "\E0* Ah,^1 wyśmienicie!^2 &* Jestem dumna./%")
ds_map_add(global.text_data_en, "SCR_TEXT_388", "\E1* .../")
ds_map_add(global.text_data_en, "SCR_TEXT_389", "\E1* ...uciekłeś.../")
ds_map_add(global.text_data_en, "SCR_TEXT_390", "\E0* Szczerze^1, to nie była&  słaba decyzja./")
ds_map_add(global.text_data_en, "SCR_TEXT_391", "\E0* W końcu lepiej unikać&  konfliktu, kiedy to&  tylko możliwe./")
ds_map_add(global.text_data_en, "SCR_TEXT_392", "\E1* To..^1. natomiast^1, jest&  tylko manekinem^2.&* Nie może cię skrzywdzić./")
ds_map_add(global.text_data_en, "SCR_TEXT_393", "\E1* Jest stworzone z bawełny^1.&* Nie pragnie zemsty.../")
ds_map_add(global.text_data_en, "SCR_TEXT_394", "\E0* Wiesz co, nieważne^2.&* Trzymaj się blisko mnie a&  ja ci zapewnię bezpieczeństwo./%")
ds_map_add(global.text_data_en, "SCR_TEXT_398", "\E3* ^1.^1.^1./")
ds_map_add(global.text_data_en, "SCR_TEXT_399", "\E4* ^1.^1.^1./")
ds_map_add(global.text_data_en, "SCR_TEXT_400", "\E0* Następne pomieszczenie czeka./%")
ds_map_add(global.text_data_en, "SCR_TEXT_405", "\E2* Przećwicz rozmowę&  z manekinem./")
ds_map_add(global.text_data_en, "SCR_TEXT_406", "\E1* Możesz powiedzieć co chcesz..^2.\E2 &* Nie sądzę, że&  zostanie urażone./%")
ds_map_add(global.text_data_en, "SCR_TEXT_411", "\E0* Potrzebujesz jakieś&  pomysły na rozmowę?/")
ds_map_add(global.text_data_en, "SCR_TEXT_412", "* Cóż^1, ja często&  zaczynam prostym&  'jak się masz...'/")
ds_map_add(global.text_data_en, "SCR_TEXT_413", "* Możesz ich spytać&  o ulubioną książkę.../")
ds_map_add(global.text_data_en, "SCR_TEXT_414", "* Żarty pomagają&  'przełamać lód.'/")
ds_map_add(global.text_data_en, "SCR_TEXT_415", "* Posłuchaj tego./")
ds_map_add(global.text_data_en, "SCR_TEXT_416", "* Co robi piłkarz&  na ulicy?/")
ds_map_add(global.text_data_en, "SCR_TEXT_417", "* ... Stoi w korkach!/")
ds_map_add(global.text_data_en, "SCR_TEXT_418", "\E1* .../")
ds_map_add(global.text_data_en, "SCR_TEXT_419", "\E0* Cóż^1, ja to uznałam &  za humorystyczne./%")
ds_map_add(global.text_data_en, "SCR_TEXT_423", "\E2* Przećwicz rozmowę&  z manekinem./")
ds_map_add(global.text_data_en, "SCR_TEXT_424", "\E1* Możesz powiedzieć co chcesz..^2.\E0 &* Nie sądzę, że&  zostanie urażone./%")
ds_map_add(global.text_data_en, "SCR_TEXT_428", "\E1* W kolejnym pomieszczeniu&  czeka kolejna&  łamigówka.../")
ds_map_add(global.text_data_en, "SCR_TEXT_429", "\E0* Zastanawiam się, czy&  dasz radę ją rozwiązać?/%")
ds_map_add(global.text_data_en, "SCR_TEXT_433", "\E1* Oto ta łamigówka^1,&  ale.../")
ds_map_add(global.text_data_en, "SCR_TEXT_434", "\E0* Masz^1, potrzymaj mnie za&  rękę na chwilę./%")
ds_map_add(global.text_data_en, "SCR_TEXT_438", "\E1* Łamigówki wydają się&  zbyt niebezpieczne&  jak narazie./%")
ds_map_add(global.text_data_en, "SCR_TEXT_442", ".../%")
ds_map_add(global.text_data_en, "SCR_TEXT_446", "\E2* Witaj,^1 słońce^2.&* Nie obawiaj się^1, nie&  opuściłam cię./")
ds_map_add(global.text_data_en, "SCR_TEXT_447", "\E0* Czekałam za tym pilarem&  ten cały czas./")
ds_map_add(global.text_data_en, "SCR_TEXT_448", "* Dziękuję, że&  mi zaufałeś./")
ds_map_add(global.text_data_en, "SCR_TEXT_449", "\E2* Jednakże^1, za tym&  ćwiczeniem stoi&  ważny powód./")
ds_map_add(global.text_data_en, "SCR_TEXT_450", "* ...aby przetestować&  twoją niezależność./")
ds_map_add(global.text_data_en, "SCR_TEXT_451", "\E1* Muszę pójść załatwić&  ważną sprawę^1, więc&  poczekaj tu chwilkę./")
ds_map_add(global.text_data_en, "SCR_TEXT_452", "\E0* Proszę zostań tutaj^2.&*\E1 To zbyt niebezpieczne,&  by poruszać się samemu./")
ds_map_add(global.text_data_en, "SCR_TEXT_453", "\E0* Mam pomysł^2.&* Podaruję ci&  TELEFON KOMÓRKOWY./")
ds_map_add(global.text_data_en, "SCR_TEXT_454", "* Jeśli będziesz czegoś&  potrzebował^1, po prostu&  zadzwoń do mnie./")
ds_map_add(global.text_data_en, "SCR_TEXT_455", "\E1* Bądź grzeczny^1, okej?/%")
ds_map_add(global.text_data_en, "SCR_TEXT_459", "\E0* Jak dotąd poradziłeś&  sobie doskonale^1,&  słońce./")
ds_map_add(global.text_data_en, "SCR_TEXT_460", "\E2* Jednakże...&  mam do ciebie&  niełatwą prośbę./")
ds_map_add(global.text_data_en, "SCR_TEXT_461", "* .../")
ds_map_add(global.text_data_en, "SCR_TEXT_462", "* Chciałabym, abyś&  dotarł do końca tego&  korytarza samodzielnie./")
ds_map_add(global.text_data_en, "SCR_TEXT_463", "\E1* Wybacz mi./%")
ds_map_add(global.text_data_en, "SCR_TEXT_467", "* Dzyn dzyn..\E0.\TT /")
ds_map_add(global.text_data_en, "SCR_TEXT_468", "\F1 %")
ds_map_add(global.text_data_en, "SCR_TEXT_469", "* Halo?&* Mówi TORIEL./")
ds_map_add(global.text_data_en, "SCR_TEXT_470", "* Bez konkretnego&  powodu...&* Które preferujesz?/")
ds_map_add(global.text_data_en, "SCR_TEXT_471", "* Cynamon czy&  toffi?&  Cynamon    Toffi \C")
ds_map_add(global.text_data_en, "SCR_TEXT_472", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_490", "* Oh^1, rozumiem.&* Dziękuję za opinię!/")
ds_map_add(global.text_data_en, "SCR_TEXT_491", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_492", "* Klik.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_493", "* /")
ds_map_add(global.text_data_en, "SCR_TEXT_497", "* To jest wędka umocowana&  do ziemi.../")
ds_map_add(global.text_data_en, "SCR_TEXT_498", "* Zawinąć?& &         Tak         Nie      \C ")
ds_map_add(global.text_data_en, "SCR_TEXT_499", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_511", "* Jedyne co jest zahaczone o&  końcówkę to zdjęcie dziwnie&  wyglądającego potwora.../")
ds_map_add(global.text_data_en, "SCR_TEXT_512", "* (Zadzwoń!&  Oto mój numer!)/")
ds_map_add(global.text_data_en, "SCR_TEXT_513", "* Postanowiłeś nie dzwonić./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_516", "* Jedyne co jest zahaczone o&  końcówkę to notatka./")
ds_map_add(global.text_data_en, "SCR_TEXT_517", "* (Już nieważne!)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_522", "* Zostawiasz to w spokoju./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_529", "* Nie powinienem był się&  tak łatwo poddawać.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_533", "* Czy ty właśnie...&* Zjadłeś kawałek mnie, który&  ci podarowałem?/")
ds_map_add(global.text_data_en, "SCR_TEXT_534", "* Prosto przed moimi oczami!?/")
ds_map_add(global.text_data_en, "SCR_TEXT_535", "* Nie mam do ciebie słów..^1.&* Wynocha!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_540", "* Dziękuję za twoją troskę&  o mnie.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_545", "* Huh^1? Znowu...?/")
ds_map_add(global.text_data_en, "SCR_TEXT_546", "* Przepraszam..^1. jeśli dam ci&  jeszcze więcej^1, nie zostanie&  ze mnie już nic./")
ds_map_add(global.text_data_en, "SCR_TEXT_547", "* Przypuszczam, że to prawda^1.&* Podróżowanie poza nasze granice&  jest zwyczajnie marzeniem./")
ds_map_add(global.text_data_en, "SCR_TEXT_548", "* Nie tylko moim, lecz&  wszystkich innych./")
ds_map_add(global.text_data_en, "SCR_TEXT_549", "* Wszystkie potwory&  są skazane na pozostanie pod&  ziemią^1 na zawsze.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_554", "* Jak się ja trzymam^1?&* Mówiąc " + '"' + "ja" + '"' + " mam na myśli część&  mnie, którą ci podarowałem.../")
ds_map_add(global.text_data_en, "SCR_TEXT_559", "* Huh^1? Zgubiłeś to...^1?&* ... Najwyraźniej muszę ci&  dać kolejny kawałek.../")
ds_map_add(global.text_data_en, "SCR_TEXT_563", "* Nie masz już miejsca^1?&* Okej..^1. Rozumiem, że nie jestem&  dla ciebie priorytetem./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_567", "* Proszę, bądź ostrożny&  tym razem./")
ds_map_add(global.text_data_en, "SCR_TEXT_568", "* (Dostałeś Kawałek&  Bałwana.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_576", "* Dzień dobry^1.&* Jestem bałwanem./")
ds_map_add(global.text_data_en, "SCR_TEXT_577", "* Chcę zobaczyć świat..^1.&* Ale nie mogę się ruszać./")
ds_map_add(global.text_data_en, "SCR_TEXT_578", "* Gdybyś był taki miły^1,&  podróżniku^1, proszę.../")
ds_map_add(global.text_data_en, "SCR_TEXT_579", "* Weź kawałek mnie i zanieś&  go gdzieś bardzo daleko.&         Tak         Nie      \C ")
ds_map_add(global.text_data_en, "SCR_TEXT_580", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_590", "* Wygląda na to, że&  nie masz wystarczająco&  miejsca na mnie./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_593", "* Dziękuję... powodzenia!/")
ds_map_add(global.text_data_en, "SCR_TEXT_594", "* (Dostałeś Kawałek&  Bałwana.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_600", "* Rozumiem^1.&* W takim razie^1, miłej podróży./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_605", "SANS!!^1!&TO NIC NIE&DAŁO!/")
ds_map_add(global.text_data_en, "SCR_TEXT_606", "SANS!!^1!&ON NAWET NA TO&NIE SPOJRZAŁ!/")
ds_map_add(global.text_data_en, "SCR_TEXT_608", "* ups./")
ds_map_add(global.text_data_en, "SCR_TEXT_609", "* wiedziałem że powinienem&  był użyć dzisiejszej&  krzyżówki zamiast tego./")
ds_map_add(global.text_data_en, "SCR_TEXT_611", "CO!^1?&KRZYŻÓWKA!?/")
ds_map_add(global.text_data_en, "SCR_TEXT_612", "NIE WIERZĘ&ŻE TO&POWIEDZIAŁEŚ!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_613", "WEDŁUG MNIE.../")
ds_map_add(global.text_data_en, "SCR_TEXT_614", "\E3WYKREŚLANKA&JEST ZDECYDOWANIE&NAJTRUDNIEJSZA./")
ds_map_add(global.text_data_en, "SCR_TEXT_616", "* co^1? naprawde^1?&* ta łatwusieńka&  łamigówka?/")
ds_map_add(global.text_data_en, "SCR_TEXT_617", "\E1* to jest dla&  baby boomerów./")
ds_map_add(global.text_data_en, "SCR_TEXT_619", "NIE^1. MOŻLIWE./")
ds_map_add(global.text_data_en, "SCR_TEXT_620", "\E0CZŁOWIEKU!!^1!&WYRAŹ SWOJĄ OPINIĘ!/")
ds_map_add(global.text_data_en, "SCR_TEXT_621", "\TS \F0 \E0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_622", "* (Kto ma rację?)& &         Papyrus     Sans \C ")
ds_map_add(global.text_data_en, "SCR_TEXT_623", "   ")
ds_map_add(global.text_data_en, "SCR_TEXT_631", "HA^1! HA^1! TAK!/")
ds_map_add(global.text_data_en, "SCR_TEXT_632", "LUDZIE MUSZĄ BYĆ&BARDZO INTELIGENTNI!/")
ds_map_add(global.text_data_en, "SCR_TEXT_633", "JEŚLI DLA NICH&WYKREŚLANKI&SĄ RÓWNIEŻ TRUDNE!/")
ds_map_add(global.text_data_en, "SCR_TEXT_634", "NYEH^1! HEH^1! HEH HEH!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_639", "WY DWAJ JESTEŚCIE DZIWNI!/")
ds_map_add(global.text_data_en, "SCR_TEXT_640", "\E3KRZYŻÓWKI SĄ TAKIE&PROSTE./")
ds_map_add(global.text_data_en, "SCR_TEXT_641", "TO JEST TO SAMO&ROZWIĄZANIE ZA KAŻDYM&RAZEM./")
ds_map_add(global.text_data_en, "SCR_TEXT_642", "\E0PO PROSTU WYPEŁNIAM&WSZYSTKIE POLA&LITERĄ 'Z'.../")
ds_map_add(global.text_data_en, "SCR_TEXT_643", "BO ZA KAŻDYM RAZEM GDY&PATRZĘ NA&KRZYŻÓWKĘ.../")
ds_map_add(global.text_data_en, "SCR_TEXT_644", "JEDYNE CO MOGĘ ROBIĆ&TO CHRAPAĆ!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_645", "NYEH HEH HEH!!!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_654", "* Heja^1!&* Chciałbyś kupić loda?/")
ds_map_add(global.text_data_en, "SCR_TEXT_655", "* To nasz lokalny przysmak,&  który ogrzewa twoje serce!/")
ds_map_add(global.text_data_en, "SCR_TEXT_656", "* Promocja, tylko 15G!& &         Tak         Nie \C")
ds_map_add(global.text_data_en, "SCR_TEXT_657", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_661", " %")
ds_map_add(global.text_data_en, "SCR_TEXT_662", "* Fajne Lody^1!&* To nasz lokalny przysmak,&  który ogrzewa ci serce!/")
ds_map_add(global.text_data_en, "SCR_TEXT_663", "* Promocja, tylko 15G!& &         Tak         Nie \C")
ds_map_add(global.text_data_en, "SCR_TEXT_664", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_682", "* Trzymaj^1!&* Życzę superaśnego dnia^1!&* (Dostałeś Fajnego Loda.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_684", "* Huh^1?&* Nie masz wystarczająco&  pieniędzy.../")
ds_map_add(global.text_data_en, "SCR_TEXT_685", "* Szkodam że nie mogę robić&  Fajnych Lodów za darmo.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_688", "* Wygląda na to, że&  masz zbyt wiele rzeczy^1!&* No cóż!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_691", "* W takim razie..^1.&* Powiedz twoim znajomym.../")
ds_map_add(global.text_data_en, "SCR_TEXT_692", "* Że są lody..^1.&* w centrum lasu.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_704", "* Heja^1!&* Chciałbyś kupić loda?/")
ds_map_add(global.text_data_en, "SCR_TEXT_705", "* To nasz lokalny przysmak,&  który ogrzewa twoje serce!/")
ds_map_add(global.text_data_en, "SCR_TEXT_706", "* Promocja, tylko 25G!& &         Tak         Nie \C")
ds_map_add(global.text_data_en, "SCR_TEXT_707", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_711", " %")
ds_map_add(global.text_data_en, "SCR_TEXT_712", "* Fajne Lody^1!&* To nasz lokalny przysmak,&  który ogrzewa ci serce!/")
ds_map_add(global.text_data_en, "SCR_TEXT_713", "* Promocja, tylko 25G!& &         Tak         Nie \C")
ds_map_add(global.text_data_en, "SCR_TEXT_714", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_721", "* Hej^1, masz parasolkę&  podobną do tego na&  moim wózku.../")
ds_map_add(global.text_data_en, "SCR_TEXT_722", "* Co za niespodzianka^1!&* Aż ci dam przyjacielską&  zniżkę!/")
ds_map_add(global.text_data_en, "SCR_TEXT_723", "* Przecenione lody! 15G!& &         Tak         Nie \C")
ds_map_add(global.text_data_en, "SCR_TEXT_724", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_728", " %")
ds_map_add(global.text_data_en, "SCR_TEXT_729", "* Co za niespodzianka!^1?&* Chyba muszę ci dać&  zniżkę.../")
ds_map_add(global.text_data_en, "SCR_TEXT_730", "* Przecenione lody! 15G!& &         Tak         Nie \C")
ds_map_add(global.text_data_en, "SCR_TEXT_731", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_736", "* Hej^1!&* Posiadasz 3 dziurkowane karty!/")
ds_map_add(global.text_data_en, "SCR_TEXT_737", "* Co ty na to, żeby wymienić&  je na Fajne Lody!?/")
ds_map_add(global.text_data_en, "SCR_TEXT_738", "* Bez dodatkowych opłat!& &         Tak         Nie \C")
ds_map_add(global.text_data_en, "SCR_TEXT_739", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_777", "* Super^1! Trzymaj.&* Twoja karta jest w skrzyni!&* (Dostałeś Fajne Lody.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_779", "* Huh^1? Brakuje ci kasy^1?&* Sorka^1, nie mogę ci tego&  dać za darmo./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_781", "* Huh^1? Nie stać cię na to&  pomimo zniżki^1?&* Ja.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_784", "* Wygląda na to, że&  masz zbyt wiele rzeczy^1!&* No cóż!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_803", "* Trzymaj^1! Darmowe Fajne Lody^1!&* (Straciłeś 3 karty i&  otrzymałeś Fajne Lody.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_809", "* W takim razie..^1.&* Powiedz twoim znajomym.../")
ds_map_add(global.text_data_en, "SCR_TEXT_810", "* Są lody..^1.&* Ukryte w głębinach&  wodnistej jaskini.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_815", "* Myślałem również o&  sprzedawaniu przekąsek./")
ds_map_add(global.text_data_en, "SCR_TEXT_816", "* chcesz trochę smażonego śniegu^1?&  to tylko 5G.&  Kup         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_817", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_823", "* oj, powiedziałem 5G^1?&* miałem na myśli 50G^1.&  Kup         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_824", "  ")
ds_map_add(global.text_data_en, "SCR_TEXT_828", "* masz rację./")
ds_map_add(global.text_data_en, "SCR_TEXT_829", "* powinienem obciążać&  o wiele więcej niż to./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_836", "* serio^1?&* to może 5000G?&  Kup         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_837", "  ")
ds_map_add(global.text_data_en, "SCR_TEXT_841", "* masz rację./")
ds_map_add(global.text_data_en, "SCR_TEXT_842", "* to dalej zbyt mało./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_849", "* 50000G^1.&* to moja finalna oferta.&  Kup         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_850", "  ")
ds_map_add(global.text_data_en, "SCR_TEXT_854", "* muszę jakoś zapłacić&  za same produkty./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_861", "* co^1?&* nie masz kasy?/")
ds_map_add(global.text_data_en, "SCR_TEXT_862", "* hej^1, nie szkodzi./")
ds_map_add(global.text_data_en, "SCR_TEXT_863", "\E1* ja nie mam śniegu./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_867", "* wow^1, to jest&  dużo gotówki./")
ds_map_add(global.text_data_en, "SCR_TEXT_868", "\E3* dlatego przepraszam, że&  to powiem.../")
ds_map_add(global.text_data_en, "SCR_TEXT_869", "\E3* ale nie mogę ci sprzedać&  tego./")
ds_map_add(global.text_data_en, "SCR_TEXT_870", "\E2* to ma zbyt wielką&  sentymentalną wartość./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_875", "* nie wiesz, kiedy jest&  dobra oferta jak&  słyszysz o takiej?/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_880", "CO!^1?&JAK ZDOŁAŁEŚ UNI-&KNĄĆ MOJEJ PUŁAPKI?/")
ds_map_add(global.text_data_en, "SCR_TEXT_881", "\E3I^1, CO&WAŻNIEJSZE.../")
ds_map_add(global.text_data_en, "SCR_TEXT_882", "\E0CZY ZOSTAŁO&COŚ JESZCZE&DLA MNIE???/")
ds_map_add(global.text_data_en, "SCR_TEXT_883", "\TS \F0 \E0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_884", "* (Co mówisz Papyrusowi&  o jego spaghetti?)&         Zjadłem      Zostawiłem   \C ")
ds_map_add(global.text_data_en, "SCR_TEXT_885", "   ")
ds_map_add(global.text_data_en, "SCR_TEXT_890", "NAPRAWDĘ!?/")
ds_map_add(global.text_data_en, "SCR_TEXT_893", "\E2WOWIE.../")
ds_map_add(global.text_data_en, "SCR_TEXT_894", "NIKOMU DO TEJ PORY&NIE POSMAKOWAŁA&MOJA KUCHNIA.../")
ds_map_add(global.text_data_en, "SCR_TEXT_895", "\E0A WIĘC!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_900", "\E2WOWIE.../")
ds_map_add(global.text_data_en, "SCR_TEXT_901", "OPARŁEŚ SIĘ&SMAKOWI MOJEGO&SPAGHETTI.../")
ds_map_add(global.text_data_en, "SCR_TEXT_902", "TYLKO PO TO BYŚ&MÓGŁ SIĘ ZE MNĄ&PODZIELIĆ???/")
ds_map_add(global.text_data_en, "SCR_TEXT_905", "\E0NIE OBAWIAJ SIĘ^1!&JA^1, WIELKI KUCHARZ&PAPYRUS.../")
ds_map_add(global.text_data_en, "SCR_TEXT_906", "ZROBIĘ CI TYLE&SPAGHETTI^1, ILE&TYLKO ZAPRAGNIESZ!/")
ds_map_add(global.text_data_en, "SCR_TEXT_907", "HEH HEH HEH HEH&HEH HEH NYEH!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_911", "HEJ!/")
ds_map_add(global.text_data_en, "SCR_TEXT_912", "TO TEN CZŁOWIEK!/")
ds_map_add(global.text_data_en, "SCR_TEXT_913", "\E0TA ŁAMIGÓWKA&CI SIĘ&SPODOBA!/")
ds_map_add(global.text_data_en, "SCR_TEXT_914", "ZOSTAŁA STWORZONA&PRZEZ WIELKĄ&DR. ALPHYS!/")
ds_map_add(global.text_data_en, "SCR_TEXT_915", "WIDZISZ&TE PŁYTY&!?/")
ds_map_add(global.text_data_en, "SCR_TEXT_916", "GDY TYLKO POCIĄGNĘ&ZA DŹWIGNIĘ.../")
ds_map_add(global.text_data_en, "SCR_TEXT_917", "TO ZACZNĄ&ZMIENIAĆ KOLOR!/")
ds_map_add(global.text_data_en, "SCR_TEXT_918", "KAŻDY KOLOR MA&INNĄ FUNKCJĘ!/")
ds_map_add(global.text_data_en, "SCR_TEXT_919", "CZERWONE PŁYTKI SĄ&NIEPRZEKRACZALNE!/")
ds_map_add(global.text_data_en, "SCR_TEXT_920", "NIE MOŻESZ&PO NICH CHODZIĆ!/")
ds_map_add(global.text_data_en, "SCR_TEXT_921", "ŻÓŁTE PŁYTKI&SĄ ELEKTRYCZNE!/")
ds_map_add(global.text_data_en, "SCR_TEXT_922", "PORAŻA CIĘ&PRĄDEM!/")
ds_map_add(global.text_data_en, "SCR_TEXT_923", "ZIELONE PŁYTKI&SĄ KLAWISZAMI&ALARMOWYMI!/")
ds_map_add(global.text_data_en, "SCR_TEXT_924", "JEŚLI NA NIE&NADEPNIESZ.../")
ds_map_add(global.text_data_en, "SCR_TEXT_925", "BĘDZIESZ MUSIAŁ&STOCZYĆ WALKĘ Z&POTWOREM!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_926", "POMARAŃCZOWE PŁYTKI&SĄ O ZAPACHU&POMARAŃCZY./")
ds_map_add(global.text_data_en, "SCR_TEXT_927", "SPRAWIĄ, ŻE&BĘDZIESZ PACHNIEĆ&PYSZNIE!/")
ds_map_add(global.text_data_en, "SCR_TEXT_928", "NIEBIESKIE PŁYTKI TO&WODNE PŁYTKI./")
ds_map_add(global.text_data_en, "SCR_TEXT_929", "PRZEPŁYŃ PRZEZ NIE&JEŚLI CHCESZ^1,&ALE.../")
ds_map_add(global.text_data_en, "SCR_TEXT_930", "JEŚLI PACHNIESZ&POMARAŃCZAMI!/")
ds_map_add(global.text_data_en, "SCR_TEXT_931", "TO ZACZNĄ CIĘ&GRYŚĆ PIRANIE./")
ds_map_add(global.text_data_en, "SCR_TEXT_932", "W DODATKU^1, JEŚLI&NIEBIESKA PŁYTKA&JEST OBOK/")
ds_map_add(global.text_data_en, "SCR_TEXT_933", "ŻÓŁTEJ PŁYTKI^1,&WODA RÓWNIEŻ&CIĘ PORAZI!/")
ds_map_add(global.text_data_en, "SCR_TEXT_934", "FIOLETOWE PŁYTKI&SĄ ŚLISKIE!/")
ds_map_add(global.text_data_en, "SCR_TEXT_935", "PRZEŚLIZGNIESZ SIĘ&NA NASTĘPNĄ&PŁYTKĘ!/")
ds_map_add(global.text_data_en, "SCR_TEXT_936", "JEDNAKŻE^1,&ŚLISKIE&MYDŁO.../")
ds_map_add(global.text_data_en, "SCR_TEXT_937", "PACHNIE&CYTRYNAMI!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_938", "KTÓRYCH PIRANIE&RÓWNIEŻ NIE LUBIĄ!/")
ds_map_add(global.text_data_en, "SCR_TEXT_939", "FIOLETOWE I&NIEBIESKIE SĄ OKEJ!/")
ds_map_add(global.text_data_en, "SCR_TEXT_940", "I NA KOŃCU^1,&RÓŻOWE PŁYTKI./")
ds_map_add(global.text_data_en, "SCR_TEXT_941", "NIE ROBIĄ&NIC./")
ds_map_add(global.text_data_en, "SCR_TEXT_942", "CHODŹ PO NICH&ILE CHCESZ./")
ds_map_add(global.text_data_en, "SCR_TEXT_943", "I JAK!^1?&ZROZUMIAŁE???/")
ds_map_add(global.text_data_en, "SCR_TEXT_944", "\TS \F0 \E0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_945", "* (Rozumiesz instrukcję?)& &         Tak          Nie        \C ")
ds_map_add(global.text_data_en, "SCR_TEXT_946", "   ")
ds_map_add(global.text_data_en, "SCR_TEXT_953", "SUPER!^1!&W TAKIM RAZIE&OSTATNIA RZECZ.../")
ds_map_add(global.text_data_en, "SCR_TEXT_954", "TA ŁAMIGÓWKA.../")
ds_map_add(global.text_data_en, "SCR_TEXT_955", "JEST KOMPLETNIE&LOSOWA&!!!!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_956", "KIEDY POCIĄGNĘ ZA&WAJCHĘ^1, UTWORZONA&ZOSTANIE ŁAMIGÓWKA.../")
ds_map_add(global.text_data_en, "SCR_TEXT_957", "KTÓREJ&JESZCZE NIGDY&NIE WIDZIANO!/")
ds_map_add(global.text_data_en, "SCR_TEXT_958", "NAWET JA NIE BĘDĘ&ZNAŁ ROZWIĄZANIA!/")
ds_map_add(global.text_data_en, "SCR_TEXT_959", "NYEH HEH HEH^1!&PRZYGOTUJ SIĘ...!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_965", "OKEJ..^1.&NAJWYRAŹNIEJ MUSZĘ&SIĘ POWTÓRZYĆ.../")
ds_map_add(global.text_data_en, "SCR_TEXT_966", "\E0CZERWONE PŁYTKI SĄ&NIE DO PRZEKROCZENIA./")
ds_map_add(global.text_data_en, "SCR_TEXT_967", "ŻÓŁTE KLAWISZE SĄ&ELEKTRYCZNIE I&NIEBEZPIECZNE./")
ds_map_add(global.text_data_en, "SCR_TEXT_968", "NIEBIESKIE PŁYTKI&WYZYWAJĄ CIĘ DO&WALKI Z POTWOREM./")
ds_map_add(global.text_data_en, "SCR_TEXT_969", "ZIELONE PŁYTKI SĄ&WODNYMI PŁYTKAMI./")
ds_map_add(global.text_data_en, "SCR_TEXT_970", "POMARAŃCZOWE PŁYTKI SĄ O&ZAPACHU POMARAŃCZY./")
ds_map_add(global.text_data_en, "SCR_TEXT_971", "JEŚLI WEJDZIESZ NA&POMARAŃCZOWE^1, NIE WCHÓDŹ NA&ZIELONE./")
ds_map_add(global.text_data_en, "SCR_TEXT_972", "\E3BRĄZOWE PŁYTKI TO.../")
ds_map_add(global.text_data_en, "SCR_TEXT_973", "\E1CHWILA!!^1!&NIE MA TU&BRĄZOWYCH PŁYTEK.../")
ds_map_add(global.text_data_en, "SCR_TEXT_974", "\E0FIOLETOWE PŁYTKI&PACHNĄ CYTRYNAMI.../")
ds_map_add(global.text_data_en, "SCR_TEXT_975", "\E3CZEMU TO NIE&ŻÓŁTE PŁYTKI&PACHNĄ CYTRYNAMI?/")
ds_map_add(global.text_data_en, "SCR_TEXT_976", "\E3UM.../")
ds_map_add(global.text_data_en, "SCR_TEXT_977", "\E1CHWILA!^1!&CZY JA POMIESZAŁEM&ZIELONE Z NIEBIESKIMI!?/")
ds_map_add(global.text_data_en, "SCR_TEXT_978", "TO NIEBIESKIE PŁYTKI&SĄ WODNE!/")
ds_map_add(global.text_data_en, "SCR_TEXT_979", "\E3RÓŻOWE PŁYTKI.../")
ds_map_add(global.text_data_en, "SCR_TEXT_980", "JA NIE..^1.&PAMIĘTAM???/")
ds_map_add(global.text_data_en, "SCR_TEXT_981", "\E1CZEKAJ!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_982", "\E3ONE NIC&NIE ROBIĄ./")
ds_map_add(global.text_data_en, "SCR_TEXT_983", "\E0OKEJ^1!&CZY TERAZ&ROZUMIESZ BARDZIEJ!?/")
ds_map_add(global.text_data_en, "SCR_TEXT_984", "\TS \F0 \E0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_985", "* (Rozumiesz wyjaśnienie?)& &         Tak         Nawet mniej \C ")
ds_map_add(global.text_data_en, "SCR_TEXT_986", "   ")
ds_map_add(global.text_data_en, "SCR_TEXT_994", "SUPER!^1!&W TAKIM RAZIE&OSTATNIA RZECZ.../")
ds_map_add(global.text_data_en, "SCR_TEXT_995", "TA ŁAMIGÓWKA.../")
ds_map_add(global.text_data_en, "SCR_TEXT_996", "JEST KOMPLETNIE&LOSOWA&!!!!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_997", "KIEDY POCIĄGNĘ ZA&WAJCHĘ^1, UTWORZONA&ZOSTANIE ŁAMIGÓWKA.../")
ds_map_add(global.text_data_en, "SCR_TEXT_998", "KTÓREJ&JESZCZE NIGDY&NIE WIDZIANO!/")
ds_map_add(global.text_data_en, "SCR_TEXT_999", "NAWET JA NIE BĘDĘ&ZNAŁ ROZWIĄZANIA!/")
ds_map_add(global.text_data_en, "SCR_TEXT_1000", "NYEH HEH HEH^1!&PRZYGOTUJ SIĘ...!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1006", "........../")
ds_map_add(global.text_data_en, "SCR_TEXT_1007", "OKEJ^1, WIESZ&CO???/")
ds_map_add(global.text_data_en, "SCR_TEXT_1008", "CO TY NA TO..^1.&ŻEBY PO PROSTU.../")
ds_map_add(global.text_data_en, "SCR_TEXT_1009", "PRZEJDŹ TĄ ŁAMIGÓWKĘ..^1.&SAMODZIELNIE.../")
ds_map_add(global.text_data_en, "SCR_TEXT_1010", "ZOSTAWIĘ CI&WSKAZÓWKI.../")
ds_map_add(global.text_data_en, "SCR_TEXT_1011", "PO PROSTU&JE PRZECZYTAJ./")
ds_map_add(global.text_data_en, "SCR_TEXT_1012", "I GDY JE&ZROZUMIESZS.../")
ds_map_add(global.text_data_en, "SCR_TEXT_1013", "BĘDZIESZ MÓGŁ&POCIĄGNĄĆ ZA WAJCHĘ./")
ds_map_add(global.text_data_en, "SCR_TEXT_1014", "I ZRÓB TO W&SWOIM TEMPIE./")
ds_map_add(global.text_data_en, "SCR_TEXT_1015", "POWODZENIA./")
ds_map_add(global.text_data_en, "SCR_TEXT_1016", "NYEH..^1.&HEH..^1.&HEH!/%%")
