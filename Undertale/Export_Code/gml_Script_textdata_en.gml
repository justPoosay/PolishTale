ds_map_add(global.text_data_en, "obj_glydeb_148", "Jaki&jestem&wspaniały.")
ds_map_add(global.text_data_en, "obj_glydeb_149", "Patrz.&Oglądaj.&Obserwuj.")
ds_map_add(global.text_data_en, "obj_glydeb_150", "Wow.&Check&out my&pecs.")
ds_map_add(global.text_data_en, "obj_glydeb_151", "Sorry...&for&NOTHING&*ollies*")
ds_map_add(global.text_data_en, "obj_glydeb_159", "Boo?&What a&wimpy&ghost.")
ds_map_add(global.text_data_en, "obj_glydeb_160", "Mmm,&Fresh&Sweet&Haters")
ds_map_add(global.text_data_en, "obj_glydeb_165", "OK!&I rule!&I admit&it!")
ds_map_add(global.text_data_en, "obj_glydeb_168", "What&else do&you have&to say!?")
ds_map_add(global.text_data_en, "obj_glydeb_174", "...")
ds_map_add(global.text_data_en, "obj_glydeb_175", "Eh?&You&forgot&to clap.")
ds_map_add(global.text_data_en, "obj_glydeb_176", "HELLO??&I'M&RIGHT&HERE!!!")
ds_map_add(global.text_data_en, "obj_glydeb_181", "%%%")
ds_map_add(global.text_data_en, "obj_glydeb_414", "* Glyde does fancy flips.")
ds_map_add(global.text_data_en, "obj_glydeb_415", "* Glyde is giving itself a&  high five^1.&* ... somehow.")
ds_map_add(global.text_data_en, "obj_glydeb_416", "* Glyde sees its reflection &  and gets jealous.")
ds_map_add(global.text_data_en, "obj_glydeb_417", "* Glyde is thinking of new&  slang for the word " + '"' + "cool." + '"' + "&* Like " + '"' + "freakadacious." + '"')
ds_map_add(global.text_data_en, "obj_glydeb_418", "* An arrogant-smelling wind&  blows through.")
ds_map_add(global.text_data_en, "obj_glydeb_420", "* Glyde is doing tons of flips&  to get your attention.")
ds_map_add(global.text_data_en, "obj_glydeb_421", "* Glyde seems satisfied.")
ds_map_add(global.text_data_en, "obj_glydeb_422", "* Glyde is dying^1, but in a&  cool way.")
ds_map_add(global.text_data_en, "obj_glydeb_455", "* GLYDE - ATK HIGH DEF HIGH&* Refuses to give more details&  about its statistics./^")
ds_map_add(global.text_data_en, "obj_glydeb_466", "* You clap really sloppily^1.&* Glyde sucks up your praise&  like a vacuum cleaner./^")
ds_map_add(global.text_data_en, "obj_glydeb_471", "* You clap like a gorilla^1.&* Glyde is becoming addicted to&  your praise./^")
ds_map_add(global.text_data_en, "obj_glydeb_486", "* You boo..^1. but haters&  only make Glyde stronger^1.&* Glyde ATTACK UP+DEFENSE DOWN./^")
ds_map_add(global.text_data_en, "obj_glydeb_492", "* You boo loudly^1.&* Glyde leaves to look elsewhere&  for praise./^")
ds_map_add(global.text_data_en, "obj_glydeb_506", "* You do nothing^1.&* No effect./^")
ds_map_add(global.text_data_en, "obj_glydeb_511", "* You do nothing^1.&* Glyde leaves to look elsewhere&  for praise./^")
ds_map_add(global.text_data_en, "obj_glydeb_519", "* You do nothing^1.&* Glyde looks desperate for&  attention./^")
ds_map_add(global.text_data_en, "obj_glydeb_525", "* You do nothing^1.&* Glyde looks disappointed you&  aren't paying attention./^")
