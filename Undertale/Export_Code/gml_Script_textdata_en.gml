ds_map_add(global.text_data_en, "obj_dummymonster_394", "* Manekin wygląda^1,&  jakby miał&  się przewrócić.")
ds_map_add(global.text_data_en, "obj_dummymonster_395", "* Manekin stoi sobie&  bezmyślnie.")
ds_map_add(global.text_data_en, "obj_dummymonster_400", "* Manekin jest zmęczony&  twoimi bezcelowymi&  wybrykami")
ds_map_add(global.text_data_en, "obj_dummymonster_437", "* MANEKIN - ATK 0 DEF 0^1 &* Ma w środku bawełniane serc^1e&* Jesteś jabłkiem w mych oczach/%%")
ds_map_add(global.text_data_en, "obj_dummymonster_445", "* Rozmawiasz z MANEKINEM^2.&* .../")
ds_map_add(global.text_data_en, "obj_dummymonster_446", "* Nie wydaje się materiałem&  na konwersację./")
