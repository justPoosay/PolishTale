ds_map_add(global.text_data_en, "obj_smallfrog_66", "\W* (\YOSZCZĘDŹ \Wgo^1, człowieku.^1)&* Kum./%%")
ds_map_add(global.text_data_en, "obj_smallfrog_70", "* Kum^1, kum^1.&* (Przepraszam^1, człowieku.)/")
ds_map_add(global.text_data_en, "obj_smallfrog_71", "* (Mam pewną poradę&  dla ciebie o walkach z&  potworami.)/")
ds_map_add(global.text_data_en, "obj_smallfrog_72", "* (Potwory w tym świecie są&  bardzo niebezpieczne i&  agresywne.)/")
ds_map_add(global.text_data_en, "obj_smallfrog_73", "* (Tutaj^1, ucieczka&  nie zadziała za &  pierwszym razem.)/")
ds_map_add(global.text_data_en, "obj_smallfrog_74", "* (Być może inna opcja&  będzie lepsza dla ciebie.^1)&* Kum./%%")
