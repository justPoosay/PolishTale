ds_map_add(global.text_data_en, "obj_tordogcall_204", "* (...)/")
ds_map_add(global.text_data_en, "obj_tordogcall_205", "* (Chrap..^1. chrap...)/")
ds_map_add(global.text_data_en, "obj_tordogcall_206", "* (Ziew...)/")
ds_map_add(global.text_data_en, "obj_tordogcall_207", "* (Mrug mrug.)/")
ds_map_add(global.text_data_en, "obj_tordogcall_208", "* (Ziew...)/")
ds_map_add(global.text_data_en, "obj_tordogcall_209", "* (Chrap..^1. chrap...)/")
ds_map_add(global.text_data_en, "obj_tordogcall_210", "* (Słyszysz zmęczony głos.)\TT/")
ds_map_add(global.text_data_en, "obj_tordogcall_211", "* Piesku..^1.&* Chodź^1, piesku.../")
ds_map_add(global.text_data_en, "obj_tordogcall_212", "* Ojej.../")
ds_map_add(global.text_data_en, "obj_tordogcall_213", "* Zastanawiam się^1, gdzie&  on jest.../")
ds_map_add(global.text_data_en, "obj_tordogcall_214", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_tordogcall_215", "* Klik.../%%")
