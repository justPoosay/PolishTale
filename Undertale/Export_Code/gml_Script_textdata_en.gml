ds_map_add(global.text_data_en, "obj_papdate_382", "NIE..^1.&CZYŻBY???/")
ds_map_add(global.text_data_en, "obj_papdate_383", "\F0 \E1 %")
ds_map_add(global.text_data_en, "obj_papdate_386", "CZYŻBYŚ CHCIAŁ&ZE MNĄ RANDKOWAĆ&OD SAMEGO&POCZĄTKU!??/*")
ds_map_add(global.text_data_en, "obj_papdate_389", "CZYŻBYŚ CHCIAŁ&ZE MNĄ SIĘ SPOTKAĆ&OD SAMEGO&POCZĄTKU!??/*")
