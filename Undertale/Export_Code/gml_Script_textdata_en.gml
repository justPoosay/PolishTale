ds_map_add(global.text_data_en, "obj_smallfrog_118_console", "* (Wydaje się^1, że możesz je&  włączyć w zakładce " + '"' + "Ustawienia" + '"' + "&  zanim załadujesz grę.)/")
ds_map_add(global.text_data_en, "obj_smallfrog_119_console", "* (Jednak, nie ma&  żabiego bordera.)/")
