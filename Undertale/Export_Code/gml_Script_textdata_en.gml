ds_map_add(global.text_data_en, "mett_opera1_16", "So sad it's#happening.       ")
ds_map_add(global.text_data_en, "mett_opera2_1", "Oh my love")
ds_map_add(global.text_data_en, "mett_opera2_2", "Has fallen#down")
ds_map_add(global.text_data_en, "mett_opera2_3", "Now in tears")
ds_map_add(global.text_data_en, "mett_opera2_4", "We all will#drown")
ds_map_add(global.text_data_en, "mett_opera2_5", "Colored#tiles")
ds_map_add(global.text_data_en, "mett_opera2_6", "Make them#a fool")
ds_map_add(global.text_data_en, "mett_opera2_7", "If only they")
ds_map_add(global.text_data_en, "mett_opera2_8", "Still knew#the rules")
ds_map_add(global.text_data_en, "mett_opera2_9", "Well that#was")
ds_map_add(global.text_data_en, "mett_opera2_10", "A sorry try")
ds_map_add(global.text_data_en, "mett_opera2_11", "Now let's#watch")
ds_map_add(global.text_data_en, "mett_opera2_12", "Them fry")
ds_map_add(global.text_data_en, "mett_operacomment_1", "(Hmmm? Getting creative?)")
ds_map_add(global.text_data_en, "mett_operacomment_2", "(Dance with me, darling.)")
ds_map_add(global.text_data_en, "mett_operacomment_3", "(Oh! The audience can feel#your passion!)")
ds_map_add(global.text_data_en, "mett_operacomment_3_unfrantic", "(Show the audience#your passion!)")
ds_map_add(global.text_data_en, "mett_operacomment_3_touch", "(So close... How passionate...)")
ds_map_add(global.text_data_en, "mett_operacomment_3_frantic1", "(... do you need some help?)")
ds_map_add(global.text_data_en, "mett_operacomment_3_frantic2", "(... what ARE you doing?)")
ds_map_add(global.text_data_en, "mett_operacomment_4", "(Don't stop now!)")
ds_map_add(global.text_data_en, "mett_operacomment_4_unfrantic", "(Look at you, leaping around#the stage...)")
ds_map_add(global.text_data_en, "mett_operacomment_4_touch", "(Can't keep your hands off, huh?)")
ds_map_add(global.text_data_en, "mett_operacomment_4_frantic1", "(Is that how humans dance?)")
ds_map_add(global.text_data_en, "mett_operacomment_4_frantic2", "(Humans are stranger#than I thought.)")
ds_map_add(global.text_data_en, "mett_operacomment_5", "(Oh! They're really#getting into it.)")
ds_map_add(global.text_data_en, "mett_operacomment_5_unfrantic", "(Moving so far...)")
ds_map_add(global.text_data_en, "mett_operacomment_5_touch", "(Who can blame you?)")
ds_map_add(global.text_data_en, "mett_operacomment_5_frantic1", "(Hmmm, I'll have to get used#to it...)")
ds_map_add(global.text_data_en, "mett_operacomment_5_frantic2", "(Even better than#I thought...)")
ds_map_add(global.text_data_en, "mett_operacomment_6", "(So that's what#it's like.)")
ds_map_add(global.text_data_en, "mett_operacomment_7", "(Dancing with... A human.)")
ds_map_add(global.text_data_en, "mett_operacomment_8", "(What a shame...)")
