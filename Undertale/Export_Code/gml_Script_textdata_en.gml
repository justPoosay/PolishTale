ds_map_add(global.text_data_en, "item_desc_58_0", "* " + '"' + "Ziamniecane Cipsy" + '"' + " Leczy 13 HP&* Zwyczajne ziamniecane cipsy./%%")
ds_map_add(global.text_data_en, "item_desc_59_0", "* " + '"' + "ŚmiecioweJedzenie" + '"' + " Leczy 17 HP&* Jedzenie, które prawdopodobnie&  zostało kiedyś wyrzucone./%%")
ds_map_add(global.text_data_en, "item_desc_60_0", "* " + '"' + "Tajemniczy Klucz" + '"' + " Unikalne&* Jest zbyt wykrzywiony, by się&  zmieścił na twój breloczek./%%")
ds_map_add(global.text_data_en, "item_desc_61_0", "* " + '"' + "TwarzoStek" + '"' + " Leczy 60 HP&* Ogromny stek w kształcie&  Twarzy Mettatona./")
ds_map_add(global.text_data_en, "item_desc_61_1", "* (Masz wrażenie, że to nie&  jest z prawdziwego mięsa...)/%%")
ds_map_add(global.text_data_en, "item_desc_62_0", "* " + '"' + "Hush Puppy" + '"' + " Leczy 65 HP&* To wspaniałe zaklęcie zatrzyma&  psa od rzucania zaklęci./%%")
