ds_map_add(global.text_data_en, "scr_battlegroup_882", "* Knight Knight blokuje drogę!")
ds_map_add(global.text_data_en, "scr_battlegroup_896", "* Finalny Froggit cały czas&  tu stał^1, czekając na ciebie.")
ds_map_add(global.text_data_en, "scr_battlegroup_910", "* Astygmatyzm się zjawia.")
ds_map_add(global.text_data_en, "scr_battlegroup_924", "* Whimsalot wtrąca się!")
ds_map_add(global.text_data_en, "scr_battlegroup_938", "* Whimsalot i Finalny Froggit&  pojawiają się.")
ds_map_add(global.text_data_en, "scr_battlegroup_953", "* Whimsalot i Astygmatysm&  pojawiają się.")
ds_map_add(global.text_data_en, "scr_battlegroup_968", "* Finalny Froggit i Astygmatysm&  pojawiają się.")
ds_map_add(global.text_data_en, "scr_battlegroup_983", "* Co za koszmar!")
ds_map_add(global.text_data_en, "scr_battlegroup_999", "* Najemnicy wyłaniają się&  spod cienia.")
ds_map_add(global.text_data_en, "scr_battlegroup_1015", "* Rozbrój bombę!")
ds_map_add(global.text_data_en, "scr_battlegroup_1029", "* Rozbrój pieseła!")
ds_map_add(global.text_data_en, "scr_battlegroup_1049", "* Rozbrój niezwykle zwinną&  szklankę wody!")
ds_map_add(global.text_data_en, "scr_battlegroup_1068", "* Rozbrój skrypt!")
ds_map_add(global.text_data_en, "scr_battlegroup_1088", "* Rozbrój piłkę!")
ds_map_add(global.text_data_en, "scr_battlegroup_1107", "* Rozbrój prezent!")
ds_map_add(global.text_data_en, "scr_battlegroup_1126", "* Rozbrój grę!")
ds_map_add(global.text_data_en, "scr_battlegroup_1160", "* Tsunderplane atakuje!&* Nie dlatego że jest&  zazdrosny o Vulkina!")
ds_map_add(global.text_data_en, "scr_battlegroup_1176", "* Rzadki i groźny&  Podwójny Davis.")
ds_map_add(global.text_data_en, "scr_battlegroup_1191", "* Dziwna parada blokuje ścieżkę.")
ds_map_add(global.text_data_en, "scr_battlegroup_1221", "* Mettaton EX robi swój debiut!")
ds_map_add(global.text_data_en, "scr_battlegroup_1236", "* Pachnie jak słodkie cytryny.")
ds_map_add(global.text_data_en, "scr_battlegroup_1250", "* ,")
ds_map_add(global.text_data_en, "scr_battlegroup_1264", "* Jest mi tak zimno.")
ds_map_add(global.text_data_en, "scr_battlegroup_1278", "*        zbliżył się!")
ds_map_add(global.text_data_en, "scr_battlegroup_1294", "* To Amalgam.")
ds_map_add(global.text_data_en, "scr_battlegroup_1314", "* Zagubiona Dusza się pojawiła.")
ds_map_add(global.text_data_en, "scr_battlegroup_1334", "* Zagubione Dusze się pojawiły.")
ds_map_add(global.text_data_en, "scr_battlegroup_1395", "\R* W mojej drodze.")
ds_map_add(global.text_data_en, "scr_battlegroup_1410", "* Bohaterka się pojawia.")
ds_map_add(global.text_data_en, "scr_battlegroup_1422", "* Wełoły Manekin cię przepuszcza.")
ds_map_add(global.text_data_en, "scr_battlegroup_1439", "* Mettaton NEO blokuje drogę!")
ds_map_add(global.text_data_en, "scr_battlegroup_1484", "* ASGORE attacks!")
ds_map_add(global.text_data_en, "scr_battlegroup_1501", "* To nie wydaje się właściwe.")
ds_map_add(global.text_data_en, "scr_battlegroup_1517", "* Finalny Froggit przestał gonić&  Migospela.")
ds_map_add(global.text_data_en, "scr_battlegroup_1532", "* Parsnik wypełznął się z ziemi!")
ds_map_add(global.text_data_en, "scr_battlegroup_1547", "* Przewróciłeś się o jakieś&  Moldessy.")
ds_map_add(global.text_data_en, "scr_battlegroup_1563", "* Sznur Moldessów blokuje& ścieżkę.")
ds_map_add(global.text_data_en, "scr_battlegroup_1580", "* Wyobrażasz to sobie?")
ds_map_add(global.text_data_en, "scr_battlegroup_1595", "* Finalny Froggit przyskoczył&  obok...?")
ds_map_add(global.text_data_en, "scr_battlegroup_1609", "* Whimsalot i Parsnik&  zjawiają się.")
ds_map_add(global.text_data_en, "scr_battlegroup_1624", "* Migospel przyfruwa^1, nosząc&  Moldessę.")
ds_map_add(global.text_data_en, "scr_battlegroup_1639", "* Migospel przyfruwa^1, nosząc&  Parsnika.")
ds_map_add(global.text_data_en, "scr_battlegroup_1654", "* Parsniki wyłaniają się z&  ziemi!")
ds_map_add(global.text_data_en, "scr_battlegroup_1669", "* Nie tylko kartofle mają oczy.")
ds_map_add(global.text_data_en, "scr_battlegroup_1684", "* Oczy pojawiły się spod cienia.")
ds_map_add(global.text_data_en, "scr_battlegroup_1699", "* Wygląda na prawdziwą imprezę.")
ds_map_add(global.text_data_en, "scr_battlegroup_1716", "* Impreza z Piekła rodem.")
ds_map_add(global.text_data_en, "scr_battlegroup_1733", "* Glyde przytupnął obok!")
ds_map_add(global.text_data_en, "scr_battlegroup_1747", "* Jesteś grzecznie zablokowany!")
ds_map_add(global.text_data_en, "scr_battlegroup_1762", "* It's the end.")
ds_map_add(global.text_data_en, "scr_battlegroup_1787", "* ASRIEL blokuje drogę!")
ds_map_add(global.text_data_en, "scr_battlegroup_1789", "* DUSZA ASRIELa została&  przebudzona dzięki sile&  przyjaźni!")
ds_map_add(global.text_data_en, "scr_battlegroup_1791", "* Czas się pożegnać.")
ds_map_add(global.text_data_en, "obj_basicmonster_act", "* Potwór robi czynność.")
ds_map_add(global.text_data_en, "obj_basicmonster_info", "* Pachnie jak potwór.")
ds_map_add(global.text_data_en, "obj_basicmonster_mercy", "* Potwór wydaje się szczęśliwy.")
ds_map_add(global.text_data_en, "obj_basicmonster_lowhp", "* Monster has low HP.")
ds_map_add(global.text_data_en, "obj_basicmonster_check", "* POTWÓR - ATK \[1] DEF \[2]&* Błędnie wierzy, że jego lawa&  jest potworem./^")
ds_map_add(global.text_data_en, "obj_basicmonster_playeract", "* You execute some action./^")
ds_map_add(global.text_data_en, "obj_napstablook_189", "* WYGRAŁEĄ!&* Straciłeś 1 exp./%")
ds_map_add(global.text_data_en, "obj_torielboss_240", "* WYGRAŁEĄ!&* Straciłeś 1 exp./%")
ds_map_add(global.text_data_en, "SCR_TEXT_2510", "* You..^1.&* You came from outside^1,&  didn't you?/")
ds_map_add(global.text_data_en, "SCR_TEXT_2511", "* People like you are so&  rare.../")
ds_map_add(global.text_data_en, "SCR_TEXT_2512", "* Please^1!* Stranger!/")
ds_map_add(global.text_data_en, "SCR_TEXT_2513", "* Tell me about outside...?& &         Yes         No\C")
ds_map_add(global.text_data_en, "SCR_TEXT_2514", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2535", "* Huh^1?&* " + '"' + "SURFACE" + '"' + "^1?&* What do you mean?/")
ds_map_add(global.text_data_en, "SCR_TEXT_2536", "* I just meant outside this&  room./")
ds_map_add(global.text_data_en, "SCR_TEXT_2537", "* If you haven't noticed^1, my&  mycelium have bound me&  to the ground./")
ds_map_add(global.text_data_en, "SCR_TEXT_2538", "* Please^1!&* Stranger!/")
ds_map_add(global.text_data_en, "SCR_TEXT_2539", "* I'll make this simple./")
ds_map_add(global.text_data_en, "SCR_TEXT_2540", "* I've spent my whole life&  in the same spot^1,&  in the same room./")
ds_map_add(global.text_data_en, "SCR_TEXT_2541", "* But I've long wondered&  what lies inside the&  room to the right./")
ds_map_add(global.text_data_en, "SCR_TEXT_2542", "* Long I've fantasized&  about entering^1, and&  changing my scenery.../")
ds_map_add(global.text_data_en, "SCR_TEXT_2543", "* No..^1.&* Changing my LIFE!/")
ds_map_add(global.text_data_en, "SCR_TEXT_2544", "* Please^1.&* Go and tell me what's&  inside./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2553", "* Is everyone out there&  like you^1?&* How terrible./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2518", "* Well^1, what are you&  waiting for?/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2522", "* Oh^1!&* You're back!/")
ds_map_add(global.text_data_en, "SCR_TEXT_2523", "* How's the room?& &         Different   Same\C")
ds_map_add(global.text_data_en, "SCR_TEXT_2524", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2561", "* Oh^1, that's a relief^1!/")
ds_map_add(global.text_data_en, "SCR_TEXT_2562", "* That's all I need to&  continue my fantasies^1.&* Thank you^1, stranger./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2506", "* My mind is running wild^1!&* I haven't felt like this&  in a long time.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2567", "* So it's the same./")
ds_map_add(global.text_data_en, "SCR_TEXT_2568", "* The same.../")
ds_map_add(global.text_data_en, "SCR_TEXT_2569", "* Same.../")
ds_map_add(global.text_data_en, "SCR_TEXT_2570", "* .../")
ds_map_add(global.text_data_en, "SCR_TEXT_2571", "* OK./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2507", "* Please leave./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2780", "* (It's a horse stable.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_2781", "* (Do you want to go&  inside?)&         Yes         No \C")
ds_map_add(global.text_data_en, "SCR_TEXT_2782", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2788", "* (You jostle the door.)&* (It's locked.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_2789", "* (Suddenly^1, from inside&  the [redacted], you hear a&/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3358", "* (It's a book labelled&  Monster History Part 6.)&         Read it     Do not\C")
ds_map_add(global.text_data_en, "SCR_TEXT_3359", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_3363", "* Unfortunately^1, monsters are&  not experienced with&  illness./")
ds_map_add(global.text_data_en, "SCR_TEXT_3364", "* However^1, when monsters are&  about to expire of age^1,&  they lie down^1, immobile./")
ds_map_add(global.text_data_en, "SCR_TEXT_3365", "* We call this state&  " + '"' + "Fallen Down." + '"' + "/")
ds_map_add(global.text_data_en, "SCR_TEXT_3366", "* A person who has Fallen&  Down will soon perish./")
ds_map_add(global.text_data_en, "SCR_TEXT_3367", "* In a way^1, this confusing&  situation was all too&  familiar./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3370", "* (Postanawiasz nie czytać.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4551", "* \YMETTATON has sent you a&  Mortal Enemy request.\W /")
ds_map_add(global.text_data_en, "SCR_TEXT_4552", "* Zaakceptować prośbę?& &         Akceptuj    Odrzuć\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4553", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4559", "* Congratulations^1!&* You are now Mortal Enemies&  with Mettaton./")
ds_map_add(global.text_data_en, "SCR_TEXT_4560", "* \YCOOLSKELETON95\W has posted&  a comment on this change./")
ds_map_add(global.text_data_en, "SCR_TEXT_4561", "* CONGRATULATIONS^1, YOU TWO^1!&* WISH YOU A LONG AND&  HORRIBLE RIVALRY./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4565", "* You rejected the request./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4571", "* \YMETTATON has sent you an&  invitation to " + '"' + "Die." + '"' + "\W /")
ds_map_add(global.text_data_en, "SCR_TEXT_4572", "* RSVP?& &         Respond     Ignore\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4573", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4579", "* Bepis valley Granola Bars/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4583", "* Bepis valley Granola Bars/%%")
