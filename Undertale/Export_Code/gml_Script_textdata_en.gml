ds_map_add(global.text_data_en, "obj_truechara_94", "Witaj./")
ds_map_add(global.text_data_en, "obj_truechara_95", "Ja^2 jestem \[C]./%%")
ds_map_add(global.text_data_en, "obj_truechara_111", "Dziękuję./")
ds_map_add(global.text_data_en, "obj_truechara_112", "Twoja moc przebudziła&mnie ze śmierci./")
ds_map_add(global.text_data_en, "obj_truechara_113", "Moja " + '"' + "ludzka dusza." + '"' + "/")
ds_map_add(global.text_data_en, "obj_truechara_114", "Moja " + '"' + "determinacja." + '"' + "/")
ds_map_add(global.text_data_en, "obj_truechara_115", "One nie były moje^1,&ale TWOJE./")
ds_map_add(global.text_data_en, "obj_truechara_116", "Na początku^1, byłam&taka zdziwiona./")
ds_map_add(global.text_data_en, "obj_truechara_117", "Nasz plan się nie&powiódł^1, czyż nie?/")
ds_map_add(global.text_data_en, "obj_truechara_118", "Dlaczego zostałam&przywrócona do życia?/")
ds_map_add(global.text_data_en, "obj_truechara_119", ".../")
ds_map_add(global.text_data_en, "obj_truechara_120", "Ty./")
ds_map_add(global.text_data_en, "obj_truechara_121", "Dzięki twojej pomocy./")
ds_map_add(global.text_data_en, "obj_truechara_122", "Uświadomiłam sobie&cel mojej reinkarnacji./")
ds_map_add(global.text_data_en, "obj_truechara_123", "Władza./")
ds_map_add(global.text_data_en, "obj_truechara_124", "Wspólnie^1, wyeliminowaliśmy&wroga i staliśmy się silni./")
ds_map_add(global.text_data_en, "obj_truechara_125", "HP. ATK. DEF.&GOLD. EXP. LV./")
ds_map_add(global.text_data_en, "obj_truechara_126", "Z każdym przyrostem&tych liczb^1, pojawiało&się to uczucie.../")
ds_map_add(global.text_data_en, "obj_truechara_127", "To byłam ja./")
ds_map_add(global.text_data_en, "obj_truechara_128", '"' + "\[C]." + '"' + "/")
ds_map_add(global.text_data_en, "obj_truechara_129", "Teraz./")
ds_map_add(global.text_data_en, "obj_truechara_130", "Teraz, osiągnęliśmy&absolut./")
ds_map_add(global.text_data_en, "obj_truechara_131", "Nie pozostało&już nam nic./")
ds_map_add(global.text_data_en, "obj_truechara_132", "Pozbądźmy się tego&daremnego świata^1, i&przejdźmy do następnego./%%")
ds_map_add(global.text_data_en, "obj_truechara_136", '"' + "\[C]." + '"' + "/")
ds_map_add(global.text_data_en, "obj_truechara_137", "Demon, który przychodzi^1,&gdy ludzie wywołują&jego imię./")
ds_map_add(global.text_data_en, "obj_truechara_138", "Nie ma znaczenia kiedy./")
ds_map_add(global.text_data_en, "obj_truechara_139", "Nie ma znaczenia gdzie./")
ds_map_add(global.text_data_en, "obj_truechara_140", "Raz po razie,&ja się objawię./")
ds_map_add(global.text_data_en, "obj_truechara_141", "I, z twoją pomocą./")
ds_map_add(global.text_data_en, "obj_truechara_142", "Wyeliminujemy&wroga i staniemy&się silni./")
ds_map_add(global.text_data_en, "obj_truechara_143", "HP. ATK. DEF.&GOLD. EXP. LV./")
ds_map_add(global.text_data_en, "obj_truechara_144", "Z każdym przyrostem&tych liczb^1, pojawiało&się to uczucie.../")
ds_map_add(global.text_data_en, "obj_truechara_145", "To byłam ja./")
ds_map_add(global.text_data_en, "obj_truechara_146", '"' + "\[C]." + '"' + "/")
ds_map_add(global.text_data_en, "obj_truechara_147", ".../")
ds_map_add(global.text_data_en, "obj_truechara_148", "Ale./")
ds_map_add(global.text_data_en, "obj_truechara_149", "Ty i ja nie jesteśmy&tacy sami^1, czyż nie?/")
ds_map_add(global.text_data_en, "obj_truechara_150", "Ta DUSZA rezonuje&dziwnym uczuciem./")
ds_map_add(global.text_data_en, "obj_truechara_151", "Jest powód^1, dla&którego kontynuujesz&re-kreację tego świata./")
ds_map_add(global.text_data_en, "obj_truechara_152", "Jest powód^1, dla&którego kontynuujesz&jego destrukcję./")
ds_map_add(global.text_data_en, "obj_truechara_153", "Ty./")
ds_map_add(global.text_data_en, "obj_truechara_154", "Jesteś wypełniony&mocno zboczonym&sentymentalizmem./")
ds_map_add(global.text_data_en, "obj_truechara_155", "Hmm^1./")
ds_map_add(global.text_data_en, "obj_truechara_156", "Ja już nie jestem&w stanie zrozumieć&tych uczuć./")
ds_map_add(global.text_data_en, "obj_truechara_157", "Pomimo tego./")
ds_map_add(global.text_data_en, "obj_truechara_158", "Czuję się zobligowana&by zaproponować./")
ds_map_add(global.text_data_en, "obj_truechara_159", "Abyś postanowił&stworzyć ten świat&raz jeszcze./")
ds_map_add(global.text_data_en, "obj_truechara_160", "Inna ścieżka byłaby&lepiej dopasowana./")
ds_map_add(global.text_data_en, "obj_truechara_161", "Teraz, partnerze./")
ds_map_add(global.text_data_en, "obj_truechara_162", "Pozwólmy, że wyślemy&ten świat z powrotem&do otchłani./%%")
ds_map_add(global.text_data_en, "obj_truechara_186", "Racja^1. Jesteś&świetnym partnerem./")
ds_map_add(global.text_data_en, "obj_truechara_187", "Będziemy razem&do końca^1, prawda?/%%")
ds_map_add(global.text_data_en, "obj_truechara_209", "Nie...?/")
ds_map_add(global.text_data_en, "obj_truechara_210", "Hmm..^1./")
ds_map_add(global.text_data_en, "obj_truechara_211", "Jak ciekawe./")
ds_map_add(global.text_data_en, "obj_truechara_212", "Musiałeś źle&zrozumieć./")
ds_map_add(global.text_data_en, "obj_truechara_213", "OD KIEDY TO TY&MIAŁEŚ KONTROLĘ?/%%")
ds_map_add(global.text_data_en, "obj_truechara_217", "Nie...?/")
ds_map_add(global.text_data_en, "obj_truechara_218", "Hmm...&To uczucie^1, które&teraz nosisz./")
ds_map_add(global.text_data_en, "obj_truechara_219", "O tym właśnie&mówiłam./")
ds_map_add(global.text_data_en, "obj_truechara_220", "Niestety,&jak się okazuje.../")
ds_map_add(global.text_data_en, "obj_truechara_221", "PODJĄŁEŚ SWOJĄ&DECYZJĘ DAWNO TEMU./%%")
ds_map_add(global.text_data_en, "obj_tsunderplane_235", "To nie tak&że cię&LUBIĘ.")
ds_map_add(global.text_data_en, "obj_tsunderplane_236", "Id...&Idiota!")
ds_map_add(global.text_data_en, "obj_tsunderplane_237", "Hmph!&Don't&get in&my way.")
ds_map_add(global.text_data_en, "obj_tsunderplane_238", ">_<...&Human&...")
ds_map_add(global.text_data_en, "obj_tsunderplane_242", "...&H-human&...&...?")
ds_map_add(global.text_data_en, "obj_tsunderplane_243", "Id...&Idiota!")
ds_map_add(global.text_data_en, "obj_tsunderplane_250", "Eeeeh?&H-human&...?")
ds_map_add(global.text_data_en, "obj_tsunderplane_251", "Human,&I...")
ds_map_add(global.text_data_en, "obj_tsunderplane_256", "Huh!?&Y-you&sicko!")
ds_map_add(global.text_data_en, "obj_tsunderplane_257", "Ah...&Is that&true...?")
ds_map_add(global.text_data_en, "obj_tsunderplane_262", "No way!&Why&would I&like YOU")
ds_map_add(global.text_data_en, "obj_tsunderplane_263", "Human,&I...")
ds_map_add(global.text_data_en, "obj_tsunderplane_266", "%%%")
ds_map_add(global.text_data_en, "obj_tsunderplane_465", "* Tsunderplane looks over^1,&  then turns up its nose.")
ds_map_add(global.text_data_en, "obj_tsunderplane_466", "* Tsunderplane shakes its&  nose dimissively at you.")
ds_map_add(global.text_data_en, "obj_tsunderplane_467", "* Tsunderplane " + '"' + "accidentally" + '"' + "&  bumps you with its wing.")
ds_map_add(global.text_data_en, "obj_tsunderplane_468", "* Tsunderplane gives you a&  condescending barrel roll.")
ds_map_add(global.text_data_en, "obj_tsunderplane_469", "* Smells like an airport&  perfume counter.")
ds_map_add(global.text_data_en, "obj_tsunderplane_470", "* Tsunderplane is looking away&  shyly.")
ds_map_add(global.text_data_en, "obj_tsunderplane_471", "* Tsunderplane's body is smoking.")
ds_map_add(global.text_data_en, "obj_tsunderplane_490", "* TSUNDERPLANE - ATK 25 DEF 26&* Seems mean^1, but does&  it secretly like you?/^")
ds_map_add(global.text_data_en, "obj_tsunderplane_499", "* You tell Tsunderplane it has&  an impressive wingspan./^")
ds_map_add(global.text_data_en, "obj_tsunderplane_501", "* You tell Tsunderplane it has&  an impressive wingspan./^")
ds_map_add(global.text_data_en, "obj_tsunderplane_502", "* You tell Tsunderplane it has&  nice turbines./^")
ds_map_add(global.text_data_en, "obj_tsunderplane_503", "* You tell Tsunderplane it has&  a powerful rudder./^")
ds_map_add(global.text_data_en, "obj_tsunderplane_504", "* You tell Tsunderplane that&  you like its taste in&  movies and books./^")
ds_map_add(global.text_data_en, "obj_tsunderplane_505", "* You tell Tsunderplane that&  it has cute winglets./^")
ds_map_add(global.text_data_en, "obj_tsunderplane_515", "* You get close to Tsunderplane^1.&* But not too close./^")
ds_map_add(global.text_data_en, "obj_tsunderplanenpc_75", "* Hey^1!&* Watch where you stand^1,&  jerk!/")
ds_map_add(global.text_data_en, "obj_tsunderplanenpc_76", "* Th-though^1, I guess if&  there's nowhere else^1, you&  can stand closer.../%%")
ds_map_add(global.text_data_en, "obj_tsunderplanenpc_79", "* Standing so spicey./%%")
ds_map_add(global.text_data_en, "obj_tsunderplanenpc_83", "* A-ah..^1. H-human..^1.&* You're leaving?/")
ds_map_add(global.text_data_en, "obj_tsunderplanenpc_84", "* I have..^1.&* Something to say to you./")
ds_map_add(global.text_data_en, "obj_tsunderplanenpc_85", "* Admittedly^1, I may have had&  limerent feelings for you&  before./")
ds_map_add(global.text_data_en, "obj_tsunderplanenpc_86", "* However^1, upon examining my&  own actions^1, I now&  realize.../")
ds_map_add(global.text_data_en, "obj_tsunderplanenpc_87", "* I did not love YOU./")
ds_map_add(global.text_data_en, "obj_tsunderplanenpc_88", "* I was merely infatuated&  with the CONCEPT of love./")
ds_map_add(global.text_data_en, "obj_tsunderplanenpc_89", "* The idea of romance^1, the&  concept of sharing affection&  with another.../")
ds_map_add(global.text_data_en, "obj_tsunderplanenpc_90", "* Through these desires^1, I&  built a false concept of&  you in my head./")
ds_map_add(global.text_data_en, "obj_tsunderplanenpc_91", "* Such a relationship would&  not have ended well./")
ds_map_add(global.text_data_en, "obj_tsunderplanenpc_92", "* In closing^1, I believe it&  is better that I chose to&  say nothing./")
ds_map_add(global.text_data_en, "obj_tsunderplanenpc_93", "* Y..^1. y-you i-idiot./%%")
ds_map_add(global.text_data_en, "obj_tsunderplanenpc_96", "* I'm not saying it again./%%")
ds_map_add(global.text_data_en, "obj_tsunderplanenpc_103", "* H-hey^1, why do you keep&  following me!!!&* You jerk!!!/")
ds_map_add(global.text_data_en, "obj_tsunderplanenpc_104", "* Eeeeh^1?&* You're walking in the&  opposite direction...?/")
ds_map_add(global.text_data_en, "obj_tsunderplanenpc_105", "* H-hey^1, you think you're too&  good for me^1, huh...?/%%")
ds_map_add(global.text_data_en, "obj_tsunderplanenpc_107", "* N-not spicey enough for you^1,&  h-huh.../%%")
ds_map_add(global.text_data_en, "obj_tsunderplanenpc_111", "* I..^1. I'm thinking of going&  to the surface.../")
ds_map_add(global.text_data_en, "obj_tsunderplanenpc_112", "* Eeeeeh^1?&* You're going to go there&  too?/")
ds_map_add(global.text_data_en, "obj_tsunderplanenpc_113", "* Idiot..^1.&* Quit following me!/%%")
ds_map_add(global.text_data_en, "obj_umbrellabox_62", "* NO!/%%")
ds_map_add(global.text_data_en, "obj_umbrellabox_135", "* (The cavern is too narrow&  for an umbrella.)/%%")
ds_map_add(global.text_data_en, "obj_undyne1_154", "\TP %")
ds_map_add(global.text_data_en, "obj_undyne1_155", "\M5H..^1. HEJ^1, UNDYNE!&PRZYBYWAM Z MOIM&DZIENNYM RAPORTEM.../")
ds_map_add(global.text_data_en, "obj_undyne1_156", "UHHH..^1. DOTYCZĄCYM&TEGO CZŁOWIEKA O KTÓRYM&WSPOMNIAŁEM WCZEŚNIEJ.../")
ds_map_add(global.text_data_en, "obj_undyne1_157", "\M0MYŚLĘ^1, ŻE..^1.&UH..^1.&JAKBY TO.../")
ds_map_add(global.text_data_en, "obj_undyne1_158", "\M1.\M6.. HUH^1?&CZY Z NIM WALCZYŁEM?/")
ds_map_add(global.text_data_en, "obj_undyne1_159", "\M4T-TAK^1!&OCZYWIŚCIE, ŻE&WALCZYŁEM!/")
ds_map_add(global.text_data_en, "obj_undyne1_160", "\M4WALCZYŁEM&BEZLITOŚNIE!/")
ds_map_add(global.text_data_en, "obj_undyne1_161", "\M5...CO^1?\M1 &CZY GO PORWAŁEM...?/")
ds_map_add(global.text_data_en, "obj_undyne1_162", "\M0C-C-CÓŻ.../")
ds_map_add(global.text_data_en, "obj_undyne1_163", "\M1NIE./")
ds_map_add(global.text_data_en, "obj_undyne1_164", "\M1TAK BARDZO PRÓBO-&WAŁEM^1, UNDYNE^1, ALE&OSTATECZNIE.../")
ds_map_add(global.text_data_en, "obj_undyne1_165", "\M0ZAWIODŁEM./")
ds_map_add(global.text_data_en, "obj_undyne1_166", "\M6... C-CO?/")
ds_map_add(global.text_data_en, "obj_undyne1_167", "\M1ODBIERZESZ DUSZĘ&CZŁOWIEKA SAMEMU.../")
ds_map_add(global.text_data_en, "obj_undyne1_168", "\M5ALE UNDYNE^1, NIE MUSISZ&I-ICH WCALE NISZCZYĆ^1!&\M0WIDZISZ.../")
ds_map_add(global.text_data_en, "obj_undyne1_169", "\M1WIDZISZ.../%%")
ds_map_add(global.text_data_en, "obj_undyne1_170", "\M6..^1.&.../")
ds_map_add(global.text_data_en, "obj_undyne1_171", "... ROZUMIEM./")
ds_map_add(global.text_data_en, "obj_undyne1_172", "POMOGĘ CI W KAŻDY&SPOSÓB^1, JAKI MOGĘ./")
ds_map_add(global.text_data_en, "obj_undyne1_173", "\TS %")
ds_map_add(global.text_data_en, "obj_undyne1_174", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_undyne1_217", "\M0.../")
ds_map_add(global.text_data_en, "obj_undyne1_218", "\M1... ROZUMIEM./")
ds_map_add(global.text_data_en, "obj_undyne1_219", "POMOGĘ CI W KAŻDY&SPOSÓB^1, JAKI MOGĘ./%%")
ds_map_add(global.text_data_en, "obj_undyne1_537", "* Jo..^1. widziałeś^1, jak&  się na ciebie&  patrzyła...?/")
ds_map_add(global.text_data_en, "obj_undyne1_538", "* To.../")
ds_map_add(global.text_data_en, "obj_undyne1_539", "* ... było NIESAMOWITE!/")
ds_map_add(global.text_data_en, "obj_undyne1_540", "* Jestem TAAAAAKI zazdrosny!/")
ds_map_add(global.text_data_en, "obj_undyne1_541", "* Coś ty zrobił^1, że&  zyskałeś jej uwagę...^1?&* Ha ha./")
ds_map_add(global.text_data_en, "obj_undyne1_542", "* No chodź^1!&* Chodźmy popatrzeć jak&  trzepie innym tyłki!/%%")
ds_map_add(global.text_data_en, "obj_undyne1_546", "* Jo..^1. widziałeś^1, jak&  się na ciebie&  patrzyła...?/")
ds_map_add(global.text_data_en, "obj_undyne1_547", "* To.../")
ds_map_add(global.text_data_en, "obj_undyne1_548", "* ... było NIESAMOWITE!/")
ds_map_add(global.text_data_en, "obj_undyne1_549", "* Jestem TAAAAAKI zazdrosny!/")
ds_map_add(global.text_data_en, "obj_undyne1_550", "* Ona po prostu tam stała&  i czekała przez WIEKI^1, i&  wtedy ty po prostu...!!!/")
ds_map_add(global.text_data_en, "obj_undyne1_551", "* No chodź^1!&* Chodźmy popatrzeć jak&  trzepie innym tyłki!/%%")
ds_map_add(global.text_data_en, "obj_undyne_echoflower_96", "* Za tobą./%%")
ds_map_add(global.text_data_en, "obj_undyne_echoflower_102", "* Nie powiesz o tym&  moim rodzicom^1, prawda?/%%")
ds_map_add(global.text_data_en, "obj_undyne_echoflower_299", "* Undyne!!^1!&* Pomogę ci w walce!!!/%%")
ds_map_add(global.text_data_en, "obj_undyne_echoflower_348", "* JO!!!!/")
ds_map_add(global.text_data_en, "obj_undyne_echoflower_349", "* Zrobiłeś to!!^1!&* Undyne jest TUŻ&  przed tobą!!!/")
ds_map_add(global.text_data_en, "obj_undyne_echoflower_350", "* Teraz masz przednie&  miejsce na oglądanie&  jej walki!!!/%%")
ds_map_add(global.text_data_en, "obj_undyne_echoflower_388", "* ... chwila./")
ds_map_add(global.text_data_en, "obj_undyne_echoflower_389", "* Z kim ona walczy???/%%")
ds_map_add(global.text_data_en, "obj_undyne_echoflower_419", "* H^1-hej!/")
ds_map_add(global.text_data_en, "obj_undyne_echoflower_420", "* Nie powiesz o tym&  moim rodzicom^1, prawda?/%%")
ds_map_add(global.text_data_en, "obj_undyne_ex_781", "* Wiatr głośno wyje...")
ds_map_add(global.text_data_en, "obj_undyne_ex_808", "* UNDYNE THE UNDYING 99ATK 99DE^1F&* Pionierka zreformowana własną&  determinacją, by ocalić Ziemię./^")
ds_map_add(global.text_data_en, "obj_undyne_ex_863", "Cholera.../")
ds_map_add(global.text_data_en, "obj_undyne_ex_864", "Więc nawet&TA moc..^1.&Nie wystarczyła...?/")
ds_map_add(global.text_data_en, "obj_undyne_ex_865", ".../")
ds_map_add(global.text_data_en, "obj_undyne_ex_866", "\E1Heh... /")
ds_map_add(global.text_data_en, "obj_undyne_ex_867", "Heheheh... /")
ds_map_add(global.text_data_en, "obj_undyne_ex_868", "\E2Jeśli ty..^1./")
ds_map_add(global.text_data_en, "obj_undyne_ex_869", "Jeśli myślisz^1, że&porzucę nadzieje^1,&mylisz się./")
ds_map_add(global.text_data_en, "obj_undyne_ex_870", "Bo ja..^1.&Mam moich przyjaciół&za moimi plecami./")
ds_map_add(global.text_data_en, "obj_undyne_ex_871", "\E3Alphys powiedziała&że będzie oglądać&moją walkę.../")
ds_map_add(global.text_data_en, "obj_undyne_ex_872", "\E4I że jeśli cokolwiek&pójdzie źle^1, to ona..^1.&zewakuuje wszystkich./")
ds_map_add(global.text_data_en, "obj_undyne_ex_873", "\E5Do tego czasu zadzwo&niła już do ASGORE'a&by pochłonął jego 6&ludzkich dusz./%%")
ds_map_add(global.text_data_en, "obj_undyne_ex_881", "I z tą&mocą.../%%")
ds_map_add(global.text_data_en, "obj_undyne_ex_893", "Świat będzie&żyć dalej...!/%%")
ds_map_add(global.text_data_en, "obj_undyne_friendc_76", "* Hej^1, smarkaczu^1!&* Co tam!?/")
ds_map_add(global.text_data_en, "obj_undyne_friendc_77", "\E1* A-ACHOO!/")
ds_map_add(global.text_data_en, "obj_undyne_friendc_78", "\E2* Papyrus^1, how can you&  stand this cold?/")
ds_map_add(global.text_data_en, "obj_undyne_friendc_80", "I HAVE NO SKIN./")
ds_map_add(global.text_data_en, "obj_undyne_friendc_82", "* So why don't we&  stand in Grillby's&  instead?/")
ds_map_add(global.text_data_en, "obj_undyne_friendc_84", "BECAUSE I HATE&GREASE./")
ds_map_add(global.text_data_en, "obj_undyne_friendc_86", "* But you don't have&  a stomach!!/")
ds_map_add(global.text_data_en, "obj_undyne_friendc_88", "NO^1, BUT I HAVE&STANDARDS!!!/%%")
ds_map_add(global.text_data_en, "obj_undyne_friendc_92", "* Papyrus.../")
ds_map_add(global.text_data_en, "obj_undyne_friendc_93", "\E1* Why do you live&  in an icy wasteland?/")
ds_map_add(global.text_data_en, "obj_undyne_friendc_95", "THE RENT'S CHEAP./")
ds_map_add(global.text_data_en, "obj_undyne_friendc_97", "* Really^1?&* Don't you live in&  a huge house?/")
ds_map_add(global.text_data_en, "obj_undyne_friendc_99", "YEAH^1, BUT MY&BROTHER PAYS&FOR IT./")
ds_map_add(global.text_data_en, "obj_undyne_friendc_101", "* Where's your brother&  get the money to&  pay for it...?/")
ds_map_add(global.text_data_en, "obj_undyne_friendc_103", "OH^1, THAT'S SIMPLE./")
ds_map_add(global.text_data_en, "obj_undyne_friendc_104", "\E0IT'S A MYSTERY./%%")
ds_map_add(global.text_data_en, "obj_undyne_friendc_112", "* So^1? What are you&  waiting for?/")
ds_map_add(global.text_data_en, "obj_undyne_friendc_113", "* The sooner you get&  it over with^1, the&  better!/%%")
ds_map_add(global.text_data_en, "obj_undyne_friendc_121", "* Hey^1, you sure&  are carrying a&  lot of things./")
ds_map_add(global.text_data_en, "obj_undyne_friendc_122", "* If someone needed&  to give you a thing^1,&  they sure couldn't!/%%")
ds_map_add(global.text_data_en, "obj_undyne_friendc_127", "* What^1?&* You LOST the letter!?/")
ds_map_add(global.text_data_en, "obj_undyne_friendc_128", "* What the HECK!^1?&* How!^1? Why!?/")
ds_map_add(global.text_data_en, "obj_undyne_friendc_129", "\E7* Ughhh..^1.&* This is unbelievable./")
ds_map_add(global.text_data_en, "obj_undyne_friendc_130", "* I should be really&  disappointed in you./")
ds_map_add(global.text_data_en, "obj_undyne_friendc_131", "\E9* But^1, uh^1, to tell&  you the truth^1, I'm&  kind of relieved!/")
ds_map_add(global.text_data_en, "obj_undyne_friendc_132", "\E1* While you were gone^1,&  I actually wrote&  a WAY BETTER letter!/")
ds_map_add(global.text_data_en, "obj_undyne_friendc_133", "\E6* And this time^1, you&  WON'T lose it!!!/")
ds_map_add(global.text_data_en, "obj_undyne_friendc_134", "\E2* I guarantee it!!!/")
ds_map_add(global.text_data_en, "obj_undyne_friendc_135", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_undyne_friendc_136", "* (You got the Undyne Letter&  EX.)/%%")
ds_map_add(global.text_data_en, "obj_undyne_friendc_149", "* Hey^1, I have something&  to give you.../")
ds_map_add(global.text_data_en, "obj_undyne_friendc_150", "\E2* But you're carrying&  way too much!!!/%%")
ds_map_add(global.text_data_en, "obj_undyne_friendc_155", "* Um^1, so^1, I have a&  favor to ask you./")
ds_map_add(global.text_data_en, "obj_undyne_friendc_156", "\E0* Uuuuh^1, I..^1.&* I need you to deliver&  this letter./")
ds_map_add(global.text_data_en, "obj_undyne_friendc_157", "\E9* To Dr. Alphys./")
ds_map_add(global.text_data_en, "obj_undyne_friendc_158", "\E1* Huh!^1?&* Why don't I do it&  myself...?/")
ds_map_add(global.text_data_en, "obj_undyne_friendc_159", "\E8* ... um^1.&* W-well.../")
ds_map_add(global.text_data_en, "obj_undyne_friendc_160", "\E9* I-it's kind of&  personal^1, but we're&  friends..^1. so.../")
ds_map_add(global.text_data_en, "obj_undyne_friendc_161", "\E8* I'll t-tell you.../")
ds_map_add(global.text_data_en, "obj_undyne_friendc_162", "\E6* Hotland SUUUUCKS!!^1!&* I don't wanna have&  to go over there!!!/")
ds_map_add(global.text_data_en, "obj_undyne_friendc_163", "\E3* So here you go./")
ds_map_add(global.text_data_en, "obj_undyne_friendc_164", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_undyne_friendc_165", "* (You got the Undyne's Letter.)/")
ds_map_add(global.text_data_en, "obj_undyne_friendc_167", "* Oh^1, and if you&  read it.../")
ds_map_add(global.text_data_en, "obj_undyne_friendc_168", "\E2* I'll KILL you./")
ds_map_add(global.text_data_en, "obj_undyne_friendc_169", "\E9* Thanks so much^1!&* You're the best!!/%%")
ds_map_add(global.text_data_en, "obj_undyne_friendc_187", "* Hey^1, Alphys^1!&* Alphys!/")
ds_map_add(global.text_data_en, "obj_undyne_friendc_188", "\E1* Do you think we&  can watch something&  with fighting next?/")
ds_map_add(global.text_data_en, "obj_undyne_friendc_189", "\E9* Oh^1, and then...&* Something..^1.&* With princesses!?/")
ds_map_add(global.text_data_en, "obj_undyne_friendc_190", "\E2* Or FIGHTING&  princesses!?/")
ds_map_add(global.text_data_en, "obj_undyne_friendc_192", "\E5* I-I'll see if I&  can manage to find&  any like that^1, Undyne./")
ds_map_add(global.text_data_en, "obj_undyne_friendc_194", "\E6* Yayyyyy!/%%")
ds_map_add(global.text_data_en, "obj_undyne_friendc_199", "\E0* Hey Frisk^1, why don't&  you go say hi to&  Napstablook?/")
ds_map_add(global.text_data_en, "obj_undyne_friendc_200", "\E1* Oh^1, tell them I&  said hi^1, too!/%%")
ds_map_add(global.text_data_en, "obj_undyne_lettercall_113", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_undyne_lettercall_115", "\E0* Hey...^1!&* Uh^1, this is&  Undyne.../")
ds_map_add(global.text_data_en, "obj_undyne_lettercall_116", "\E2* (Shut up^1, Papyrus^1!)&* (This was YOUR idea!)/")
ds_map_add(global.text_data_en, "obj_undyne_lettercall_117", "\E1* HUMAN^1!&* You have to deliver&  something for me!/")
ds_map_add(global.text_data_en, "obj_undyne_lettercall_118", "\E9* Uh^1, please?/")
ds_map_add(global.text_data_en, "obj_undyne_lettercall_119", "\E0* I'm at Snowdin&  in front of&  Papyrus's./")
ds_map_add(global.text_data_en, "obj_undyne_lettercall_120", "\E6* See ya^1, punk!/")
ds_map_add(global.text_data_en, "obj_undyne_lettercall_121", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_undyne_lettercall_122", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_undynebattle2_275", "...")
ds_map_add(global.text_data_en, "obj_undynebattle2_278", "Show me what&you've got!")
ds_map_add(global.text_data_en, "obj_undynebattle2_282", "Do your worst!")
ds_map_add(global.text_data_en, "obj_undynebattle2_286", "What's the&matter, scared?")
ds_map_add(global.text_data_en, "obj_undynebattle2_290", "\E6What the hell&is the holdup?")
ds_map_add(global.text_data_en, "obj_undynebattle2_293", "COME ON ALREADY!")
ds_map_add(global.text_data_en, "obj_undynebattle2_295", "IT'S GETTING&HOT IN HERE!")
ds_map_add(global.text_data_en, "obj_undynebattle2_299", "%%%")
ds_map_add(global.text_data_en, "obj_undynebattle2_488", "* Undyne is letting you make&  the first attack.")
ds_map_add(global.text_data_en, "obj_undynebattle2_520", "* UNDYNE - ATK 41 DEF 21&* This time^1, don't hold&  anything back!/^")
ds_map_add(global.text_data_en, "obj_undynebattle2_530", "* You pretend to swing at&  UNDYNE with all your might./%%")
ds_map_add(global.text_data_en, "obj_undynebattle2_578", "I've been&defeated..^1.&My house is in&shambles.../")
ds_map_add(global.text_data_en, "obj_undynebattle2_579", "I even failed to&befriend you./")
ds_map_add(global.text_data_en, "obj_undynebattle2_580", "That's it./")
ds_map_add(global.text_data_en, "obj_undynebattle2_581", "\E8I don't care if&you're my guest&anymore./")
ds_map_add(global.text_data_en, "obj_undynebattle2_582", "\E6One final rematch^1!&All out on both&sides!!!/")
ds_map_add(global.text_data_en, "obj_undynebattle2_583", "IT'S THE ONLY WAY&I CAN REGAIN MY&LOST PRIDE!!!/")
ds_map_add(global.text_data_en, "obj_undynebattle2_584", "NOW COME ON^1!&HIT ME WITH&ALL YOU'VE GOT!&NGAHHHH!!!/%%")
ds_map_add(global.text_data_en, "obj_undynebattle2_599", "* Undyne is letting you make&  the first attack.")
ds_map_add(global.text_data_en, "obj_undynebattle2_645", "What./")
ds_map_add(global.text_data_en, "obj_undynebattle2_646", "\E2That's the best&you can manage?/")
ds_map_add(global.text_data_en, "obj_undynebattle2_647", "\E3Even attacking at&full force.../")
ds_map_add(global.text_data_en, "obj_undynebattle2_648", "You just can't&muster any intent&to hurt me^1,&huh?/")
ds_map_add(global.text_data_en, "obj_undynebattle2_649", "\E4.../")
ds_map_add(global.text_data_en, "obj_undynebattle2_650", "\E7Heh^1, you know&what?/%%")
ds_map_add(global.text_data_en, "obj_undynebattle2_670", "I don't actually&want to hurt you&either./")
ds_map_add(global.text_data_en, "obj_undynebattle2_671", "At first^1, I hated&your stupid&saccharine&schtick^1, but.../")
ds_map_add(global.text_data_en, "obj_undynebattle2_672", "\E3The way you hit&me right now^1,&it.../")
ds_map_add(global.text_data_en, "obj_undynebattle2_673", "\E4Reminded me of&someone I used&to train with./")
ds_map_add(global.text_data_en, "obj_undynebattle2_674", "\E7Now I know you&aren't just some&wimpy loser./")
ds_map_add(global.text_data_en, "obj_undynebattle2_678", "\E9You're a wimpy&loser with a&big heart!/")
ds_map_add(global.text_data_en, "obj_undynebattle2_679", "\E4Just like him.../")
ds_map_add(global.text_data_en, "obj_undynebattle2_680", "\E7.../")
ds_map_add(global.text_data_en, "obj_undynebattle2_681", "\E3Listen^1, human./")
ds_map_add(global.text_data_en, "obj_undynebattle2_682", "\E2It seems that you&and ASGORE are&fated to fight./")
ds_map_add(global.text_data_en, "obj_undynebattle2_683", "\E3But knowing him.../")
ds_map_add(global.text_data_en, "obj_undynebattle2_684", "\E4He probably&doesn't want to./")
ds_map_add(global.text_data_en, "obj_undynebattle2_685", "\E2Talk to him./")
ds_map_add(global.text_data_en, "obj_undynebattle2_686", "\E1I'm sure you can&persuade him to&let you go home./")
ds_map_add(global.text_data_en, "obj_undynebattle2_687", "\E3Eventually^1, some&mean human will&fall down here.../")
ds_map_add(global.text_data_en, "obj_undynebattle2_688", "\E3And I'll take&THEIR soul instead./")
ds_map_add(global.text_data_en, "obj_undynebattle2_689", "\E1That makes sense^1,&right^1?&Fuhuhu./")
ds_map_add(global.text_data_en, "obj_undynebattle2_690", "\E2Oh^1, and if you&DO hurt ASGORE.../")
ds_map_add(global.text_data_en, "obj_undynebattle2_691", "\E7I'll take the&human souls..^1.&Cross the barrier.../")
ds_map_add(global.text_data_en, "obj_undynebattle2_692", "\E6And beat the&hell out of you!/")
ds_map_add(global.text_data_en, "obj_undynebattle2_693", "\E9That's what friends&are for^1, right?/")
ds_map_add(global.text_data_en, "obj_undynebattle2_694", "\E9Fuhuhu!/")
ds_map_add(global.text_data_en, "obj_undynebattle2_695", "\E9Now let's get the&hell out of this&flaming house!/%%")
ds_map_add(global.text_data_en, "obj_undyneboss_401", "Ngahhh!")
ds_map_add(global.text_data_en, "obj_undyneboss_402", "Bring&it on!")
ds_map_add(global.text_data_en, "obj_undyneboss_403", "C'mon!")
ds_map_add(global.text_data_en, "obj_undyneboss_404", "Fuhuhu!")
ds_map_add(global.text_data_en, "obj_undyneboss_405", "Ngahh!!")
ds_map_add(global.text_data_en, "obj_undyneboss_406", "Urahhh!!")
ds_map_add(global.text_data_en, "obj_undyneboss_410", "\E1  You're strong...&  But not strong&  enough!")
ds_map_add(global.text_data_en, "obj_undyneboss_411", "\E4  You're a pain in&  the neck, huh?")
ds_map_add(global.text_data_en, "obj_undyneboss_412", "\E5  DIE ALREADY, YOU&  LITTLE BRAT!")
ds_map_add(global.text_data_en, "obj_undyneboss_416", "%%%")
ds_map_add(global.text_data_en, "obj_undyneboss_427", "  \XAs long as you're&  \GGREEN\X you \RCAN'T&  ESCAPE\X!/")
ds_map_add(global.text_data_en, "obj_undyneboss_428", "  \XUnless you learn&  to \Rface danger&  head-on\X.../")
ds_map_add(global.text_data_en, "obj_undyneboss_429", "  You won't last&  a SECOND against&  ME!/%%")
ds_map_add(global.text_data_en, "obj_undyneboss_437", "  You^1?&  Sparing ME^1?&  Fuhuhuhu!/")
ds_map_add(global.text_data_en, "obj_undyneboss_438", "  How insulting^1!&  I'd NEVER&  surrender to the&  likes of you!/%%")
ds_map_add(global.text_data_en, "obj_undyneboss_439", "  Not bad^1!&  Then how about&  THIS!?/%%")
ds_map_add(global.text_data_en, "obj_undyneboss_442", "\E0  I wanted this to&  be a fair fight./")
ds_map_add(global.text_data_en, "obj_undyneboss_443", "\E1  I thought if I&  beat you like&  this.../")
ds_map_add(global.text_data_en, "obj_undyneboss_444", "  It'd truly show&  how strong&  monsters can be./")
ds_map_add(global.text_data_en, "obj_undyneboss_445", "\E4  BUT NOW???/")
ds_map_add(global.text_data_en, "obj_undyneboss_446", "\E5  I DON'T CARE!/")
ds_map_add(global.text_data_en, "obj_undyneboss_447", "  I'M NOT YOUR&  FREAKING&  KINDERGARTEN&  TEACHER!/")
ds_map_add(global.text_data_en, "obj_undyneboss_448", "\E1  Unless your&  kindergarten&  teacher.../")
ds_map_add(global.text_data_en, "obj_undyneboss_449", "\E5  DOES THIS!/%%")
ds_map_add(global.text_data_en, "obj_undyneboss_459", "\E5  WHAT ARE YOU&  DOING?/")
ds_map_add(global.text_data_en, "obj_undyneboss_460", "  JUST FACE&  UPWARDS!!!/")
ds_map_add(global.text_data_en, "obj_undyneboss_461", "  IT'S NOT HARD!/")
ds_map_add(global.text_data_en, "obj_undyneboss_462", "\E0 %%")
ds_map_add(global.text_data_en, "obj_undyneboss_470", "\E4  Look./")
ds_map_add(global.text_data_en, "obj_undyneboss_471", "\E4  I gave you a&  spear to block&  the bullets with./")
ds_map_add(global.text_data_en, "obj_undyneboss_472", "\E4  Do I have to&  explain this&  any more&  clearly?/")
ds_map_add(global.text_data_en, "obj_undyneboss_473", "\E0 %%")
ds_map_add(global.text_data_en, "obj_undyneboss_481", "\E1  \XWhen I said&  \Rface towards&  danger\X.../")
ds_map_add(global.text_data_en, "obj_undyneboss_482", "\E4  I meant face&  towards the&  bullets!/")
ds_map_add(global.text_data_en, "obj_undyneboss_483", "\E0 %%")
ds_map_add(global.text_data_en, "obj_undyneboss_496", "  For years,&  we've dreamed&  of a happy&  ending...")
ds_map_add(global.text_data_en, "obj_undyneboss_501", "  And now,&  sunlight is&  just within&  our reach!")
ds_map_add(global.text_data_en, "obj_undyneboss_506", "  I won't let&  you snatch it&  away from&  us!")
ds_map_add(global.text_data_en, "obj_undyneboss_510", "\E1  NGAHHH!&  Enough warming&  up!/%%")
ds_map_add(global.text_data_en, "obj_undyneboss_515", "  Heh...&  You're tough!")
ds_map_add(global.text_data_en, "obj_undyneboss_519", "  Mercy^1!&  Ha!/")
ds_map_add(global.text_data_en, "obj_undyneboss_520", "  I still can't&  believe YOU&  want to spare&  ME!/%%")
ds_map_add(global.text_data_en, "obj_undyneboss_528", "  But even if&  you could&  beat me...")
ds_map_add(global.text_data_en, "obj_undyneboss_530", "  But even if&  I spared&  YOU...")
ds_map_add(global.text_data_en, "obj_undyneboss_538", "\X  No human has&  EVER made it&  past&  \RASGORE\X!")
ds_map_add(global.text_data_en, "obj_undyneboss_546", "  Honestly^1,&  killing you&  now is an act&  of mercy...!")
ds_map_add(global.text_data_en, "obj_undyneboss_554", "  ...")
ds_map_add(global.text_data_en, "obj_undyneboss_563", "  Honestly, I'm&  doing you&  a favor...")
ds_map_add(global.text_data_en, "obj_undyneboss_570", "\X  No human has&  EVER made it&  past&  \RASGORE\X!")
ds_map_add(global.text_data_en, "obj_undyneboss_577", "\E1  Killing you&  now is an act&  of mercy!")
ds_map_add(global.text_data_en, "obj_undyneboss_582", "\E4  So STOP being&  so damn&  resilient!/%%")
ds_map_add(global.text_data_en, "obj_undyneboss_587", "  What the&  hell are&  humans made&  out of!?")
ds_map_add(global.text_data_en, "obj_undyneboss_593", "  Anyone else&  would be DEAD&  by now!")
ds_map_add(global.text_data_en, "obj_undyneboss_599", "  Alphys told me&  humans were&  determined...")
ds_map_add(global.text_data_en, "obj_undyneboss_605", "  I see now what&  she meant by&  that!")
ds_map_add(global.text_data_en, "obj_undyneboss_611", "  But I'm&  determined,&  too!")
ds_map_add(global.text_data_en, "obj_undyneboss_616", "  Determined to&  end this&  RIGHT NOW!")
ds_map_add(global.text_data_en, "obj_undyneboss_622", "  ... RIGHT NOW!")
ds_map_add(global.text_data_en, "obj_undyneboss_628", "  ... RIGHT...&  ...&  ... NOW!!")
ds_map_add(global.text_data_en, "obj_undyneboss_634", "  Ha...&  Ha...")
ds_map_add(global.text_data_en, "obj_undyneboss_639", "\E5  NGAHHH!!!&  DIE ALREADY, YOU&  LITTLE BRAT!/%%")
ds_map_add(global.text_data_en, "obj_undyneboss_656", "  YOU'RE GETTING&  IN MY WAY!")
ds_map_add(global.text_data_en, "obj_undyneboss_658", "  I WILL NEVER&  TAKE MERCY FROM&  THE LIKES OF YOU!")
ds_map_add(global.text_data_en, "obj_undyneboss_664", "  I WILL NOT&  BE DEFEATED!")
ds_map_add(global.text_data_en, "obj_undyneboss_666", "  YOU! WILL!&  NEVER! SPARE! ME!")
ds_map_add(global.text_data_en, "obj_undyneboss_672", "\X  YOU'LL NEVER \RESCAPE\X&  FROM ME!!!")
ds_map_add(global.text_data_en, "obj_undyneboss_682", "  Come on^1, is that&  all you've got!?/%%")
ds_map_add(global.text_data_en, "obj_undyneboss_686", "  ... pathetic./")
ds_map_add(global.text_data_en, "obj_undyneboss_687", "  You're going to&  have to try&  harder than that!/%%")
ds_map_add(global.text_data_en, "obj_undyneboss_691", "  S-see how strong&  we are when we&  believe in&  ourselves?/%%")
ds_map_add(global.text_data_en, "obj_undyneboss_695", "  H... heh.../")
ds_map_add(global.text_data_en, "obj_undyneboss_696", "  Had enough yet?/%%")
ds_map_add(global.text_data_en, "obj_undyneboss_700", "\E7  .../")
ds_map_add(global.text_data_en, "obj_undyneboss_701", "  ... I won't..^1.&  ... give up.../%%")
ds_map_add(global.text_data_en, "obj_undyneboss_705", "\E7.../%%")
ds_map_add(global.text_data_en, "obj_undyneboss_1085", "* Wiatr głośno wyje...")
ds_map_add(global.text_data_en, "obj_undyneboss_1086", "* Undyne flips her spear&  impatiently.")
ds_map_add(global.text_data_en, "obj_undyneboss_1087", "* Flower pollen drifts in&  front of you.")
ds_map_add(global.text_data_en, "obj_undyneboss_1088", "* Water rushes around you.")
ds_map_add(global.text_data_en, "obj_undyneboss_1089", "* The spears pause for a&  moment.")
ds_map_add(global.text_data_en, "obj_undyneboss_1094", "* Undyne points heroically&  towards the sky.")
ds_map_add(global.text_data_en, "obj_undyneboss_1095", "* Undyne flips her spear&  impatiently.")
ds_map_add(global.text_data_en, "obj_undyneboss_1096", "* Undyne suplexes a huge&  boulder^1, just because&  she can.")
ds_map_add(global.text_data_en, "obj_undyneboss_1097", "* Undyne bounces impatiently.")
ds_map_add(global.text_data_en, "obj_undyneboss_1098", "* Undyne flashes a menacing&  smile.")
ds_map_add(global.text_data_en, "obj_undyneboss_1099", "* Undyne draws her finger&  across her neck.")
ds_map_add(global.text_data_en, "obj_undyneboss_1100", "* Undyne holds her fist in&  front of her and shakes&  her head.")
ds_map_add(global.text_data_en, "obj_undyneboss_1101", "* Undyne towers threateningly.")
ds_map_add(global.text_data_en, "obj_undyneboss_1102", "* Undyne thinks of her friends&  and pounds the ground&  with her fists.")
ds_map_add(global.text_data_en, "obj_undyneboss_1103", "* Smells like sushi.")
ds_map_add(global.text_data_en, "obj_undyneboss_1107", "* Undyne's eye is twitching&  involuntarily.")
ds_map_add(global.text_data_en, "obj_undyneboss_1108", "* Undyne is smashing spears&  on the ground.")
ds_map_add(global.text_data_en, "obj_undyneboss_1109", "* Undyne's eyes dart around&  to see if this is&  a prank.")
ds_map_add(global.text_data_en, "obj_undyneboss_1110", "* Undyne is hyperventilating.")
ds_map_add(global.text_data_en, "obj_undyneboss_1111", "* Smells like angry fish.")
ds_map_add(global.text_data_en, "obj_undyneboss_1118", "* Undyne is smiling as if&  nothing is wrong.")
ds_map_add(global.text_data_en, "obj_undyneboss_1119", "* Undyne's body is wavering.")
ds_map_add(global.text_data_en, "obj_undyneboss_1120", "* Undyne's body is losing&  its shape.")
ds_map_add(global.text_data_en, "obj_undyneboss_1121", "* Undyne's body...")
ds_map_add(global.text_data_en, "obj_undyneboss_1122", "* ...")
ds_map_add(global.text_data_en, "obj_undyneboss_1145", "* UNDYNE - ATK 50 DEF 20&* The heroine that NEVER gives&  up./^")
ds_map_add(global.text_data_en, "obj_undyneboss_1168", "* You tell UNDYNE her attacks&  are too easy^1.&* She doesn't care./^")
ds_map_add(global.text_data_en, "obj_undyneboss_1174", "* You tell UNDYNE her attacks&  are too easy^1.&* The bullets get faster./^")
ds_map_add(global.text_data_en, "obj_undyneboss_1176", "* You tell UNDYNE her attacks&  are too easy^1.&* The bullets get unfair./^")
ds_map_add(global.text_data_en, "obj_undyneboss_1182", "* Didn't work./^")
ds_map_add(global.text_data_en, "obj_undyneboss_1195", "* Hamburger Helpers./^")
ds_map_add(global.text_data_en, "obj_undyneboss_1205", "* You told Undyne you didn't&  want to fight^1.&* But nothing happened./^")
ds_map_add(global.text_data_en, "obj_undyneboss_1209", "* You told Undyne you just&  want to be friends.&* She remembers someone.../")
ds_map_add(global.text_data_en, "obj_undyneboss_1210", "* Her attacks became a little&  less extreme./^")
ds_map_add(global.text_data_en, "obj_undyneboss_1215", "* Didn't work./^")
ds_map_add(global.text_data_en, "obj_undyneboss_1278", "En guarde!/%%")
ds_map_add(global.text_data_en, "obj_undyneboss_1281", "\E1  You won't get&  away from me&  this time!/%%")
ds_map_add(global.text_data_en, "obj_undyneboss_1286", "\E4  You've escaped&  from me for&  the LAST time!/%%")
ds_map_add(global.text_data_en, "obj_undyneboss_1292", "\E5  STOP RUNNING&  AWAY!!!/%%")
ds_map_add(global.text_data_en, "obj_undyneboss_1298", "\E5  COME BACK HERE^1,&  YOU LITTLE&  PUNK!!/%%")
ds_map_add(global.text_data_en, "obj_undyneboss_1310", "* Undyne attacks!")
ds_map_add(global.text_data_en, "obj_undyneboss_1336", "Ngahhh.../")
ds_map_add(global.text_data_en, "obj_undyneboss_1337", "You were stronger...&Than I thought.../")
ds_map_add(global.text_data_en, "obj_undyneboss_1338", "So then..^1.&... this is where..^1.&... it ends.../")
ds_map_add(global.text_data_en, "obj_undyneboss_1339", ".../%%")
ds_map_add(global.text_data_en, "obj_undyneboss_1365", "  No.../%%")
ds_map_add(global.text_data_en, "obj_undyneboss_1386", "NO!/")
ds_map_add(global.text_data_en, "obj_undyneboss_1387", "I won't die!/")
ds_map_add(global.text_data_en, "obj_undyneboss_1388", "Alphys..^1.&Asgore..^1.&Papyrus.../")
ds_map_add(global.text_data_en, "obj_undyneboss_1389", "Everyone is counting&on me to protect&them!/")
ds_map_add(global.text_data_en, "obj_undyneboss_1390", "NNNNGAH!/%%")
ds_map_add(global.text_data_en, "obj_undyneboss_1401", "Human!/")
ds_map_add(global.text_data_en, "obj_undyneboss_1402", "In the name of&everybody's hopes&and dreams.../")
ds_map_add(global.text_data_en, "obj_undyneboss_1403", "I WILL DEFEAT YOU!/%%")
ds_map_add(global.text_data_en, "obj_undyneboss_1410", "* Undyne looks determined.")
ds_map_add(global.text_data_en, "obj_undyneboss_1424", ".../")
ds_map_add(global.text_data_en, "obj_undyneboss_1425", "Ha..^1. ha.../")
ds_map_add(global.text_data_en, "obj_undyneboss_1426", "... Alphys.../")
ds_map_add(global.text_data_en, "obj_undyneboss_1427", "This is what I&  was afraid of.../")
ds_map_add(global.text_data_en, "obj_undyneboss_1428", "This is why I&  never told you.../")
ds_map_add(global.text_data_en, "obj_undyneboss_1429", ".../%%")
ds_map_add(global.text_data_en, "obj_undyneboss_1438", "No..^1.&No!/")
ds_map_add(global.text_data_en, "obj_undyneboss_1439", "Not yet!/")
ds_map_add(global.text_data_en, "obj_undyneboss_1440", "I won't die!/%%")
ds_map_add(global.text_data_en, "obj_undyneboss_1449", "NGAHHHHHHHH!!^2! %%")
ds_map_add(global.text_data_en, "obj_undyneboss_1460", " I WON'T DIE^3! %%")
ds_map_add(global.text_data_en, "obj_undyneboss_1470", " I WON'T DIE^3! %%")
ds_map_add(global.text_data_en, "obj_undyneboss_1480", " I WON'T DIE^3! %%")
ds_map_add(global.text_data_en, "obj_undyneboss_1490", " I^2 WON'T^2 %%")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_114", "* Well^1, that was&  fun^1, huh?/")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_115", "\E6* We'll have to hang&  out again another&  time...!/")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_116", "\E9* But^1, uh^1, somewhere&  else I guess./")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_117", "\E0* In the meantime^1,&  I guess I'll go&  hang with Papyrus./")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_118", "* So if you need&  me^1, drop by Snowdin^1,&  OK!?/")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_119", "\E1* OH^1!&* And if you ever&  need help.../")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_120", "\E9* Just give Papyrus a&  ring^1, ok?/")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_121", "\E0* Since we're in the&  same spot^1, I'll be&  able to talk too!/")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_122", "\E6* Well^1, see ya&  later^1, punk!!/%%")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_140", "* Well^1, that was&  fun^1, huh?/")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_141", "\E6* We'll have to hang&  out again another&  time...!/")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_142", "\E9* But^1, uh^1, somewhere&  else I guess./")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_143", "\E0* In the meantime^1,&  I guess I'll go&  hang with Papyrus./")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_144", "* So if you need&  me^1, drop by Snowdin^1,&  OK!?/")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_145", "\E1* OH^1!&* And if you ever&  need help.../")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_146", "\E9* Just give Papyrus a&  ring^1, ok?/")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_147", "\E0* Since we're in the&  same spot^1, I'll be&  able to talk too!/")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_148", "\E6* Well^1, see ya&  later^1, punk.../")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_149", "\E1* OH!!^1!&* WAIT!!/")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_150", "\E0* This is sudden^1, but.../")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_151", "\E9* Can you deliver&  something for me?/")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_152", "\E0* Papyrus suggested&  that I ask you./")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_153", "\E3* But he told me when&  I still hated you^1,&  so.../")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_154", "\E1* Uh^1! Anyway!!^1!&* Here^1! Just take it!/")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_155", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_156", "* (You got the Undyne's&  Letter.)/")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_158", "* Well^1, what are you&  waiting for!?/")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_159", "\E1* Go deliver it!!!/")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_160", "* .../")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_161", "\E9* Uhhhh..^1.&* Oh^1, yeah.../")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_162", "* It's addressed to&  Dr. Alphys./")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_163", "\E6* OK^1, see you!!/%%")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_169", "* Well^1, that was&  fun^1, huh?/")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_170", "\E6* We'll have to hang&  out again another&  time...!/")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_171", "\E9* But^1, uh^1, somewhere&  else I guess./")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_172", "\E0* In the meantime^1,&  I guess I'll go&  hang with Papyrus./")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_173", "* So if you need&  me^1, drop by Snowdin^1,&  OK!?/")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_174", "\E1* OH^1!&* And if you ever&  need help.../")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_175", "\E9* Just give Papyrus a&  ring^1, ok?/")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_176", "\E0* Since we're in the&  same spot^1, I'll be&  able to talk too!/")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_177", "\E6* Well^1, see ya&  later^1, punk.../")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_178", "\E1* OH!!^1!&* WAIT!!/")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_179", "\E0* This is sudden^1, but.../")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_180", "* Can you.../")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_181", "\E1* Hey^1, wait^1!&* Your inventory's&  full./")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_182", "\E9* Uh^1, well^1, I'll be&  at Papyrus's./")
ds_map_add(global.text_data_en, "obj_undynedate_afterward_183", "\E6* Come see me when&  you have less&  stuff!/%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_120", "HERE^1, UNDYNE./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_121", "MY FRIEND BROUGHT&A GIFT FOR YOU^1,&ON THEIR OWN!/%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_143", "* Uhhh..^1. thanks./%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_177", "* I'll^1, uh^1, put it&  with the others./%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_236", "* So are we ready&  to start?/%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_250", "WHOOPSY DOOPSY^1!&I JUST REMEMBERED!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_251", "I HAVE TO GO&TO THE BATHROOM!!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_252", "\E0YOU TWO HAVE&FUN!!!/%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_335", "DANG^1!&WHAT A SHAME.../")
ds_map_add(global.text_data_en, "obj_undynedate_inside_336", "\E2I THOUGHT UNDYNE&COULD BE FRIENDS&WITH YOU./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_337", "\E3BUT I GUESS.../")
ds_map_add(global.text_data_en, "obj_undynedate_inside_338", "\E3I OVERESTIMATED&HER./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_339", "\E3SHE'S JUST NOT&UP TO THE&CHALLENGE./%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_351", "* CHALLENGE!^1?&* What!?/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_352", "\E0* Papyrus^1!&* Wait a second...!/%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_367", "* Darnit!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_368", "* He thinks I can't&  be friends with&  YOU!?/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_369", "\E6* Fuhuhu^1!&* What a joke!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_370", "* I could make friends&  with a wimpy loser&  like you any day!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_371", "\E2* I'll show him!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_372", "\E3* Listen up^1, human./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_373", "\E2* We're not just&  going to be&  friends./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_374", "\E3* We're going to&  be.../")
ds_map_add(global.text_data_en, "obj_undynedate_inside_375", "\M1* BESTIES./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_376", "* I'll make you&  like me so much.../")
ds_map_add(global.text_data_en, "obj_undynedate_inside_377", "\E1* You won't be able&  to think of anyone&  else!!!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_378", "\E3* Fuhuhuhu^1!&* It's the PERFECT&  REVENGE!!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_379", "* .../")
ds_map_add(global.text_data_en, "obj_undynedate_inside_380", "\E9* Czemu sobie nie&  usiądziesz?/%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_415", "* Oh^1, leaving so soon?/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_416", "\E3* No^1.&* No you're not./%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_471", "* Comfortable?/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_472", "* I'll get you&  something to drink./%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_561", "* All set^1!&* What would you like?/%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_604", "* HEY!!^1!&* DON'T GET UP!!!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_605", "* YOU'RE THE GUEST!^1!&* SIT DOWN AND ENJOY&  YOURSELF!!!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_606", "* .../%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_614", "\E9* Um^1, why not just&  point to what you&  want?/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_615", "* You can use the&  spear!/%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_643", "\E4* Y'know^1, I was a&  pretty hotheaded&  kid./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_644", "* Once^1, to prove I was&  the strongest^1, I tried&  to fight ASGORE./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_645", "\E1* Emphasis on TRIED./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_646", "\E0* I couldn't land&  a single blow&  on him!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_647", "\E4* And worse^1, the whole&  time^1, he refused&  to fight back!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_648", "\E7* I was so&  humiliated.../")
ds_map_add(global.text_data_en, "obj_undynedate_inside_649", "\E0* Afterwards^1, he&  apologized and said&  something goofy.../")
ds_map_add(global.text_data_en, "obj_undynedate_inside_650", "* " + '"' + "Excuse me^1, do you&  want to know how&  to beat me?" + '"' + "/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_651", "\E0* I said yes^1, and&  from then on^1, he&  trained me./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_652", "\E4* One day^1, during&  practice^1, I finally&  knocked him down./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_653", "\E7* I felt..^1. bad./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_654", "\E9* But he was&  beaming.../")
ds_map_add(global.text_data_en, "obj_undynedate_inside_655", "\E6* I had never seen&  someone more proud to&  get their butt kicked./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_656", "\E1* ... oh!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_657", "\E9* I almost forgot&  about your tea!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_658", "* Just a moment!/%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_696", "* Wait a second./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_697", "* Papyrus..^1.&* His cooking lesson.../")
ds_map_add(global.text_data_en, "obj_undynedate_inside_698", "\M2* HE WAS SUPPOSED&  TO HAVE THAT RIGHT&  NOW!!!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_699", "\E3* And if HE's not&  here to have it.../")
ds_map_add(global.text_data_en, "obj_undynedate_inside_700", "\E2* YOU'LL HAVE TO&  HAVE IT FOR HIM!!!/%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_833", "* That's right!!!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_834", "\E1* NOTHING has brought&  Papyrus and I&  closer than cooking!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_835", "\E3* Which means that if&  I give you his&  lesson.../")
ds_map_add(global.text_data_en, "obj_undynedate_inside_836", "\E2* WE'LL BECOME CLOSER&  THAN YOU CAN&  EVER IMAGINE!!!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_837", "\E6* Fuhuhu!!^1! Afraid!^1?&* We're gonna be best&  friends!!!/%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1000", "* Ready!^1?&* It's spaghetti time!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1001", "* Let's start with the&  sauce!!/%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1128", "* Uhh^1, we'll just scrape&  this into a bowl&  later./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1129", "\E1* But for NOW!/%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1235", "* Alright^1!&* Now it's time&  to stir the pasta!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1236", "* As a general rule&  of thumb^1, the more&  you stir.../")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1237", "\E1* THE BETTER IT IS!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1238", "\E0* Ready^1?&* Let's do it!/%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1326", "\M0* Fuhuhuhu^1!&* That's the stuff!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1328", "\E0* Alright^1, now for&  the final step:/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1329", "\E1* TURN UP THE HEAT!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1330", "\E0* Let the stovetop&  symbolize your&  passion!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1331", "\E1* Let your hopes and&  dreams turn into&  burning fire!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1332", "\E2* READY^1?&* Don't hold anything&  back!!!/%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1444", "* Ah./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1445", "* Man^1, no wonder&  Papyrus sucks at&  cooking./%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1465", "* So what's next^1?&* Scrapbooking^1?&* Friendship bracelets?/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1466", "* .../%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1475", "* ... oh^1, who am I&  kidding./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1476", "* I really screwed this&  up^1, didn't I?/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1477", "\E4* I can't force you to&  like me^1, human./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1478", "\E4* Some people just&  don't get along&  with each other./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1479", "\E7* I understand if&  you feel that&  way about me./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1480", "\E4* And if we can't&  be friends.../")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1481", "\E7* That's okay./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1482", "\E7* Because..^1.&* If we're not&  friends.../%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1490", "\E2*\M2 IT MEANS I CAN&  DESTROY YOU WITHOUT&  REGRET!/%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1641", "* It'll take a moment&  for the water to&  boil./%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1671", "* Okay^1, it's all&  done!/%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1771", "* Here we are./%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1833", "* Careful^1, it's hot./%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1850", "* It's not THAT hot!^1!&* Just drink it already!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1851", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1852", "* (You take a sip of the&  tea.^1)&* (It's burning...)/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1853", "* (But other than that^1,&  it's pretty good.)/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1855", "* It's pretty good^1,&  right?/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1856", "\E6* Nothing but the best&  for my ABSOLUTELY&  PRECIOUS FRIEND!!/%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1873", "\E9* Hey.../")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1874", "\E9* You know...&* It's kind of strange&  you chose THAT tea./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1875", "\E4* Golden flower tea.../")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1876", "\E0* That's ASGORE's&  favorite kind./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1877", "\E4* Actually^1, now that&  I think about it.../")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1878", "\E9* You kind of remind&  me of him./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1879", "\E6* You're both TOTAL&  weenies!!!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1880", "\E7* ... sort of./%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1898", "\E4* Y'know^1, I was a&  pretty hotheaded&  kid./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1899", "* Once^1, to prove I was&  the strongest^1, I tried&  to fight ASGORE./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1900", "\E1* Emphasis on TRIED./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1901", "\E0* I couldn't land&  a single blow&  on him!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1902", "\E4* And worse^1, the whole&  time^1, he refused&  to fight back!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1903", "\E7* I was so&  humiliated.../")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1904", "\E0* Afterwards^1, he&  apologized and said&  something goofy.../")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1905", "* " + '"' + "Excuse me^1, do you&  want to know how&  to beat me?" + '"' + "/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1906", "\E0* I said yes^1, and&  from then on^1, he&  trained me./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1907", "\E4* One day^1, during&  practice^1, I finally&  knocked him down./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1908", "\E7* I felt..^1. bad./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1909", "\E9* But he was&  beaming.../")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1910", "\E6* I had never seen&  someone more proud to&  get their butt kicked./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1911", "\E4* Anyway^1, long story&  short^1, he kept training&  me.../")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1912", "\E0* And now I'm the&  head of the Royal&  Guard!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1913", "\E6* So I'm the one&  who gets to train&  dorks to fight!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1914", "\E9* ... like^1, uh^1, Papyrus./%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1935", "\E4* But^1, um^1, to be&  honest.../")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1936", "\E9*... I don't know if.../")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1937", "\E7* I can ever let&  Papyrus into the&  Royal Guard./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1938", "\E1* Don't tell him I&  said that!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1939", "\E4* He's just..^1.&* Well.../")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1940", "\E9* I mean^1, it's not&  that he's weak./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1941", "\E1* He's actually&  pretty freaking&  tough!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1942", "\E7* It's just that..^1.&* He's.../")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1943", "\E1* He's too innocent&  and nice!!!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1944", "\E7* I mean^1, look^1, he&  was SUPPOSED to&  capture you.../")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1945", "\E5* And he ended up&  being FRIENDS with&  you instead!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1946", "\E1* I could NEVER send&  him into battle!/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1947", "\E7* He'd get ripped&  into little smiling&  shreds./")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1948", "\E7* That's part of why.../")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1949", "\E9* I started teaching&  him how to cook^1,&  you know?/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1950", "\E7* So^1, um^1, maybe he&  can do something&  else with his life./%%")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1978", "\E1* Oh^1, sorry^1, I was&  talking for so&  long.../")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1979", "\E9* You're out of tea^1,&  aren't you?/")
ds_map_add(global.text_data_en, "obj_undynedate_inside_1980", "\E0* I'll get you some&  more./%%")
ds_map_add(global.text_data_en, "obj_undynedate_outside_155", "PSST./")
ds_map_add(global.text_data_en, "obj_undynedate_outside_156", "\E0DAJ JEJ TO!/%%")
ds_map_add(global.text_data_en, "obj_undynedate_outside_173", "ONA JE KOCHA!/%%")
ds_map_add(global.text_data_en, "obj_undynedate_outside_241", "* Hi^1, Papyrus!/")
ds_map_add(global.text_data_en, "obj_undynedate_outside_243", "* Ready for your extra-&  private^1, one-on-one&  training?/")
ds_map_add(global.text_data_en, "obj_undynedate_outside_245", "YOU BET I AM!/")
ds_map_add(global.text_data_en, "obj_undynedate_outside_246", "AND I BROUGHT&A FRIEND!/%%")
ds_map_add(global.text_data_en, "obj_undynedate_outside_276", "* Hi^1, I don't think&  we've.../")
ds_map_add(global.text_data_en, "obj_undynedate_outside_277", "\E2* .../")
ds_map_add(global.text_data_en, "obj_undynedate_outside_278", "\M9* .../")
ds_map_add(global.text_data_en, "obj_undynedate_outside_280", "\M0.../")
ds_map_add(global.text_data_en, "obj_undynedate_outside_282", "\E1* Why don't^1.&* You two^1.&* Come in?/%%")
ds_map_add(global.text_data_en, "obj_undynedate_outside_364", "* (You hear someone shouting&  a whisper at you from&  inside the house.)/")
ds_map_add(global.text_data_en, "obj_undynedate_outside_366", "NO^1!&YOU CAN'T ESCAPE&FRIENDSHIP!!/%%")
ds_map_add(global.text_data_en, "obj_undyneencounter2_329", "* Jo..^1. widziałeś to!?/")
ds_map_add(global.text_data_en, "obj_undyneencounter2_330", "* Undyne właśnie.../")
ds_map_add(global.text_data_en, "obj_undyneencounter2_331", "* ... DOTKNĘŁA MNIE!/")
ds_map_add(global.text_data_en, "obj_undyneencounter2_332", "* Już nigdy nie umyję&  mojej twarzy...!/")
ds_map_add(global.text_data_en, "obj_undyneencounter2_333", "* Rany^1, jakiego masz niefarta./")
ds_map_add(global.text_data_en, "obj_undyneencounter2_334", "* Gdybyś tylko stanął&  TROSZECZKĘ po lewej...!/")
ds_map_add(global.text_data_en, "obj_undyneencounter2_335", "* Jo^1, nie martw się^1!&* Z pewnością jeszcze ją&  zobaczymy!/%%")
ds_map_add(global.text_data_en, "obj_undyneencounter2_338", "* ... jo^1, zauważyłeś^1?&* Ona wydawała się naprawdę&  zła o coś!/")
ds_map_add(global.text_data_en, "obj_undyneencounter2_339", "* Wyglądała jakby miała mnie&  roztrzelić na kawałki!/")
ds_map_add(global.text_data_en, "obj_undyneencounter2_340", "* Ale..^1. ech..^1.&* Wtedy postanowiła mnie&  położyć na ziemię.../")
ds_map_add(global.text_data_en, "obj_undyneencounter2_341", "* Jo^1!&* Będziesz przecież następny&  raz^1, right^1? Chodźmy!/%%")
ds_map_add(global.text_data_en, "obj_undyneencounter4_255", "Ten dźwięk chyba&doszedł z&tamtąd.../")
ds_map_add(global.text_data_en, "obj_undyneencounter4_256", "Oh^1! Spadłeś z&góry^1, czyż&nie.../")
ds_map_add(global.text_data_en, "obj_undyneencounter4_257", "Wszystko w&porządku?/")
ds_map_add(global.text_data_en, "obj_undyneencounter4_258", "Chodź^1,&wstawaj.../")
ds_map_add(global.text_data_en, "obj_undyneencounter4_259", ".../")
ds_map_add(global.text_data_en, "obj_undyneencounter4_260", "\[C]^1, huh?/")
ds_map_add(global.text_data_en, "obj_undyneencounter4_261", "To ładne imię./%%")
ds_map_add(global.text_data_en, "obj_undyneencounter4_275", "Ja nazywam się     %%")
ds_map_add(global.text_data_en, "obj_undynefall_99", "* (Ktoś skrupulatnie&  wyczyścił cały śluz&  z tego ślimaka.)/%%")
ds_map_add(global.text_data_en, "obj_undynetrash_69", "* (The trashcan is full&  of broken spears.)/%%")
ds_map_add(global.text_data_en, "obj_undynetrash_72", "* (The trashcan is empty.)/%%")
ds_map_add(global.text_data_en, "obj_undynetrash_76", "* (You found a trashcan.)/")
ds_map_add(global.text_data_en, "obj_undynetrash_77", "* (Inside the trashcan&  was a key^1, barely visible&  to the naked eye...)/")
ds_map_add(global.text_data_en, "obj_undynetrash_78", "* (You take it.)/%%")
ds_map_add(global.text_data_en, "obj_undynetrash_87", "* (A garbage can.^1)&* (But it's pretty cute.)/%%")
ds_map_add(global.text_data_en, "obj_undynetrash_88", "* (Jest zbyt ciemno^1, by widzieć&  koło ścian.)/%%")
ds_map_add(global.text_data_en, "obj_undynetrash_91", "* (There's a message crumpled&  up in the trash can.)/")
ds_map_add(global.text_data_en, "obj_undynetrash_92", "* (It's in a strange kind&  of handwriting.)/")
ds_map_add(global.text_data_en, "obj_undynetrash_93", "* (It says...)/")
ds_map_add(global.text_data_en, "obj_undynetrash_94", "* (I KNOW WHAT YOU DID.)/%%")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_157", "* Siedem./")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_158", "\W* Seven human souls^1, and&  \RKing ASGORE\W will become&  a god./")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_159", "* Six./")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_160", "* That's how many we have&  collected thus far./")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_161", "* Understand?/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_162", "* Through your seventh and&  final soul^1, this world will&  be transformed./")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_163", "* First^1, however^1, as is customary&  for those who make it this&  far.../")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_164", "* I shall tell you the tragic&  tale of our people./")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_165", "* It all started^1, long ago.../%%")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_190", "* .../")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_191", "* No^1, you know what?/%%")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_199", "* SCREW IT^3! %%")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_206", "* WHY SHOULD I TELL THAT STORY^1  %%")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_213", "* WHEN YOU'RE ABOUT TO DIE!?^1!   %%")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_220", "* NGAAAAAHHHHHHHHHHHHHHHHH^1! %%")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_325", "* YOU!/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_326", "* You're standing in&  the way of everybody's&  hopes and dreams!/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_327", "\E4* Alphys's history books&  made me think&  humans were cool.../")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_328", "\E0* ... with their giant&  robots and flowery&  swordswomen./")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_329", "\E1* BUT YOU?/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_330", "\E2* You're just a coward!/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_331", "\E3* Hiding behind that kid&  so you could run away&  from me again!/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_332", "* You abandoned your&  friend just so you&  could run away!/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_335", "\E2* And let's not forget&  your wimpy goody-two-&  shoes-schtick!/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_336", "\E6* Oooh^1! I'm making such a&  difference by hugging&  random strangers!/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_337", "*\E3 You know what would&  be more valuable&  to everyone?/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_338", "*\E1 IF YOU WERE DEAD!!!/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_339", "\E0* That's right^1, human^1!&* Your continued&  existence is a crime!/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_340", "* Your life is all&  that stands between&  us and our freedom!/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_341", "* Right now^1, I can&  feel everyone's hearts&  pounding together!/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_342", "\E0* Everyone's been&  waiting their whole&  lives for this moment!/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_343", "\E0* But we're not&  nervous at all./")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_344", "\E1* When everyone puts&  their hearts together^1,&  they can't lose!/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_345", "\E5* Now^1, human^1!&* Let's end this^1,&  right here^1, right now./")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_346", "\E0* I'll show you how&  determined monsters&  can be!/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_347", "\E0* Step forward when&  you're ready^1!&* Fuhuhuhu!/%%")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_351", "\E1* And^1! And!/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_352", "\E7*... and something's&  been bothering me^1,&  too./")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_353", "\E4* The whole time I was&  chasing after you.../")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_354", "\E7* I felt something..^1.&* Strange./")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_355", "* The echoes of something&  warm^1, something.../")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_356", "\E9* Something like " + '"' + "I miss&  being friends with you." + '"' + "/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_357", "\E2* BUT THAT'S RIDICULOUS!/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_358", "\E6I WOULD NEVER GET&  CHUMMY WITH A COWARD&  LIKE YOU!/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_359", "\E1* You^1!&* You must have been&  mind-controlling me!/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_360", "\E6* Manipulating people to&  make them like you..^1.&* What a Grade-A FREAK!/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_361", "\E1* Now enough^1!&* For everyone's hopes^1!&* For everyone's dreams!/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_362", "\E2* And for my own&  freaking dignity!/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_363", "\E3* I^1, UNDYNE^1, will&  knock you down!/%%")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_369", "* YOU!/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_370", "* You're standing in&  the way of everybody's&  hopes and dreams!/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_371", "\E4* Alphys's history books&  made me think humans&  were compassionate.../")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_372", "\E1* BUT YOU?/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_373", "\E5* You're just a&  remorseless criminal!/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_374", "* You wander through the&  caverns^1, attacking&  anyone in your path./")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_375", "\E4* Self-defense^1?&* Please./")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_376", "* You didn't kill them&  because you had to./")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_377", "\E5* You killed them&  because it was&  easy for you./")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_378", "* Because it was fun&  for you./")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_379", "\E4* Do you think it&  was fun when I&  found out...?/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_381", "* Do you think it's&  fun when people's&  family members.../")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_382", "* ... never come home^1?&* Is that fun?/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_386", "* Shyren^1, who was&  just learning to&  sing.../")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_387", "* ... was dead^1, because&  of the whims of&  a single human?/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_392", "* A teenage comedian&  who fell in with&  the wrong crowd.../")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_393", "* ... was dead^1, because&  of the whims of&  a single human?/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_399", "* Doggo^1, who always&  made me laugh.../")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_400", "* ... was dead^1, because&  of the whims of&  a single human?/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_405", "* Those two sweet dogs^1,&  who always took care&  of each other.../")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_406", "* ... were dead^1, because&  of the whims of&  a single human?/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_412", "* That big dog^1, who&  wanted nothing more&  than to play.../")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_413", "* ... was dead^1, because&  of the whims of&  a single human?/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_419", "* Lesser Dog^1, who&  wanted nothing more&  than affection.../")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_420", "* ... was dead^1, because&  of the whims of&  a single human?/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_425", "* The Snowdin Canine&  Unit had been&  completely decimated./")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_426", "* My troops and friends^1,&  destroyed..^1.&* Is that fun?/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_429", "\E5* No./")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_430", "\E3* But your time's up^1,&  villain!/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_431", "\E0* You won't hurt anyone&  else./")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_432", "* A knight in shining&  armor has appeared./")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_433", "\E4* And all the pain&  you inflicted on&  the fallen.../")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_434", "* Every hope^1, every&  dream you've turned&  to dust.../")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_435", "\E0* She's gonna send&  right back through&  her spear!/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_436", "\E1* NGAHHH!!!/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_437", "\E0* I'll show you how&  determined monsters&  truly are!/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_438", "* Come on^1!&* Step forward and&  let's end this!/%%")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_468", "* .../")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_469", "* Forget it./%%")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_490", "* Look./")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_491", "* Papyrus didn't come&  to his meeting&  today./")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_492", "* Say what you want&  about him./")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_493", "* He's weird^1, he's&  naive^1, he's self-&  absorbed.../")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_494", "\E5* But Papyrus has&  NEVER missed a&  meeting./")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_495", "\E4* And no matter what&  time you call him&  on the phone.../")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_496", "* Night^1, day^1, afternoon^1,&  morning.../")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_497", "\E5* He ALWAYS answers&  within the first&  two rings./")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_498", "\E4* .../")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_499", "* But now he's gone./")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_500", "* And his brother&  isn't around^1,&  either./")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_501", "\E5* .../")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_502", "* What did you do&  to him?/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_503", "* What did you DO&  TO HIM?/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_504", "\E4* Papyrus^1, who I have&  trained every day.../")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_505", "* Even though I KNOW&  he's too goofy to&  ever hurt anyone.../")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_506", "\E5* .../")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_507", "\E4* Go ahead^1.&* Prepare however you&  want./")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_508", "\E5* But when you step&  forward.../")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_509", "\E1* I will KILL you./%%")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss_638", "*TEST!!!/%%")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss2_99", "* That's it^1, then...!/")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss2_100", "* No more running away!/%%")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss2_103", "* I KNEW you would&  come back here!/%%")
ds_map_add(global.text_data_en, "obj_undynetrigger_boss2_116", "* HERE I COME!!!!!!!")
ds_map_add(global.text_data_en, "obj_undynetrigger_dry_122", "* Armor..^1. so..^1. hot..^1./")
ds_map_add(global.text_data_en, "obj_undynetrigger_dry_123", "* But I can't..^1.&* Give up.../%%")
ds_map_add(global.text_data_en, "obj_vegetoid_172", "Zawiera&Witaminę&A")
ds_map_add(global.text_data_en, "obj_vegetoid_173", "Część&Dobrego&Śniadania")
ds_map_add(global.text_data_en, "obj_vegetoid_175", "Uprawa&Lokalna,&Bardzo&Lokalna")
ds_map_add(global.text_data_en, "obj_vegetoid_176", "Świeży&Poranny&Smak")
ds_map_add(global.text_data_en, "obj_vegetoid_178", "Zjadłwszy&Swoje&Warzywa")
ds_map_add(global.text_data_en, "obj_vegetoid_182", "Rośliny&Nie&Gadają&Głupku")
ds_map_add(global.text_data_en, "obj_vegetoid_186", "Jedz&Swoje&Warzywa")
ds_map_add(global.text_data_en, "obj_vegetoid_190", "%%%")
ds_map_add(global.text_data_en, "obj_vegetoid_383", "* Vegetoid dał ci&  tajemniczy uśmiech.")
ds_map_add(global.text_data_en, "obj_vegetoid_384", "* Vegetoid śmieje się łagodnie.")
ds_map_add(global.text_data_en, "obj_vegetoid_385", "* Vegetoid jest tutaj&  dla twojego&  zdrowia.")
ds_map_add(global.text_data_en, "obj_vegetoid_386", "* Pachnie jak marchewki&  i groszek na parze.")
ds_map_add(global.text_data_en, "obj_vegetoid_387", "* Vegetoid wydaje się&  trochę posiniaczony.")
ds_map_add(global.text_data_en, "obj_vegetoid_414", "* VEGETOID - ATK 6 DEF 6&* Porcjowanie: 1 Potwór&* Niemonitorowane przez USDA/^")
ds_map_add(global.text_data_en, "obj_vegetoid_428", "* Spróowałeś pożreć Vegetoida^1,&  ale nie było wystarczająco&  osłabione./^")
ds_map_add(global.text_data_en, "obj_vegetoid_431", "* Odgryzłeś kawałek&  Vegetoida^1.&* Odzyskałeś 5 HP!/^")
ds_map_add(global.text_data_en, "obj_vegetoid_445", "* Klepiesz się po brzuchu^1.&* Vegetoid oferuje zdrowy&  posiłek./^")
ds_map_add(global.text_data_en, "obj_vsflowey_heartdefeated_114", "  I ty NIGDY się&  nie budzisz!^3 %%")
ds_map_add(global.text_data_en, "obj_vsflowey_heartdefeated_115", "%%")
ds_map_add(global.text_data_en, "obj_vsflowey_heartdefeated_198", "  To wszystko &  jest złym&  snem...^4 %%")
ds_map_add(global.text_data_en, "obj_vsflowey_heartdefeated_199", "%%%")
ds_map_add(global.text_data_en, "obj_vulkin_271", "Ah!&Pomogę!&Lecząca&magma!")
ds_map_add(global.text_data_en, "obj_vulkin_272", "Jesteś&ranny!&Pomogę&ci!!!")
ds_map_add(global.text_data_en, "obj_vulkin_277", "Thunder!&Helpful&speed&up!!!")
ds_map_add(global.text_data_en, "obj_vulkin_278", "Speed&will&help&dodge!!")
ds_map_add(global.text_data_en, "obj_vulkin_283", "Ahh...")
ds_map_add(global.text_data_en, "obj_vulkin_284", "Does&not&help...")
ds_map_add(global.text_data_en, "obj_vulkin_291", "Oh!&Ah!&I'm&helping!")
ds_map_add(global.text_data_en, "obj_vulkin_292", "Feels&so&warm...")
ds_map_add(global.text_data_en, "obj_vulkin_298", "Ahh!&Tries&the&hardest!")
ds_map_add(global.text_data_en, "obj_vulkin_299", "Works&hard!&Works&hot!")
ds_map_add(global.text_data_en, "obj_vulkin_307", "Ahh!&Ahh!&Does&my best!")
ds_map_add(global.text_data_en, "obj_vulkin_314", "Ahh...&Not...&helping?&OK...")
ds_map_add(global.text_data_en, "obj_vulkin_317", "Trash...&rump...&Ahh...")
ds_map_add(global.text_data_en, "obj_vulkin_323", "Ahh...&So...&LOVEY!")
ds_map_add(global.text_data_en, "obj_vulkin_325", "Hug...&continue&...")
ds_map_add(global.text_data_en, "obj_vulkin_327", "Starting&to get&weird.")
ds_map_add(global.text_data_en, "obj_vulkin_332", "%%%")
ds_map_add(global.text_data_en, "obj_vulkin_538", "* Vulkin parades around the&  room.")
ds_map_add(global.text_data_en, "obj_vulkin_539", "* Vulkin is making coffee&  in its crater.")
ds_map_add(global.text_data_en, "obj_vulkin_540", "* Vulkin is wiggling its&  weird rump.")
ds_map_add(global.text_data_en, "obj_vulkin_541", "* Vulkin makes a smoke hoop&  and jumps through it.")
ds_map_add(global.text_data_en, "obj_vulkin_542", "* Smells like a lava lamp.")
ds_map_add(global.text_data_en, "obj_vulkin_544", "* Vulkin's cheeks glow with&  a bright heat.")
ds_map_add(global.text_data_en, "obj_vulkin_545", "* Vulkin parades around you&  proudly.")
ds_map_add(global.text_data_en, "obj_vulkin_546", "* Vulkin stands in the corner.")
ds_map_add(global.text_data_en, "obj_vulkin_547", "* Little streams of lava come&  from Vulkin's eyes.")
ds_map_add(global.text_data_en, "obj_vulkin_551", "* Vulkin reassures you the&  plane turning tiny is^1, like^1,&  completely intentional.")
ds_map_add(global.text_data_en, "obj_vulkin_599", "* VULKIN - ATK 25 DEF 0&* Mistakenly believes its lava&  can heal people./^")
ds_map_add(global.text_data_en, "obj_vulkin_608", "* You tell Vulkin that its&  attacks are NOT helpful./^")
ds_map_add(global.text_data_en, "obj_vulkin_609", "* You tell Vulkin that its&  rump looks like a sack&  of trash./^")
ds_map_add(global.text_data_en, "obj_vulkin_627", "* You tell Vulkin it's doing&  a great job.&* Its attacks become extreme.../^")
ds_map_add(global.text_data_en, "obj_vulkin_640", "* You give Vulkin a hug^1.&* It warms your heart.../")
ds_map_add(global.text_data_en, "obj_vulkin_644", "* And your whole body!&* Ouch!&* Your DEFENSE dropped!/^")
ds_map_add(global.text_data_en, "obj_vulkin_647", "* Nothing else happened./^")
ds_map_add(global.text_data_en, "obj_vulkinnpc_72", "* Oh..^1.&* When you hug me^1, I feel..^1.&* So spicey./%%")
