ds_map_add(global.text_data_en, "obj_papdate_367", '"' + "NOŚ UBRANIA..." + '"' + "/")
ds_map_add(global.text_data_en, "obj_papdate_369", "TO COŚ NA&TWOIM CIELE.../")
ds_map_add(global.text_data_en, "obj_papdate_370", "TEN BANDAŻ&ZWISAJĄCY OD&CIEBIE.../")
ds_map_add(global.text_data_en, "obj_papdate_371", "TA WSTĄŻKA W&TWOICH WŁOSACH.../")
ds_map_add(global.text_data_en, "obj_papdate_372", "TA BANDANA&OWINIĘTA WOKÓŁ&TWOJEJ GŁOWY.../")
ds_map_add(global.text_data_en, "obj_papdate_373", "TO TUTU&OWINIĘTE W&TWOJEJ TALII.../")
ds_map_add(global.text_data_en, "obj_papdate_374", "TE OKULARY NA&TWOJEJ TWARZY.../")
ds_map_add(global.text_data_en, "obj_papdate_375", "TEN FARTUCH&KTÓRY ZAŁOŻYŁEŚ.../")
ds_map_add(global.text_data_en, "obj_papdate_376", "TA CZAPKA&KOWBOJA NA&TWOJEJ GŁOWIE.../")
ds_map_add(global.text_data_en, "obj_papdate_377", "TEN WISIOREK&NA TWOJEJ&SZYI./")
ds_map_add(global.text_data_en, "obj_papdate_378", "\E1NOSISZ UBRANIA&JUŻ TERAZ!!!/")
ds_map_add(global.text_data_en, "obj_papdate_379", "\E3MAŁO TEGO.../")
ds_map_add(global.text_data_en, "obj_papdate_380", "\E1WCZEŚNIEJ TEGO&SAMEGO DNIA^1, TY&TEŻ NOSIŁEŚ UBRANIA!/")
