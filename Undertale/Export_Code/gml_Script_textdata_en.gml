ds_map_add(global.text_data_en, "obj_colorlever_89", "* (Klik!^1)&* (Czerwony klucz idealnie&  pasuje do zamku.)/%%")
ds_map_add(global.text_data_en, "obj_colorlever_98", "* (To jakiś rodzaj dźwigni.^1)&* (Jest niebieski zamek&  w środku.)/%%")
ds_map_add(global.text_data_en, "obj_colorlever_102", "* (Niebieska dźwignia&  została uruchomiona.)/%%")
ds_map_add(global.text_data_en, "obj_colorlever_110", "* (Klik!^1)&* (Niebieski klucz idealnie&  pasuje do zamku.)/%%")
ds_map_add(global.text_data_en, "obj_colorlever_119", "* (To jakiś rodzaj dźwigni.^1)&* (Jest zielony zamek&  w środku.)/%%")
ds_map_add(global.text_data_en, "obj_colorlever_123", "* (Zielona dźwignia&  została uruchomiona.)/%%")
ds_map_add(global.text_data_en, "obj_colorlever_131", "* (Klik!^1)&* (Zielony klucz idealnie&  pasuje do zamku.)/%%")
ds_map_add(global.text_data_en, "obj_colorlever_140", "* (To jakiś rodzaj dźwigni.^1)&* (Jest żółty zamek&  w środku.)/%%")
ds_map_add(global.text_data_en, "obj_colorlever_144", "* Żółta dźwignia&  została uruchomiona.)/%%")
ds_map_add(global.text_data_en, "obj_colorlever_152", "* (Klik!^1)&* (Żółty klucz idealnie&  pasuje do zamku.)/%%")
ds_map_add(global.text_data_en, "obj_controlspear_89", "* Aim with arrows and select with \*Z.")
ds_map_add(global.text_data_en, "obj_controlspear_90", "* Aim with \*A \*D and select with \*Z.")
ds_map_add(global.text_data_en, "obj_controlspear_132", "* Teabox - Blatantly correct choice.")
ds_map_add(global.text_data_en, "obj_controlspear_143", "* Hot Chocolate - Green cylinder.")
ds_map_add(global.text_data_en, "obj_controlspear_154", "* Soda - Sickly yellow liquid.")
ds_map_add(global.text_data_en, "obj_controlspear_165", "* Sugar - Goes in tea.")
ds_map_add(global.text_data_en, "obj_controlspear_176", "* Undyne.")
ds_map_add(global.text_data_en, "obj_controlspear_192", "* Fridge - Full of food.")
ds_map_add(global.text_data_en, "obj_controlspear_204", "* Sword - Acquired taste.")
ds_map_add(global.text_data_en, "obj_controlspear_select", "* Select with \*Z.")
ds_map_add(global.text_data_en, "obj_controlspear_218", "\E1* ... are you.../")
ds_map_add(global.text_data_en, "obj_controlspear_219", "\E5* Hitting on me????/%%")
ds_map_add(global.text_data_en, "obj_controlspear_223", "* ????????????????/%%")
ds_map_add(global.text_data_en, "obj_controlspear_235", "* The sugar is for&  tea^1, mmm'kay?/%%")
ds_map_add(global.text_data_en, "obj_controlspear_243", "* Oh^1, soda?/")
ds_map_add(global.text_data_en, "obj_controlspear_244", "\E4* Actually^1, even though&  you pointed to it^1,&  you don't look happy./")
ds_map_add(global.text_data_en, "obj_controlspear_245", "\E0* Heh^1, that's fine^1!&* I think soda's gross^1,&  too!/")
ds_map_add(global.text_data_en, "obj_controlspear_246", "\E4* It rots your teeth..^1.&* It rots your mind.../")
ds_map_add(global.text_data_en, "obj_controlspear_247", "\E1* IT ROTS YOUR FIGHTING&  SPIRIT!/")
ds_map_add(global.text_data_en, "obj_controlspear_248", "\E9* ... huh^1?&* Why do I have it?/")
ds_map_add(global.text_data_en, "obj_controlspear_249", "\E8* .../%%")
ds_map_add(global.text_data_en, "obj_controlspear_253", "* What^1?&* You wanna throw the&  spear at it?/%%")
ds_map_add(global.text_data_en, "obj_controlspear_261", "* Oh^1, you want some&  hot chocolate?/")
ds_map_add(global.text_data_en, "obj_controlspear_262", "\E1* Wait^1, wait^1, I just&  remembered..^1.&* That container's empty./")
ds_map_add(global.text_data_en, "obj_controlspear_263", "\E9* I stopped getting&  it because it was&  always a hassle.../")
ds_map_add(global.text_data_en, "obj_controlspear_264", "\E6* ASGORE kept getting&  marshmallows stuck in&  his beard./%%")
ds_map_add(global.text_data_en, "obj_controlspear_268", "* That container's empty./%%")
ds_map_add(global.text_data_en, "obj_controlspear_276", "\E9* ... tea^1, huh^1?&* Coming right up!/%%")
ds_map_add(global.text_data_en, "obj_controlspear_284", "* The fridge!^1?&* You want to have&  the entire fridge!?/")
ds_map_add(global.text_data_en, "obj_controlspear_285", "\E1* No!/%%")
ds_map_add(global.text_data_en, "obj_controlspear_291", "* Believe me^1, I would&  GLADLY give you your&  fill of swords./")
ds_map_add(global.text_data_en, "obj_controlspear_292", "\E9* If you weren't my&  beloved houseguest!/%%")
ds_map_add(global.text_data_en, "obj_convenientlamp_55", "* Tylko dogodnie-&  ukształtowana lampa./%%")
ds_map_add(global.text_data_en, "obj_cookshowevent_89", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_cookshowevent_90", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_cookshowevent_91", "* H-hey^1, it's kind of&  dark \M9in there^1, isn't&  it?/")
ds_map_add(global.text_data_en, "obj_cookshowevent_92", "\E6* Don't worry!/")
ds_map_add(global.text_data_en, "obj_cookshowevent_93", "\E0*\M8 I'll hack into the&  light system and&  brighten it up!/%%")
ds_map_add(global.text_data_en, "obj_cookshowevent_135", "* Oh no./%%")
ds_map_add(global.text_data_en, "obj_cookshowevent_156", "* OHHHH YES!!!/")
ds_map_add(global.text_data_en, "obj_cookshowevent_157", "* WELCOME^1, BEAUTIES, TO THE&  UNDERGROUND'S PREMIER COOKING&  SHOW!!!/%%")
ds_map_add(global.text_data_en, "obj_cookshowevent_174", "* PRE-HEAT YOUR OVENS^1, BECAUSE&  WE'VE GOT A VERY SPECIAL&  RECIPE FOR YOU TODAY!/")
ds_map_add(global.text_data_en, "obj_cookshowevent_175", "* WE'RE GOING TO BE MAKING.../")
ds_map_add(global.text_data_en, "obj_cookshowevent_176", "* A CAKE!/")
ds_map_add(global.text_data_en, "obj_cookshowevent_177", "* MY LOVELY ASSISTANT HERE&  WILL GATHER THE INGREDIENTS./")
ds_map_add(global.text_data_en, "obj_cookshowevent_178", "* EVERYONE GIVE THEM A BIG&  HAND!!!/%%")
ds_map_add(global.text_data_en, "obj_cookshowevent_202", "\W* WE'LL NEED \YSUGAR^1,&  MILK^1, \WAND\Y EGGS.\W /")
ds_map_add(global.text_data_en, "obj_cookshowevent_203", "* GO FOR IT^1, SWEETHEART!/%%")
ds_map_add(global.text_data_en, "obj_cookshowevent_253", "\W* A \YHUMAN SOUL\W!!!!/%%")
ds_map_add(global.text_data_en, "obj_cookshowevent_295", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_cookshowevent_296", "\TS \E3 \F0 \TM %")
ds_map_add(global.text_data_en, "obj_cookshowevent_297", "* HELLO...?&* I'M KIND OF IN THE&  MIDDLE OF SOMETHING HERE./")
ds_map_add(global.text_data_en, "obj_cookshowevent_298", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_cookshowevent_299", "* W-wait a second!!!/")
ds_map_add(global.text_data_en, "obj_cookshowevent_300", "* Couldn't you make&  a.../")
ds_map_add(global.text_data_en, "obj_cookshowevent_301", "\E6* Couldn't you use&  a.../")
ds_map_add(global.text_data_en, "obj_cookshowevent_302", "\E4* Couldn't you make&  a substitution in&  the recipe?!/")
ds_map_add(global.text_data_en, "obj_cookshowevent_303", "\TS \E3 \F0 \TM %")
ds_map_add(global.text_data_en, "obj_cookshowevent_304", "* ... A SUBSTITUTION?&* YOU MEAN, USE A DIFFERENT,&  NON-HUMAN INGREDIENT?/")
ds_map_add(global.text_data_en, "obj_cookshowevent_305", "* ... WHY?/")
ds_map_add(global.text_data_en, "obj_cookshowevent_306", "\TS \E6 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_cookshowevent_307", "* Uhh^1, what if&  someone's.../")
ds_map_add(global.text_data_en, "obj_cookshowevent_308", "\E2* .../")
ds_map_add(global.text_data_en, "obj_cookshowevent_309", "\E4* Vegan?/")
ds_map_add(global.text_data_en, "obj_cookshowevent_310", "\TS \E3 \F0 \TM %")
ds_map_add(global.text_data_en, "obj_cookshowevent_311", "* ... VEGAN./")
ds_map_add(global.text_data_en, "obj_cookshowevent_312", "\TS \E5 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_cookshowevent_313", "* Uh well I mean%%")
ds_map_add(global.text_data_en, "obj_cookshowevent_326", "* THAT'S A BRILLIANT IDEA,&  ALPHYS!!/")
ds_map_add(global.text_data_en, "obj_cookshowevent_327", "* ACTUALLY, I HAPPEN TO&  HAVE AN OPTION RIGHT HERE!!!/")
ds_map_add(global.text_data_en, "obj_cookshowevent_328", "* MTT-BRAND ALWAYS-CONVENIENT&  HUMAN-SOUL-FLAVOR-SUBSTITUTE!/")
ds_map_add(global.text_data_en, "obj_cookshowevent_329", "* A CAN OF WHICH...&* IS JUST OVER ON THAT&  COUNTER!!!/%%")
ds_map_add(global.text_data_en, "obj_cookshowevent_376", "* WELL, DARLING?&* WHY DON'T YOU GO GET IT?/%%")
ds_map_add(global.text_data_en, "obj_cookshowevent_434", "* BY THE WAY^1, OUR SHOW RUNS ON&  A STRICT SCHEDULE./")
ds_map_add(global.text_data_en, "obj_cookshowevent_435", "\W* IF YOU CAN'T GET THE&  CAN IN THE NEXT&  \YONE MINUTE...\W /")
ds_map_add(global.text_data_en, "obj_cookshowevent_436", "\W* WE'LL JUST HAVE TO GO&  BACK TO THE \RORIGINAL PLAN\W!!!/")
ds_map_add(global.text_data_en, "obj_cookshowevent_437", "* SO...&* BETTER START CLIMBING,&  BEAUTIFUL!!!/%%")
ds_map_add(global.text_data_en, "obj_cookshowevent_472", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_cookshowevent_473", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_cookshowevent_474", "* Oh no!!^1!&* There's not enough&  time to climb up!/")
ds_map_add(global.text_data_en, "obj_cookshowevent_475", "\E2* .../")
ds_map_add(global.text_data_en, "obj_cookshowevent_476", "\E6* F-f-fortunately, I&  might have a plan!/")
ds_map_add(global.text_data_en, "obj_cookshowevent_477", "\E0* When I was upgrading&  your phone, I added&  a few... features./")
ds_map_add(global.text_data_en, "obj_cookshowevent_478", "\E6* You see that huge&  button that says..^1.&* " + '"' + "JETPACK" + '"' + "?/")
ds_map_add(global.text_data_en, "obj_cookshowevent_479", "\E3* Watch this!/%%")
ds_map_add(global.text_data_en, "obj_cookshowevent_515", "* There!/")
ds_map_add(global.text_data_en, "obj_cookshowevent_516", "* You should have&  just enough fuel to&  reach the top!/")
ds_map_add(global.text_data_en, "obj_cookshowevent_517", "\E3* Now^1, get up&  there!!!/%%")
ds_map_add(global.text_data_en, "obj_cookshowevent_565", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_cookshowevent_566", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_cookshowevent_567", "* Wow^1!&* We..^1. we did it!!/")
ds_map_add(global.text_data_en, "obj_cookshowevent_568", "\E0* We..^1. we really did&  it!!!/")
ds_map_add(global.text_data_en, "obj_cookshowevent_569", "\E0* Great job out&  there^1, team!/")
ds_map_add(global.text_data_en, "obj_cookshowevent_570", "\E3* W-well^1, uh^1, anyway^1,&  let's keep heading&  forward!!!/")
ds_map_add(global.text_data_en, "obj_cookshowevent_571", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_cookshowevent_572", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_cookshowevent_575", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_cookshowevent_576", "\TS \E1 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_cookshowevent_577", "* .../")
ds_map_add(global.text_data_en, "obj_cookshowevent_578", "\E4* U-um..^1.&* I guess we..^1.&* ... did it?/")
ds_map_add(global.text_data_en, "obj_cookshowevent_579", "\E3* W-well^1, uh^1, anyway^1,&  let's keep heading&  forward!!!/")
ds_map_add(global.text_data_en, "obj_cookshowevent_580", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_cookshowevent_581", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_core_enemyevent_97", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_core_enemyevent_98", "\TS \E6 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_core_enemyevent_99", "* H-hey^1, why don't&  you try to use&  the elevator first?/")
ds_map_add(global.text_data_en, "obj_core_enemyevent_100", "* .../%%")
ds_map_add(global.text_data_en, "obj_core_enemyevent_106", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_core_enemyevent_107", "\TS \E6 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_core_enemyevent_108", "* H-hey^1, why don't&  you try to go&  to the right first?/")
ds_map_add(global.text_data_en, "obj_core_enemyevent_109", "* .../%%")
ds_map_add(global.text_data_en, "obj_core_enemyevent_116", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_core_enemyevent_117", "\TS \E6 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_core_enemyevent_118", "* Okay^1, you should&  be able to make&  it through here.../")
ds_map_add(global.text_data_en, "obj_core_enemyevent_119", "* .../%%")
ds_map_add(global.text_data_en, "obj_core_enemyevent_139", "* W-watch out!/%%")
ds_map_add(global.text_data_en, "obj_core_enemyevent_182", "* Th-that was close.../")
ds_map_add(global.text_data_en, "obj_core_enemyevent_183", "* Wh..^1. why are there&  so many monsters&  here?/")
ds_map_add(global.text_data_en, "obj_core_enemyevent_184", "\E6* I mean..^1.&* It's no problem^1,&  r-r-right?/")
ds_map_add(global.text_data_en, "obj_core_enemyevent_185", "* W-w-we've just got&  to keep heading&  forward!/")
ds_map_add(global.text_data_en, "obj_core_enemyevent_186", "\E9* .../")
ds_map_add(global.text_data_en, "obj_core_enemyevent_187", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_core_enemyevent_188", "* (Klik...)/%%")
ds_map_add(global.text_data_en, "obj_core_enemyevent2_142", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_core_enemyevent2_143", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_core_enemyevent2_144", "* Sorry^1, I..^1. I.../")
ds_map_add(global.text_data_en, "obj_core_enemyevent2_145", "* I thought that.../")
ds_map_add(global.text_data_en, "obj_core_enemyevent2_146", "\E8* Let's try the&  right path instead./")
ds_map_add(global.text_data_en, "obj_core_enemyevent2_147", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_core_enemyevent2_148", "* (Klik...)/%%")
ds_map_add(global.text_data_en, "obj_core_enemyevent2_152", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_core_enemyevent2_153", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_core_enemyevent2_154", "* A-are you okay?/")
ds_map_add(global.text_data_en, "obj_core_enemyevent2_155", "* Why didn't you&  head to the&  right...?/")
ds_map_add(global.text_data_en, "obj_core_enemyevent2_156", "\E4* C-C'mon..^1.&* Y-you trust me^1,&  d-don't you?/")
ds_map_add(global.text_data_en, "obj_core_enemyevent2_157", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_core_enemyevent2_158", "* (Klik...)/%%")
ds_map_add(global.text_data_en, "obj_core_laserswitch_118", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_core_laserswitch_119", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_core_laserswitch_120", "* Oh my god^1, are&  you okay?/")
ds_map_add(global.text_data_en, "obj_core_laserswitch_121", "\E8* I..^1. I'm sorry^1, I&  gave you the&  wrong order./")
ds_map_add(global.text_data_en, "obj_core_laserswitch_122", "\E8* .../")
ds_map_add(global.text_data_en, "obj_core_laserswitch_123", "\E6* E-everything's fine^1,&  okay?/")
ds_map_add(global.text_data_en, "obj_core_laserswitch_124", "* L-let's just keep&  heading to the&  right./")
ds_map_add(global.text_data_en, "obj_core_laserswitch_125", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_core_laserswitch_126", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_core_laserswitch_130", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_core_laserswitch_131", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_core_laserswitch_132", "* Oh my god..^1.&* Are you hurt?/")
ds_map_add(global.text_data_en, "obj_core_laserswitch_133", "\E8* I..^1. I'm so sorry^1,&  I... I gave you&  the wrong order./")
ds_map_add(global.text_data_en, "obj_core_laserswitch_134", "\E8* .../")
ds_map_add(global.text_data_en, "obj_core_laserswitch_135", "\E6* Everything's going&  to be fine^1, okay?/")
ds_map_add(global.text_data_en, "obj_core_laserswitch_136", "* L-let's just keep&  heading to the&  right./")
ds_map_add(global.text_data_en, "obj_core_laserswitch_137", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_core_laserswitch_138", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_countermiddle_116", "* SUPER^1!&* DOBRA ROBOTA^1, PRZEPIĘKNA!/")
ds_map_add(global.text_data_en, "obj_countermiddle_117", "* MAMY WSZYSTKIE SKŁADNIKI&  KTÓRE POTRZEBUJEMY DO&  UPIECZENIA CIASTA!/")
ds_map_add(global.text_data_en, "obj_countermiddle_118", "\W* \YMLEKO\W... &* \YCUKIER\W...&* \YJAJKA\W.../")
ds_map_add(global.text_data_en, "obj_countermiddle_119", "* ... O MATKO^1!&* ZACZEKAJ WSPANIAŁĄ CHWILĘ^1!&* JAK MOGŁEM ZAPOMNIEĆ!!!/")
ds_map_add(global.text_data_en, "obj_countermiddle_120", "\W* BRAKUJE NAM NAJBARDZIEJ&  \YWAŻNEGO SKŁADNIKA\W!/%%")
ds_map_add(global.text_data_en, "obj_creditsloader_449", "\XW sensie^1, my nawet&nie robiliśmy jeszcze\R &Specjalnych Podziękowań\X.../")
ds_map_add(global.text_data_en, "obj_creditsloader_450", "Gotowy^1?&Zakończmy to&wszystko na dobre!/%%")
ds_map_add(global.text_data_en, "obj_creditsloader_492", "Ha ha ha ha... /")
ds_map_add(global.text_data_en, "obj_creditsloader_493", "\M1Czy ty NAPRAWDĘ&myślałeś że to&KONIEC!?!?/%%")
