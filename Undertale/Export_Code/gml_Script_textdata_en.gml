ds_map_add(global.text_data_en, "obj_royal_rabbitbounce_88", "* So^1, like^1, us Royal Guards are&  blocking off the elevators&  for now./")
ds_map_add(global.text_data_en, "obj_royal_rabbitbounce_89", "* Ngah^1! Even if the elevators&  aren't working anyway^1, we'll&  do our best^1, Ms. UNDYNE!/%%")
ds_map_add(global.text_data_en, "obj_royal_rabbitbounce_93", "* Like^1, NO WAY you're getting&  by us./")
ds_map_add(global.text_data_en, "obj_royal_rabbitbounce_94", "* But^1, between you and me...&* I think you could go through&  that creepy lab over there./")
ds_map_add(global.text_data_en, "obj_royal_rabbitbounce_95", "* Between you^1, me^1, and my&  bro here^1, I mean./")
ds_map_add(global.text_data_en, "obj_royal_rabbitbounce_96", "* I tell him ALL my secrets./%%")
ds_map_add(global.text_data_en, "obj_royal_rabbitbounce_101", "* Hey^1!&* No loitering!/")
ds_map_add(global.text_data_en, "obj_royal_rabbitbounce_102", "* Like^1, just kidding^1.&* I don't care^1.&* Like^1, loiter your heart out./%%")
ds_map_add(global.text_data_en, "obj_royal_rabbitbounce_107", "* Oh^1, hey./")
ds_map_add(global.text_data_en, "obj_royal_rabbitbounce_108", "* We're^1, like^1, taking a rain&  check on that killing-you&  thing./")
ds_map_add(global.text_data_en, "obj_royal_rabbitbounce_109", "* Like^1, don't tell Undyne&  about this^1, OK?/%%")
ds_map_add(global.text_data_en, "obj_royal_rabbitbounce_113", "* You didn't tell her^1, did&  you...?/%%")
ds_map_add(global.text_data_en, "obj_royal_rabbitbounce_118", "* Undyne told us that the&  Royal Guard is being disbanded./")
ds_map_add(global.text_data_en, "obj_royal_rabbitbounce_119", "* Like^1, bummer..^1.&* Guess we'll have to get&  used to Love and Peace./%%")
ds_map_add(global.text_data_en, "obj_saddragon_70", "* Yeah^1, I'm not gonna be home&  tonight... um.../")
ds_map_add(global.text_data_en, "obj_saddragon_71", "* I think there's some cold&  pizza in my treasure horde&  you can heat up.../%%")
ds_map_add(global.text_data_en, "obj_saddragon_75", "* Ummm^1, are you guys on your&  way out^1?/")
ds_map_add(global.text_data_en, "obj_saddragon_76", "* Guess I'll catch up with you&  later.../%%")
ds_map_add(global.text_data_en, "obj_saddragon_81", "* Yeah^1, I'm not gonna be home&  tonight... um.../")
ds_map_add(global.text_data_en, "obj_saddragon_82", "* In fact^1, I don't feel like&  I'll be home tomorrow^1,&  either^1, at this rate.../%%")
ds_map_add(global.text_data_en, "obj_sans_friendc_75", "* hey^1, frisk^1, what's&  with that weird&  expression?/")
ds_map_add(global.text_data_en, "obj_sans_friendc_77", "\E2* Sans^1, did I tell you&  about the time Frisk&  flirted with me...?/")
ds_map_add(global.text_data_en, "obj_sans_friendc_79", "\E8* And then asked to&  call me " + '"' + "mother?" + '"' + "/")
ds_map_add(global.text_data_en, "obj_sans_friendc_81", "\E0* I felt so embarrassed&  for them./")
ds_map_add(global.text_data_en, "obj_sans_friendc_83", "\E1* oh boy./")
ds_map_add(global.text_data_en, "obj_sans_friendc_85", "\E3WOW^1, FRISK.../")
ds_map_add(global.text_data_en, "obj_sans_friendc_86", "\E0THIS REALLY PUTS&OUR RELATIONSHIP&IN A NEW LIGHT./")
ds_map_add(global.text_data_en, "obj_sans_friendc_88", "\E1* hey^1, tori^1, do you&  have any other&  embarrassing stories?/")
ds_map_add(global.text_data_en, "obj_sans_friendc_90", "\E0* Oh^1, do I ever!/")
ds_map_add(global.text_data_en, "obj_sans_friendc_91", "\E1* But, I think that&  story is one of the&  most unbelievable./")
ds_map_add(global.text_data_en, "obj_sans_friendc_92", "\E0* It is hard to think&  anyone would want to&  flirt with me./")
ds_map_add(global.text_data_en, "obj_sans_friendc_94", "\E0* Ehehe.../")
ds_map_add(global.text_data_en, "obj_sans_friendc_95", "\E7* Ehehehe.../")
ds_map_add(global.text_data_en, "obj_sans_friendc_96", "\E1* AHA^1! AHAHAH^1!&* HA!^1! HA!!!/")
ds_map_add(global.text_data_en, "obj_sans_friendc_97", "\E2* Oh^1, Toriel^1.&* You have NO idea./%%")
ds_map_add(global.text_data_en, "obj_sans_friendc_102", "\E0* oh hey^1, what's up^1,&  frisk?/")
ds_map_add(global.text_data_en, "obj_sans_friendc_103", "\E2* we were just talking&  about you./")
ds_map_add(global.text_data_en, "obj_sans_friendc_104", "\E1* apparently you asked&  to call tori " + '"' + "mom" + '"' + " right&  after meeting her?/")
ds_map_add(global.text_data_en, "obj_sans_friendc_106", "\E1* Well^1, it was not&  RIGHT after./")
ds_map_add(global.text_data_en, "obj_sans_friendc_107", "\E0* It took a couple&  minutes./")
ds_map_add(global.text_data_en, "obj_sans_friendc_109", "\E0* frisk..^1.&* i gotta tell ya./")
ds_map_add(global.text_data_en, "obj_sans_friendc_110", "\E2* that's^1, uh^1, not the&  best way to get&  to know someone./")
ds_map_add(global.text_data_en, "obj_sans_friendc_112", "\E3IT'S NOT???/")
ds_map_add(global.text_data_en, "obj_sans_friendc_114", "\E9* Papyrus^1, we've been&  over this./")
ds_map_add(global.text_data_en, "obj_sans_friendc_116", "\E4WHATEVER^1, MOM!!!/")
ds_map_add(global.text_data_en, "obj_sans_friendc_118", "\E1* Don't talk back to&  me like that!/")
ds_map_add(global.text_data_en, "obj_sans_friendc_119", "\E6* Go to your room^1,&  Papyrus!/")
ds_map_add(global.text_data_en, "obj_sans_friendc_121", "\E5OK^1, UNDYNE./")
ds_map_add(global.text_data_en, "obj_sans_friendc_123", "\E1* Wait^1!&* Don't ACTUALLY go&  to your room!!/")
ds_map_add(global.text_data_en, "obj_sans_friendc_125", "\E7I'M GETTING MIXED&  MESSAGES HERE!!!/%%")
ds_map_add(global.text_data_en, "obj_sans_friendc_131", "\E0* frisk^1, tori was telling&  me how she made&  b'scotch pie for you./")
ds_map_add(global.text_data_en, "obj_sans_friendc_133", "\E0* Oh^1, I should bake it&  for everyone sometime!/")
ds_map_add(global.text_data_en, "obj_sans_friendc_135", "* .../")
ds_map_add(global.text_data_en, "obj_sans_friendc_137", "\E3* (O-oh^1, that sounds&  REALLY good.)/")
ds_map_add(global.text_data_en, "obj_sans_friendc_139", "\E3COOKING???/")
ds_map_add(global.text_data_en, "obj_sans_friendc_140", "\E0CAN I HELP?/")
ds_map_add(global.text_data_en, "obj_sans_friendc_142", "* Wait a second!!!/")
ds_map_add(global.text_data_en, "obj_sans_friendc_143", "\E6* Can I help too!?/")
ds_map_add(global.text_data_en, "obj_sans_friendc_145", "\E0* Certainly^1!&* It would be fun to&  cook together!/")
ds_map_add(global.text_data_en, "obj_sans_friendc_147", "\E9* (On second thought^1,&  maybe I'll o-order&  a pizza.)/%%")
ds_map_add(global.text_data_en, "obj_sans_friendc_154", "\E0* sorry..^1.&* i don't have time&  to talk^1, frisk./")
ds_map_add(global.text_data_en, "obj_sans_friendc_155", "\E1* i'm supposed to be&  working right now./")
ds_map_add(global.text_data_en, "obj_sans_friendc_157", "\E4BUT YOU AREN'T&  WORKING!!!/")
ds_map_add(global.text_data_en, "obj_sans_friendc_159", "\E2* i know^1, and it's&  taking all my&  concentration./%%")
ds_map_add(global.text_data_en, "obj_sans_interactable1_68", "* lepiej już idź^1.&* on może powrócić^1.&* a jeśli powróci.../")
ds_map_add(global.text_data_en, "obj_sans_interactable1_69", "\E2* ... będziesz musiał&  wysłuchać więcej&  moich śmiesznych żartów./%%")
ds_map_add(global.text_data_en, "obj_sans_interactable1_74", "* co to za wstrzymanie^1?&* słuchaj^1, nie ma niczego&  do obawiania się./")
ds_map_add(global.text_data_en, "obj_sans_interactable1_75", "\E2* to tylko ciemna jaskinia&  wypełniona szkieletami&  i okrutnymi potworami./%%")
ds_map_add(global.text_data_en, "obj_sans_interactable1_79", "* cóż?/%%")
ds_map_add(global.text_data_en, "obj_sans_interactable1_85", "\E5* ... będziesz tak po&  prostu gapił się&  na mnie^1, czy...?/%%")
ds_map_add(global.text_data_en, "obj_sans_prefinaldate_127", "* grievous error/%%")
ds_map_add(global.text_data_en, "obj_sans_prefinaldate_297", "* tędy^1.&* znam taki skrót./%%")
ds_map_add(global.text_data_en, "obj_sans_room_114", "* hej^1, jest coś ważnego&  do zapamiętania./")
ds_map_add(global.text_data_en, "obj_sans_room_115", "\W* mój brat posiada dosyć&  \Bspecyficzny atak\W./")
ds_map_add(global.text_data_en, "obj_sans_room_116", "\W* jeśli zobaczysz \Lniebie-&  ski atak\W,^1 nie ruszaj&  się^1, a będzie okej./")
ds_map_add(global.text_data_en, "obj_sans_room_117", "* zaprezentuję łatwy&  sposób na wbicie&  sobie do głowy./")
ds_map_add(global.text_data_en, "obj_sans_room_118", "\W* wyobraź sobie znak STOP^1.&* kiedy widzisz taki znak^1,&  \Rzatrzymujesz\W się^1, ta?/")
ds_map_add(global.text_data_en, "obj_sans_room_119", "\W* znaki stopu są \Rczerwone\W.&* wię wyobraź sobie \Lnie-&  bieski\W znak dla odmiany./")
ds_map_add(global.text_data_en, "obj_sans_room_120", "\W* proste^1, nie^1? kiedy wal-&  czysz^1, pomyśł sobie o&  \Yniebieskich stop\W./%%")
ds_map_add(global.text_data_en, "obj_sans_room_123", "* pamiętaj..^1.&* niebieskie znaki stop./%%")
ds_map_add(global.text_data_en, "obj_sans_room_128", "* ... heja./%%")
ds_map_add(global.text_data_en, "obj_sans_room_135", "* hej^1, dzięki tak wogule.^1.&* mój brat wydaje się&  na zadowolonego./")
ds_map_add(global.text_data_en, "obj_sans_room_136", "* tak wogule^1, widziałeś&  ten dziwny outfit^1,&  który nosi na sobie?/")
ds_map_add(global.text_data_en, "obj_sans_room_137", "* zrobiliśmy go kilka&  tygodni temu na bal&  kostiumowy./")
ds_map_add(global.text_data_en, "obj_sans_room_138", "* od wtedy nie zakładał&  nic innego.../")
ds_map_add(global.text_data_en, "obj_sans_room_139", "* cały czas to nazywa&  " + '"' + "walecznym ciałem." + '"' + "/")
ds_map_add(global.text_data_en, "obj_sans_room_140", "* bro./")
ds_map_add(global.text_data_en, "obj_sans_room_141", "\E1* czy mój bro nie&  jest czadowy?/%%")
ds_map_add(global.text_data_en, "obj_sans_room_145", "\E5* mój brat byłby&  szczęśliwy gdybyś się&  wczuł w ten roleplay./%%")
ds_map_add(global.text_data_en, "obj_sans_room_160", "* dzięki^1, że powiedziałeś&  " + '"' + "junior jumble" + '"' + " tylko&  żeby uradować Papyrusa./")
ds_map_add(global.text_data_en, "obj_sans_room_161", "\E1* wczoraj wpadł w szał&  próbując " + '"' + "rozwiązać" + '"' + "&  jego horoskop./%%")
ds_map_add(global.text_data_en, "obj_sans_room_166", "* papyrus..^1.&* ... ma kompleksy do&  ciekawych miejsc./")
ds_map_add(global.text_data_en, "obj_sans_room_167", "\E1* wczoraj wpadł w szał&  próbując " + '"' + "rozwiązać" + '"' + "&  jego horoskop./%%")
ds_map_add(global.text_data_en, "obj_sans_room_175", "* najwyraźniej nie lubisz&  szukać słów^1, huh?/")
ds_map_add(global.text_data_en, "obj_sans_room_176", "\E2* ja też^1. jestem chyba&  bardziej kimś typu& " + '"' + "wyluzowany ziomek" + '"' + "./")
ds_map_add(global.text_data_en, "obj_sans_room_177", "\E0* .../")
ds_map_add(global.text_data_en, "obj_sans_room_178", "\E1* .../%%")
ds_map_add(global.text_data_en, "obj_sans_room_182", "\E1* najwyraźniej pomimo&  wszystkiego^1, dalej lubisz&  krzyżówki^1, huh...?/")
ds_map_add(global.text_data_en, "obj_sans_room_183", "\E0* to znaczy^1, że nie&  możesz być taki zły./%%")
ds_map_add(global.text_data_en, "obj_sans_room_191", "* tak naprawdę^1,&  to spaghetti&  z wcześniej..^1./")
ds_map_add(global.text_data_en, "obj_sans_room_192", "* nie było najgorsze&  jak na mojego&  brata./")
ds_map_add(global.text_data_en, "obj_sans_room_193", "* odkąd zaczął chodzić na&  lekcje gotowania^1,&  stawał się coraz lepszy./")
ds_map_add(global.text_data_en, "obj_sans_room_194", "\E1* jeśli tak będzie dalej^1,&  może nawet zrobi coś&  rzeczywiście jadalnego./%%")
ds_map_add(global.text_data_en, "obj_sans_room_198", "* hej..^1.&* puzzle mogą być fajne^2.&\E5* gdybyś ich spróbował./%%")
ds_map_add(global.text_data_en, "obj_sans_room_211", "* dobra robota w rozwią-&  zaniu tego tak szybko^1./")
ds_map_add(global.text_data_en, "obj_sans_room_212", "* nawet nie&  potrzebowałeś&  mojej pomocy./")
ds_map_add(global.text_data_en, "obj_sans_room_213", "* co się dobrze składa^1,&  bo kocham robienie&  absolutnie niczego./%%")
ds_map_add(global.text_data_en, "obj_sans_room_217", "* ... musisz być naprawdę&  dobry w łamigówkach^1,&  huh?/")
ds_map_add(global.text_data_en, "obj_sans_room_218", "* w sensie./")
ds_map_add(global.text_data_en, "obj_sans_room_219", "* to niemożliwe że&  nie widziałeś jeszcze&  tego poprzednio./%%")
ds_map_add(global.text_data_en, "obj_sans_room_223", "* hej^1, czemu nie&  poprosiłeś o&  pomoc?/")
ds_map_add(global.text_data_en, "obj_sans_room_224", "\E1* stałem dosłownie obok./%%")
ds_map_add(global.text_data_en, "obj_sans_room_229", "* nie ma problemu^1, huh?/%%")
ds_map_add(global.text_data_en, "obj_sans_room_237", "* co tam?/%%")
ds_map_add(global.text_data_en, "obj_sans_room_238", "* z pewnością lubisz&  wysiłek fizyczny./%%")
ds_map_add(global.text_data_en, "obj_sans_room_246", "* nie wiem co mój brat&  teraz planuje zrobić./")
ds_map_add(global.text_data_en, "obj_sans_room_247", "\W* na twoim miejscu upew-&  niłbym się^1, że rozumiem&  \Bniebieskie ataki\W./%%")
ds_map_add(global.text_data_en, "obj_sans_room_250", "* słuchaj^1, dam ci radę&  co do walki z moim&  bratem./")
ds_map_add(global.text_data_en, "obj_sans_room_251", "\E1* nie walcz^1.&* capiche?/%%")
ds_map_add(global.text_data_en, "obj_sans_room_256", "\E1* hmm.../")
ds_map_add(global.text_data_en, "obj_sans_room_257", "\E2* chyba nie potrzebowa-&  liśmy twojej pomocy by&  dobrze spędzić czas./")
ds_map_add(global.text_data_en, "obj_sans_room_258", "\E3* .../")
ds_map_add(global.text_data_en, "obj_sans_room_259", "\E2* powiedz^1.&  tak sobie myślałem.../")
ds_map_add(global.text_data_en, "obj_sans_room_260", "\E1* wygląda na to^1, że&  niebawem wkroczysz w&  walkę z moim bratem./")
ds_map_add(global.text_data_en, "obj_sans_room_261", "\E2* oto przyjacielska rada./")
ds_map_add(global.text_data_en, "obj_sans_room_262", "\E5* jeśli będziesz szedł&  dalej tą drogą.../")
ds_map_add(global.text_data_en, "obj_sans_room_263", "* .../")
ds_map_add(global.text_data_en, "obj_sans_room_264", "\E4* będziesz miał&  przejebane./%%")
ds_map_add(global.text_data_en, "obj_sans_room_280", "\E0* kurczę^1, szkoda że nie&  wziąłem parasola./")
ds_map_add(global.text_data_en, "obj_sans_room_281", "\E1* dostaję paskudnego&  oparzenia od tego&  całego słońca./%%")
ds_map_add(global.text_data_en, "obj_sans_sentry2_127", "* grievous error/%%")
ds_map_add(global.text_data_en, "obj_sans_sentry2_134", "* spotkajmy się jeszcze&  kiedyś./%%")
ds_map_add(global.text_data_en, "obj_sans_sentry2_141", "\E3* hej^1, naprawdę&  szanuję twój wybór&  tam wcześniej./")
ds_map_add(global.text_data_en, "obj_sans_sentry2_142", "\E2* thanks./%%")
ds_map_add(global.text_data_en, "obj_sans_sentry2_306", "* tędy^1.&* znam taki skrót./%%")
ds_map_add(global.text_data_en, "obj_sansb_90", "* Przeszedłeś dalej.")
ds_map_add(global.text_data_en, "obj_sansb_252", "co^1?&myślałeś że będę&po prostu stać&jak głupi?/%%")
ds_map_add(global.text_data_en, "obj_sansb_256", "nasze dane wykazały&ogromne dziury w&czasoprzestrzeni./")
ds_map_add(global.text_data_en, "obj_sansb_257", "osie czasowe w&prawo i lewo,&zatrzymując i&zaczynając.../%%")
ds_map_add(global.text_data_en, "obj_sansb_262", "\E4aż do chwili^1,&gdy wszystko&się skończy./%%")
ds_map_add(global.text_data_en, "obj_sansb_266", "\E4heh heh heh.../")
ds_map_add(global.text_data_en, "obj_sansb_267", "\E5to twoja wina^1,&czyż nie?/%%")
ds_map_add(global.text_data_en, "obj_sansb_272", "\E1nie jesteś w&stanie zrozumieć&tego uczucia./%%")
ds_map_add(global.text_data_en, "obj_sansb_277", "\E4wiedząc że jednego&dnia^1, bez żadnego&ostrzeżenia.../")
ds_map_add(global.text_data_en, "obj_sansb_278", "\E9to wszystko&zostanie&zresetowane./%%")
ds_map_add(global.text_data_en, "obj_sansb_284", "\E9słuchaj^1.&ja poddałem się&dalszych prób&powrotu już dawno./%%")
ds_map_add(global.text_data_en, "obj_sansb_290", "\E4i dostanie się na&powierzchnięnie&bardzo mnie już&motywuje./%%")
ds_map_add(global.text_data_en, "obj_sansb_296", "\E4bo nawet jeśli&wyjdziemy.../")
ds_map_add(global.text_data_en, "obj_sansb_297", "\E5to i tak skończymy&spowrotem tutaj^1,&bez żadnych wspom-&nień^1, prawda?/%%")
ds_map_add(global.text_data_en, "obj_sansb_303", "\E1szczerze&mówiąc.../")
ds_map_add(global.text_data_en, "obj_sansb_304", "\E4to utrudnia&chęc włożenia&w to wszystkiego./%%")
ds_map_add(global.text_data_en, "obj_sansb_310", "\E1... albo to tylko&głupia wymówka&bycia leniwym...?/")
ds_map_add(global.text_data_en, "obj_sansb_311", "\E3chuj wie./%%")
ds_map_add(global.text_data_en, "obj_sansb_317", "\E4jedyne co wiem..^1.&widząc co będzie&dalej.../")
ds_map_add(global.text_data_en, "obj_sansb_318", "\E9po prostu nie&chce mi się&obchodzić już./%%")
ds_map_add(global.text_data_en, "obj_sansb_334", "\E9ugh..^1.&to powiedziawszy.../")
ds_map_add(global.text_data_en, "obj_sansb_335", "\E1ty^1, uh^1, naprawdę&lubisz huśtać&tym czymś^1, huh?/")
ds_map_add(global.text_data_en, "obj_sansb_336", "\E0.../")
ds_map_add(global.text_data_en, "obj_sansb_337", "\E4słuchaj./")
ds_map_add(global.text_data_en, "obj_sansb_338", "wiem, że poprzednio&mi nie odpowiedziałeś^1,&ale.../")
ds_map_add(global.text_data_en, "obj_sansb_339", "\E4gdzieś tam&u ciebie^1.&czuję to./")
ds_map_add(global.text_data_en, "obj_sansb_340", "\E0czuję promyczek&dobrej osoby&wewnątrz ciebie./")
ds_map_add(global.text_data_en, "obj_sansb_341", "\E4wspomnienia kogoś&kto wcześniej&chciał zrobić&właściwą rzecz./")
ds_map_add(global.text_data_en, "obj_sansb_342", "\E1ktoś kto^1, w&innej osi&czasowej^1, mógł&nawet być.../")
ds_map_add(global.text_data_en, "obj_sansb_343", "\E4przyjacielem?/")
ds_map_add(global.text_data_en, "obj_sansb_344", "\E3no chodź&ziom./")
ds_map_add(global.text_data_en, "obj_sansb_345", "\E0pamiętasz&mnie?/")
ds_map_add(global.text_data_en, "obj_sansb_346", "\E4proszę^1, jeśli&mnie słyszysz.../")
ds_map_add(global.text_data_en, "obj_sansb_347", "\E9zapomnijmy&o tym^1, ok?/")
ds_map_add(global.text_data_en, "obj_sansb_348", "\E3po prostu połóż&twoją broń^1, i.../")
ds_map_add(global.text_data_en, "obj_sansb_349", "\E4cóż^1, moja praca&będzie o wiele&łatwiejsza./%%")
ds_map_add(global.text_data_en, "obj_sansb_353", "\E9ugh..^1.&to powiedziawszy.../")
ds_map_add(global.text_data_en, "obj_sansb_354", "\E1ty^1, uh^1, naprawdę&lubisz huśtać&tym czymś^1, huh?/")
ds_map_add(global.text_data_en, "obj_sansb_355", "\E0.../")
ds_map_add(global.text_data_en, "obj_sansb_356", "\E4słuchaj./")
ds_map_add(global.text_data_en, "obj_sansb_357", "przyjaźń.../")
ds_map_add(global.text_data_en, "obj_sansb_358", "\E3jest świetna^1,&co nie?/")
ds_map_add(global.text_data_en, "obj_sansb_359", "skończmy&ten nonsens./%%")
ds_map_add(global.text_data_en, "obj_sansb_380", "\E3cóż^1, było&warto spró-&bować./")
ds_map_add(global.text_data_en, "obj_sansb_381", "\E5najwyraźniej lubisz&załatwiać sprawy tą&cięższą metodą^1, huh?/%%")
ds_map_add(global.text_data_en, "obj_sansb_384", "\E3woah^1, wyglądasz&MOCNO wkurwiony.../")
ds_map_add(global.text_data_en, "obj_sansb_385", "\E4heheheh.../")
ds_map_add(global.text_data_en, "obj_sansb_386", "\E5złapałem cię?/")
ds_map_add(global.text_data_en, "obj_sansb_387", "\E4cóż^1, jeśli&powróciłeś.../")
ds_map_add(global.text_data_en, "obj_sansb_388", "\E1to znaczy że my&nigdy nie BYLIŚMY&przyjaciółmi^1, huh?/")
ds_map_add(global.text_data_en, "obj_sansb_389", "\E4heh./")
ds_map_add(global.text_data_en, "obj_sansb_390", "\E9nie mów tego&innym sansom^1,&ok?/%%")
ds_map_add(global.text_data_en, "obj_sansb_398", "\E4brzmi dziwnie^1, ale&przed tym wszystkim&miałem nadzieję że&się zaprzyjaźnimy./")
ds_map_add(global.text_data_en, "obj_sansb_399", "\E1zawsze myślałem że&ta anomalia robiła&to ponieważ oni&byli nieszczęśliwi./")
ds_map_add(global.text_data_en, "obj_sansb_400", "a kiedy dostali&to czego chcieli^1,&przestaliby robić&to wszystko./%%")
ds_map_add(global.text_data_en, "obj_sansb_405", "\E3i może jedyne co&potrzebowali to..^1.&idk./")
ds_map_add(global.text_data_en, "obj_sansb_406", "\M1trochę jedzenia^1,&słabych żartów^1,&miłych przyjaciół./%%")
ds_map_add(global.text_data_en, "obj_sansb_411", "\E4ale to jest&absurdalne^1,&prawda?/")
ds_map_add(global.text_data_en, "obj_sansb_412", "\E5ta^1, ty jesteś&typem osoby która&NIGDY nie będzie&zadowolona./%%")
ds_map_add(global.text_data_en, "obj_sansb_417", "\E5będziesz pożerał&osie czasowe w&kółko^1, dopóki.../")
ds_map_add(global.text_data_en, "obj_sansb_418", "\E4cóż./")
ds_map_add(global.text_data_en, "obj_sansb_419", "\M1hej./")
ds_map_add(global.text_data_en, "obj_sansb_420", "\E3słuchaj^1,&dzieciaku./")
ds_map_add(global.text_data_en, "obj_sansb_421", "jednego dnia.../")
ds_map_add(global.text_data_en, "obj_sansb_422", "będziesz musiał&się nauczyć&kiedy masz&ODPUŚCIĆ./%%")
ds_map_add(global.text_data_en, "obj_sansb_423", "%%%")
ds_map_add(global.text_data_en, "obj_sansb_427", "\E3a to kiedyś&to DZISIAJ./%%")
ds_map_add(global.text_data_en, "obj_sansb_433", "\E4bo..^1.&widzisz../")
ds_map_add(global.text_data_en, "obj_sansb_434", "\E1to całe walczenie&naprawdę mnie&wykańcza./%%")
ds_map_add(global.text_data_en, "obj_sansb_441", "\E4i jeśli będziesz&mnie dalej pchał.../")
ds_map_add(global.text_data_en, "obj_sansb_442", "\Xt\E3o będę zmuszony&do użycia mojego\R &specjalnego ataku\X./%%")
ds_map_add(global.text_data_en, "obj_sansb_448", "\Xt\E3a^1, mój&\Rspecjalny atak\X.&brzmi znajomo?/")
ds_map_add(global.text_data_en, "obj_sansb_449", "\Xc\E1óż^1, przygotuj się^1.&bo w następnej&kolejce^1, ja go&\Rużyję\X./")
ds_map_add(global.text_data_en, "obj_sansb_450", "\E3więc^1, jeśli nie&chcesz go zobaczyć^1,&teraz jest dobry&czas na śmierć./%%")
ds_map_add(global.text_data_en, "obj_sansb_456", "\E4cóż^1, sam tego&chciałeś.../")
ds_map_add(global.text_data_en, "obj_sansb_457", "\E3gotowy?/")
ds_map_add(global.text_data_en, "obj_sansb_458", "\Xp\E5rzetrwaj TO^1, a&pokaże ci mój\R &specjalny atak\X!/%%")
ds_map_add(global.text_data_en, "obj_sansb_477", ".../")
ds_map_add(global.text_data_en, "obj_sansb_478", "oszczędzasz mnie?/")
ds_map_add(global.text_data_en, "obj_sansb_479", "\E1w końcu./")
ds_map_add(global.text_data_en, "obj_sansb_480", "\E3kumplu^1.&ziom./")
ds_map_add(global.text_data_en, "obj_sansb_481", "\E4wiem jakie to&musi być ciężkie.../")
ds_map_add(global.text_data_en, "obj_sansb_482", "aby podjąć&tą decyzję./")
ds_map_add(global.text_data_en, "obj_sansb_483", "aby zrezygnować ze&wszystkiego nad&czym pracowałeś./")
ds_map_add(global.text_data_en, "obj_sansb_484", "\E0chcę żebyś&wiedział..^1.&nie pozwolę temu&pójśćna marne./")
ds_map_add(global.text_data_en, "obj_sansb_485", "\M1.../")
ds_map_add(global.text_data_en, "obj_sansb_486", "\E3no chodź^1, ziom./%%")
ds_map_add(global.text_data_en, "obj_sansb_954", "* Po prostu atakuj dalej.")
ds_map_add(global.text_data_en, "obj_sansb_956", "* Ruchy Sansa robią się coraz&  bardziej zmęczone.")
ds_map_add(global.text_data_en, "obj_sansb_958", "* Ruchy Sansa wydają się być&  wolniejsze.")
ds_map_add(global.text_data_en, "obj_sansb_960", "* Uczucie punktu zwrotnego.")
ds_map_add(global.text_data_en, "obj_sansb_962", "* Poczułeś twoje grzechy&  pełzające po plecach.")
ds_map_add(global.text_data_en, "obj_sansb_963", "* Poczułeś twoje grzechy&  obciążające twój kark.")
ds_map_add(global.text_data_en, "obj_sansb_964", "* KARMA płynie przez&  twoje żyły.")
ds_map_add(global.text_data_en, "obj_sansb_965", "* Skazany na śmierć KARMĄ!")
ds_map_add(global.text_data_en, "obj_sansb_969", "* PRAWDZIWA walka w końcu&  się zaczyna.")
ds_map_add(global.text_data_en, "obj_sansb_971", "* Czytanie tego nie wydaje się&  być najlepszym wykorzystaniem&  twojego czasu.")
ds_map_add(global.text_data_en, "obj_sansb_973", "* Sans zaczyna wyglądać&  naprawdę zmęczony.")
ds_map_add(global.text_data_en, "obj_sansb_975", "* Sans przygotowuje coś.")
ds_map_add(global.text_data_en, "obj_sansb_977", "* Sans przygotowuje się do&  użycia jego specjalnego ataku.")
ds_map_add(global.text_data_en, "obj_sansb_985", "* Sans cię oszczędza.")
ds_map_add(global.text_data_en, "obj_sansb_1013", "* SANS 1 ATK 1 DEF&* Najłatwiejszy potwór^1.&* Może tylko zadać 1 obrażenie./")
ds_map_add(global.text_data_en, "obj_sansb_1014", "* Nie może unikać ataków&  w nieskończoność^1.&* Atakuj dalej./^")
ds_map_add(global.text_data_en, "obj_sansb_1018", "* SANS 1 ATK 1 DEF&* Najłatwiejszy potwór^1.&* Może tylko zadać 1 obrażenie./^")
ds_map_add(global.text_data_en, "obj_sansb_1079", "Jest przepiękny&dzień na dworze./")
ds_map_add(global.text_data_en, "obj_sansb_1080", "ptaszki&śpiewają^1,&kwiatki&kwitną.../")
ds_map_add(global.text_data_en, "obj_sansb_1081", "w takie dni^1,&dzieciaki&jak ty.../%%")
ds_map_add(global.text_data_en, "obj_sansb_1084", "Jest przepiękny&dzień na dworze./")
ds_map_add(global.text_data_en, "obj_sansb_1085", "ptaszki śpiewają^1,%%")
ds_map_add(global.text_data_en, "obj_sansb_1089", "gotowy?/%%")
ds_map_add(global.text_data_en, "obj_sansb_1152", "Powinny&płonąć&w&piekle./%%")
ds_map_add(global.text_data_en, "obj_sansb_body_1446", "\E1huh./")
ds_map_add(global.text_data_en, "obj_sansb_body_1447", "\M1ciekawe czemu inni&nie robią najsil-&niejszych ataków&na początku./%%")
ds_map_add(global.text_data_en, "obj_sansb_body_1450", "\E3w każdym razie^1,&tak jak mówiłem^1,&jest ładny dzień&na zewnątrz./")
ds_map_add(global.text_data_en, "obj_sansb_body_1451", "\M1czemu nie&zrelaksować się&i wziąć urlop?/%%")
ds_map_add(global.text_data_en, "obj_sansb_body_1455", "zaczynamy./%%")
ds_map_add(global.text_data_en, "obj_sansb_body_1468", "* Czujesz, że będziesz&  miał zły czas.")
ds_map_add(global.text_data_en, "obj_sansb_body_2091", "huf..^1. puf.../")
ds_map_add(global.text_data_en, "obj_sansb_body_2092", "okej^1.&doczekałeś&się./")
ds_map_add(global.text_data_en, "obj_sansb_body_2093", "\Xc\M1zas na mój\R &specjalny atak\X./")
ds_map_add(global.text_data_en, "obj_sansb_body_2094", "\E3gotowy?/")
ds_map_add(global.text_data_en, "obj_sansb_body_2095", "\E4no to lecimy./%%")
ds_map_add(global.text_data_en, "obj_sansb_body_2111", "\E1yep./")
ds_map_add(global.text_data_en, "obj_sansb_body_2112", "\E1zgadza sie./")
ds_map_add(global.text_data_en, "obj_sansb_body_2113", "\E3to dosłownie&nic./")
ds_map_add(global.text_data_en, "obj_sansb_body_2114", "\E1i nic też&nie będzie^1,&zresztą./")
ds_map_add(global.text_data_en, "obj_sansb_body_2115", "\E4heh heh heh..^1.&czaisz?/")
ds_map_add(global.text_data_en, "obj_sansb_body_2116", "\E1wiem że nie&mogę cię&pokonać./")
ds_map_add(global.text_data_en, "obj_sansb_body_2117", "\E4w jednej z&twoich kolejek.../")
ds_map_add(global.text_data_en, "obj_sansb_body_2118", "\E9po prostu&mnie zabijesz./")
ds_map_add(global.text_data_en, "obj_sansb_body_2119", "\E1więc^1, uh./")
ds_map_add(global.text_data_en, "obj_sansb_body_2120", "\E4postanowiłem.../")
ds_map_add(global.text_data_en, "obj_sansb_body_2121", "że nigdy nie&BĘDZIE twojej&kolejki./")
ds_map_add(global.text_data_en, "obj_sansb_body_2122", "\E3po prostu będę&trzymał MOJĄ&kolejkę aż&się poddasz./")
ds_map_add(global.text_data_en, "obj_sansb_body_2123", "\E5nawet jeśli to&znaczy że my&będziemy stali&do końca czasu./")
ds_map_add(global.text_data_en, "obj_sansb_body_2124", "\E1czaisz baze?/%%")
ds_map_add(global.text_data_en, "obj_sansb_body_2141", "\E9znudzisz się&tutaj./")
ds_map_add(global.text_data_en, "obj_sansb_body_2142", "\E1jeśli już się&nie znudziłeś^1,&to znaczy./")
ds_map_add(global.text_data_en, "obj_sansb_body_2143", "\E5a wtedy^1, ty&w końcu&odpuścisz./%%")
ds_map_add(global.text_data_en, "obj_sansb_body_2161", "\E5znam twój typ./")
ds_map_add(global.text_data_en, "obj_sansb_body_2162", "\E1jesteś^1, uh^1, bardzo&zdeterminowany^1,&czyż nie?/")
ds_map_add(global.text_data_en, "obj_sansb_body_2163", "\E4nigdy się nie&poddasz^1, nawet&jeśli nie ma^1, uh.../")
ds_map_add(global.text_data_en, "obj_sansb_body_2164", "\E3absolutnie ZERO&benefitów by&brnąć w to&dalej./")
ds_map_add(global.text_data_en, "obj_sansb_body_2165", "\E1jeśli mogę to&dobrze określić./")
ds_map_add(global.text_data_en, "obj_sansb_body_2166", "\E4niezależnie co^1,&ty po prostu&będziesz szedł&dalej./")
ds_map_add(global.text_data_en, "obj_sansb_body_2167", "\E9nie z żadnego&pragnienia&dobra czy zła.../")
ds_map_add(global.text_data_en, "obj_sansb_body_2168", "\E3ale po prostu&dlatego, że&myślisz że&możesz./")
ds_map_add(global.text_data_en, "obj_sansb_body_2169", "\E1i ponieważ&" + '"' + "możesz" + '"' + ".../")
ds_map_add(global.text_data_en, "obj_sansb_body_2170", "\E9... to " + '"' + "musisz." + '"' + "/%%")
ds_map_add(global.text_data_en, "obj_sansb_body_2188", "\E9ale teraz^1,&dobiegłeś do&końca./")
ds_map_add(global.text_data_en, "obj_sansb_body_2189", "\E4nie pozostało&już nic dla&ciebie teraz./")
ds_map_add(global.text_data_en, "obj_sansb_body_2190", "\E1więc^1, uh^1, w mojej&osobistej opinii.../")
ds_map_add(global.text_data_en, "obj_sansb_body_2191", "\E3najbardziej&" + '"' + "zdeterminowaną" + '"' + "&rzeczą którą tu&możesz zrobić?/")
ds_map_add(global.text_data_en, "obj_sansb_body_2192", "\E1to^1, uh^1,&kompletnie&się poddać./")
ds_map_add(global.text_data_en, "obj_sansb_body_2193", "\E3i..^1. (ziew)&robić dosłownie&cokolwiek innego./%%")
ds_map_add(global.text_data_en, "obj_sansb_body_2344", "heh^1, czy ty serio&myślałeś że będziesz&w stanie mnie")
ds_map_add(global.text_data_en, "obj_sansb_body_2495", ".../")
ds_map_add(global.text_data_en, "obj_sansb_body_2496", ".../")
ds_map_add(global.text_data_en, "obj_sansb_body_2497", ".../")
ds_map_add(global.text_data_en, "obj_sansb_body_2498", "więc.../")
ds_map_add(global.text_data_en, "obj_sansb_body_2499", "tak to się&kończy^1, huh?/")
ds_map_add(global.text_data_en, "obj_sansb_body_2500", ".../")
ds_map_add(global.text_data_en, "obj_sansb_body_2501", "ale.../")
ds_map_add(global.text_data_en, "obj_sansb_body_2502", "nie mów że cię&nie ostrzegałem./%%")
ds_map_add(global.text_data_en, "obj_sansb_body_2539", "no cóż./")
ds_map_add(global.text_data_en, "obj_sansb_body_2540", "idę do&grillby's./%%")
ds_map_add(global.text_data_en, "obj_sansb_body_2574", "papyrus^1,&chcesz czegoś?/%%")
ds_map_add(global.text_data_en, "obj_sansbyetrigger_124", "* w sumie^1, hej..^1.&* nie chcę cię trzymać^1,& ale zrobisz coś dla mnie?/")
ds_map_add(global.text_data_en, "obj_sansbyetrigger_125", "* myślałem sobie..^1.&* mój brat się czuł trochę&  przytłoczony ostatnio.../")
ds_map_add(global.text_data_en, "obj_sansbyetrigger_126", "* nigdy jeszcze nie widział&  ludzi wcześniej^1. i widząc&  cię może mu zrobić dzień./")
ds_map_add(global.text_data_en, "obj_sansbyetrigger_127", "* nie martw się^1, on nie& jest niebezpieczny./")
ds_map_add(global.text_data_en, "obj_sansbyetrigger_128", "\E1* nawet jeśli próbuje być./")
ds_map_add(global.text_data_en, "obj_sansbyetrigger_129", "\E0* dzięki wielkie^1.&* będę przed tobą./%%")
ds_map_add(global.text_data_en, "obj_sansbyetrigger_132", "\E0* cóż^1, będę zupełnie&  szczery z tobą./")
ds_map_add(global.text_data_en, "obj_sansbyetrigger_133", "\E1* mój brat naprawdę&  chciałby zobaczyć&  człowieka.../")
ds_map_add(global.text_data_en, "obj_sansbyetrigger_134", "\E2* więc^1, no wiesz^1, to by&  naprawdę mi pomogło.../")
ds_map_add(global.text_data_en, "obj_sansbyetrigger_135", "\E1* gdybyś dalej udawał&  bycie jednym./%%")
ds_map_add(global.text_data_en, "obj_sanscheckpoint_98", "* To jakiegoś rodzaju&  checkpoint czy&  stacyjka./")
ds_map_add(global.text_data_en, "obj_sanscheckpoint_99", "* Ale tu są butelki&  ketchupu^1, musztardy^1, i&  innych sosów w środku.../%%")
ds_map_add(global.text_data_en, "obj_sansdate3_116", "* cóż^1, oto jesteśmy./%%")
ds_map_add(global.text_data_en, "obj_sansdate3_124", "* więc./")
ds_map_add(global.text_data_en, "obj_sansdate3_125", "* twoja podróż w końcu&  dobiega końca^1, huh?/")
ds_map_add(global.text_data_en, "obj_sansdate3_126", "\E0* musisz naprawdę chcieć&  wrócić do domu./")
ds_map_add(global.text_data_en, "obj_sansdate3_127", "\E1* hej^1.&* znam to uczucie^1,&  ziom./")
ds_map_add(global.text_data_en, "obj_sansdate3_128", "\E0* chociaż.../")
ds_map_add(global.text_data_en, "obj_sansdate3_129", "\E1* może czasami lepiej&  czerpać z tego co&  masz pod nosem./")
ds_map_add(global.text_data_en, "obj_sansdate3_130", "\E0* tu na dole masz już&  jedzenie^1, picie^1,&  przyjaciół.../")
ds_map_add(global.text_data_en, "obj_sansdate3_131", "* czy to co musisz&  zrobić.../")
ds_map_add(global.text_data_en, "obj_sansdate3_132", "\E1* jest tego warte?/%%")
ds_map_add(global.text_data_en, "obj_sansdate3_149", "* .../")
ds_map_add(global.text_data_en, "obj_sansdate3_150", "\E1* ah^1, zapomnij./")
ds_map_add(global.text_data_en, "obj_sansdate3_151", "\E0* kibicuję ci^1, ziom./%%")
ds_map_add(global.text_data_en, "obj_sansdate3_168", "* hej./")
ds_map_add(global.text_data_en, "obj_sansdate3_169", "\E1* opowiem ci pewną&  historię./")
ds_map_add(global.text_data_en, "obj_sansdate3_170", "\E0* więc jestem posterun-&  kowym w lesie snowdin^1,&  co nie?/")
ds_map_add(global.text_data_en, "obj_sansdate3_171", "* siedzę tam sobie i&  czekam na człowieka^1.&* to nieco nudne./")
ds_map_add(global.text_data_en, "obj_sansdate3_172", "\E2* na szczęście^1, głęboko&  w tym lesie.../")
ds_map_add(global.text_data_en, "obj_sansdate3_173", "\E0* są takie OGROMNE&  zamknięte drzwi./")
ds_map_add(global.text_data_en, "obj_sansdate3_174", "* i są idealne do&  ćwiczenia żartów&  typu puk-puk./")
ds_map_add(global.text_data_en, "obj_sansdate3_175", "* więc jednego dnia^1,&  odwiedzam te drzwi^1,&  jak zwykle./")
ds_map_add(global.text_data_en, "obj_sansdate3_176", "* pukam w te drzwi&  i mówię " + '"' + "puk puk." + '"' + "/")
ds_map_add(global.text_data_en, "obj_sansdate3_177", "* i nagle^1, z drugiej&  strony.../")
ds_map_add(global.text_data_en, "obj_sansdate3_178", "\E1* słyszę głos kobiety./")
ds_map_add(global.text_data_en, "obj_sansdate3_179", "\Tt*\E0 " + '"' + "kto tam?" + '"' + " /")
ds_map_add(global.text_data_en, "obj_sansdate3_180", "\Ts*\E1 więc^1, naturalnie^1,&  odpowiadam:/")
ds_map_add(global.text_data_en, "obj_sansdate3_181", "\E0* " + '"' + "tojest." + '"' + "/")
ds_map_add(global.text_data_en, "obj_sansdate3_182", "\Tt* " + '"' + "tojest kto?" + '"' + "/")
ds_map_add(global.text_data_en, "obj_sansdate3_183", "\Ts*\E2 " + '"' + "tojest naprawdę&  słaby żart." + '"' + "/")
ds_map_add(global.text_data_en, "obj_sansdate3_184", "\E0* i wtedy ona po prostu&  umiera ze śmiechu./")
ds_map_add(global.text_data_en, "obj_sansdate3_185", "\E1* jakby to był najlepszy&  żart jaki słyszała&  od stu lat./")
ds_map_add(global.text_data_en, "obj_sansdate3_186", "\E0* więc dalej walę&  żartami^1, i ona&  dalej się śmieje./")
ds_map_add(global.text_data_en, "obj_sansdate3_187", "\E1* ona jest najlepszą&  widownią jaką kiedy-&  kolwiek miałem./")
ds_map_add(global.text_data_en, "obj_sansdate3_188", "\E0* potem^1, po wielu&  żartach^1, ONA&  puka i mówi.../")
ds_map_add(global.text_data_en, "obj_sansdate3_189", "\Tt* " + '"' + "Puk puk!" + '"' + "/")
ds_map_add(global.text_data_en, "obj_sansdate3_190", "\Ts* \E1ja mówię& " + '"' + "kto tam?" + '"' + "/")
ds_map_add(global.text_data_en, "obj_sansdate3_191", "\Tt* \E0" + '"' + "stara pani!" + '"' + "/")
ds_map_add(global.text_data_en, "obj_sansdate3_192", "\Ts*\E1 " + '"' + "stara pani kto?" + '"' + "/")
ds_map_add(global.text_data_en, "obj_sansdate3_193", "\Tt*\E2 " + '"' + "oh! Ja nie wiedziałam&  że ty jesteś bezpośredni!" + '"' + "/")
ds_map_add(global.text_data_en, "obj_sansdate3_194", "\Ts*\E1 wow./")
ds_map_add(global.text_data_en, "obj_sansdate3_195", "\E2* mówiąc wprost^1,&  ta pani była&  niesamowicie dobra./")
ds_map_add(global.text_data_en, "obj_sansdate3_196", "\E0* kontynuowaliśmy&  mówienie żartów&  przez godziny./")
ds_map_add(global.text_data_en, "obj_sansdate3_197", "\E0* ewentualnie^1,&  musiałem opuścić./")
ds_map_add(global.text_data_en, "obj_sansdate3_198", "\E2* papyrus robi się nieco&  pobudliwy bez jego&  nocnej czytanki./")
ds_map_add(global.text_data_en, "obj_sansdate3_199", "\E0* ale powiedziała mi&  żebym jeszcze wrócił^1,&  więc wróciłem./")
ds_map_add(global.text_data_en, "obj_sansdate3_200", "\E0* a potem znów^1.&* i znów^1.&* to nasza tradycja./")
ds_map_add(global.text_data_en, "obj_sansdate3_201", "* mówienie słabych&  żartów przez drzwi./")
ds_map_add(global.text_data_en, "obj_sansdate3_202", "\E1* to rządzi./%%")
ds_map_add(global.text_data_en, "obj_sansdate3_221", "* .../")
ds_map_add(global.text_data_en, "obj_sansdate3_222", "\E0* jednego dnia^1, natomiast^1,&  zauważyłem że ona nie&  śmiała się zbytnio./")
ds_map_add(global.text_data_en, "obj_sansdate3_223", "* zapytałem o&  co chodzi./")
ds_map_add(global.text_data_en, "obj_sansdate3_224", "* wtedy powiedziała mi&  coś dziwnego./")
ds_map_add(global.text_data_en, "obj_sansdate3_225", "* \Tt" + '"' + "jeśli człowiek kiedy-&  kolwiek przejdzie przez&  te drzwi.../" + '"')
ds_map_add(global.text_data_en, "obj_sansdate3_226", "* " + '"' + "... mógłbyś proszę^1,&  proszę obiecać mi&  coś?" + '"' + "/")
ds_map_add(global.text_data_en, "obj_sansdate3_227", "* " + '"' + "miej go na oku^1,&  i chroń go^1,&  w porządku?" + '"' + "/")
ds_map_add(global.text_data_en, "obj_sansdate3_228", "\E0*\Ts teraz^1, nienawidzę&  składania obietnic./")
ds_map_add(global.text_data_en, "obj_sansdate3_229", "\E1* i ta kobieta^1,&  nawet nie znam&  jej imienia./")
ds_map_add(global.text_data_en, "obj_sansdate3_230", "\E3* ale.../")
ds_map_add(global.text_data_en, "obj_sansdate3_231", "\E1* komuś kto szczerze&  lubi słabe żarty.../")
ds_map_add(global.text_data_en, "obj_sansdate3_232", "\E2* ma zdolność do&  niepotrafienie&  odmawiania./%%")
ds_map_add(global.text_data_en, "obj_sansdate3_259", "\E1* czaisz co mam&  na myśli?/")
ds_map_add(global.text_data_en, "obj_sansdate3_260", "\E0* ta obietnica którą&  jej złożyłem.../")
ds_map_add(global.text_data_en, "obj_sansdate3_261", "\E1* wiesz co by się stało&  gdyby ona mi nic nie&  powiedziała?/")
ds_map_add(global.text_data_en, "obj_sansdate3_262", "\E3* ... ziom./%%")
ds_map_add(global.text_data_en, "obj_sansdate3_279", "* ... Byłbyś martwy&  tam gdzie stoisz./%%")
ds_map_add(global.text_data_en, "obj_sansdate3_304", "\E3* .../")
ds_map_add(global.text_data_en, "obj_sansdate3_305", "\E1* hej^1, rozchmurz się^1,&  dzieciaku!/")
ds_map_add(global.text_data_en, "obj_sansdate3_306", "\E2* ja sobie tylko&  żartuję./")
ds_map_add(global.text_data_en, "obj_sansdate3_307", "\E1* zresztą.../")
ds_map_add(global.text_data_en, "obj_sansdate3_308", "\E0* czyż ja nie zrobiłem&  dobrej roboty w&  chronieniu ciebie?/")
ds_map_add(global.text_data_en, "obj_sansdate3_309", "* w sensie^1, spójrz na&  siebie./")
ds_map_add(global.text_data_en, "obj_sansdate3_310", "\E2* nie umarłeś&  ani razu./")
ds_map_add(global.text_data_en, "obj_sansdate3_313", "\E0* to się zgadza^1,&  co nie?/")
ds_map_add(global.text_data_en, "obj_sansdate3_314", "\E2* cóż^1, podziękuj&  moim niesamowitym&  zdolnościom./%%")
ds_map_add(global.text_data_en, "obj_sansdate3_317", "\E0* hej^1, a co ma to&  spojrzenie oznaczać?/")
ds_map_add(global.text_data_en, "obj_sansdate3_318", "\E1* mylę się...?/%%")
ds_map_add(global.text_data_en, "obj_sansdate3_336", "* heh./%%")
ds_map_add(global.text_data_en, "obj_sansdate3_380", "* cóż^1, to wszystko./")
ds_map_add(global.text_data_en, "obj_sansdate3_381", "\E1* dbaj o siebie^1,&  ziom./")
ds_map_add(global.text_data_en, "obj_sansdate3_382", "\E0* bo innym naprawdę&  na tobie zależy./%%")
ds_map_add(global.text_data_en, "obj_sansdoor_98", "* (Te drzwi są zamknięte.)/%%")
ds_map_add(global.text_data_en, "obj_sansdoor_102", "* (Odblokowałeś drzwi i&  wszedłeś...)/%%")
ds_map_add(global.text_data_en, "obj_sansmailbox_60", "* (To skrzynka pocztowa&  przepełniona nieprzeczy-&  tanym spamem.)/%%")
ds_map_add(global.text_data_en, "obj_sanssnowman_98", "* (To grudka śniegu z napisem&  'sans' napisany czerwonym&  markerem.)/%%")
ds_map_add(global.text_data_en, "obj_sanssteps_56", "* Wygląda, że ktoś chodził&  w kółka tylko aby&  robić dźwięki.../%%")
ds_map_add(global.text_data_en, "obj_savepoint_97", "\R* Jeszcze \[1]./%%")
ds_map_add(global.text_data_en, "obj_savepoint_99", "\R* Co za komik.../%%")
ds_map_add(global.text_data_en, "obj_savepoint_101", "* Determinacja./%%")
ds_map_add(global.text_data_en, "obj_savepoint_103", "* Ten komik uciekł^1.&* Co za porażka z niego./%%")
ds_map_add(global.text_data_en, "obj_savepoint_118", "\R* Jeszcze \[1]./%%")
ds_map_add(global.text_data_en, "obj_savepoint_120", "* Determinacja./%%")
ds_map_add(global.text_data_en, "obj_savepoint_135", "\R* Jeszcze \[1]./%%")
ds_map_add(global.text_data_en, "obj_savepoint_137", "* Determinacja./%%")
ds_map_add(global.text_data_en, "obj_savepoint_145", "* Determinacja./%%")
ds_map_add(global.text_data_en, "obj_savepoint_fake_266", "Howdy!/")
ds_map_add(global.text_data_en, "obj_savepoint_fake_267", "It's me, FLOWEY./")
ds_map_add(global.text_data_en, "obj_savepoint_fake_268", "\E2FLOWEY the FLOWER!/")
ds_map_add(global.text_data_en, "obj_savepoint_fake_269", "\E0I owe you a HUGE thanks./")
ds_map_add(global.text_data_en, "obj_savepoint_fake_270", "\E9You really did a number&on that old fool./")
ds_map_add(global.text_data_en, "obj_savepoint_fake_271", "\E0Without you^1, I NEVER could&have gotten past him./")
ds_map_add(global.text_data_en, "obj_savepoint_fake_272", "\E7But now^1, with YOUR help.../")
ds_map_add(global.text_data_en, "obj_savepoint_fake_273", "\E8 %")
ds_map_add(global.text_data_en, "obj_savepoint_fake_274", "\TFHe's DEAD./")
ds_map_add(global.text_data_en, "obj_savepoint_fake_275", "\E6And I'VE got the human&SOULS!/%%")
ds_map_add(global.text_data_en, "obj_savepoint_fake_278", "%%%")
ds_map_add(global.text_data_en, "obj_savepoint_fake_332", "\E0Boy!/")
ds_map_add(global.text_data_en, "obj_savepoint_fake_333", "\E0I've been empty for so&long.../")
ds_map_add(global.text_data_en, "obj_savepoint_fake_334", "\E4It feels great to have a&SOUL inside me again./")
ds_map_add(global.text_data_en, "obj_savepoint_fake_335", "\E1Mmmm^1, I can feel them&wriggling.../")
ds_map_add(global.text_data_en, "obj_savepoint_fake_337", "\E6Awww^1, you're feeling&left out^1, aren't you?/")
ds_map_add(global.text_data_en, "obj_savepoint_fake_338", "\E1Well^1, that's just perfect./")
ds_map_add(global.text_data_en, "obj_savepoint_fake_339", "\E0After all^1, I only have&six souls./")
ds_map_add(global.text_data_en, "obj_savepoint_fake_340", "\E1I still need one more.../")
ds_map_add(global.text_data_en, "obj_savepoint_fake_341", "\TFB\E2efore I become GOD./")
ds_map_add(global.text_data_en, "obj_savepoint_fake_342", "\E3And then^1, with my&newfound powers.../")
ds_map_add(global.text_data_en, "obj_savepoint_fake_343", "\E7Monsters./")
ds_map_add(global.text_data_en, "obj_savepoint_fake_344", "\E5Humans./")
ds_map_add(global.text_data_en, "obj_savepoint_fake_345", "\E5Everyone^2./")
ds_map_add(global.text_data_en, "obj_savepoint_fake_346", "\E8I'll show them all the REAL&meaning of this world./%%")
ds_map_add(global.text_data_en, "obj_savepoint_fake_347", "%%%")
ds_map_add(global.text_data_en, "obj_savepoint_fake_435", "\E0Oh^1, and forget about escaping&to your old SAVE FILE./")
ds_map_add(global.text_data_en, "obj_savepoint_fake_436", "\TFI\E2t's gone FOREVER./")
ds_map_add(global.text_data_en, "obj_savepoint_fake_439", "\E0Golly^1, if only you&had a SAVE FILE you&could run away to.../")
ds_map_add(global.text_data_en, "obj_savepoint_fake_440", "\TFB\E2ut you were just&too STUPID to make one!/")
ds_map_add(global.text_data_en, "obj_savepoint_fake_442", "\TfB\E3ut don't worry./")
ds_map_add(global.text_data_en, "obj_savepoint_fake_443", "\E0Your old friend FLOWEY.../")
ds_map_add(global.text_data_en, "obj_savepoint_fake_444", "\E1Has worked out a replacement&for you!/")
ds_map_add(global.text_data_en, "obj_savepoint_fake_445", "\TFI\E6'll SAVE over your own&death./")
ds_map_add(global.text_data_en, "obj_savepoint_fake_446", "\E7So you can watch me tear&you to bloody pieces.../")
ds_map_add(global.text_data_en, "obj_savepoint_fake_447", "\E8Over^1, and over^1, and over.../%%")
ds_map_add(global.text_data_en, "obj_savepoint_fake_490", "\E9... what?/")
ds_map_add(global.text_data_en, "obj_savepoint_fake_491", "Do you really think&you can stop ME?/")
ds_map_add(global.text_data_en, "obj_savepoint_fake_492", "\TfH\E4ee hee hee.../%%")
ds_map_add(global.text_data_en, "obj_savepoint_fake_507", "\E5You really ARE an idiot^4.%%")
ds_map_add(global.text_data_en, "obj_shamblingmass_70", "* Jako szlam^1,&  jestem oburzony./%%")
ds_map_add(global.text_data_en, "obj_shamblingmass_74", "* Jako szlam^1,&  jestem zaszczycony./%%")
ds_map_add(global.text_data_en, "obj_shamblingmass_79", "* Jako szlam^1,&  jestem zasmucony./%%")
ds_map_add(global.text_data_en, "obj_shop1_263", "\E0* Nie spiesz się./*")
ds_map_add(global.text_data_en, "obj_shop1_264", "\E0* Witaj^1, podróżniku^1.&* W czym mogę pomóc?/*")
ds_map_add(global.text_data_en, "obj_shop1_265", "* Ale nikt nie&  przyszedł./*")
ds_map_add(global.text_data_en, "obj_shop1_352", "\E0Co byś&chciał&kupić?/*")
ds_map_add(global.text_data_en, "obj_shop1_353", "\E5Dziękuję&za&zakup./*")
ds_map_add(global.text_data_en, "obj_shop1_354", "\E0Tylko&patrzysz?/*")
ds_map_add(global.text_data_en, "obj_shop1_355", "\E6Brakuje&pieniędzy./*")
ds_map_add(global.text_data_en, "obj_shop1_356", "\E6Nosisz&zbyt&wiele./*")
ds_map_add(global.text_data_en, "obj_shop1_357", "/*")
ds_map_add(global.text_data_en, "obj_shop1_438", "\E0Chcesz&pogadać?/*")
ds_map_add(global.text_data_en, "obj_shop1_476", "\E3* Huh^1?&* Sprzedać coś^1? Czy to wygląda&  na jakiś lombard?/")
ds_map_add(global.text_data_en, "obj_shop1_477", "\E4* Nie wiem jak to działa tam&  skąd pochodzisz... ale.../")
ds_map_add(global.text_data_en, "obj_shop1_478", "\E0* Gdybym zaczęła wydawać kasę&  na stare gałęzie i zużyte&  bandaże^1, zbankrutowałabym&  ot tak!/%%")
ds_map_add(global.text_data_en, "obj_shop1_480", "\E4* Jeśli naprawdę potrzebujesz&  kasy^1, to może mógłbyś założyć&  jakiś wolontariat./")
ds_map_add(global.text_data_en, "obj_shop1_481", "* Słyszałam^1, że ludzie zapłacą&  za WSZYSTKO w tych czasach./%%")
ds_map_add(global.text_data_en, "obj_shop1_486", "* Wziąłeś 758G zza kantorka./%%")
ds_map_add(global.text_data_en, "obj_shop1_492", "* Nic nie pozostało./%%")
ds_map_add(global.text_data_en, "obj_shop1_498", "\E0* Papatki^1!&* Zapraszam ponownie!/%%")
ds_map_add(global.text_data_en, "obj_shop1_500", "* .../%%")
ds_map_add(global.text_data_en, "obj_shop1_504", "\E0* Heja^1! Witaj w Snowdinie^1!&* Nie pamiętam^1, kiedy ostatnio&  widziałam świeżą twarz./")
ds_map_add(global.text_data_en, "obj_shop1_505", "\E4* Skąd pochodzisz^1?&* Ze stolicy?/")
ds_map_add(global.text_data_en, "obj_shop1_506", "\E0* Nie wyglądasz na turystę^1.&* Przyszedłeś tu samemu?/%%")
ds_map_add(global.text_data_en, "obj_shop1_511", "\E0* W sensie^1, tobie to się też&  wydarzyło^1, prawda?/")
ds_map_add(global.text_data_en, "obj_shop1_512", "* Był dziwny błysk światła..^1.&* Wtedy poczułam jak moje ciało&  zostaje przyciągane&  przez..^1. coś./")
ds_map_add(global.text_data_en, "obj_shop1_513", "* I nagle^1, wszystko wróciło&  do normy./%%")
ds_map_add(global.text_data_en, "obj_shop1_518", "\E0* Chcesz wiedzieć co się robi&  tutaj w Snowdinie?/")
ds_map_add(global.text_data_en, "obj_shop1_519", "\E4* U Grillby's jest jedzenie^1, a&  w bibliotece są informacje.../")
ds_map_add(global.text_data_en, "obj_shop1_520", "* A jeśli jesteś zmęczony^1, możesz&  uciąć sobie drzemkę w hotelu^1.&* Jest tuż obok ^1- moja siostra&  nią zarządza./")
ds_map_add(global.text_data_en, "obj_shop1_521", "\E0* A jeśli się nudzisz^1, możesz&  siedzieć na zewnątrz i&  obserwować tych dziwnych szkie-&  letów robiących swoje rzeczy./")
ds_map_add(global.text_data_en, "obj_shop1_522", "\E0* Jest ich dwojga..^1.&*\E4 Braci^1, wydaje mi się^1.&* Pojawili się jednego dnia i..^1.&*\E0 ... udomowili się./")
ds_map_add(global.text_data_en, "obj_shop1_523", "* Ta wioska stała się o wiele&  bardziej interesująca od wtedy./%%")
ds_map_add(global.text_data_en, "obj_shop1_528", "\E0* Słyszałam^1, że to wszystko przez&  to^1, że człowiek się tu zjawił&  pewnego dnia./")
ds_map_add(global.text_data_en, "obj_shop1_529", "* Człowiek..^1.&* Ledwo w to wierzę!/")
ds_map_add(global.text_data_en, "obj_shop1_530", "* Jeśli oni się zjawią u mnie^1,&  upewnię się^1, że gorąco ich&  tu przywitam jako bohaterów./%%")
ds_map_add(global.text_data_en, "obj_shop1_536", "\E4* Wróćmy się do lekcji historii.../")
ds_map_add(global.text_data_en, "obj_shop1_537", "\E0* Dawno temu^1, potwory żyły w&  RUINACH tam w lesie./")
ds_map_add(global.text_data_en, "obj_shop1_538", "* Krótko mówiąc^1, wszyscy&  postanowiliśmy opuścić ruiny&  i celować w krańce jaskiń./")
ds_map_add(global.text_data_en, "obj_shop1_539", "* Po drodze^1, jakiś puchatek&  uznał^1, że lubi zimno i rozpalił&  ognisko w Snowdinie./")
ds_map_add(global.text_data_en, "obj_shop1_540", "\E6* Oh^1, nie myśl sobie nawet o&  powrocie do RUIN.../")
ds_map_add(global.text_data_en, "obj_shop1_541", "\E0* Drzwi są zamknięte od wieków^1.&* Więc jeśli nie jesteś duchem&  albo nie możesz się podkopać^1,&  zapomnij o tym./%%")
ds_map_add(global.text_data_en, "obj_shop1_545", "\E0* Słyszałeś^1?&* RUINY zostały otwarte^1,&  i słuchaj tego.../")
ds_map_add(global.text_data_en, "obj_shop1_546", "* Zostały otworzone od ŚRODKA./")
ds_map_add(global.text_data_en, "obj_shop1_547", "* Najwyraźniej Królowa siedziała&  tam przez kto wie jak długo./")
ds_map_add(global.text_data_en, "obj_shop1_548", "* Nie do wiary^1, huh?/%%")
ds_map_add(global.text_data_en, "obj_shop1_555", "\E0* Życie jest takie jak zwykle./")
ds_map_add(global.text_data_en, "obj_shop1_556", "\E1* Trochę klaustrofobiczne.../")
ds_map_add(global.text_data_en, "obj_shop1_557", "\E2* Ale..^1. wszyscy wiemy głęboko&  w sercu że wolność nadchodzi^1,&  prawda?/")
ds_map_add(global.text_data_en, "obj_shop1_558", "\E2* I dopóki trzymamy tą nadzieję^1,&  możemy przecisnąć zęby i&  przechodzić przez te same&  trudności^1, dzień po dniu.../")
ds_map_add(global.text_data_en, "obj_shop1_559", "\E5* To jest życie^1, czyż nie?/%%")
ds_map_add(global.text_data_en, "obj_shop1_563", "\E0* Cóż^1, myślę^1, że niedługo&  przeniosę mój sklep na&  powierzchnię.../")
ds_map_add(global.text_data_en, "obj_shop1_564", "* ... nie planowałam jednak nic&  więcej^1, obawiam się./%%")
ds_map_add(global.text_data_en, "obj_shop1_570", "* (Jest tu notatka.)/")
ds_map_add(global.text_data_en, "obj_shop1_571", "* Proszę nie krzywdź mojej&  rodziny./%%")
ds_map_add(global.text_data_en, "obj_shop2_234", "* No^1, nie wstydź się./*")
ds_map_add(global.text_data_en, "obj_shop2_235", "* Ło panie^1!&* Mam całkiem fajne&  śmieci na sprzedaż./*")
ds_map_add(global.text_data_en, "obj_shop2_236", "* Wah ha ha^1!&* Wiedziałem^1,&  że dasz radę!/*")
ds_map_add(global.text_data_en, "obj_shop2_237", "* Wa ha ha..^1.&* A więc przyszedłeś^1.&* Co za niespodzianka!/*")
ds_map_add(global.text_data_en, "obj_shop2_287", "Czego&konkretnie&szukasz?/*")
ds_map_add(global.text_data_en, "obj_shop2_288", "Dzięki!&Wa ha ha./*")
ds_map_add(global.text_data_en, "obj_shop2_289", "Ostrożnie&z tym./*")
ds_map_add(global.text_data_en, "obj_shop2_290", "Trochę&kończy&ci się&kasa./*")
ds_map_add(global.text_data_en, "obj_shop2_291", "Nosisz&zbyt&wiele!/*")
ds_map_add(global.text_data_en, "obj_shop2_295", "Nie&oczekuj&zniżki./*")
ds_map_add(global.text_data_en, "obj_shop2_296", "Oto&tu jes-&teśmy./*")
ds_map_add(global.text_data_en, "obj_shop2_297", ".../* ")
ds_map_add(global.text_data_en, "obj_shop2_298", "Eh^1?&Nie stać&cię na&to?/*")
ds_map_add(global.text_data_en, "obj_shop2_299", "Nie masz&jeszcze&dosyć?/*")
ds_map_add(global.text_data_en, "obj_shop2_390", "Co&chcesz&wiedzieć?/*")
ds_map_add(global.text_data_en, "obj_shop2_392", "Serio?&TY&chcesz&pogadać?/*")
ds_map_add(global.text_data_en, "obj_shop2_438", "\E2* Ha^1!\E0 &* Próbuję się POZBYĆ moich&  śmieci^1, a nie zdobyć więcej!/")
ds_map_add(global.text_data_en, "obj_shop2_439", "\E4* Chociaż^1, słyszałem^1, że jeśli&  chcesz sprzedawać^1, to Wioska&  Temów to idealne miejsce./")
ds_map_add(global.text_data_en, "obj_shop2_440", "\E0* Gdzie ona jest?/")
ds_map_add(global.text_data_en, "obj_shop2_441", "\E3* .../")
ds_map_add(global.text_data_en, "obj_shop2_442", "\E0* Nie pamiętam./%%")
ds_map_add(global.text_data_en, "obj_shop2_444", "* Nosz cholera jasna^1,&  nie chcę twoich śmieci!/%%")
ds_map_add(global.text_data_en, "obj_shop2_445", "* Słyszałam^1, że ludzie zapłacą&  za WSZYSTKO w tych czasach./%%")
ds_map_add(global.text_data_en, "obj_shop2_448", "\E3* Nie kupię twoich żałosnych&  śmieci choćbyś mi groził&  nożem przy gardle./%%")
ds_map_add(global.text_data_en, "obj_shop2_454", "* Uważaj tam na siebie!/%%")
ds_map_add(global.text_data_en, "obj_shop2_456", "* Widzimy się później! (nie)./%%")
ds_map_add(global.text_data_en, "obj_shop2_462", "* Żyję już dosyć długo^1.&*\E3 Może zbyt długo./")
ds_map_add(global.text_data_en, "obj_shop2_463", "\E2* Nauka historii z pewnością jest&  łatwa kiedy sam tam byłeś&  i widziałeś na własne oczy^1!&*\E0 Wa ha ha!/%%")
ds_map_add(global.text_data_en, "obj_shop2_468", "\E0* Dawno temu^1, ASGORE i ja&  uznaliśmy^1, że bez sensu byłoby&  wychodzić na powierzchnię.../")
ds_map_add(global.text_data_en, "obj_shop2_469", "\E3* Bo kiedy wychodziliśmy^1, ludzkość&  po prostu nas zabijała./")
ds_map_add(global.text_data_en, "obj_shop2_470", "\E1* Czułem się lekko zdradzony gdy&  on ostatecznie zmienił zdanie./")
ds_map_add(global.text_data_en, "obj_shop2_471", "\E4* Ale teraz myślę..^1.&* Myślę^1, że może miał do&  tego prawo./")
ds_map_add(global.text_data_en, "obj_shop2_472", "\E2* Bo pod koniec dnia^1, nawet jeśli&  nidgy nie zdołaliśmy uciec.../")
ds_map_add(global.text_data_en, "obj_shop2_473", "\E3* Jakiś człowiek przybył nas&  pozabijać^1, czyż nie?/%%")
ds_map_add(global.text_data_en, "obj_shop2_478", "* OK^1, OK^1!&* Już pamiętam teraz../")
ds_map_add(global.text_data_en, "obj_shop2_479", "\E3* It was the monthly address at&  the castle^1, and the queen&  was giving her part on&  current events./")
ds_map_add(global.text_data_en, "obj_shop2_480", "\E0* After finishing her update^1,&  she moved to pass the&  microphone to the king./")
ds_map_add(global.text_data_en, "obj_shop2_481", "\E3* However^1, she didn't realize&  the microphone was still in&  her hands when she said:/")
ds_map_add(global.text_data_en, "obj_shop2_482", "\E2* " + '"' + "Your turn^1, Fluffybuns." + '"' + "/")
ds_map_add(global.text_data_en, "obj_shop2_483", "\E0* The audience burst into&  laughter./")
ds_map_add(global.text_data_en, "obj_shop2_484", "\E2* Realizing what she had said^1,&  she started laughing too./")
ds_map_add(global.text_data_en, "obj_shop2_485", "\E0* After a few moments^1, the&  king held up his arms^1.&* The crowd grew silent./")
ds_map_add(global.text_data_en, "obj_shop2_486", "\E3* He leaned towards the&  microphone^1, expression..^1.&* Stern./")
ds_map_add(global.text_data_en, "obj_shop2_487", "\E0* " + '"' + "Dear citizens.^1" + '"' + "&* " + '"' + "Thank you for coming&  here today." + '"' + "/")
ds_map_add(global.text_data_en, "obj_shop2_488", "\E3* " + '"' + "I..^1. King Fluffybuns..." + '"' + "/")
ds_map_add(global.text_data_en, "obj_shop2_489", "\E2* And the rest is history./%%")
ds_map_add(global.text_data_en, "obj_shop2_497", "\E2* Co tam mamroczesz^1?&* Chcesz, żebym się powtórzył?/")
ds_map_add(global.text_data_en, "obj_shop2_498", "\E0* Oj nie^1!&* Twoje oczy jeszcze działają..^1.&* Idź przeczytać jakąś książkę^1!&* Wahaha!/%%")
ds_map_add(global.text_data_en, "obj_shop2_503", "\E0* A tak..^1.&* Przepowiednia./")
ds_map_add(global.text_data_en, "obj_shop2_504", "\E4* Legenda głosi^1, że, 'anioł'^1,&  który widział powierzchnię^1&   przybędzie z niebios i&  uwolni nas wszystkich./")
ds_map_add(global.text_data_en, "obj_shop2_505", "\E3* Ostatnio^1, zaczęliśmy się przy-&  glądywać temu nieco bliżej.../")
ds_map_add(global.text_data_en, "obj_shop2_506", "\E4* I nazywaliśmy to oskrzydlone&  kółko 'Aniołem Śmierci.'/")
ds_map_add(global.text_data_en, "obj_shop2_507", "\E3* Ucieleśnienie destrukcji^1,&  czekające by 'uwolnić' nas&  wszystkich ze świata&  śmiertelników.../")
ds_map_add(global.text_data_en, "obj_shop2_508", "* Osobiście^1, kiedy widzę&  to małe kółeczko.../")
ds_map_add(global.text_data_en, "obj_shop2_509", "\E2* Po prostu myślę, że&  fajnie wygląda^1!&* Wahaha!/%%")
ds_map_add(global.text_data_en, "obj_shop2_516", "\E0* Tak naprawę ten emblem jest&  wyposażona w bogatą historię^1.&* Jego prawdziwe znaczenie zostało&  zagrzebane w czasie.../")
ds_map_add(global.text_data_en, "obj_shop2_517", "\E4* Jedyne co wiemy to że te&  trójkąty symbolizują nas potworów&  na dole^1, a oskrzydlone kółko&  symbolizuje.../")
ds_map_add(global.text_data_en, "obj_shop2_518", "\E3* Coś innego./")
ds_map_add(global.text_data_en, "obj_shop2_519", "\E0* Większość uznaje to za&  'anioła'^1, tego z przepowiedni.../%%")
ds_map_add(global.text_data_en, "obj_shop2_524", "\E0* Eh^1?&* Nie wiesz co to jest?/")
ds_map_add(global.text_data_en, "obj_shop2_525", "\E1* What are they teaching you&  kids in school nowadays...^1?&*\E2 Wa ha ha!/")
ds_map_add(global.text_data_en, "obj_shop2_526", "\W*\E0 That's the \YDelta Rune^1,\W the&  emblem of our kingdom^1.&* The Kingdom.../")
ds_map_add(global.text_data_en, "obj_shop2_527", "* ... of Monsters./")
ds_map_add(global.text_data_en, "obj_shop2_528", "* Wahaha^1!&* Great name^1, huh^1?&* It's as I always say.../")
ds_map_add(global.text_data_en, "obj_shop2_529", "* Ol' King Fluffybuns can't name&  for beans!/%%")
ds_map_add(global.text_data_en, "obj_shop2_537", "\E3* Eh^1?&* Goat?/")
ds_map_add(global.text_data_en, "obj_shop2_538", "\E2* Actually^1, that reminds me^1.&* Toriel once wore a flower-&  patterned muu-muu... /")
ds_map_add(global.text_data_en, "obj_shop2_539", "\E0* Folks kept saying " + '"' + "nice muu-&  muu" + '"' + " to her^1, but she kept&  thinking they were calling&  her a cow./")
ds_map_add(global.text_data_en, "obj_shop2_540", "\E1* So she never wore it again./")
ds_map_add(global.text_data_en, "obj_shop2_541", "\E3* What was the question again?/")
ds_map_add(global.text_data_en, "obj_shop2_542", "\E0* Oh^1.&* Right^1.&* ASGORE./")
ds_map_add(global.text_data_en, "obj_shop2_543", "\E3* He's a real interesting&  type of monster^1.&* The strongest type of all./")
ds_map_add(global.text_data_en, "obj_shop2_544", "\E0* We call 'em Boss Monsters./")
ds_map_add(global.text_data_en, "obj_shop2_545", "* When they have an offspring^1,&  the SOUL power of the&  parents flows into the&  child.../")
ds_map_add(global.text_data_en, "obj_shop2_546", "* Causing the child to grow&  as the parents age./")
ds_map_add(global.text_data_en, "obj_shop2_547", "\E3* But ASGORE doesn't have a&  child^1.&* So he's been stuck at the&  same age..^1.&* And probably will be forever./")
ds_map_add(global.text_data_en, "obj_shop2_548", "\E1* Huh^1?&* What if the child is a&  human...^1? What?/")
ds_map_add(global.text_data_en, "obj_shop2_549", "\E1* Nah^1. That wouldn't work^1.&* So if ASGORE's your father^1,&  he'll definitely outlive&  you./%%")
ds_map_add(global.text_data_en, "obj_shop2_555", "\E1* I've lived too long to&  be afraid of something&  like you./")
ds_map_add(global.text_data_en, "obj_shop2_556", "\E2* Try it^1, kiddo!/")
ds_map_add(global.text_data_en, "obj_shop2_557", "\E3* ... I know you can't here./")
ds_map_add(global.text_data_en, "obj_shop2_558", "\E1* Wah ha..^1.&* Knowledge like that is&  the only reason I've&  survived so long./%%")
ds_map_add(global.text_data_en, "obj_shop2_564", "* King Fluffybuns^1?&* He's a friendly^1, happy-go-lucky&  kind of guy.../")
ds_map_add(global.text_data_en, "obj_shop2_565", "\E4* If you keep walking around long&  enough^1, you'll probably meet him^1.&*\E0 He loves to walk around and&  talk to people./")
ds_map_add(global.text_data_en, "obj_shop2_566", "\E3* Eh^1?&* Why do I call Dreemurr&  'Fluffybuns?^1'&*\E2 Oh^1, that's a great story!/")
ds_map_add(global.text_data_en, "obj_shop2_567", "\E3* .../")
ds_map_add(global.text_data_en, "obj_shop2_568", "\E0* I don't remember it./")
ds_map_add(global.text_data_en, "obj_shop2_569", "* But if you come back much&  later^1, I'm sure I'll have&  remembered by then./%%")
ds_map_add(global.text_data_en, "obj_shop2_573", "\E2* Oh yeah^1!&* Of course^1.&* Toriel was queen^1, and&  Asgore was the king./")
ds_map_add(global.text_data_en, "obj_shop2_574", "\E3* It was tragic when she left./")
ds_map_add(global.text_data_en, "obj_shop2_575", "\E1* Since everyone knew she was&  really the brains behind the&  throne.../")
ds_map_add(global.text_data_en, "obj_shop2_576", "\E0* But it was also just a&  teensy^1, teensy bit relieving^1,&  you know?/")
ds_map_add(global.text_data_en, "obj_shop2_577", "\E3* Those two were really&  insufferable together..^1.&* Nuzzling noses^1, bein' all cute&  n' cuddly in public..^1.&* Embarrassing their children.../")
ds_map_add(global.text_data_en, "obj_shop2_578", "\E0* They were so sweet it&  made me SICK^1.&* Thank god those days are&  over!/%%")
ds_map_add(global.text_data_en, "obj_shop2_584", "\E3* Eh^1? Fight you?/")
ds_map_add(global.text_data_en, "obj_shop2_585", "\E1* Nah..^1. I'm not a hero^1.&* Never was./")
ds_map_add(global.text_data_en, "obj_shop2_586", "\E2* And b'sides..^1.&* These old bones aren't fit&  for fighting anyhoo./")
ds_map_add(global.text_data_en, "obj_shop2_587", "\E3* One attack from you^1, and&  then I'd... well.../")
ds_map_add(global.text_data_en, "obj_shop2_588", "\E2* At least by talking to&  you^1, I've bought enough time&  for some of them to escape./%%")
ds_map_add(global.text_data_en, "obj_shop2_595", "\E0* Undyne^1?&* Yeah^1, she's a local hero&  around here./")
ds_map_add(global.text_data_en, "obj_shop2_596", "\E4* Through grit and determination&  alone^1, she fought her way to&  the top of the Royal Guard./")
ds_map_add(global.text_data_en, "obj_shop2_597", "\E3* Actually^1, she just came through&  here asking about someone who&  looked just like you.../")
ds_map_add(global.text_data_en, "obj_shop2_598", "\E0* I'd watch your back^1, kid^1.&* And buy some items..^1.&* It might just save your hide^1!&* Wa ha ha!/%%")
ds_map_add(global.text_data_en, "obj_shop2_601", "\E0* Undyne^1.&* She's really come a long way&  since she was a little&  urchin./")
ds_map_add(global.text_data_en, "obj_shop2_602", "\E2* I used to be a hero myself^1,&  back in the old days^1.&* Gerson^1, the Hammer of Justice./")
ds_map_add(global.text_data_en, "obj_shop2_603", "\E3* When she was younger^1, Undyne&  would follow me around^1, to&  watch me beat up bad guys.../")
ds_map_add(global.text_data_en, "obj_shop2_604", "\E0* Sometimes she'd even try&  to help!/")
ds_map_add(global.text_data_en, "obj_shop2_605", "\E3* Though^1, most of the time&  the folks she attacked weren't&  bad guys^1.&* It'd be the mailman or&  something like that./")
ds_map_add(global.text_data_en, "obj_shop2_606", "\E2* Anyhoo^1, I appreciated it^1!&* Wah ha ha ha!!!/%%")
ds_map_add(global.text_data_en, "obj_shop2_612", "\E1* I'm not a hero./")
ds_map_add(global.text_data_en, "obj_shop2_613", "\E3* But I know there's someone&  out there./")
ds_map_add(global.text_data_en, "obj_shop2_614", "\E0* Someone who'll never give&  up trying to do the&  right thing^1, no matter&  what./")
ds_map_add(global.text_data_en, "obj_shop2_615", "\E4* There's no prophecy or&  legend 'bout anyone like&  that./")
ds_map_add(global.text_data_en, "obj_shop2_616", "\E3* It's just something I know&  is true./")
ds_map_add(global.text_data_en, "obj_shop2_617", "\E0* That someone like that&  will strike you down./%%")
ds_map_add(global.text_data_en, "obj_shop3_357", "* No^1, nie wstydź się./*")
ds_map_add(global.text_data_en, "obj_shop3_358", "* Hey^1!&* Check it&  out!/*")
ds_map_add(global.text_data_en, "obj_shop3_359", "* But^1, like./*")
ds_map_add(global.text_data_en, "obj_shop3_362", "* Yeah!&* Check it&  out!/*")
ds_map_add(global.text_data_en, "obj_shop3_363", "* Nobody&  came and&  stuff./*")
ds_map_add(global.text_data_en, "obj_shop3_474", "\E0You should&buy ALL&our stuff!/*")
ds_map_add(global.text_data_en, "obj_shop3_475", "\E4Bratty!&We're&gonna&be rich!/*")
ds_map_add(global.text_data_en, "obj_shop3_476", "\E0So are&you gonna&buy it??/*")
ds_map_add(global.text_data_en, "obj_shop3_477", "\E0You need&WAY more&money./*")
ds_map_add(global.text_data_en, "obj_shop3_478", "\E0You have&TOO many&items!!!/*")
ds_map_add(global.text_data_en, "obj_shop3_479", "\E4We're all&$$$$$old&out!&Mee-YOW!/*")
ds_map_add(global.text_data_en, "obj_shop3_481", "/*")
ds_map_add(global.text_data_en, "obj_shop3_599", "So, like,&what's up?/*")
ds_map_add(global.text_data_en, "obj_shop3_650", "* Thanks^1, but we^1,&  like^1, don't&  really need&  anything./*")
ds_map_add(global.text_data_en, "obj_shop3_658", "\M2* Oh my God^1.&* Is that a&  glamburger?/*")
ds_map_add(global.text_data_en, "obj_shop3_668", "* Stole 5G&  from the&  till./%%")
ds_map_add(global.text_data_en, "obj_shop3_673", "* The till&  is empty./%%")
ds_map_add(global.text_data_en, "obj_shop3_683", "* Like^1, see&  you later!/*")
ds_map_add(global.text_data_en, "obj_shop3_685", "* Like^1, later&  and stuff!/*")
ds_map_add(global.text_data_en, "obj_shop3_690", "* .../*")
ds_map_add(global.text_data_en, "obj_shop3_692", "* .../*")
ds_map_add(global.text_data_en, "obj_shop3_710", "* I'm Bratty^1, and&  this is my&  best friend^1,&  Catty./*")
ds_map_add(global.text_data_en, "obj_shop3_713", "* I'm Catty^1, and&  this is my&  best friend^1,&  Bratty./*")
ds_map_add(global.text_data_en, "obj_shop3_726", "\M3* Well^1, that kind&  of guy.../")
ds_map_add(global.text_data_en, "obj_shop3_727", "\M5* You hang out&  with him once^1,&  then he wants&  to hang out.../")
ds_map_add(global.text_data_en, "obj_shop3_728", "\M2* All^1.&* The^1.&* Time./%%")
ds_map_add(global.text_data_en, "obj_shop3_736", "\M5* Oh^1, uh.../*")
ds_map_add(global.text_data_en, "obj_shop3_745", "\M4* OK^1, like^1,&  the annoying&  thing is.../*")
ds_map_add(global.text_data_en, "obj_shop3_754", "\M2* Oh^1, that guy&  from the&  store^1?&*\M4 Yuck^1, what a&  creep./*")
ds_map_add(global.text_data_en, "obj_shop3_763", "\M0* So^1, we're&  like^1,&  totally&  free now^1,&  huh?/*")
ds_map_add(global.text_data_en, "obj_shop3_778", "* Where do we&  get the&  garbage?/")
ds_map_add(global.text_data_en, "obj_shop3_779", "\M4* Like^1, the&  garbage store^1,&  duh!!!/%%")
ds_map_add(global.text_data_en, "obj_shop3_788", "* I mean^1, like^1,&  where does&  anyone get guns^1,&  or food^1, or.../*")
ds_map_add(global.text_data_en, "obj_shop3_798", "* The stuff&  inside^1, is&  like.../*")
ds_map_add(global.text_data_en, "obj_shop3_807", "\M2* Oh^1, oops^1,&  really?/")
ds_map_add(global.text_data_en, "obj_shop3_808", "\M3* Uh^1, well^1,&  when we&  said^1, um.../")
ds_map_add(global.text_data_en, "obj_shop3_809", "* We were&  hyped for the&  destruction&  of humanity.../")
ds_map_add(global.text_data_en, "obj_shop3_810", "* We were^1,&  just^1, like^1,&  joking^1, you&  know?/%%")
ds_map_add(global.text_data_en, "obj_shop3_822", "* So^1, like^1,&  Dr. Alphys&  built Mettaton^1,&  right?/*")
ds_map_add(global.text_data_en, "obj_shop3_829", "\M6* Oh my God^1.&* Mettaton./")
ds_map_add(global.text_data_en, "obj_shop3_830", "\M6* He's like..^1.&* My robot&  husband.          /")
ds_map_add(global.text_data_en, "obj_shop3_831", "\M4* I think we're&  like..^1. both&  going to marry&  him./*")
ds_map_add(global.text_data_en, "obj_shop3_833", "\E2* Oh my GOD^1,&* METTATON./")
ds_map_add(global.text_data_en, "obj_shop3_834", "\E2* Actually he's&  like..^1.&* MY robot&  husband./")
ds_map_add(global.text_data_en, "obj_shop3_835", "* We're both&  like^1, ALREADY&  married to&  him./*")
ds_map_add(global.text_data_en, "obj_shop3_836", "\E6* He just^1, like^1,&  doesn't know&  it yet./%%")
ds_map_add(global.text_data_en, "obj_shop3_845", "* Hmmm..^1.&* Now that&  we're&  gonna be&  free.../*")
ds_map_add(global.text_data_en, "obj_shop3_859", "\M5* Oh my God^1.&* Alphys./")
ds_map_add(global.text_data_en, "obj_shop3_860", "\M0* She used to&  live on our&  street./*")
ds_map_add(global.text_data_en, "obj_shop3_862", "\E7* Oh my god^1,&* ALPHYS./")
ds_map_add(global.text_data_en, "obj_shop3_863", "\E0* She was like&  a big sister./*")
ds_map_add(global.text_data_en, "obj_shop3_870", "\M0* So Alphys&  has always^1,&  like.../*")
ds_map_add(global.text_data_en, "obj_shop3_879", "\M4* Oh my God^1.&* He's a total&  goober./")
ds_map_add(global.text_data_en, "obj_shop3_880", "\M0* Like^1, I LOVE&  that guy./")
ds_map_add(global.text_data_en, "obj_shop3_881", "\M5* God^1, we're&  like.../")
ds_map_add(global.text_data_en, "obj_shop3_882", "\M1* SO hyped for&  the destruction&  of humanity./*")
ds_map_add(global.text_data_en, "obj_shop3_884", "\E0* He's a big^1,&  fuzzy&  goofball!!   /")
ds_map_add(global.text_data_en, "obj_shop3_885", "\E0* He's like^1,&  SO nice.  /")
ds_map_add(global.text_data_en, "obj_shop3_886", "\E7* God^1, we're&  like.../")
ds_map_add(global.text_data_en, "obj_shop3_887", "\E1* SO hyped for&  the destruction&  of humanity./*")
ds_map_add(global.text_data_en, "obj_shop3_898", "\M0* Me^1?&* Yeah^1, I&  LOVE cats!/")
ds_map_add(global.text_data_en, "obj_shop3_899", "\M1* They're^1,&  like^1,&  SO tasty!!/*")
ds_map_add(global.text_data_en, "obj_shop3_901", "\E8* Me^1?&* Yeah^1, I&  LOVE cats!/")
ds_map_add(global.text_data_en, "obj_shop3_902", "\E1* They're^1,&  like^1,&  SO cute!!!/*")
ds_map_add(global.text_data_en, "obj_shop3_910", "* Hey^1, this is&  Bratty!/*")
ds_map_add(global.text_data_en, "obj_shop3_912", "* Hey^1, this is&  Catty!/*")
ds_map_add(global.text_data_en, "obj_shop3_959", "\E3* TOTALLY wicked&  expensive./%%")
ds_map_add(global.text_data_en, "obj_shop3_970", "* But^1, like^1, this&  stuff we found&  is like.../*")
ds_map_add(global.text_data_en, "obj_shop3_980", "\E3* TOTALLY wicked&  cheap./%%")
ds_map_add(global.text_data_en, "obj_shop3_991", "\M5* You should.../")
ds_map_add(global.text_data_en, "obj_shop3_992", "\M1* TOTALLY wicked&  buy all of&  it?/*")
ds_map_add(global.text_data_en, "obj_shop3_994", "\E7* Like...      /")
ds_map_add(global.text_data_en, "obj_shop3_995", "\E4* TOTALLY wicked&  buy all of&  it?/*")
ds_map_add(global.text_data_en, "obj_shop3_1014", "\E1* We found it in&  the garbage!/%%")
ds_map_add(global.text_data_en, "obj_shop3_1033", "\M3* It's GOOD&  garbage./*")
ds_map_add(global.text_data_en, "obj_shop3_1035", "\E4* It's like^1,&  really good&  garbage./%%")
ds_map_add(global.text_data_en, "obj_shop3_1055", "\M5* ...../")
ds_map_add(global.text_data_en, "obj_shop3_1056", "\M1* Waterfall&  mostly./*")
ds_map_add(global.text_data_en, "obj_shop3_1058", "\E7* ...../")
ds_map_add(global.text_data_en, "obj_shop3_1059", "\E1* I found a gun&  in a dumpster!/%%")
ds_map_add(global.text_data_en, "obj_shop3_1071", "\E6* That's like^1,&  what they&  TELL you./%%")
ds_map_add(global.text_data_en, "obj_shop3_1082", "\M2* But like..^1.&* Mettaton always&  acts like.../*")
ds_map_add(global.text_data_en, "obj_shop3_1093", "\E5* ... being built&  was HIS&  idea somehow./%%")
ds_map_add(global.text_data_en, "obj_shop3_1104", "\M5* And even right&  after he was&  built.../*")
ds_map_add(global.text_data_en, "obj_shop3_1115", "\E7* ... he acted&  like Alphys was&  an old friend./%%")
ds_map_add(global.text_data_en, "obj_shop3_1126", "\M4* But they're&  like..^1.&* Not friends&  anymore./*")
ds_map_add(global.text_data_en, "obj_shop3_1137", "\E1* Yeah!!^1!&* Unlike me&  and Bratty!^1!&* Best friends&  for-EVER!!!/%%")
ds_map_add(global.text_data_en, "obj_shop3_1156", "\M4* I mean^1, like^1,&  if your big&  sister.../*")
ds_map_add(global.text_data_en, "obj_shop3_1167", "\E1* Takes you on&  trips to the&  dump./%%")
ds_map_add(global.text_data_en, "obj_shop3_1179", "\M0* She showed us&  the coolest&  places to&  find trash./*")
ds_map_add(global.text_data_en, "obj_shop3_1189", "\E7* She was always&  collecting&  these weird&  cartoons./%%")
ds_map_add(global.text_data_en, "obj_shop3_1201", "\M5* Then she&  became the&  Royal&  Scientist.../*")
ds_map_add(global.text_data_en, "obj_shop3_1211", "\E5* Yeah^1, we&  haven't seen&  her in&  forever.../%%")
ds_map_add(global.text_data_en, "obj_shop3_1231", "\E2* Thought ASGORE&  is a SUPER&  cutie./%%")
ds_map_add(global.text_data_en, "obj_shop3_1243", "\M4* So^1, like^1, I'm&  pretty sure&  she.../*")
ds_map_add(global.text_data_en, "obj_shop3_1253", "\E0* Made Mettaton&  to^1, like^1,&  totally&  impress him./%%")
ds_map_add(global.text_data_en, "obj_shop3_1265", "\M2* A robot with a&  SOUL.../*")
ds_map_add(global.text_data_en, "obj_shop3_1275", "\E5* That's^1, like^1,&  SUPER relevant&  to his hobbies!/%%")
ds_map_add(global.text_data_en, "obj_shop3_1288", "\M0* So after seeing&  Mettaton^1,&  ASGORE.../*")
ds_map_add(global.text_data_en, "obj_shop3_1298", "\E0* Asked her to do&  all this science&  stuff for him!/")
ds_map_add(global.text_data_en, "obj_shop3_1299", "\E5* But nobody's^1,&  like^1, seen&  anything from&  her yet./%%")
ds_map_add(global.text_data_en, "obj_shop3_1319", "\M2* Or...&  her at all.../*")
ds_map_add(global.text_data_en, "obj_shop3_1329", "\E0* She must^1,&  like^1, just&  stay in her&  lab all day./%%")
ds_map_add(global.text_data_en, "obj_shop3_1341", "\M4* Like^1, live&  a little^1,&  girl./*")
ds_map_add(global.text_data_en, "obj_shop3_1351", "\E1* Yeah!!^1!&* Like us!!!/%%")
ds_map_add(global.text_data_en, "obj_shop3_1371", "\E4* Oh my god^1,&  can you go&  get us some&  Glamburgers?/%%")
ds_map_add(global.text_data_en, "obj_shop3_1383", "\M0* We don't.&* Really need^1.&* Anything./*")
ds_map_add(global.text_data_en, "obj_shop3_1395", "\E2* Wait^1! I'll pay&  you 1000G if&  you get Mettaton&  to autograph&  my butt!/%%")
ds_map_add(global.text_data_en, "obj_shop3_1415", "\E4* OH MY GOD!!^1!&* GIMME!!!/%%")
ds_map_add(global.text_data_en, "obj_shop3_1427", "\M4* God^1, Catty.&* Try to have&  some&  self-control./*")
ds_map_add(global.text_data_en, "obj_shop3_1439", "\E5* Sorry.../%%")
ds_map_add(global.text_data_en, "obj_shop3_1451", "\M6* 'Cause they&  OBVIOUSLY&  brought that&  Glamburger&  for ME./*")
ds_map_add(global.text_data_en, "obj_shop3_1463", "\E1* NOOO WAYYY!!!!!/%%")
ds_map_add(global.text_data_en, "obj_shop3_1484", "\E5* Yeah^1! He's&  a creep!/%%")
ds_map_add(global.text_data_en, "obj_shop3_1495", "\E7* But he's kind&  of cute^1,&  too.../%%")
ds_map_add(global.text_data_en, "obj_shop3_1504", "\M4* C'mon^1,&  Catty^1, don't&  you have&  ANY&  standards^2?/*")
ds_map_add(global.text_data_en, "obj_shop3_1517", "\E1*\M1 Nope!!!/%%")
ds_map_add(global.text_data_en, "obj_shop3_1537", "\E7* He'd be OK&  if he just&  treated us&  with some&  respect./%%")
ds_map_add(global.text_data_en, "obj_shop3_1549", "\M5* But he just&  acts..^1.&* Really&  weird./*")
ds_map_add(global.text_data_en, "obj_shop3_1561", "\E5* And then acts&  like it's OUR&  fault he&  acts that&  way!/%%")
ds_map_add(global.text_data_en, "obj_shop3_1573", "\M0* Like^1, when&  we asked him&  to get those&  Glamburgers.../*")
ds_map_add(global.text_data_en, "obj_shop3_1586", "\E0* He dropped them&  and ran away&  before we&  could even say&  anything!/%%")
ds_map_add(global.text_data_en, "obj_shop3_1598", "\M3* We were^1,&  like^1, going&  to share&  them./*")
ds_map_add(global.text_data_en, "obj_shop3_1610", "\E7* Really^1?&* I wasn't./%%")
ds_map_add(global.text_data_en, "obj_shop3_1624", "\M1* Catty!!/%%")
ds_map_add(global.text_data_en, "obj_shop3_1644", "\E1*\M2 Yeah!^1!&* He should come&  look for&  junk with us!/%%")
ds_map_add(global.text_data_en, "obj_shop3_1657", "\M3* But like^1, if&  we let him&  hang out with&  us..^1. I just&  worry it'll.../*")
ds_map_add(global.text_data_en, "obj_shop3_1669", "\E4*\M2 ... be really&  super fun!/%%")
ds_map_add(global.text_data_en, "obj_shop3_1682", "\M1* Um^1, that was&  NOT what I&  was gonna say./*")
ds_map_add(global.text_data_en, "obj_shop3_1694", "\E1* But I was&  close^1, right!?/%%")
ds_map_add(global.text_data_en, "obj_shop3_1707", "\E7* But don't you&  feel bad for&  him^1, Bratty?/")
ds_map_add(global.text_data_en, "obj_shop3_1708", "\E5* Poor&  Burgerpants.../")
ds_map_add(global.text_data_en, "obj_shop3_1709", "\E4* Think about how&  cool we are&  compared to&  him!!!/")
ds_map_add(global.text_data_en, "obj_shop3_1710", "* We'd be saving&  his LIFE with&  our&  friendship!!/")
ds_map_add(global.text_data_en, "obj_shop3_1711", "\E1* His LIFE^1,&  Bratty!!/%%")
ds_map_add(global.text_data_en, "obj_shop3_1724", "\M4* Uh^1, so?/%%")
ds_map_add(global.text_data_en, "obj_shop3_1735", "\E7* ..^5. %")
ds_map_add(global.text_data_en, "obj_shop3_1736", "\E1* Think of all&  the glamburgers&  he could get&  for us!!/*")
ds_map_add(global.text_data_en, "obj_shop3_1749", "\M3* ... so is he&  free after&  work?/%%")
ds_map_add(global.text_data_en, "obj_shop3_1761", "\E0* Yeah^1, like^1,&  totally&  free./%%")
ds_map_add(global.text_data_en, "obj_shop3_1773", "* Like..^1.&* Cool./*")
ds_map_add(global.text_data_en, "obj_shop3_1785", "\E0* Yeah^1, like^1,&  cool./%%")
ds_map_add(global.text_data_en, "obj_shop3_1797", "* Like^1,&  millennia&  of being&  imprisoned&  finally over?/*")
ds_map_add(global.text_data_en, "obj_shop3_1809", "\E0* Yeah^1, that's&  like pretty&  chill I guess./%%")
ds_map_add(global.text_data_en, "obj_shop3_1822", "\E7* Did we say&  that?/%%")
ds_map_add(global.text_data_en, "obj_shop3_1834", "\M4* Probably?/")
ds_map_add(global.text_data_en, "obj_shop3_1835", "\M1* It's^1, like^1,&  practically&  our&  catchphrase./%%")
ds_map_add(global.text_data_en, "obj_shop3_1847", "\E8* Really^1?&* I thought our&  catchphrase&  was.../")
ds_map_add(global.text_data_en, "obj_shop3_1848", "\E4* B-B-Bratty's&  the best^1,&  C-C-Catty's&  the coolest!/%%")
ds_map_add(global.text_data_en, "obj_shop3_1861", "\M1* Um^1, no?/")
ds_map_add(global.text_data_en, "obj_shop3_1862", "* We've like&  literally&  NEVER said&  that./%%")
ds_map_add(global.text_data_en, "obj_shop3_1873", "\E1* CAN it be&  though!^1?&* CAN it be!?/%%")
ds_map_add(global.text_data_en, "obj_shop3_1886", "\E4* OMG^1, we&  can finally&  fulfill our&  DREAM of having&  a pet cat!/%%")
ds_map_add(global.text_data_en, "obj_shop3_1899", "\M1* That's^1, like^1,&  YOUR dream^1,&  Catty./*")
ds_map_add(global.text_data_en, "obj_shop3_1910", "* But Bratty.../")
ds_map_add(global.text_data_en, "obj_shop3_1911", "\E5*\M5 I don't wanna&  have a dream&  without YOU&  in it...!/%%")
ds_map_add(global.text_data_en, "obj_shop3_1924", "* Aww..^1.&* Catty..^3./*")
ds_map_add(global.text_data_en, "obj_shop3_1936", "\E1* And^1, in my&  dream^1, YOU clean&  up after&  the cat!/%%")
ds_map_add(global.text_data_en, "obj_shop3_1949", "\M1* Catty!!!/%%")
ds_map_add(global.text_data_en, "obj_shop3_1974", "\E5* Bratty&  NOOOO!!!/%%")
ds_map_add(global.text_data_en, "obj_shop3_1987", "\M1* I'm just&  kidding!!/")
ds_map_add(global.text_data_en, "obj_shop3_1988", "\M4*\E8 Kind of./")
ds_map_add(global.text_data_en, "obj_shop3_1989", "\M5*\E7 Anyway^1, when&  was the last&  time you even&  SAW a cat&  around here?/%%")
ds_map_add(global.text_data_en, "obj_shop3_2001", "\E8* Oh!^1!&* JUST the other&  day!/")
ds_map_add(global.text_data_en, "obj_shop3_2002", "\E3* There was&  this CUTE&  little white&  cat walking&  around.../")
ds_map_add(global.text_data_en, "obj_shop3_2003", "\E4* It was^1, like^1,&  SOOOOOO&  clueless&  looking./")
ds_map_add(global.text_data_en, "obj_shop3_2004", "\E1* I pet it&  for like an&  hour!!/%%")
ds_map_add(global.text_data_en, "obj_shop3_2017", "\M5* ....^1.&* ....^1.&* ... Catty^2./*")
ds_map_add(global.text_data_en, "obj_shop3_2028", "\E7* Yeah^1, Bratty?/%%")
ds_map_add(global.text_data_en, "obj_shop3_2042", "\M1* I think that&  was^1, like..^1.&* A dog^3./*")
ds_map_add(global.text_data_en, "obj_shop3_2053", "\E1* DOGS ARE JUST&  FIRM CATS!!!!/%%")
ds_map_add(global.text_data_en, "obj_shop3_2067", "* If you're&  reading&  this.../*")
ds_map_add(global.text_data_en, "obj_shop3_2077", "\E7* Then^1, like^1,&  bad news you&  mega-evil&  weirdo!/%%")
ds_map_add(global.text_data_en, "obj_shop3_2088", "* Alphys just&  came here&  and she's&  taking us.../*")
ds_map_add(global.text_data_en, "obj_shop3_2098", "\E7* Someplace&  super duper&  safe!/%%")
ds_map_add(global.text_data_en, "obj_shop3_2109", "* But^1, first^1,&  we gotta use&  up these gel&  pens./*")
ds_map_add(global.text_data_en, "obj_shop3_2119", "\E7* Yeah^1!&* Chill^1, Alphys!&* We don't wanna&  waste pens!/%%")
ds_map_add(global.text_data_en, "obj_shop3_2131", "* And don't even&  THINK about&  stealing our&  stuff./*")
ds_map_add(global.text_data_en, "obj_shop3_2141", "* Yeah^1, creep^1!&* Leave our&  junk alone!/%%")
ds_map_add(global.text_data_en, "obj_shop3_2152", "* Catty^1, it's&  not JUNK^1.&* It's really&  valuable./*")
ds_map_add(global.text_data_en, "obj_shop3_2162", "* Yeah^1!&* Our garbage&  is REALLY&  valuable!/%%")
ds_map_add(global.text_data_en, "obj_shop3_2174", "* Anyway^1.&* In closing^1:&* You're a&  total loser!/*")
ds_map_add(global.text_data_en, "obj_shop3_2184", "* Yeah^1!&* Loser!!^1!&* Nya ha ha!!!/%%")
ds_map_add(global.text_data_en, "obj_shop3_2196", "* Signed^1,&  Bratty <3/*")
ds_map_add(global.text_data_en, "obj_shop3_2198", "* Signed^1,&  Catty <3/*")
ds_map_add(global.text_data_en, "obj_shop4_244", "\E0* The customer is&  always right./*")
ds_map_add(global.text_data_en, "obj_shop4_245", "\E0* Welcome to MTT-Brand&  Burger Emporium^1, home&  of the Glamburger^1.&* Sparkle up your&  day (TM)./*")
ds_map_add(global.text_data_en, "obj_shop4_249", "\E3* Anything else you&  need?/*")
ds_map_add(global.text_data_en, "obj_shop4_250", "\E3* What can I do for you^1,&  little buddy?/*")
ds_map_add(global.text_data_en, "obj_shop4_252", "\E1* (Why do I always&  get the freaks?)/*")
ds_map_add(global.text_data_en, "obj_shop4_329", "\E0How can&I help&you, O&customer?/*")
ds_map_add(global.text_data_en, "obj_shop4_330", "\E2Thanksy!&Have a&FABU-FUL&day!!!/*")
ds_map_add(global.text_data_en, "obj_shop4_331", "\E1So do&you want&it or&not???/*")
ds_map_add(global.text_data_en, "obj_shop4_332", "\E1That's not&the right&amount of&money./*")
ds_map_add(global.text_data_en, "obj_shop4_333", "\E1You&don't&have&room./*")
ds_map_add(global.text_data_en, "obj_shop4_334", "\E1We don't&HAVE&any&more./*")
ds_map_add(global.text_data_en, "obj_shop4_338", "\E6Take what&you want^1,&little&buddy./*")
ds_map_add(global.text_data_en, "obj_shop4_339", "\E6Here you&go^1,&little&buddy./*")
ds_map_add(global.text_data_en, "obj_shop4_340", "\E6Don't&worry&about&it./*")
ds_map_add(global.text_data_en, "obj_shop4_341", "\E6Sorry...&You can't&take it&for free./*")
ds_map_add(global.text_data_en, "obj_shop4_342", "\E6You gotta&drop some&stuff./*")
ds_map_add(global.text_data_en, "obj_shop4_343", "\E6Like I'm&making&THAT&again./*")
ds_map_add(global.text_data_en, "obj_shop4_347", "\E3Are you&gonna&order or&what?/*")
ds_map_add(global.text_data_en, "obj_shop4_348", "\E6Here you&go^1,&little&weirdo./*")
ds_map_add(global.text_data_en, "obj_shop4_349", "\E1So do&you want&it or&not???/*")
ds_map_add(global.text_data_en, "obj_shop4_350", "\E1That's not&the right&amount of&money./*")
ds_map_add(global.text_data_en, "obj_shop4_351", "\E1You&don't&have&room./*")
ds_map_add(global.text_data_en, "obj_shop4_352", "\E1We don't&HAVE&any&more./*")
ds_map_add(global.text_data_en, "obj_shop4_472", "\E3Take it&from me^1,&little&buddy./*")
ds_map_add(global.text_data_en, "obj_shop4_473", "\E3Nothing&else to&do!/*")
ds_map_add(global.text_data_en, "obj_shop4_519", "\E1* (WHY IS THIS PERSON TRYING TO&  SELL ME SOMETHING THIS IS&  A HAMBURGER RESTAURANT I'M&  JUST TRYING TO SURVIVE)/%%")
ds_map_add(global.text_data_en, "obj_shop4_521", "\E3* WHO DO YOU THINK YOU ARE./%%")
ds_map_add(global.text_data_en, "obj_shop4_525", "\E6* Hmmm..^1.&* Why not try selling that to&  the two chicks in the alley?/%%")
ds_map_add(global.text_data_en, "obj_shop4_529", "\E3* Ah^1. Yes^1.&* I really want to buy your&  weird dusty artifacts..^1.&* NOT./%%")
ds_map_add(global.text_data_en, "obj_shop4_535", "\E2* Have a SPARKULAR day!/%%")
ds_map_add(global.text_data_en, "obj_shop4_538", "\E6* Any time^1, little buddy./%%")
ds_map_add(global.text_data_en, "obj_shop4_539", "\E6* Alone again.../%%")
ds_map_add(global.text_data_en, "obj_shop4_545", "\E6* I'm getting on in years^1, so&  let me give you some&  advice^1, little buddy./")
ds_map_add(global.text_data_en, "obj_shop4_546", "\E3* You've still got time^1.&* Don't live like me./")
ds_map_add(global.text_data_en, "obj_shop4_547", "\E6* I'm 19 years old and I've&  already wasted my entire life./%%")
ds_map_add(global.text_data_en, "obj_shop4_551", "\E0* So we're free^1, huh^1?&* Mettaton told us as much./")
ds_map_add(global.text_data_en, "obj_shop4_552", "\E4* Then he told me^1, " + '"' + "don't&  think that means you're&  getting out of work early." + '"' + "/")
ds_map_add(global.text_data_en, "obj_shop4_553", "\E6* Ah..^1. my boss.&* I love that guy./")
ds_map_add(global.text_data_en, "obj_shop4_554", "\E3* And by that I mean I hate&  him so^1, so much./%%")
ds_map_add(global.text_data_en, "obj_shop4_559", "\E1* Evacuation^1?&* You're yanking my chain^1,&  little weirdo./")
ds_map_add(global.text_data_en, "obj_shop4_560", "\E3* So WHAT if everybody else&  left work?&* So WHAT if nobody's buying&  anything?/")
ds_map_add(global.text_data_en, "obj_shop4_561", "\E6* Par for the course^1,&  little weirdo^1.&* Par for the course./%%")
ds_map_add(global.text_data_en, "obj_shop4_566", "* I'm a goofy goober Yeah &  this errorr. message./%%")
ds_map_add(global.text_data_en, "obj_shop4_570", "\E6* Thank you^1, little buddy./%%")
ds_map_add(global.text_data_en, "obj_shop4_575", "\E5* They wanna hang out after&  work?/")
ds_map_add(global.text_data_en, "obj_shop4_576", "\E3* Ha^1! Ahahaha!^1! Yes!!^1!&* I won't let you down!!/")
ds_map_add(global.text_data_en, "obj_shop4_577", "\E6* Little buddy..^1. thank you./")
ds_map_add(global.text_data_en, "obj_shop4_578", "* You've brought a tear to the&  eye of this old man./")
ds_map_add(global.text_data_en, "obj_shop4_579", "\E5* So^1, uh^1, where do they&  want to go?/")
ds_map_add(global.text_data_en, "obj_shop4_580", "\E4* .../")
ds_map_add(global.text_data_en, "obj_shop4_581", "* They want to hang out at&  the garbage dump./")
ds_map_add(global.text_data_en, "obj_shop4_582", "* .../")
ds_map_add(global.text_data_en, "obj_shop4_583", "\E6* Well^1, nowhere to go but&  up^1, right^1, little buddy?/%%")
ds_map_add(global.text_data_en, "obj_shop4_588", "\E6* Hey little buddy^1, wanna help&  me pick a spicy outfit for&  my little shindig later?/")
ds_map_add(global.text_data_en, "obj_shop4_589", "\E4* Though^1, now that I think&  about it^1, I had to throw away&  all of my clothes to make&  room for the outfits Mettaton&  gave me.../")
ds_map_add(global.text_data_en, "obj_shop4_590", "\E5* Don't take it the wrong way^1.&* They're just all these.../")
ds_map_add(global.text_data_en, "obj_shop4_591", "\E4* Weird getups./")
ds_map_add(global.text_data_en, "obj_shop4_592", "\E1* " + '"' + "Promotional" + '"' + " costumes^1.&* For " + '"' + "holidays.^1" + '"' + "&* Or " + '"' + "specials.^1" + '"' + "&* Or " + '"' + "because he felt like it." + '"' + "/")
ds_map_add(global.text_data_en, "obj_shop4_593", "\E3* The thing IS though^1!&* Most of the time I'm the&  only employee who has to&  wear this stuff!/")
ds_map_add(global.text_data_en, "obj_shop4_594", "\E3* Sometimes he even calls me&  into his office just to..^1.&* Make me put something on.../")
ds_map_add(global.text_data_en, "obj_shop4_595", "\E4* Then he laughs and lets me&  go back to work as normal./")
ds_map_add(global.text_data_en, "obj_shop4_596", "\E6* Anyways^1, I won't sweat it^1,&  little buddy^1.&* I'll take it casual./")
ds_map_add(global.text_data_en, "obj_shop4_597", "* NEVER let hot people think&  you care^1.&* That's how they GET you./%%")
ds_map_add(global.text_data_en, "obj_shop4_603", "\E5* Well^1?&* Don't keep me waiting^1,&  little buddy!!/%%")
ds_map_add(global.text_data_en, "obj_shop4_608", "\E4* The girls were..^1.&* Talking about me...?/")
ds_map_add(global.text_data_en, "obj_shop4_609", "* They say I should stop acting&  like they owe me.../")
ds_map_add(global.text_data_en, "obj_shop4_610", "\E5* ... and if I want to be&  FRIENDS with them^1, I should&  just..^1. uh^1, try to see&  things from their&  perspective?/")
ds_map_add(global.text_data_en, "obj_shop4_611", "\E4* Wow./")
ds_map_add(global.text_data_en, "obj_shop4_612", "\E6* Poor^1, naive little buddy^1.&* They've brainwashed you./")
ds_map_add(global.text_data_en, "obj_shop4_613", "* " + '"' + "Friendship" + '"' + " is just a hot&  person's way of making you&  their slave./")
ds_map_add(global.text_data_en, "obj_shop4_614", "\E4* .../")
ds_map_add(global.text_data_en, "obj_shop4_615", "\E5* So^1, uh^1, what time would&  they wanna hang out?/%%")
ds_map_add(global.text_data_en, "obj_shop4_620", "\E5* Huh^1?&* Yeah^1, those two vendors in back^1.&* The girls./")
ds_map_add(global.text_data_en, "obj_shop4_621", "\E3* NOT the Nice Cream guy./")
ds_map_add(global.text_data_en, "obj_shop4_622", "\E5* He keeps coming in here and&  asking me stuff like^1,&* " + '"' + "Hey Burgy, what do you think&  of this joke for my next&  ice cream wrapper?" + '"' + "/")
ds_map_add(global.text_data_en, "obj_shop4_623", "\E4* Joke^1?&* Why are you calling it a JOKE?/")
ds_map_add(global.text_data_en, "obj_shop4_624", "\E3* You drew a picture of two&  dudes hugging and wrote&  " + '"' + "I love hugs!" + '"' + " on it./")
ds_map_add(global.text_data_en, "obj_shop4_625", "\E3* You somehow understand comedy&  EVEN LESS than that guy who&  keeps going on stage and&  crying about his family./")
ds_map_add(global.text_data_en, "obj_shop4_626", "\E5* Anyway^1, I^1, uh^1, just tell him&  that they're good^1, because he&  gives me the nice cream for&  free afterward.../%%")
ds_map_add(global.text_data_en, "obj_shop4_631", "\E4* Everyone calls me burgerpants&  now./")
ds_map_add(global.text_data_en, "obj_shop4_632", "\E5* But you won't^1, will you^1,&  little buddy?/%%")
ds_map_add(global.text_data_en, "obj_shop4_638", "\E6* So I went out to the alley&  to see those two ladies^1, and&  uh..^1. you know^1, see what'd&  happen next./")
ds_map_add(global.text_data_en, "obj_shop4_639", "\E4* .../")
ds_map_add(global.text_data_en, "obj_shop4_640", "\E5* Then my boss^1, uh^1, saw me and&  asked me what I was doing./")
ds_map_add(global.text_data_en, "obj_shop4_641", "\E1* I was so startled^1, the hamburgers&  in my pockets tumbled out&  onto the ground./")
ds_map_add(global.text_data_en, "obj_shop4_642", "\E3* Not wanting to lose face^1,&  I scrambled to pick them up!/")
ds_map_add(global.text_data_en, "obj_shop4_643", "\E3* But^1, as I was leaning over^1,&  the weight of the remaining&  hamburgers.../")
ds_map_add(global.text_data_en, "obj_shop4_644", "\E5* ... caused my pants to fall&  down./")
ds_map_add(global.text_data_en, "obj_shop4_645", "\E4* Then the girls laughed at me./")
ds_map_add(global.text_data_en, "obj_shop4_646", "\E4* Everyone calls me Burgerpants&  now./%%")
ds_map_add(global.text_data_en, "obj_shop4_647", "%%%")
ds_map_add(global.text_data_en, "obj_shop4_651", "\E6* Listen^1.&* I like you^1, little buddy^1.&* So I'm gonna save you a lot&  of trouble./")
ds_map_add(global.text_data_en, "obj_shop4_652", "\E3* Never interact with attractive&  people./")
ds_map_add(global.text_data_en, "obj_shop4_653", "\E6* Unless you're " + '"' + "one of them^1," + '"' + "&  they're just gonna take&  advantage of you./")
ds_map_add(global.text_data_en, "obj_shop4_654", "\E3* Like that time those two&  chicks asked me to sneak them&  some glamburgers./")
ds_map_add(global.text_data_en, "obj_shop4_655", "\E6* And I^1, naive teenager that&  I was^1, said yes to them./")
ds_map_add(global.text_data_en, "obj_shop4_656", "\E4* Bad idea./%%")
ds_map_add(global.text_data_en, "obj_shop4_662", "\E4* Those girls?&* The ones who saw my pants&  fall down?/")
ds_map_add(global.text_data_en, "obj_shop4_663", "\E5* Well^1, we're all gonna be&  free^1, so I'll never see&  them again^1, at least!/%%")
ds_map_add(global.text_data_en, "obj_shop4_667", "\E4* So we're free now./")
ds_map_add(global.text_data_en, "obj_shop4_668", "\E5* Does that mean my double-&  date is cancelled...?/")
ds_map_add(global.text_data_en, "obj_shop4_669", "\E4* .../")
ds_map_add(global.text_data_en, "obj_shop4_670", "\E5* I know^1, it wasn't really&  a..^1.&* A date./")
ds_map_add(global.text_data_en, "obj_shop4_671", "\E6* Here's a trick^1, little buddy^1:&* Lie to yourself all the time^1.&* It makes you feel better./%%")
ds_map_add(global.text_data_en, "obj_shop4_678", "\E4* Well^1, Mettaton didn't tell me&  I HAD to work, I guess.../")
ds_map_add(global.text_data_en, "obj_shop4_679", "\E3* But that's the thing^1!&* Sometimes he doesn't even&  call me into work until&  halfway into my shift!/")
ds_map_add(global.text_data_en, "obj_shop4_680", "\E4* If I don't play it safe^1,&  he's going to yell at me./")
ds_map_add(global.text_data_en, "obj_shop4_681", "\E6* Okay^1, maybe " + '"' + "yell" + '"' + " is the&  wrong term./")
ds_map_add(global.text_data_en, "obj_shop4_682", "\E4* It's more like he has this..^1.&* CD album he plays.../")
ds_map_add(global.text_data_en, "obj_shop4_683", "\E5* That's entirely full of&  songs about how bad I am&  at my job./%%")
ds_map_add(global.text_data_en, "obj_shop4_698", "\E5* Let's not talk about this./%%")
ds_map_add(global.text_data_en, "obj_shop4_704", "\E1* Why do people find him so&  attractive??/")
ds_map_add(global.text_data_en, "obj_shop4_705", "\E3* He's literally just a freaking&  rectangle./")
ds_map_add(global.text_data_en, "obj_shop4_706", "\E4* .../")
ds_map_add(global.text_data_en, "obj_shop4_707", "* You know^1, one time^1, I bought&  one of those^1, uh^1, kits&  online..^1. to.../")
ds_map_add(global.text_data_en, "obj_shop4_708", "\E5* Uh^1, make yourself more&  rectangular./")
ds_map_add(global.text_data_en, "obj_shop4_709", "\E4* .../")
ds_map_add(global.text_data_en, "obj_shop4_710", "\E5* They don't work./%%")
ds_map_add(global.text_data_en, "obj_shop4_716", "\E3* God^1, have you even looked&  around^1?&* This place is a labyrinth of&  bad choices./")
ds_map_add(global.text_data_en, "obj_shop4_717", "* And every time we try to change&  something for the better^1, he&  vetoes it and says " + '"' + "that's not&  how they do it on the&  surface." + '"' + "/")
ds_map_add(global.text_data_en, "obj_shop4_718", "\E1Oh! Right!/")
ds_map_add(global.text_data_en, "obj_shop4_719", "\E3* Humans are always eating&  hamburgers made of SEQUINS&  AND GLUE./%%")
ds_map_add(global.text_data_en, "obj_shop4_724", "\E5* When I first came to Hotland^1,&  it was my dream to work&  with Mettaton./")
ds_map_add(global.text_data_en, "obj_shop4_725", "\E4* .../")
ds_map_add(global.text_data_en, "obj_shop4_726", "\E3* Well^1, be careful what you&  wish for^1, little buddy!/%%")
ds_map_add(global.text_data_en, "obj_shop4_734", "\E3* Don't tell anyone this^1, Little&  Buddy./")
ds_map_add(global.text_data_en, "obj_shop4_735", "\E4* (Because they'll make fun&  of me,)/")
ds_map_add(global.text_data_en, "obj_shop4_736", "\E5* But I..^1.&* I feel like I played a hand in&  everyone getting free&  somehow./")
ds_map_add(global.text_data_en, "obj_shop4_737", "\E1* Even if it was just&  working this awful job.../")
ds_map_add(global.text_data_en, "obj_shop4_738", "\E5* I think I did something!/")
ds_map_add(global.text_data_en, "obj_shop4_739", "\E3* I don't know if it's true^1,&  but I'll believe it anyway!/%%")
ds_map_add(global.text_data_en, "obj_shop4_744", "\E3* Huh?&* Everyone else is DEAD?/")
ds_map_add(global.text_data_en, "obj_shop4_745", "\E4* .../")
ds_map_add(global.text_data_en, "obj_shop4_746", "\E5* Does that mean I don't&  have to work today?/")
ds_map_add(global.text_data_en, "obj_shop4_747", "\E6* God^1.&* That it were true^1,&  little weirdo^1.&* That it were true./%%")
ds_map_add(global.text_data_en, "obj_shop4_756", "\E3* Future^1?&* WHAT future^1?&* Nothing down here EVER&  changes./")
ds_map_add(global.text_data_en, "obj_shop4_757", "\E4* I'll probably be trapped&  at this stupid job forever./")
ds_map_add(global.text_data_en, "obj_shop4_758", "* .../")
ds_map_add(global.text_data_en, "obj_shop4_759", "\E3* But wait^1!&* There's one thing that keeps&  me going!/")
ds_map_add(global.text_data_en, "obj_shop4_760", "* If ASGORE gets just one&  more SOUL^1, we'll finally get&  to go to the surface!/")
ds_map_add(global.text_data_en, "obj_shop4_761", "* It'll be a brand new world^1!&* There's gotta be a second&  chance out there for me^1!&* For everyone!/")
ds_map_add(global.text_data_en, "obj_shop4_762", "\E6* So stay strong^1, little buddy^1.&* When I make it big^1, I'll&  keep you in mind./%%")
ds_map_add(global.text_data_en, "obj_shop4_767", "\E3* Little buddy^1!&* There's a brand new world&  out there waiting&  for us./")
ds_map_add(global.text_data_en, "obj_shop4_768", "\E6* I'm sure with my (ahem)&  qualifications^1, it won't&  be long before I'm a&  famous movie star.../")
ds_map_add(global.text_data_en, "obj_shop4_769", "\E4* Or^1, maybe I'll just end up&  flipping burgers again./")
ds_map_add(global.text_data_en, "obj_shop4_770", "\E3* But it's as I say^1!&* Nowhere to go but up^1!&* Literally^1, in this case!/%%")
ds_map_add(global.text_data_en, "obj_shop4_775", "\E6* Sorry^1, little weirdo^1.&* Threats won't work on me./")
ds_map_add(global.text_data_en, "obj_shop4_776", "* I can't go to hell^1.&* I'm all out of vacation&  days./%%")
ds_map_add(global.text_data_en, "obj_shop4_785", "\E0* I'm sorry^1, (Ha ha) it's against&  the rules to talk to customers&  who haven't bought anything./%%")
ds_map_add(global.text_data_en, "obj_shop4_790", "\E1* What^1?&* Why do you keep trying to talk&  to me?/")
ds_map_add(global.text_data_en, "obj_shop4_792", "\E1* I'll get in trouble if I get&  chummy with the customers./")
ds_map_add(global.text_data_en, "obj_shop4_793", "\E0* Sorry./")
ds_map_add(global.text_data_en, "obj_shop4_794", "\E4* .../")
ds_map_add(global.text_data_en, "obj_shop4_795", "\E3* SO^1, I wanted to be an ACTOR./%%")
ds_map_add(global.text_data_en, "obj_shop5_343", "\E0* hOI^1!&* witoj w..^1.&* SKLEPIE TEMA!!!/*")
ds_map_add(global.text_data_en, "obj_shop5_344", "\E0* hOI^1!&* witoj w..^1.&* SKLEPIE TEMA!!!/*")
ds_map_add(global.text_data_en, "obj_shop5_405", "\E0hOI^1!&witoj w..^1.&SKLEPIE&TEM!/*")
ds_map_add(global.text_data_en, "obj_shop5_406", "\E6dziemkować&ZAKUP!/*")
ds_map_add(global.text_data_en, "obj_shop5_407", "\E0fdshfgfg/*")
ds_map_add(global.text_data_en, "obj_shop5_408", "\E2ni masz&paltkuf&:</*")
ds_map_add(global.text_data_en, "obj_shop5_409", "\E1WAO!!^1!&torba..^1.&PEŁUNA!/*")
ds_map_add(global.text_data_en, "obj_shop5_491", "\E0HOI!!^1!&ja być&temmie/*")
ds_map_add(global.text_data_en, "obj_shop5_536", "\E2* nie ma wioncej.../%%")
ds_map_add(global.text_data_en, "obj_shop5_540", "\E0* bOI!!/%%")
ds_map_add(global.text_data_en, "obj_shop5_544", "\E0* hOI!!!/")
ds_map_add(global.text_data_en, "obj_shop5_545", "* jestom temmie/%%")
ds_map_add(global.text_data_en, "obj_shop5_549", "\E0* hOI!!!/")
ds_map_add(global.text_data_en, "obj_shop5_550", "* jestom temmie/%%")
ds_map_add(global.text_data_en, "obj_shop5_554", "\E1* zbroja tema taka DOBRA^1!&* każuda walka mile widzuaNA^1!&* ŁAtwE zfycienstwo!!!/")
ds_map_add(global.text_data_en, "obj_shop5_555", "\E4* ale^1, hnnn^1, tem myśli..^1.&* jak użyjosz zbroje^1, walki noe&  bedom jusz wysfaniem,/")
ds_map_add(global.text_data_en, "obj_shop5_556", "\E3* ale tem..^1.&* mieć rozfionsanue!/")
ds_map_add(global.text_data_en, "obj_shop5_557", "\W* \E6tem oferuje..^1.\Y &* DOFINANSOWANIE\W!/")
ds_map_add(global.text_data_en, "obj_shop5_558", "\W*\E3 jesli \Ypszegrasz dduszo walk^1, \W &  tem \YOBNISZY CENEO\W!/")
ds_map_add(global.text_data_en, "obj_shop5_559", "\E3* wionc jośli bundziesz w&  CIONSZKIEJ WALCE i czujesz&  FRUSTRACJE^1, moszna kupidźć&  zbroje TEM jako ucieczke!/")
ds_map_add(global.text_data_en, "obj_shop5_560", "\E5* ale zbroja tem taka dobzia^1,&* obiecać^1, ze tylko kupuisz&  jaśli bardzo potszebujes^1,/%%")
ds_map_add(global.text_data_en, "obj_shop5_564", "\E1* wbłasciwue..^1.&* CENEO JUSZ MOŻE NISZSZA!!!&* WOA!!!!/")
ds_map_add(global.text_data_en, "obj_shop5_565", "\E6* Kongra-tem-ulacje!!!/%%")
ds_map_add(global.text_data_en, "obj_shop5_575", "\E0* my temy mieć GŁEMBOKOM&  HISTORIE!!!/%%")
ds_map_add(global.text_data_en, "obj_shop5_579", "\E0* yaYA!!^1!&* tem mieć stopieni na UCZELNI^1!&* tem móc powiedziedź wrzysdko&  o GŁEMBOKIEJ HISTORI temuw!!!/%%")
ds_map_add(global.text_data_en, "obj_shop5_584", "\E0* yaYA!!!&* ić do SKLEPU TEMA!!!/%%")
ds_map_add(global.text_data_en, "obj_shop5_589", "\E1* WOA!!/")
ds_map_add(global.text_data_en, "obj_shop5_590", "\E2* mas... \[1]s!!!/")
ds_map_add(global.text_data_en, "obj_shop5_591", "\E4* hnnn...^1.&* tem musieć mieć \[1]..^1.&* ale muse zapalcić za uczelniem,/")
ds_map_add(global.text_data_en, "obj_shop5_594", "\E4* hnnn...^1.&* tem musieć miec \[1]..^1.&* ale musie zapalćic za szkoułe,/")
ds_map_add(global.text_data_en, "obj_shop5_596", "\E5* hnnnn....!!^1!&* tem od zawsze chćieć&  \[1]...!/%%")
ds_map_add(global.text_data_en, "obj_shop5_601", "\E2* a..^1 ale.../")
ds_map_add(global.text_data_en, "obj_shop5_602", "\E4* p!!!!!!!!!!!!/%%")
ds_map_add(global.text_data_en, "obj_shop5_607", "\E3* Pożałujesz tego./%%")
ds_map_add(global.text_data_en, "obj_shop5_611", "\E3* Czy to żart^1?&* Coś cię bawi^1?&* Ha ha^1, bardzo śmieszne^1.&* To JA mam dyplomat tEM./%%")
ds_map_add(global.text_data_en, "obj_shop5_633", "\E1* WOA!!/")
ds_map_add(global.text_data_en, "obj_shop5_634", "\E2* to wiele płuatkuf..^1.&* czy tEM naprafde mosze&  to przyjonć.../")
ds_map_add(global.text_data_en, "obj_shop5_635", "\E7* OKs!!!^1!&* tem iŚĆ na stUDIA i ucynić&  ce dumny OwO!!!/%%")
ds_map_add(global.text_data_en, "obj_shop5_672", "* tem wrućić ze studia,/")
ds_map_add(global.text_data_en, "obj_shop5_673", "\E0* tem naucyć siem WIELE RZECZY^1,&* i uczyć siem spszedawuac NOWE&  RZECZY^1!&* yayA!!!/%%")
