ds_map_add(global.text_data_en, "obj_lastsans_trigger_704", "\E1* to wyraz twarzy kogoś&  kto umarł osiem razy&  z rzędu./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_705", "\E2* to liczba palców u&  typowego pająka./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_706", "\E3* ale niedługo.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_707", "\E1* chwila^1, czy pająki&  nie mają nóg?/%%")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_713", "\E0* hmm^1.&* ta twarz.../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_714", "\E1* to wyraz twarzy kogoś&  kto umarł siedem razy&  z rzędu./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_715", "\E1* .../")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_716", "\E2* niet^1, chwila^1, to&  definitywnie dziewięć^1,&  sorry./")
