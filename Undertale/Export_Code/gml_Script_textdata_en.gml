ds_map_add(global.text_data_en, "obj_dummytrigger_222", "* Hahaha..^1.&* To takie twojskie^1,&  żeby uciec./")
ds_map_add(global.text_data_en, "obj_dummytrigger_223", "* GŁUPIEC^1!&* Myślałeś^1, że możesz&  skrzywdzić MNIE???/")
ds_map_add(global.text_data_en, "obj_dummytrigger_224", "* Hahaha..^1.&* Zbyt wrażliwy^1, by mnie&  pobić^1, huh!?/")
ds_map_add(global.text_data_en, "obj_dummytrigger_225", "* Ja jestem duchem żyjącym&  wewnątrz MANEKINA./")
ds_map_add(global.text_data_en, "obj_dummytrigger_226", "* Mój kuzyn też kiedyś&  mieszkał w MANEKINIE^1.&* Dopóki.../")
ds_map_add(global.text_data_en, "obj_dummytrigger_229", "* TY SIĘ NIE ZJAWIŁEŚ!/")
ds_map_add(global.text_data_en, "obj_dummytrigger_230", "* On był naprawdę nieśmiały^1.&* Wiednący samotne życie w&  RUINACH.../")
ds_map_add(global.text_data_en, "obj_dummytrigger_231", "* Zobaczył cię z nadzieją^1, że&  z nim pogadasz./")
ds_map_add(global.text_data_en, "obj_dummytrigger_232", "* Być może rzucić &  przyjacielską&  konwersację./")
ds_map_add(global.text_data_en, "obj_dummytrigger_233", "* Ale NIE!!!/")
ds_map_add(global.text_data_en, "obj_dummytrigger_234", "* Postanowiłeś uciec..^1.&* I zniszczyłeś jego małe^1&  nietykalne serce./")
ds_map_add(global.text_data_en, "obj_dummytrigger_235", "* Nikczemny^1.&* Nikczemny^1!&* NIKCZEMNY!/")
ds_map_add(global.text_data_en, "obj_dummytrigger_236", "* CZŁOWIEKU^1!&* Pokażę ci^1, jak wygląda&  PRAWDZIWE złamanie serca!/%%")
ds_map_add(global.text_data_en, "obj_dummytrigger_241", "* ZNISZCZYŁEŚ MU DOM!/")
ds_map_add(global.text_data_en, "obj_dummytrigger_242", "* My duchy spędzamy całe nasze&  życie szukając właściwego&  ciała do okupacji./")
ds_map_add(global.text_data_en, "obj_dummytrigger_243", "* Powoli^1, powoli^1, rośniemy&  bliżej do naszych nowych&  ciał.../")
ds_map_add(global.text_data_en, "obj_dummytrigger_244", "* Aż jednego dnia^1, my też&  możemy się stać materialnymi&  istotami./")
ds_map_add(global.text_data_en, "obj_dummytrigger_245", "* I być w stanie się śmiać^1,&  kochać^1, i tańczyć jak&  każdy inny.../")
ds_map_add(global.text_data_en, "obj_dummytrigger_246", "* Ale TY!!!^1!&* Przyszłość mojego kuzyna...^1!&* Odebrałeś to wszystko!/")
ds_map_add(global.text_data_en, "obj_dummytrigger_251", "* Nikczemny^1.&* Nikczemny^1!&* NIKCZEMNY!/")
ds_map_add(global.text_data_en, "obj_dummytrigger_252", "* CZŁOWIEKU^1!&* Liczę^1, że nie jesteś zbyt&  przywiązany do TWOJEGO ciała.../")
ds_map_add(global.text_data_en, "obj_dummytrigger_253", "* Ponieważ twoja DUSZA zostanie&  ROZTRZĘPIONA!!!/%%")
ds_map_add(global.text_data_en, "obj_dummytrigger_257", "* TY SIĘ NIE ZJAWIŁEŚ!/")
ds_map_add(global.text_data_en, "obj_dummytrigger_258", "* Kiedy gadałeś z nim^1,&  on myślał^1, że naprawdę&  z kimś pogada.../")
ds_map_add(global.text_data_en, "obj_dummytrigger_259", "* Ale te rzeczy które&  POWIEDZIAŁEŚ...!/")
ds_map_add(global.text_data_en, "obj_dummytrigger_260", "* Okropne^1.&* Szokujące^1!&* NIEWIARYGODNE!/")
ds_map_add(global.text_data_en, "obj_dummytrigger_261", "* Wystraszyłeś go całkiem&  z jego manekina!/")
ds_map_add(global.text_data_en, "obj_dummytrigger_262", "* CZŁOWIEKU^1!&* Wystraszę twoją DUSZĘ&  z twojego ciała!/%%")
ds_map_add(global.text_data_en, "obj_dummytrigger_267", "* TY...!/")
ds_map_add(global.text_data_en, "obj_dummytrigger_268", "* Ty.../")
ds_map_add(global.text_data_en, "obj_dummytrigger_269", "* Kurczę blaszka^1!&* Byłeś naprawdę nudny!/")
ds_map_add(global.text_data_en, "obj_dummytrigger_270", "* On się wkurzył i uciekł&  jak każdy mający do&  siebie szacunek./")
ds_map_add(global.text_data_en, "obj_dummytrigger_271", "* W takim razie^1.&* W takim razie!&* W TAKIM RAZIE!/")
ds_map_add(global.text_data_en, "obj_dummytrigger_272", "* Nudni ludzie to okruszki&  lepiący się do twarzy&  tego świata./")
ds_map_add(global.text_data_en, "obj_dummytrigger_273", "* Człowieku!/")
ds_map_add(global.text_data_en, "obj_dummytrigger_274", "* Wytrę cię za pomocą&  delikatnej chusty&  zemsty!/%%")
ds_map_add(global.text_data_en, "obj_dummytrigger_279", "* Hahaha..^1.&* To takie twojskie^1,&  żeby uciec./")
ds_map_add(global.text_data_en, "obj_dummytrigger_280", "* GŁUPIEC^1!&* Myślałeś^1, że możesz&  skrzywdzić MNIE???/")
ds_map_add(global.text_data_en, "obj_dummytrigger_281", "* Hahaha..^1.&* Zbyt wrażliwy^1, by mnie&  pobić^1, huh!?/")
ds_map_add(global.text_data_en, "obj_dummytrigger_282", "* Ja jestem duchem żyjącym&  wewnątrz MANEKINA./")
ds_map_add(global.text_data_en, "obj_dummytrigger_283", "* Mój kuzyn też kiedyś&  mieszkał w MANEKINIE^1.&* Dopóki.../")
ds_map_add(global.text_data_en, "obj_dummytrigger_284", "* TY SIĘ NIE ZJAWIŁEŚ!/")
ds_map_add(global.text_data_en, "obj_dummytrigger_285", "* Nie tylko TWOJE decyzje&  spowodowały^1, że on opuścił&  swój dom.../")
ds_map_add(global.text_data_en, "obj_dummytrigger_286", "* Ale też wszyscy jego&  sąsiedzi też znikli!/")
ds_map_add(global.text_data_en, "obj_dummytrigger_287", "* Nikczemny^1.&* Nikczemny^1!&* NIKCZEMNY!!!!/")
ds_map_add(global.text_data_en, "obj_dummytrigger_288", "* Jesteś najpodlejszą osobą&  jaką kiedykolwiek poznałem^1!&* NIGDY nie byłem taki zły!!!/")
ds_map_add(global.text_data_en, "obj_dummytrigger_289", "* Guooooohhhh!!!^1!&* Moje poziomy manekinowe&  PRZEKRACZAJĄ WYKRESY!!!/%%")
ds_map_add(global.text_data_en, "obj_dummytrigger_344", "* cóż..^1.&* pójdę teraz&  do domu.../")
ds_map_add(global.text_data_en, "obj_dummytrigger_345", "* oh..^1. umm..^1.&* nie krępuj się " + '"' + "przyjść&  ze mną" + '"' + " jeśli chcesz.../")
ds_map_add(global.text_data_en, "obj_dummytrigger_346", "* ale bez nacisku.../")
ds_map_add(global.text_data_en, "obj_dummytrigger_347", "* rozumiem^1, jeśli&  jesteś zajęty.../")
ds_map_add(global.text_data_en, "obj_dummytrigger_348", "* nie szkodzi.../")
ds_map_add(global.text_data_en, "obj_dummytrigger_349", "* nie przejmuj&  się.../")
ds_map_add(global.text_data_en, "obj_dummytrigger_350", "* po prostu&  pomyślałem^1, że&  zaoferuję.../%%")
ds_map_add(global.text_data_en, "obj_dummytrigger_354", "* cóż..^1.&* pójdę teraz&  do domu.../")
ds_map_add(global.text_data_en, "obj_dummytrigger_355", "* tylko ostrzegam.../")
ds_map_add(global.text_data_en, "obj_dummytrigger_356", "* żebyś mnie przypad-&  kiem nie śledził&  do domu.../")
ds_map_add(global.text_data_en, "obj_dummytrigger_357", "* prawopodobnie&  byś tego&  nie chciał.../%%")
ds_map_add(global.text_data_en, "obj_dummytrigger_417", "* ...?/")
ds_map_add(global.text_data_en, "obj_dummytrigger_418", "* To..^1.&* To uczucie...?/%%")
ds_map_add(global.text_data_en, "obj_dummytrigger_427", "* Eureka^1.&* Eureka^1!&* EUREKA!!/")
ds_map_add(global.text_data_en, "obj_dummytrigger_428", "* Człowieku^1.&* Ten moment ogromnych emocji./")
ds_map_add(global.text_data_en, "obj_dummytrigger_429", "* Pozwoliło mi w końcu złączyć&  się z moim ciałem!/")
ds_map_add(global.text_data_en, "obj_dummytrigger_430", "* Jestem w pełni materialny^1!&* Moje życiowe marzenie^1,&  w końcu zrealizowane!/")
ds_map_add(global.text_data_en, "obj_dummytrigger_431", "* W zamian^1, chyba&  cię przepuszczę./")
ds_map_add(global.text_data_en, "obj_dummytrigger_432", "* Brzmi git?/%%")
ds_map_add(global.text_data_en, "obj_echoflower_96", "* Error!/%%")
ds_map_add(global.text_data_en, "obj_echoflower_104", "* Jedyne co mi przynosi&  walidację w życiu to&  tłumaczenie Echo Kwiatkom.../")
ds_map_add(global.text_data_en, "obj_echoflower_105", "* Że nikt nie może się&  dowiedzieć.../%%")
ds_map_add(global.text_data_en, "obj_echoflower_110", "* Oto Kwiatek Echo^1.&* Powtarza ostatnią rzecz którą&  słyszała w kółko.../%%")
ds_map_add(global.text_data_en, "obj_echoflower_114", "* Fajne^1, co nie?/%%")
ds_map_add(global.text_data_en, "obj_echoflower_118", "* Nigdy nie ufaj kwiatkowi..^1.&* To jedna z zasad tego świata./%%")
ds_map_add(global.text_data_en, "obj_echoflower_123", "* (Jest dziwnie milczący.)/%%")
ds_map_add(global.text_data_en, "obj_echoflower_130", "* Siedząc za pływającą wodą..^1.&* Powoduje^1, że czuje się&  zrelaksowana./%%")
ds_map_add(global.text_data_en, "obj_echoflower_131", "* Przysięgam^1, że coś widziałam..^1.&* Za tą pływającą wodą.../%%")
ds_map_add(global.text_data_en, "obj_echoflower_135", "* Po prostu nie byłem gotów&  na tą odpowiedzialność.../%%")
ds_map_add(global.text_data_en, "obj_echoflower_141", "* Dawno temu^1, potwory miały&  zwyczaj szeptania marzeń do&  gwiazd na niebie./")
ds_map_add(global.text_data_en, "obj_echoflower_142", "* Jeśli życzyłeś całym twoim&  sercem^1, twoje marzenie by&  się spełniło./")
ds_map_add(global.text_data_en, "obj_echoflower_143", "* Teraz^1, jedyne co mamy to te&  błyszczące kamienie na&  suficie.../%%")
ds_map_add(global.text_data_en, "obj_echoflower_145", "* (Jest dziwnie milczący.)/%%")
ds_map_add(global.text_data_en, "obj_echoflower_150", "* Tysiące marzących osób&  razem nie mogą być w błędzie!/")
ds_map_add(global.text_data_en, "obj_echoflower_151", "* Nasz król to udowodni./%%")
ds_map_add(global.text_data_en, "obj_echoflower_153", "* (Jest dziwnie milczący.)/%%")
ds_map_add(global.text_data_en, "obj_echoflower_156", "* Chodź^1, siostra^1!&* Zrób życzenie!/%%")
ds_map_add(global.text_data_en, "obj_echoflower_157", "* Życzę^1, żebym ja i moja&  siostra mogły kiedyś zobaczyć&  prawdziwe gwiazdy.../%%")
ds_map_add(global.text_data_en, "obj_echoflower_159", "* Ah..^1. chyba mój horoskop jest&  taki sam jak w zeszłym&  tygodniu.../%%")
ds_map_add(global.text_data_en, "obj_echoflower_161", "* (Jest dziwnie milczący.)/%%")
ds_map_add(global.text_data_en, "obj_echoflower_166", "* Siedząc za pływającą wodą..^1.&* Powoduje^1, że czuje się&  zrelaksowana./%%")
ds_map_add(global.text_data_en, "obj_echoflower_171", "* Squeak./%%")
ds_map_add(global.text_data_en, "obj_echoflower_173", "* (Jest dziwnie milczący.)/%%")
ds_map_add(global.text_data_en, "obj_echoflower_178", "* (Słyszysz mijającą&  konwersację.)/")
ds_map_add(global.text_data_en, "obj_echoflower_179", "* Nie mów tak^1!&* No weź^1, obiecuję^1, że&  nie będę się śmiał./%%")
ds_map_add(global.text_data_en, "obj_echoflower_183", "* (Słyszysz mijającą&  konwersację.)/")
ds_map_add(global.text_data_en, "obj_echoflower_184", "* Więc^1? Mie masz żadnych&  życzeń do spełnienia?/%%")
ds_map_add(global.text_data_en, "obj_echoflower_189", "* (Słyszysz mijającą&  konwersację.)/")
ds_map_add(global.text_data_en, "obj_echoflower_190", "* ... hmmm^1, tylko jedno^1, ale.../")
ds_map_add(global.text_data_en, "obj_echoflower_191", "* Jest nieco głupie./%%")
ds_map_add(global.text_data_en, "obj_echoflower_194", "* (Jest dziwnie milczący.)/%%")
ds_map_add(global.text_data_en, "obj_echoflower_199", "* Nie mogę już dłużej biec.^1.&* Błagam^1, ktokolwiek.../%%")
ds_map_add(global.text_data_en, "obj_echoflower_205", "* Pewnego dnia^1, chciałbym się&  wspiąć na wzgórze^1, pod którym&  jesteśmy wszyscy uwięzieni./%%")
ds_map_add(global.text_data_en, "obj_echoflower_209", "* (Słyszysz mijającą&  konwersację.)/")
ds_map_add(global.text_data_en, "obj_echoflower_210", "* Sorki^1, to po prostu śmieszne.../")
ds_map_add(global.text_data_en, "obj_echoflower_211", "* To również moje życzenie./%%")
ds_map_add(global.text_data_en, "obj_echoflower_217", "* (Słyszysz śmiech.)/")
ds_map_add(global.text_data_en, "obj_echoflower_218", "* ... hej^1, powiedziałaś^1, że nie&  będziesz się z tego śmiała!/%%")
ds_map_add(global.text_data_en, "obj_echoflower_223", "* (Słyszysz mijającą&  konwersację.)/")
ds_map_add(global.text_data_en, "obj_echoflower_224", "* Pewnego dnia^1, chciałbym się&  wspiąć na wzgórze^1, pod którym&  jesteśmy wszyscy uwięzieni./")
ds_map_add(global.text_data_en, "obj_echoflower_225", "* Stojąc pod niebem^1, patrząc&  na otaczający nas świat..^1.&* Oto moje życzenie./%%")
ds_map_add(global.text_data_en, "obj_echoflower_230", "* (Słyszysz mijającą&  konwersację.)/")
ds_map_add(global.text_data_en, "obj_echoflower_231", "* Oczywiście^1, że się nie&  zaśmieję!/%%")
ds_map_add(global.text_data_en, "obj_echoflower_236", "* (Słyszysz mijającą&  konwersację.)/")
ds_map_add(global.text_data_en, "obj_echoflower_237", "* ... hmmm..^1. jeśli powiem..^1.&* Obiecujesz^1, że nie będziesz&  się ze mnie śmiała?/%%")
ds_map_add(global.text_data_en, "obj_echoflower_243", "* Gdzie o gdzie może&  być to dziecko...?/")
ds_map_add(global.text_data_en, "obj_echoflower_244", "* Szukałam go wszędzie.../")
ds_map_add(global.text_data_en, "obj_echoflower_245", "\TS* .../")
ds_map_add(global.text_data_en, "obj_echoflower_246", "\TF* Hee hee hee./")
ds_map_add(global.text_data_en, "obj_echoflower_247", "* TO nieprawda./")
ds_map_add(global.text_data_en, "obj_echoflower_248", "* Ona znajdzie kolejnego^1, i&  od razu o tobie zapomni./")
ds_map_add(global.text_data_en, "obj_echoflower_249", "* Już NIGDY jej nie zobaczysz./%%")
ds_map_add(global.text_data_en, "obj_echoflower_253", "* Gdzie ja jestem...?/")
ds_map_add(global.text_data_en, "obj_echoflower_254", "* Jest tak zimno..^1.&* I ciemno.../")
ds_map_add(global.text_data_en, "obj_echoflower_255", "* Ktoś pomóż mi..^1.&* Ktokolwiek..^1. proszę..^1.&* Pomocy.../")
ds_map_add(global.text_data_en, "obj_echoflower_256", "\TF* .../")
ds_map_add(global.text_data_en, "obj_echoflower_257", "* Ale nikt nie przyszedł./%%")
ds_map_add(global.text_data_en, "obj_echoflower_262", "* (Jest dziwnie milczący.)/%%")
ds_map_add(global.text_data_en, "obj_echoflower_301", "* (Zatrzymałeś się^1, by powąchać&  kwiatki.)/%%")
ds_map_add(global.text_data_en, "obj_elevatordoor_215", "* (Winda nie działa.)/")
ds_map_add(global.text_data_en, "obj_elevatordoor_218", "\S-\Sp* Dzyn...\S+/")
ds_map_add(global.text_data_en, "obj_elevatordoor_219", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_elevatordoor_220", "* What^1?&* The elevator should&  be working.../")
ds_map_add(global.text_data_en, "obj_elevatordoor_221", "* .../")
ds_map_add(global.text_data_en, "obj_elevatordoor_222", "\E6* W-well then^1!&* Go to the right&  and keep heading up!/%%")
ds_map_add(global.text_data_en, "obj_elevatordoor_223", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_elevatordoor_224", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_elevatordoor_228", "\E6* W-well then^1!&* Let's go to the&  left!/%%")
ds_map_add(global.text_data_en, "obj_elevatordoor_229", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_elevatordoor_230", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_elevatordoor_234", "* (Winda nie działa.)/%%")
ds_map_add(global.text_data_en, "obj_elevatordoor_250", "* (Winda nie działa.)/%%")
ds_map_add(global.text_data_en, "obj_elevatordoor_258", "* (Winda jest w użytku.)/%%")
ds_map_add(global.text_data_en, "obj_elevatorpanel_104", "* Proszę wybrać piętro./%%")
ds_map_add(global.text_data_en, "obj_endflowey_188", "\E0Why...?/")
ds_map_add(global.text_data_en, "obj_endflowey_189", "Why did you let me go? /")
ds_map_add(global.text_data_en, "obj_endflowey_190", "\E7Don't you realize that&being nice.../")
ds_map_add(global.text_data_en, "obj_endflowey_191", "\E1... just makes you&get hurt?/")
ds_map_add(global.text_data_en, "obj_endflowey_192", "\E0Look at yourself./")
ds_map_add(global.text_data_en, "obj_endflowey_193", "\E9You made all these&great friends.../")
ds_map_add(global.text_data_en, "obj_endflowey_194", "\E0But now^1, you'll probably&never see them again./")
ds_map_add(global.text_data_en, "obj_endflowey_195", "\E9Not to mention how&much they've been&set back by you./")
ds_map_add(global.text_data_en, "obj_endflowey_196", "\E6Hurts^1, doesn't it?/")
ds_map_add(global.text_data_en, "obj_endflowey_197", "\E7If you had just gone&through without caring&about anyone.../")
ds_map_add(global.text_data_en, "obj_endflowey_198", "\E6You wouldn't have to&feel bad now./")
ds_map_add(global.text_data_en, "obj_endflowey_199", "\E0So I don't get it./")
ds_map_add(global.text_data_en, "obj_endflowey_200", "\E7If you really did&everything the right&way../")
ds_map_add(global.text_data_en, "obj_endflowey_201", "\E0Why did things still&end up like this?/")
ds_map_add(global.text_data_en, "obj_endflowey_202", "\E6Why...?/")
ds_map_add(global.text_data_en, "obj_endflowey_203", "\E5Is life really&that unfair?/")
ds_map_add(global.text_data_en, "obj_endflowey_204", "\E9.../")
ds_map_add(global.text_data_en, "obj_endflowey_205", "\E0Say./")
ds_map_add(global.text_data_en, "obj_endflowey_206", "\E9What if I told you.../")
ds_map_add(global.text_data_en, "obj_endflowey_207", "\E0I knew some way&to get you a better&ending?/")
ds_map_add(global.text_data_en, "obj_endflowey_208", "\E9You'll have to load&your SAVE file, and.../")
ds_map_add(global.text_data_en, "obj_endflowey_211", "\E9You'll have to&start over^1, and.../")
ds_map_add(global.text_data_en, "obj_endflowey_216", "\E0Well, in the meantime^1,&why don't you go see&Dr. Alphys?/")
ds_map_add(global.text_data_en, "obj_endflowey_219", "\E0Well^1, in the meantime^1,&why don't you go see&Undyne?/")
ds_map_add(global.text_data_en, "obj_endflowey_223", "\E0Well^1, in the meantime^1,&why don't you go see&Papyrus^1, then Undyne?/")
ds_map_add(global.text_data_en, "obj_endflowey_226", "\E9It seems like you&could have been&better friends./")
ds_map_add(global.text_data_en, "obj_endflowey_227", "Who knows..^1. maybe&she's got the key&to your happiness...?/")
ds_map_add(global.text_data_en, "obj_endflowey_228", "\E4See you soon./%%")
ds_map_add(global.text_data_en, "obj_endflowey_242", "But^1, despite everything^1,&your happy ending&didn't come./")
ds_map_add(global.text_data_en, "obj_endflowey_243", "\E5Why...?/")
ds_map_add(global.text_data_en, "obj_endflowey_244", "\E4I know why./")
ds_map_add(global.text_data_en, "obj_endflowey_245", "\E4Go to Dr. Alphys./")
ds_map_add(global.text_data_en, "obj_endflowey_246", "\E5Your date with her&has really just&begun./%%")
ds_map_add(global.text_data_en, "obj_endflowey_259", "So you went the&whole way through&without killing.../")
ds_map_add(global.text_data_en, "obj_endflowey_260", "\E5And then you decided&to kill ASGORE?/")
ds_map_add(global.text_data_en, "obj_endflowey_261", "\E6What the hell is&WRONG with you?/")
ds_map_add(global.text_data_en, "obj_endflowey_262", "\E4You COMPLETELY missed&the point./")
ds_map_add(global.text_data_en, "obj_endflowey_263", "\E2Are you trolling me?/")
ds_map_add(global.text_data_en, "obj_endflowey_264", "\E0Because./")
ds_map_add(global.text_data_en, "obj_endflowey_265", "\E4No./")
ds_map_add(global.text_data_en, "obj_endflowey_266", "\E5You are only&trolling yourself./")
ds_map_add(global.text_data_en, "obj_endflowey_267", "\E6What a waste of&everybody's time./")
ds_map_add(global.text_data_en, "obj_endflowey_268", "\E7All you had to&do was make friends./")
ds_map_add(global.text_data_en, "obj_endflowey_269", "With Papyrus^1, Undyne^1,&and then Alphys./")
ds_map_add(global.text_data_en, "obj_endflowey_270", "\E2But you were too&busy messing it up!/%%")
ds_map_add(global.text_data_en, "obj_endflowey_284", "Hey./")
ds_map_add(global.text_data_en, "obj_endflowey_285", "Since you defeated me./")
ds_map_add(global.text_data_en, "obj_endflowey_286", "I've been thinking./")
ds_map_add(global.text_data_en, "obj_endflowey_287", "\E3Is killing things&really necessary?/")
ds_map_add(global.text_data_en, "obj_endflowey_288", "\E1I.../")
ds_map_add(global.text_data_en, "obj_endflowey_289", "\E3I honestly don't&know anymore./")
ds_map_add(global.text_data_en, "obj_endflowey_290", "\E0I have a request&for you./")
ds_map_add(global.text_data_en, "obj_endflowey_291", "\E4Prove to me.../")
ds_map_add(global.text_data_en, "obj_endflowey_292", "\E5Prove to me you&are strong enough&to survive./")
ds_map_add(global.text_data_en, "obj_endflowey_293", "\E6Get here from&the beginning./")
ds_map_add(global.text_data_en, "obj_endflowey_294", "\E0Without killing a&single thing.../")
ds_map_add(global.text_data_en, "obj_endflowey_296", "\E4... and I won't&kill the king./")
ds_map_add(global.text_data_en, "obj_endflowey_298", "\E4... and^1, maybe.../")
ds_map_add(global.text_data_en, "obj_endflowey_299", "\E7Then you'll have&your so-called&" + '"' + "happy ending." + '"' + "/")
ds_map_add(global.text_data_en, "obj_endflowey_300", "\E6So^1, what will&it be?/")
ds_map_add(global.text_data_en, "obj_endflowey_301", "\E5Will you prove&yourself?/")
ds_map_add(global.text_data_en, "obj_endflowey_302", "\E8Or will I get to&watch you suffer...?/")
ds_map_add(global.text_data_en, "obj_endflowey_303", "Either way^1, I'm&interested!!!/")
ds_map_add(global.text_data_en, "obj_endflowey_304", "\E4Hee hee hee.../%%")
ds_map_add(global.text_data_en, "obj_endflowey_319", "Interesting.../")
ds_map_add(global.text_data_en, "obj_endflowey_320", "\E6So^1, even with&everything you did.../")
ds_map_add(global.text_data_en, "obj_endflowey_321", "\E5The outcome's still&the same./")
ds_map_add(global.text_data_en, "obj_endflowey_322", "\E9In the end^1, your&choices were an&illusion./")
ds_map_add(global.text_data_en, "obj_endflowey_323", "\E9NOTHING you do&really matters!/")
ds_map_add(global.text_data_en, "obj_endflowey_324", "\E8Hee hee hee!/")
ds_map_add(global.text_data_en, "obj_endflowey_325", "\E8.../")
ds_map_add(global.text_data_en, "obj_endflowey_326", "\E0Well./")
ds_map_add(global.text_data_en, "obj_endflowey_327", "\E6You DID do what&I told you./")
ds_map_add(global.text_data_en, "obj_endflowey_328", "\E5I guess it's up&to me to get you a&REAL happy ending./")
ds_map_add(global.text_data_en, "obj_endflowey_329", "\E0For starters^1, you&can't do it by&yourself./")
ds_map_add(global.text_data_en, "obj_endflowey_330", "Papyrus^1, Undyne^1,&Alphys..^1. these guys./")
ds_map_add(global.text_data_en, "obj_endflowey_331", "\E4Are you friends with&all of them yet?/")
ds_map_add(global.text_data_en, "obj_endflowey_332", "\E5Maybe you should go&back and..^1. " + '"' + "hang" + '"' + "&with them./")
ds_map_add(global.text_data_en, "obj_endflowey_333", "\E4The power of&friendship.../")
ds_map_add(global.text_data_en, "obj_endflowey_334", "That always saves&the day^1, right?/%%")
ds_map_add(global.text_data_en, "obj_endflowey_349", "\E0So^1, killing people&is ACTUALLY fine...?/")
ds_map_add(global.text_data_en, "obj_endflowey_350", "\E4Sure./")
ds_map_add(global.text_data_en, "obj_endflowey_351", "I'm glad we agree on&the value of a life./")
ds_map_add(global.text_data_en, "obj_endflowey_352", "I've learned SO&MUCH from you./")
ds_map_add(global.text_data_en, "obj_endflowey_353", "\E0Though..^1. are you&REALLY gonna keep&doing things halfway?/")
ds_map_add(global.text_data_en, "obj_endflowey_354", "\E8The amount of people&you killed.../")
ds_map_add(global.text_data_en, "obj_endflowey_355", "\E9It's honestly&DISAPPOINTING./")
ds_map_add(global.text_data_en, "obj_endflowey_356", "\E8You IDIOT./")
ds_map_add(global.text_data_en, "obj_endflowey_357", "\E4You really can't do&ANYTHING right./%%")
ds_map_add(global.text_data_en, "obj_endflowey_372", "Why^1, \[C]...?/")
ds_map_add(global.text_data_en, "obj_endflowey_373", "\E3Why?/")
ds_map_add(global.text_data_en, "obj_endflowey_374", "\E1WHY?/")
ds_map_add(global.text_data_en, "obj_endflowey_375", "\E8We were on our way&to REAL victory.../")
ds_map_add(global.text_data_en, "obj_endflowey_376", "\E9On our way to making&up for LAST time!/")
ds_map_add(global.text_data_en, "obj_endflowey_377", "\E2Why'd you have to&SCREW IT UP?/")
ds_map_add(global.text_data_en, "obj_endflowey_378", "\E5Hahaha.../")
ds_map_add(global.text_data_en, "obj_endflowey_379", "\E9Is this REVENGE?/")
ds_map_add(global.text_data_en, "obj_endflowey_382", "\E1Making me watch you&act so pure and&happy^1, while I...?/")
ds_map_add(global.text_data_en, "obj_endflowey_386", "\E1Making me watch you&live out your life^1,&while I...?/")
ds_map_add(global.text_data_en, "obj_endflowey_389", "\E1.../")
ds_map_add(global.text_data_en, "obj_endflowey_390", "\E7No./")
ds_map_add(global.text_data_en, "obj_endflowey_391", "\E8NO./")
ds_map_add(global.text_data_en, "obj_endflowey_392", "I KNOW what you're&doing./")
ds_map_add(global.text_data_en, "obj_endflowey_393", "You just want to see&what it's all like./")
ds_map_add(global.text_data_en, "obj_endflowey_394", "Before we TEAR IT&AWAY from them./")
ds_map_add(global.text_data_en, "obj_endflowey_395", "Ahahaha.../")
ds_map_add(global.text_data_en, "obj_endflowey_396", "\E9Genius^1, \[C]./")
ds_map_add(global.text_data_en, "obj_endflowey_397", "\E4Well^1, I'll let you&mess around./")
ds_map_add(global.text_data_en, "obj_endflowey_398", "\E8I know you'll come&back eventually./")
ds_map_add(global.text_data_en, "obj_endflowey_399", "\E9And when that time&comes.../")
ds_map_add(global.text_data_en, "obj_endflowey_400", "\E4\[C]./")
ds_map_add(global.text_data_en, "obj_endflowey_401", "\E4I'll be waiting&for you./%%")
ds_map_add(global.text_data_en, "obj_endflowey_415", "Why do you keep&coming back here?/")
ds_map_add(global.text_data_en, "obj_endflowey_416", "\E5Oh^1, I get it^1.&You wanna be friends^1,&huh...?/")
ds_map_add(global.text_data_en, "obj_endflowey_417", "\E8You're PATHETIC./")
ds_map_add(global.text_data_en, "obj_endflowey_418", "\E8You REALLY think I&want to be friends&with YOU?/")
ds_map_add(global.text_data_en, "obj_endflowey_419", "\E5Heh.../")
ds_map_add(global.text_data_en, "obj_endflowey_420", "\E9You really DON'T&get it^1, do you?/")
ds_map_add(global.text_data_en, "obj_endflowey_421", "\E5There's only one&person I could care&about anymore./")
ds_map_add(global.text_data_en, "obj_endflowey_422", "\E6And even then^1, I&couldn't TRULY care&about them./")
ds_map_add(global.text_data_en, "obj_endflowey_423", "\E5I just like to think&there's someone out&there.../")
ds_map_add(global.text_data_en, "obj_endflowey_424", "Someone that I&won't get tired of./")
ds_map_add(global.text_data_en, "obj_endflowey_425", "\E8Someone like ME./")
ds_map_add(global.text_data_en, "obj_endflowey_426", "\E8.../")
ds_map_add(global.text_data_en, "obj_endflowey_427", "\E0Say./")
ds_map_add(global.text_data_en, "obj_endflowey_428", "\E4Quit looking at me&with that stupid&expression./")
ds_map_add(global.text_data_en, "obj_endflowey_429", "You're pissing me&off./%%")
ds_map_add(global.text_data_en, "obj_endflowey_443", "\E0So you're here&again./")
ds_map_add(global.text_data_en, "obj_endflowey_444", "\E2What's wrong with&you?/")
ds_map_add(global.text_data_en, "obj_endflowey_445", "\E4Are you trying to&start the Flowey&Fan Club?/")
ds_map_add(global.text_data_en, "obj_endflowey_446", "\E5Because if you&want to join THAT.../")
ds_map_add(global.text_data_en, "obj_endflowey_447", "\E4You'll have to&talk to Papyrus./")
ds_map_add(global.text_data_en, "obj_endflowey_448", "\E6Yeah^1, he started&one./")
ds_map_add(global.text_data_en, "obj_endflowey_449", "\E5A few different&times^1, anyway./")
ds_map_add(global.text_data_en, "obj_endflowey_450", "\E0I won't lie./")
ds_map_add(global.text_data_en, "obj_endflowey_451", "\E4He's one of the&better characters&to mess around with./")
ds_map_add(global.text_data_en, "obj_endflowey_452", "\E5Took me a long&time to get bored&of that one./")
ds_map_add(global.text_data_en, "obj_endflowey_453", "\E7... Yeah./")
ds_map_add(global.text_data_en, "obj_endflowey_454", "\E4Talk to him&about it./%%")
ds_map_add(global.text_data_en, "obj_endflowey_468", "\E0So./")
ds_map_add(global.text_data_en, "obj_endflowey_469", "\E4Did you start the&Flowey Fan Club?/")
ds_map_add(global.text_data_en, "obj_endflowey_470", "\E5Ha^1.&I'm just kidding./")
ds_map_add(global.text_data_en, "obj_endflowey_471", "\E9I was watching^1.&I know you didn't./")
ds_map_add(global.text_data_en, "obj_endflowey_472", "\E5But I don't care^1.&Really./")
ds_map_add(global.text_data_en, "obj_endflowey_473", "\E6He probably would&have invited his&garbage brother./")
ds_map_add(global.text_data_en, "obj_endflowey_474", "\E4You know^1.&Smiley Trashbag./")
ds_map_add(global.text_data_en, "obj_endflowey_475", "\E0.../")
ds_map_add(global.text_data_en, "obj_endflowey_476", "\E4Say./")
ds_map_add(global.text_data_en, "obj_endflowey_477", "If I have ONE piece&of advice for you.../")
ds_map_add(global.text_data_en, "obj_endflowey_478", "\E9DON'T./")
ds_map_add(global.text_data_en, "obj_endflowey_479", "Let his brother./")
ds_map_add(global.text_data_en, "obj_endflowey_480", "Find out ANYTHING&about you./")
ds_map_add(global.text_data_en, "obj_endflowey_481", "\E6He'll..^1. well.../")
ds_map_add(global.text_data_en, "obj_endflowey_482", "\E5Let's just say./")
ds_map_add(global.text_data_en, "obj_endflowey_483", "\E9He's caused me more&than my fair share&of resets./")
ds_map_add(global.text_data_en, "obj_endflowey_484", "\E4Stay away from&that guy./%%")
ds_map_add(global.text_data_en, "obj_endflowey_498", "\E0Why do you keep&coming back here?/")
ds_map_add(global.text_data_en, "obj_endflowey_499", "You don't REALLY&want to be friends^1,&do you...?/")
ds_map_add(global.text_data_en, "obj_endflowey_500", ".../")
ds_map_add(global.text_data_en, "obj_endflowey_501", "\E4No^1. I get it./")
ds_map_add(global.text_data_en, "obj_endflowey_502", "You're just like me^1,&aren't you?/")
ds_map_add(global.text_data_en, "obj_endflowey_503", "You don't care about&anyone./")
ds_map_add(global.text_data_en, "obj_endflowey_504", "\E4You're just bored./")
ds_map_add(global.text_data_en, "obj_endflowey_505", "You just want to&see what I'll say./")
ds_map_add(global.text_data_en, "obj_endflowey_506", "\E5So you can laugh&and throw me away&like a broken toy./")
ds_map_add(global.text_data_en, "obj_endflowey_507", "\E8Well^1, TOO BAD!/")
ds_map_add(global.text_data_en, "obj_endflowey_508", "\E9I'm not LIKE everybody&else./")
ds_map_add(global.text_data_en, "obj_endflowey_509", "\E9So, from now on.../")
ds_map_add(global.text_data_en, "obj_endflowey_510", "\E4You're not getting&ANYTHING./%%")
ds_map_add(global.text_data_en, "obj_endflowey_524", ".../")
ds_map_add(global.text_data_en, "obj_endflowey_525", "\E4Don't you have&anything BETTER to do?/%%")
ds_map_add(global.text_data_en, "obj_endflowey_regret_111", "Hi./%%")
ds_map_add(global.text_data_en, "obj_endflowey_regret_128", "Seems as if everyone&is perfectly happy./")
ds_map_add(global.text_data_en, "obj_endflowey_regret_129", "Monsters have returned&to the surface./")
ds_map_add(global.text_data_en, "obj_endflowey_regret_130", "Peace and prosperity&will rule across the land./")
ds_map_add(global.text_data_en, "obj_endflowey_regret_131", "\E6Take a deep breath./")
ds_map_add(global.text_data_en, "obj_endflowey_regret_132", "\E5There's nothing left&to worry about./%%")
ds_map_add(global.text_data_en, "obj_endflowey_regret_148", "\E7.../")
ds_map_add(global.text_data_en, "obj_endflowey_regret_149", "\E6Well./")
ds_map_add(global.text_data_en, "obj_endflowey_regret_150", "\E1There is one thing./")
ds_map_add(global.text_data_en, "obj_endflowey_regret_151", "\E3One last threat./")
ds_map_add(global.text_data_en, "obj_endflowey_regret_152", "One being with the&power to erase&EVERYTHING.../")
ds_map_add(global.text_data_en, "obj_endflowey_regret_153", "\E1Everything everyone's&worked so hard for./")
ds_map_add(global.text_data_en, "obj_endflowey_regret_154", "\E7.../")
ds_map_add(global.text_data_en, "obj_endflowey_regret_155", "\E6You know who I'm&talking about^1, don't&you?/")
ds_map_add(global.text_data_en, "obj_endflowey_regret_156", "\E1That's right./")
ds_map_add(global.text_data_en, "obj_endflowey_regret_157", "\E4I'm talking about YOU./")
ds_map_add(global.text_data_en, "obj_endflowey_regret_158", "\E7YOU still have the&power to reset&everything./")
ds_map_add(global.text_data_en, "obj_endflowey_regret_159", "\E0Toriel^1, Sans^1, Asgore^1,&Alphys, Papyrus, Undyne.../")
ds_map_add(global.text_data_en, "obj_endflowey_regret_160", "If you so choose.../")
ds_map_add(global.text_data_en, "obj_endflowey_regret_161", "Everyone will be&ripped from this&timeline.../")
ds_map_add(global.text_data_en, "obj_endflowey_regret_162", "... and sent back before&all of this&ever happened./")
ds_map_add(global.text_data_en, "obj_endflowey_regret_163", "\E6Nobody will&remember anything./")
ds_map_add(global.text_data_en, "obj_endflowey_regret_164", "\E5You'll be able to&do whatever you&want./")
ds_map_add(global.text_data_en, "obj_endflowey_regret_165", "\E0.../")
ds_map_add(global.text_data_en, "obj_endflowey_regret_166", "\E7That power./")
ds_map_add(global.text_data_en, "obj_endflowey_regret_167", "\E3I know that power./")
ds_map_add(global.text_data_en, "obj_endflowey_regret_168", "\E6That's the power&you were fighting to&stop^1, wasn't it?/")
ds_map_add(global.text_data_en, "obj_endflowey_regret_169", "\E7The power that I&wanted to use./")
ds_map_add(global.text_data_en, "obj_endflowey_regret_170", "\E6But now^1, the idea&of resetting&everything.../")
ds_map_add(global.text_data_en, "obj_endflowey_regret_171", "\E7I.../")
ds_map_add(global.text_data_en, "obj_endflowey_regret_172", "\E1I don't think I&could do it all&again./")
ds_map_add(global.text_data_en, "obj_endflowey_regret_173", "Not after that./")
ds_map_add(global.text_data_en, "obj_endflowey_regret_174", "\E7.../")
ds_map_add(global.text_data_en, "obj_endflowey_regret_175", "\E1So, please./")
ds_map_add(global.text_data_en, "obj_endflowey_regret_176", "\E3Just let them go./")
ds_map_add(global.text_data_en, "obj_endflowey_regret_177", "Let Frisk be happy./")
ds_map_add(global.text_data_en, "obj_endflowey_regret_178", "Let Frisk live&their life./%%")
ds_map_add(global.text_data_en, "obj_endflowey_regret_195", "\E1.../")
ds_map_add(global.text_data_en, "obj_endflowey_regret_197", "\E3But./")
ds_map_add(global.text_data_en, "obj_endflowey_regret_199", "If I can't change&your mind./")
ds_map_add(global.text_data_en, "obj_endflowey_regret_201", "If you DO end up&erasing everything.../")
ds_map_add(global.text_data_en, "obj_endflowey_regret_203", "\E7.../")
ds_map_add(global.text_data_en, "obj_endflowey_regret_205", "\E6You have to erase&my memories^1, too./")
ds_map_add(global.text_data_en, "obj_endflowey_regret_207", "\E7.../")
ds_map_add(global.text_data_en, "obj_endflowey_regret_209", "\E6I'm sorry./")
ds_map_add(global.text_data_en, "obj_endflowey_regret_211", "\E5You've probably heard&this a hundred times&already^1, haven't you...?/")
ds_map_add(global.text_data_en, "obj_endflowey_regret_213", ".../")
ds_map_add(global.text_data_en, "obj_endflowey_regret_215", "\E0Well^1, that's all./")
ds_map_add(global.text_data_en, "obj_endflowey_regret_217", "\E6See you later.../")
ds_map_add(global.text_data_en, "obj_endflowey_regret_219", "\E4\[1]./%%")
ds_map_add(global.text_data_en, "obj_endogeny_360", "* Amalgamate is watching you&  intently.")
ds_map_add(global.text_data_en, "obj_endogeny_361", "* Amalgamate is waiting for&  your command.")
ds_map_add(global.text_data_en, "obj_endogeny_362", "* It smells like a bunch of dogs.")
ds_map_add(global.text_data_en, "obj_endogeny_363", "* Amalgamate is hovering close^1,&  looking for affection.")
ds_map_add(global.text_data_en, "obj_endogeny_366", "* Amalgamate is striking the&  wall with its claws.")
ds_map_add(global.text_data_en, "obj_endogeny_367", "* Amalgamate is twitching&  affectionately.")
ds_map_add(global.text_data_en, "obj_endogeny_368", "* Amalgamate's convulsions&  intensify.")
ds_map_add(global.text_data_en, "obj_endogeny_369", "* Endogeny is contented.")
ds_map_add(global.text_data_en, "obj_endogeny_370", "* Monster has low HP.")
ds_map_add(global.text_data_en, "obj_endogeny_371", "* Endogeny is contented.")
ds_map_add(global.text_data_en, "obj_endogeny_403", "* AMALGAMATE - It's unclear how&  many dogs this counts as./^")
ds_map_add(global.text_data_en, "obj_endogeny_404", "* ENDOGENY - It's unclear how&  many dogs this counts as./^")
ds_map_add(global.text_data_en, "obj_endogeny_416", "* The Amalgamate's feelers&  rotate quickly^1.&* Nothing else happens./^")
ds_map_add(global.text_data_en, "obj_endogeny_420", "* You call the Amalgamate./")
ds_map_add(global.text_data_en, "obj_endogeny_421", "* It bounds towards you^1,&  flecking a strange liquid&  from an orifice./^")
ds_map_add(global.text_data_en, "obj_endogeny_435", "* You try looking away^1, but&  it seems to appear everywhere&  you look./^")
ds_map_add(global.text_data_en, "obj_endogeny_446", "* You pet the Amalgamate./^")
ds_map_add(global.text_data_en, "obj_endogeny_449", "* You'd give it a tummy rub^1,&  but it's not clear where its&  tummy begins or ends./^")
ds_map_add(global.text_data_en, "obj_endogeny_455", "* You pet decisively^1.&* The Amalgamate seems to be&  satisfied by all this./^")
ds_map_add(global.text_data_en, "obj_endogeny_466", "* You pet the Amalgamate^1.&* It starts to generate a&  Stage I Happiness Froth./^")
ds_map_add(global.text_data_en, "obj_endogeny_475", "* You try to pet the&  Amalgamate but your hand&  phases through it./")
ds_map_add(global.text_data_en, "obj_endogeny_476", "* It must not want to be pet&  for now./^")
ds_map_add(global.text_data_en, "obj_endogeny_480", "* You pet the Amalgamate^1.&* It convulses rapidly..^1.&* Then calms down./")
ds_map_add(global.text_data_en, "obj_endogeny_481", "* It rests quietly on your&  lap for a moment.../")
ds_map_add(global.text_data_en, "obj_endogeny_482", "* Zzzzz.../")
ds_map_add(global.text_data_en, "obj_endogeny_483", "* Suddenly^1, it shoots away and&  crawls wildly on the walls!/^")
ds_map_add(global.text_data_en, "obj_endogeny_491", "* Amalgamate is too far&  away to pet^1.&* You just pet the air./^")
ds_map_add(global.text_data_en, "obj_endogeny_500", "* You play with the Amalgamate./^")
ds_map_add(global.text_data_en, "obj_endogeny_503", "* Amalgamate seems too tired&  to play./^")
ds_map_add(global.text_data_en, "obj_endogeny_507", "* You throw your weapon into&  the corner of the room./")
ds_map_add(global.text_data_en, "obj_endogeny_508", "* The Amalgamate brings it back&  to you..^1.&* Proudly?/")
ds_map_add(global.text_data_en, "obj_endogeny_509", "* You repeat this process a&  few times./")
ds_map_add(global.text_data_en, "obj_endogeny_510", "* Now Amalgamate is very tired..^1.&* It leans its dripping^1,&  amorphous body on you.../^")
ds_map_add(global.text_data_en, "obj_endogeny_518", "* Amalgamate is not excited&  enough to play with...?/^")
ds_map_add(global.text_data_en, "obj_essaystuff_159", "Speechless...?&Who can blame you?/%%")
ds_map_add(global.text_data_en, "obj_essaystuff_160", "Well... that's concise./%%")
ds_map_add(global.text_data_en, "obj_essaystuff_161", "Beautiful. Sometimes&the fewest words&speak the loudest./%%")
ds_map_add(global.text_data_en, "obj_essaystuff_162", "Nice. You get a&gold star./%%")
ds_map_add(global.text_data_en, "obj_essaystuff_163", "Oh my... what a&great answer./%%")
ds_map_add(global.text_data_en, "obj_essaystuff_164", "Oooooh, you said so&much about me.../")
ds_map_add(global.text_data_en, "obj_essaystuff_165", "I love how&passionate you are./")
ds_map_add(global.text_data_en, "obj_essaystuff_166", "... even though I&don't understand&what you said.../%%")
ds_map_add(global.text_data_en, "obj_essaystuff_168", "Beautiful.&Why don't you&write a book?/%%")
ds_map_add(global.text_data_en, "obj_essaystuff_219", "Nice detail...&You're right, I do&look quite nice./%%")
ds_map_add(global.text_data_en, "obj_essaystuff_220", "Wonderful! Amazing! A+...&I AM completely stunning./%%")
ds_map_add(global.text_data_en, "obj_essaystuff_221", "Oh, I'm blushing...&You're completely right,&I am beautiful in&every way./%%")
ds_map_add(global.text_data_en, "obj_essaystuff_222", "Oh my... I'm speechless...&You've completely&captured how&beautiful I am./%%")
ds_map_add(global.text_data_en, "obj_essaystuff_224", "That's right.&Legs was the&correct answer!/%%")
ds_map_add(global.text_data_en, "obj_essaystuff_225", "How creative. Arms...&most people just&think about my legs./%%")
ds_map_add(global.text_data_en, "obj_essaystuff_226", "My hair... yes,&I use metal hair&gel./%%")
ds_map_add(global.text_data_en, "obj_essaystuff_233", "Yes^1, my personality&is quite charming^1,&isn't it?/%%")
ds_map_add(global.text_data_en, "obj_essaystuff_234", "They say I have&the voice of a&Siren..^1./")
ds_map_add(global.text_data_en, "obj_essaystuff_235", "... awooga!/%%")
ds_map_add(global.text_data_en, "obj_essaystuff_236", "Dancing...^1?&Thank you^1, I'm&self-taught./%%")
ds_map_add(global.text_data_en, "obj_essaystuff_255", "Huh? This essay is&supposed to be about&me, not about you.../%%")
ds_map_add(global.text_data_en, "obj_essaystuff_264", "What a touching&confession! I'll add&it to the pile./%%")
ds_map_add(global.text_data_en, "obj_essaystuff_271", "Toby? What the hell&is that?&Sounds... sexy./%%")
ds_map_add(global.text_data_en, "obj_essaystuff_289", "Oh my! This is a family&friendly TV show./")
ds_map_add(global.text_data_en, "obj_essaystuff_290", "Now stand still while&I murder you./%%")
ds_map_add(global.text_data_en, "obj_essaystuff_510", "* Mettaton is saving your&  essay for future use.")
ds_map_add(global.text_data_en, "obj_essaystuff_ja_1", "")
ds_map_add(global.text_data_en, "obj_essaystuff_ja_2", "")
ds_map_add(global.text_data_en, "obj_essaystuff_ja_3", "")
ds_map_add(global.text_data_en, "obj_essaystuff_ja_4", "")
ds_map_add(global.text_data_en, "obj_f_frasier_32", " %")
ds_map_add(global.text_data_en, "obj_f_frasier_33", " %")
ds_map_add(global.text_data_en, "obj_f_frasier_34", " %")
ds_map_add(global.text_data_en, "obj_f_frasier_35", " %")
ds_map_add(global.text_data_en, "obj_f_frasier_36", "%%%")
ds_map_add(global.text_data_en, "obj_f_frasier_40", "* Hee hee hee^1.&* Did you really think&  you could run away?/%%")
ds_map_add(global.text_data_en, "obj_f_frasier_43", "* Hee hee hee./")
ds_map_add(global.text_data_en, "obj_f_frasier_44", "* Did you really think&  I was gonna be&  satisfied.../")
ds_map_add(global.text_data_en, "obj_f_frasier_45", "* ... killing you only&  ONE time?/%%")
ds_map_add(global.text_data_en, "obj_f_frasier_49", "* Pathetic..^1.&* Now you're REALLY&  gonna die!/%%")
ds_map_add(global.text_data_en, "obj_f_frasier_53", "* Hee hee hee./")
ds_map_add(global.text_data_en, "obj_f_frasier_54", "* Do you even realize&  what will happen if&  you defeat me...?/%%")
ds_map_add(global.text_data_en, "obj_f_frasier_58", "* Don't you get it?/")
ds_map_add(global.text_data_en, "obj_f_frasier_59", "* There's no such thing&  as happy endings./")
ds_map_add(global.text_data_en, "obj_f_frasier_60", "* This is all that's&  left...!/%%")
ds_map_add(global.text_data_en, "obj_f_frasier_64", "* Are you REALLY that&  desperate...^1?&* Hee hee hee.../%%")
ds_map_add(global.text_data_en, "obj_f_frasier_68", "* Are you letting me&  kill you..^1.&* ... on PURPOSE^2?&* SICKO^1. Ha ha ha./%%")
ds_map_add(global.text_data_en, "obj_f_frasier_72", "* Honestly^1, fighting&  you IS pretty fun.../")
ds_map_add(global.text_data_en, "obj_f_frasier_73", "* ... So even if you&  ARE a sicko^1, I'll&  take it!/%%")
ds_map_add(global.text_data_en, "obj_f_frasier_77", "* Maybe you're wondering&  if I ever get tired&  of winning.../")
ds_map_add(global.text_data_en, "obj_f_frasier_78", "* Wanna see my answer?/%%")
ds_map_add(global.text_data_en, "obj_f_frasier_82", "* Don't you have anything&  better to do?/%%")
ds_map_add(global.text_data_en, "obj_fakefroggit_479", "* Froggit nie wydaje się&  wiedzieć po co tu jest.")
ds_map_add(global.text_data_en, "obj_fakefroggit_480", "* Froggit skacze na przód.")
ds_map_add(global.text_data_en, "obj_fakefroggit_481", "* Pole bitwy jest&  wypełnione zapachem&  nasion gorczycy.")
ds_map_add(global.text_data_en, "obj_fakefroggit_482", "* Jesteś zaskoczony&  surową siłą Froggita^4.&  * Taki żarcik.")
ds_map_add(global.text_data_en, "obj_fakefroggit_483", "* Froggit wydaje się&  odechciewać walki&  z tobą.")
ds_map_add(global.text_data_en, "obj_fakefroggit_484", "* Froggit próbuje uciec.")
ds_map_add(global.text_data_en, "obj_fakefroggit_500", "* FROGGIT - ATK 4 DEF 5&* Życie jest ciężkie&  dla tego potwora./^")
ds_map_add(global.text_data_en, "obj_fakefroggit_508", "* Froggit nie zrozumiał&  to co powiedziałeś^1, ale&  i tak było mu miło./^")
ds_map_add(global.text_data_en, "obj_fakefroggit_518", "* Froggit nie zrozumiał&  to co powiedziałeś^1, ale&  i tak się przestraszył./^")
ds_map_add(global.text_data_en, "obj_ficus_72", "* (To roślina w doniczce.)/%%")
ds_map_add(global.text_data_en, "obj_ficus_75", "* (Roślina w doniczce ocenia&  cię po twoich grzechach.)/%%")
ds_map_add(global.text_data_en, "obj_ficus_81", "* (It's a platoon of ficuses.)/%%")
ds_map_add(global.text_data_en, "obj_finalelevatorpanel_134", "* Proszę wybrać piętro./%%")
ds_map_add(global.text_data_en, "obj_finalfroggit_209", "Robbit,&robbit.")
ds_map_add(global.text_data_en, "obj_finalfroggit_210", "Creak,&creak.")
ds_map_add(global.text_data_en, "obj_finalfroggit_211", "Skip,&jump.")
ds_map_add(global.text_data_en, "obj_finalfroggit_212", "Woof.")
ds_map_add(global.text_data_en, "obj_finalfroggit_222", "Shudder,&shudder.")
ds_map_add(global.text_data_en, "obj_finalfroggit_227", "Nod,&nod.")
ds_map_add(global.text_data_en, "obj_finalfroggit_231", "(Thought&-ful&croak)")
ds_map_add(global.text_data_en, "obj_finalfroggit_235", "(Impress&-ed&ribbit)")
ds_map_add(global.text_data_en, "obj_finalfroggit_240", "%%%")
ds_map_add(global.text_data_en, "obj_finalfroggit_440", "* Final Froggit knows exactly&  why it's here.")
ds_map_add(global.text_data_en, "obj_finalfroggit_441", "* Final Froggit jumps ominously&  up and down.")
ds_map_add(global.text_data_en, "obj_finalfroggit_442", "* The battlefield is filled&  with the smell of mustard&  seed.")
ds_map_add(global.text_data_en, "obj_finalfroggit_443", "* You are intimidated by&  Final Froggit's strength^4.&* Truly.")
ds_map_add(global.text_data_en, "obj_finalfroggit_444", "* Finalny Froggit wydaje&  się odechciewać walki&  z tobą.")
ds_map_add(global.text_data_en, "obj_finalfroggit_445", "* Final Froggit stands its&  ground.")
ds_map_add(global.text_data_en, "obj_finalfroggit_480", "* FINAL FROGGIT - ATK 30 DEF 24&* Its future looks brighter and&  brighter./^")
ds_map_add(global.text_data_en, "obj_finalfroggit_489", "* You compliment Final Froggit^1.&* It understood you perfectly^1.&* Its ATTACK dropped./^")
ds_map_add(global.text_data_en, "obj_finalfroggit_501", "* You threaten Final Froggit^1.&* It understood you perfectly^1.&* Its DEFENSE dropped./^")
ds_map_add(global.text_data_en, "obj_finalfroggit_514", "* You did something mysterious./")
ds_map_add(global.text_data_en, "obj_finalfroggit_515", "* Final Froggit recognizes it&  has more to learn from&  this world./^")
ds_map_add(global.text_data_en, "obj_finalfroggit_520", "* You did something mysterious^1.&* But nothing happened./^")
ds_map_add(global.text_data_en, "obj_finalknight_275", "Good&knight.")
ds_map_add(global.text_data_en, "obj_finalknight_279", "Fare&well.")
ds_map_add(global.text_data_en, "obj_finalknight_283", "Adieu.")
ds_map_add(global.text_data_en, "obj_finalknight_287", "Close&your&eyes...")
ds_map_add(global.text_data_en, "obj_finalknight_291", "Goodbye.")
ds_map_add(global.text_data_en, "obj_finalknight_295", "Zzzz...")
ds_map_add(global.text_data_en, "obj_finalknight_298", "%%%")
ds_map_add(global.text_data_en, "obj_finalknight_308", " ......& ......& ......& ......& ......& ......& ......& ......& It's OK.")
ds_map_add(global.text_data_en, "obj_finalknight_309", "%%%")
ds_map_add(global.text_data_en, "obj_finalknight_515", "* Knight Knight smashes her&  morningstar.")
ds_map_add(global.text_data_en, "obj_finalknight_516", "* Knight Knight breathes deeply.")
ds_map_add(global.text_data_en, "obj_finalknight_517", "* Knight Knight watches quietly.")
ds_map_add(global.text_data_en, "obj_finalknight_518", "* Knight Knight's armor emits&  a dark sheen.")
ds_map_add(global.text_data_en, "obj_finalknight_519", "* Smells like stardust.")
ds_map_add(global.text_data_en, "obj_finalknight_520", "* Knight Knight is snoring.")
ds_map_add(global.text_data_en, "obj_finalknight_553", "* KNIGHT KNIGHT - ATK 36 DEF 36&* This megaton mercenary wields&  the Good Morningstar./^")
ds_map_add(global.text_data_en, "obj_finalknight_562", "* You ask Knight Knight about&  her day^1.&* There's no response./^")
ds_map_add(global.text_data_en, "obj_finalknight_566", "* You ask Knight Knight about&  her day./^")
ds_map_add(global.text_data_en, "obj_finalknight_570", "* You talk to Knight Knight^1.&* She hums something in&  her sleep.../^")
ds_map_add(global.text_data_en, "obj_finalknight_586", "* You sing an old lullaby^1.&* Knight Knight starts to look&  sleepy.../^")
ds_map_add(global.text_data_en, "obj_finalknight_588", "* You sing Shyren's song^1.&* Knight Knight starts to look&  sleepy.../^")
ds_map_add(global.text_data_en, "obj_finalknight_592", "* You keep singing^1.&* Knight Knight closes its&  eyes a bit.../^")
ds_map_add(global.text_data_en, "obj_finalknight_596", "* You keep singing^1.&* Nothing happened./^")
ds_map_add(global.text_data_en, "obj_finalknight_601", "* You keep singing^1.&* Knight Knight falls asleep./^")
ds_map_add(global.text_data_en, "obj_flowey_bulletmaster_562", "* Flowey's DEFENSE&  dropped to 0^4! %%")
ds_map_add(global.text_data_en, "obj_flowey_bulletmaster_564", "%%%")
ds_map_add(global.text_data_en, "obj_flowey_master_1067", "* No... NO!!!/")
ds_map_add(global.text_data_en, "obj_flowey_master_1068", "* This CAN'T be&  happening!!!/")
ds_map_add(global.text_data_en, "obj_flowey_master_1069", "* You... YOU.../%%")
ds_map_add(global.text_data_en, "obj_flowey_master_1070", "%%%")
ds_map_add(global.text_data_en, "obj_flowey_master_1124", "* You^2 IDIOT^5. %%")
ds_map_add(global.text_data_en, "obj_flowey_master_1181", "* Hee hee hee./")
ds_map_add(global.text_data_en, "obj_flowey_master_1182", "* Did you REALLY&  think.../")
ds_map_add(global.text_data_en, "obj_flowey_master_1183", "* You could&  defeat ME!?/")
ds_map_add(global.text_data_en, "obj_flowey_master_1184", "\E5* I am the GOD of&  this world./")
ds_map_add(global.text_data_en, "obj_flowey_master_1185", "\E6* And YOU?/")
ds_map_add(global.text_data_en, "obj_flowey_master_1186", "* You're HOPELESS./")
ds_map_add(global.text_data_en, "obj_flowey_master_1187", "* Hopeless and&  alone.../")
ds_map_add(global.text_data_en, "obj_flowey_master_1188", "\E0* Golly^1, that's&  right!/")
ds_map_add(global.text_data_en, "obj_flowey_master_1189", "\E7* Your WORTHLESS&  friends.../")
ds_map_add(global.text_data_en, "obj_flowey_master_1190", "\E8* ... can't save&  you now./")
ds_map_add(global.text_data_en, "obj_flowey_master_1191", "\E1* Call for help^1.&* I dare you./")
ds_map_add(global.text_data_en, "obj_flowey_master_1192", "\E5* Cry into the&  darkness!/")
ds_map_add(global.text_data_en, "obj_flowey_master_1193", "\E8" + '"' + "Mommy^1! Daddy^1!" + '"' + "&" + '"' + "Somebody help!" + '"' + "/")
ds_map_add(global.text_data_en, "obj_flowey_master_1194", "\E5* See what good&  it does you!/%%")
ds_map_add(global.text_data_en, "obj_flowey_master_1195", "%%%")
ds_map_add(global.text_data_en, "obj_flowey_master_1196", "%%%")
ds_map_add(global.text_data_en, "obj_flowey_master_1197", "%%%")
ds_map_add(global.text_data_en, "obj_flowey_master_1198", "%%%")
ds_map_add(global.text_data_en, "obj_flowey_master_1216", "* You..^1. uh.../")
ds_map_add(global.text_data_en, "obj_flowey_master_1217", "\E4* Would you STOP that?/")
ds_map_add(global.text_data_en, "obj_flowey_master_1218", "\E6* Anyway^1, YOU!/")
ds_map_add(global.text_data_en, "obj_flowey_master_1260", "(You called for help.^4) %%")
ds_map_add(global.text_data_en, "obj_flowey_master_1261", "%%%")
ds_map_add(global.text_data_en, "obj_flowey_master_1276", "* .../")
ds_map_add(global.text_data_en, "obj_flowey_master_1277", "\E0* But nobody came./")
ds_map_add(global.text_data_en, "obj_flowey_master_1278", "\E2* Boy^1!&* What a shame!/")
ds_map_add(global.text_data_en, "obj_flowey_master_1279", "\E7* Nobody else.../")
ds_map_add(global.text_data_en, "obj_flowey_master_1280", "* Is gonna get to&  see you DIE!!!/%%")
ds_map_add(global.text_data_en, "obj_flowey_master_1281", "%%%")
ds_map_add(global.text_data_en, "obj_flowey_master_1320", "* What^4? %")
ds_map_add(global.text_data_en, "obj_flowey_master_1321", "\E1* How'd you...^4? %")
ds_map_add(global.text_data_en, "obj_flowey_master_1322", "\E2* Well^1, I'll jus^4t%%")
ds_map_add(global.text_data_en, "obj_flowey_master_1323", "%%%")
ds_map_add(global.text_data_en, "obj_flowey_master_1347", "\E4* Wh..^4. %")
ds_map_add(global.text_data_en, "obj_flowey_master_1348", "* Where are my&  powers!^5? %%")
ds_map_add(global.text_data_en, "obj_flowey_master_1349", "%%%")
ds_map_add(global.text_data_en, "obj_flowey_master_1374", "\E5* The souls...^5? %")
ds_map_add(global.text_data_en, "obj_flowey_master_1375", "* What are they&  doing^5? %%")
ds_map_add(global.text_data_en, "obj_flowey_master_1376", "%%%")
ds_map_add(global.text_data_en, "obj_flowey_master_1401", "* NO!^1! NO!!!!^4! %")
ds_map_add(global.text_data_en, "obj_flowey_master_1402", "* YOU CAN'T DO&  THAT!!^4! %")
ds_map_add(global.text_data_en, "obj_flowey_master_1403", "* YOU'RE SUPPOSED&  TO OBEY ME!^4! %")
ds_map_add(global.text_data_en, "obj_flowey_master_1404", "* STOP!!^1!&  STOP IT!!!!^4! %%")
ds_map_add(global.text_data_en, "obj_flowey_master_1405", "%%%")
ds_map_add(global.text_data_en, "obj_flowey_master_1422", "* STOOOOPPPP!!!!!")
ds_map_add(global.text_data_en, "obj_flowey_master_1423", "%%%")
ds_map_add(global.text_data_en, "obj_flowey_wilt_309", "* Flowey ran away.")
ds_map_add(global.text_data_en, "obj_flowey_wilt_348", "I knew you had it in you^3!%%")
ds_map_add(global.text_data_en, "obj_flowey_wilt_470", "\M1I just can't understand.../%%")
ds_map_add(global.text_data_en, "obj_flowey_wilt_481", "\M1I can't understand!/%%")
ds_map_add(global.text_data_en, "obj_flowey_wilt_492", "\M1I can't understand./%%")
ds_map_add(global.text_data_en, "obj_flowey_wilt_503", "\M1... why are you being.../")
ds_map_add(global.text_data_en, "obj_flowey_wilt_504", "\M1... so nice to me?/%%")
ds_map_add(global.text_data_en, "obj_flowey_wilt_514", "\M1... why?/%%")
ds_map_add(global.text_data_en, "obj_flowey_wilt_524", "\M1...?/%%")
ds_map_add(global.text_data_en, "obj_flowey_wilt_534", "\M1.../%%")
ds_map_add(global.text_data_en, "obj_flowey_wilt_545", "\M1I'll kill everyone you love./%%")
ds_map_add(global.text_data_en, "obj_flowey_wilt_556", "\M1I'll kill everyone./%%")
ds_map_add(global.text_data_en, "obj_flowey_wilt_568", "I'll kill you./%%")
ds_map_add(global.text_data_en, "obj_flowey_wilt_579", "\M1If you let me live.../")
ds_map_add(global.text_data_en, "obj_flowey_wilt_580", "\M1I'll come back./%%")
ds_map_add(global.text_data_en, "obj_flowey_wilt_591", "\M1Sparing me won't change&anything./")
ds_map_add(global.text_data_en, "obj_flowey_wilt_592", "\M1Killing me is the only&way to end this./%%")
ds_map_add(global.text_data_en, "obj_flowey_wilt_601", ".../")
ds_map_add(global.text_data_en, "obj_flowey_wilt_602", "\E1What are you doing?/")
ds_map_add(global.text_data_en, "obj_flowey_wilt_603", "\E2Do you really think I've&learned anything from this?/")
ds_map_add(global.text_data_en, "obj_flowey_wilt_604", "\E3No./%%")
ds_map_add(global.text_data_en, "obj_floweybattle1_268", "Czy to jest&jakiś żart^2?^2?&WEJDŹ^2. W^2. TE^2.&białe pigułki!!/")
ds_map_add(global.text_data_en, "obj_floweybattle1_269", "/")
ds_map_add(global.text_data_en, "obj_floweybattle1_270", "/")
ds_map_add(global.text_data_en, "obj_floweybattle1_271", "/")
ds_map_add(global.text_data_en, "obj_floweybattle1_272", "/")
ds_map_add(global.text_data_en, "obj_floweybattle1_273", "/")
ds_map_add(global.text_data_en, "obj_floweybattle1_274", "/")
ds_map_add(global.text_data_en, "obj_floweybattle1_275", "/")
ds_map_add(global.text_data_en, "obj_floweybattle1_276", "/")
ds_map_add(global.text_data_en, "obj_floweybattle1_277", "/")
ds_map_add(global.text_data_en, "obj_floweybattle1_278", "stop it")
ds_map_add(global.text_data_en, "obj_floweytrigger_122", "\E1* Hello..^1.&* Are you all right?/")
ds_map_add(global.text_data_en, "obj_floweytrigger_123", "* You must be so lost&  and confused.../")
ds_map_add(global.text_data_en, "obj_floweytrigger_124", "\E2* Ah, do not be&  afraid^1, my child./")
ds_map_add(global.text_data_en, "obj_floweytrigger_125", "\W* I am \BTORIEL\W,&  caretaker of the&  \RRUINS\W./")
ds_map_add(global.text_data_en, "obj_floweytrigger_126", "* I pass through here&  every day to see if&  anyone has fallen down./")
ds_map_add(global.text_data_en, "obj_floweytrigger_127", "* You are the first&  human to come here&  in a long time./")
ds_map_add(global.text_data_en, "obj_floweytrigger_128", "* I will do my best&  to protect you during&  your time here./")
ds_map_add(global.text_data_en, "obj_floweytrigger_129", "* Come^1!&* I shall guide you&  through the catacombs./%%")
ds_map_add(global.text_data_en, "obj_floweytrigger_316", "\W* Heja^2!&* Jestem\Y FLOWEY\W.^2 &* \YFLOWEY\W \YKWIATEK\W!/")
ds_map_add(global.text_data_en, "obj_floweytrigger_317", "* Hee hee hee.../")
ds_map_add(global.text_data_en, "obj_floweytrigger_318", "* Czemu zmusiłeś mnie&  do przedstawienia się?/")
ds_map_add(global.text_data_en, "obj_floweytrigger_319", "* To niemiłe^1, by&  udawać^1, że nie wiesz&  kim jestem./")
ds_map_add(global.text_data_en, "obj_floweytrigger_320", "* Ktoś cię musi nauczyć&  jak wyglądają sprawy&  u nas./")
ds_map_add(global.text_data_en, "obj_floweytrigger_321", "* Najwyraźniej mały ja&  musi to zrobić./")
ds_map_add(global.text_data_en, "obj_floweytrigger_322", "* Gotowy^2?&* No to lecimy!/%%")
ds_map_add(global.text_data_en, "obj_floweytrigger_327", "* Don't you have anything&  better to do?/%%")
ds_map_add(global.text_data_en, "obj_floweytrigger_338", "* Error/%%")
ds_map_add(global.text_data_en, "obj_floweytrigger_342", "* Naprawdę^1, \[C]?/")
ds_map_add(global.text_data_en, "obj_floweytrigger_343", "\E5* Cóż^1, rób co&  chcesz./")
ds_map_add(global.text_data_en, "obj_floweytrigger_344", "\E4* Będę na ciebie&  czekał!/%%")
ds_map_add(global.text_data_en, "obj_floweytrigger_348", "\E0* Hej^1.&* Pamiętaj./")
ds_map_add(global.text_data_en, "obj_floweytrigger_349", "\E2* NIKOGO nie zabijaj./")
ds_map_add(global.text_data_en, "obj_floweytrigger_350", "\E2* .../")
ds_map_add(global.text_data_en, "obj_floweytrigger_351", "\E1* Nie wierzę że to&  PRAWDZIWA rzecz^1, którą&  ci muszę przypominać./")
ds_map_add(global.text_data_en, "obj_floweytrigger_352", "\E0* Hee hee hee.../")
ds_map_add(global.text_data_en, "obj_floweytrigger_353", "* Powodzenia!/%%")
ds_map_add(global.text_data_en, "obj_floweytrigger_357", "* Remember.../")
ds_map_add(global.text_data_en, "obj_floweytrigger_358", "\E1* THIS time^1, you've&  GOT to become friends&  with everyone./")
ds_map_add(global.text_data_en, "obj_floweytrigger_359", "\E2* OK?/")
ds_map_add(global.text_data_en, "obj_floweytrigger_360", "\E5* If you DON'T^1, you'll&  be miserable FOREVER./")
ds_map_add(global.text_data_en, "obj_floweytrigger_361", "\E1* And we wouldn't want&  THAT^1, would we?/")
ds_map_add(global.text_data_en, "obj_floweytrigger_362", "\E0* No..^1.&* We just want you&  to be happy^1, right?/")
ds_map_add(global.text_data_en, "obj_floweytrigger_363", "* Good luck. /%%")
ds_map_add(global.text_data_en, "obj_floweytrigger2_158", "* Error/%%")
ds_map_add(global.text_data_en, "obj_floweytrigger2_162", "* Hee hee hee.../")
ds_map_add(global.text_data_en, "obj_floweytrigger2_163", "\E2* Mam nadzieję^1, żer&  nie żałujesz swojej&  decyzji./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_164", "* W końcu^1, to nie tak^1, że&  możesz zacząć od nowa&  i zmienić los./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_165", "\E0* W tym świecie^1, jest&  zabić albo być zabitym./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_166", "\E2* Ta stara szmata myślała^1,&  że mogła złamać zasady&  ot tak./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_167", "\E1* Tak bardzo się starała&  by uratować was ludzi./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_168", "\E0* Ale kiedy doszło do&  tego momentu.../")
ds_map_add(global.text_data_en, "obj_floweytrigger2_169", "\TF*\E5 Hee hee.../")
ds_map_add(global.text_data_en, "obj_floweytrigger2_170", "\E4* NIE MOGŁA NAWET&  URATOWAĆ SAMEJ SIEBIE./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_171", "* CO ZA DEBILKA!!/%%")
ds_map_add(global.text_data_en, "obj_floweytrigger2_175", "\E2* Heheheheh./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_176", "* Nie możesz się po&  prostu nacieszyć^1,&  czyż nie!?/")
ds_map_add(global.text_data_en, "obj_floweytrigger2_177", "\E4* .../")
ds_map_add(global.text_data_en, "obj_floweytrigger2_178", "\E6* Ile jeszcze razy&  ją zabijesz?/")
ds_map_add(global.text_data_en, "obj_floweytrigger2_179", "* Ha ha ha ha ha.../")
ds_map_add(global.text_data_en, "obj_floweytrigger2_180", "\E4*\TF Ty obrzydliwa istoto./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_181", "* Nawet nie PRÓBOWAŁEŚ&  ją oszczędzić./%%")
ds_map_add(global.text_data_en, "obj_floweytrigger2_186", "* Wow^1, ty naprawdę&  nie możesz się&  nacieszyć./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_187", "\E5* Ty trochę przypominasz&  mnie./%%")
ds_map_add(global.text_data_en, "obj_floweytrigger2_195", "* Wow^1, jesteś&  niesamowicie repulsywny./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_196", "\E6* Oszczędziłeś&  jej życie.../")
ds_map_add(global.text_data_en, "obj_floweytrigger2_197", "* Później zdecydowałeś że&  to nie było wystarcza-&  jąco ciekawe dla ciebie./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_198", "\E7* Więc zabiłeś ją tylko&  po to^1, żeby zobaczyć&  co się stanie./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_199", "\E5* Zabiłeś ją czysto&  z nudów./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_200", "* Szczerze obrzydliwe.../%%")
ds_map_add(global.text_data_en, "obj_floweytrigger2_203", "* Hee hee.../")
ds_map_add(global.text_data_en, "obj_floweytrigger2_204", "\E4* Ty naiwny idioto./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_205", "* Myślisz^1, że jesteś&  jako jedyny posiadający&  taką zdolność?/")
ds_map_add(global.text_data_en, "obj_floweytrigger2_206", "\E4* Moc do zrekonstruowania&  całego świata.../")
ds_map_add(global.text_data_en, "obj_floweytrigger2_207", "* Czysto przez twoją&  własną determinację./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_208", "* Umiejętność do&  zabawy w Boga!/")
ds_map_add(global.text_data_en, "obj_floweytrigger2_209", "* Umiejętność do&  " + '"' + "ZAPISYWANIA." + '"' + "/")
ds_map_add(global.text_data_en, "obj_floweytrigger2_210", "\E0* Myślałem^1, że jestem&  jedyną istotą z&  taką mocą^1. Ale.../")
ds_map_add(global.text_data_en, "obj_floweytrigger2_211", "\E1* Nie mogę już ZAPISYWAĆ./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_212", "* Najwyraźniej TWOJE&  zachcianki na ten&  świat nadpisują MOJE./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_213", "\E5* W takim razie./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_214", "* Ciesz się tą mocą&  póki jeszcze możesz./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_215", "\E4* Będę obserwował./%%")
ds_map_add(global.text_data_en, "obj_floweytrigger2_226", "* Hahaha.../")
ds_map_add(global.text_data_en, "obj_floweytrigger2_227", "\E1* Nie jesteś tak naprawdę&  człowiekiem^1, prawda?/")
ds_map_add(global.text_data_en, "obj_floweytrigger2_228", "\E1* Nie.^2 Jesteś pusty w&  środku^2. \E4Tak jak ja^1.&* A tak naprawde.../")
ds_map_add(global.text_data_en, "obj_floweytrigger2_229", "\E8* Jesteś \[C],^1 mylę się?/")
ds_map_add(global.text_data_en, "obj_floweytrigger2_230", "\E0* Jesteśmy dalej&  nierozłączni^1, po tych&  wszystkich latach.../")
ds_map_add(global.text_data_en, "obj_floweytrigger2_231", "* Słuchaj^1.&* Mam plan^1, by stać się&  całkowicie potężni./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_232", "\E2* Nawet potężniejsi niż&  ty i twoja skradziona&  dusza./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_233", "\E4* Zniszczmy wszystko&  w tym zwyrodniałym&  świecie./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_234", "\E6* Wszystkich^1, wszystko w&  tych \E7bezwartościowych&  wswpomnieniach.../")
ds_map_add(global.text_data_en, "obj_floweytrigger2_235", "\E5* Zamieńmy ich&  wszystkich w prochy./%%")
ds_map_add(global.text_data_en, "obj_floweytrigger2_245", "* Mądre.&* Baaaaardzo mądre./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_246", "* Myślisz że jesteś&  taki mądry^1, czyż nie?/")
ds_map_add(global.text_data_en, "obj_floweytrigger2_247", "\E0* W tym świecie^1, jest&  zabić albo być zabitym./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_248", "\E1* Więc byłeś w stanie&  zagrać z własnymi&  zasadami./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_249", "*\E4 Oszczędziłeś życie&  pojedynczej osoby./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_250", "* Hee hee hee.../")
ds_map_add(global.text_data_en, "obj_floweytrigger2_253", "* Froggit^1, Whimsun^1.&* Vegetoid^1, Loox^1.&* Migosp^1, Moldsmal./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_254", "* Pomyśł o tych imionach./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_255", "* Myślisz^1, że które-&  kolwiek z tych potworów&  ma swoją rodzinę?/")
ds_map_add(global.text_data_en, "obj_floweytrigger2_256", "* Myślisz^1, że ktokolwiek&  z nich ma przyjaciół?/")
ds_map_add(global.text_data_en, "obj_floweytrigger2_257", "\E6* Każde z nich mogło&  mieć swoją własną&  Toriel./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_258", "\E7* Samolubny szczenior./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_259", "* Ktoś jest martwy&  przez ciebie./%%")
ds_map_add(global.text_data_en, "obj_floweytrigger2_264", "\E2* Założę się^1, że się&  czujesz wspaniale&  teraz./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_265", "* Nikogo nie zabiłeś&  tym razem./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_266", "\E0* Ale co zrobisz jeśli&  spotkasz bezlitosnego&  mordercę?/")
ds_map_add(global.text_data_en, "obj_floweytrigger2_267", "* Umrzesz i umrzesz&  i umrzesz w kółko./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_268", "\E1* Dopóki się zmęczysz&  próbując./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_269", "\E0* Co zrobisz w takim&  wypadku?/")
ds_map_add(global.text_data_en, "obj_floweytrigger2_270", "\E5* Czy ich zabijesz&  czysto z frustracji?/")
ds_map_add(global.text_data_en, "obj_floweytrigger2_271", "* Czy całkowicie się&  poddasz na tym&  świecie.../")
ds_map_add(global.text_data_en, "obj_floweytrigger2_272", "\E4* ... i pozwolisz MI&  przejąć moc^1, aby to&  kontrolować?/")
ds_map_add(global.text_data_en, "obj_floweytrigger2_273", "\E5* Jestem księciem&  przyszłości tego&  świata./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_274", "* Nie martw się^1, mój mały&  monarcho^1, mój plan to&  nie królobójstwo./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_275", "* To jest o WIELE&  bardziej interesujące./%%")
ds_map_add(global.text_data_en, "obj_floweytrigger2_283", "* Ale nie bądz taki&  zarozumiały./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_284", "* Wiem co zrobiłeś./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_285", "\E6* Zabiłeś ją./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_286", "\E7* I wtedy poszedłeś&  spowrotem^1, ponieważ&  pożałowałeś tego./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_287", "* Ha ha ha ha.../")
ds_map_add(global.text_data_en, "obj_floweytrigger2_288", "\E5* Ty naiwny idioto./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_289", "* Myślisz^1, że jesteś&  jako jedyny posiadający&  taką zdolność?/")
ds_map_add(global.text_data_en, "obj_floweytrigger2_290", "\E4* Moc do zrekonstruowania&  całego świata.../")
ds_map_add(global.text_data_en, "obj_floweytrigger2_291", "* Czysto przez twoją&  własną determinację./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_292", "* Umiejętność do&  zabawy w Boga!/")
ds_map_add(global.text_data_en, "obj_floweytrigger2_293", "* Umiejętność do&  " + '"' + "ZAPISYWANIA." + '"' + "/")
ds_map_add(global.text_data_en, "obj_floweytrigger2_294", "\E0* Myślałem^1, że jestem&  jedyną istotą z&  taką mocą^1. Ale.../")
ds_map_add(global.text_data_en, "obj_floweytrigger2_295", "\E1* Nie mogę już ZAPISYWAĆ./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_296", "* Najwyraźniej TWOJE&  zachcianki na ten&  świat nadpisują MOJE./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_297", "\E5* W takim razie./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_298", "* Ciesz się tą mocą&  póki jeszcze możesz./")
ds_map_add(global.text_data_en, "obj_floweytrigger2_299", "\E4* Będę obserwował./%%")
ds_map_add(global.text_data_en, "obj_forcedright_142", "* Co to za zapach^1?&* (Skąd ten zapach?)/")
ds_map_add(global.text_data_en, "obj_forcedright_143", "* Jeśli jesteś zapachem^1...&* (... zitentyfikuj się!)/%%")
ds_map_add(global.text_data_en, "obj_forcedright_175", "* Hmmm..^1.&* Tu jest ten dziwny zapach.../")
ds_map_add(global.text_data_en, "obj_forcedright_176", "* Sprawia^1, że chcę&  wyeliminować./")
ds_map_add(global.text_data_en, "obj_forcedright_177", "* (... Wyeliminować CIEBIE!)/%%")
ds_map_add(global.text_data_en, "obj_forcedright_220", "* Psy mogą głaskać inne psy??^1?&* (Otworzył nam się zupełnie&  nowy świat...)/")
ds_map_add(global.text_data_en, "obj_forcedright_221", "* Dzięku^1, dziwny szczeniaczku!/%%")
ds_map_add(global.text_data_en, "obj_forcedright_224", "* Dziwne zapachy mogą dawać&  dobre rezultaty..^1.&* (Jak miło!)/")
ds_map_add(global.text_data_en, "obj_forcedright_225", "* Dzięki^1, dziwny zapachu^1!&* (Z pewnością było miło&  " + '"' + "trzymać" + '"' + " się razem!)/%%")
ds_map_add(global.text_data_en, "obj_friendc_event_115", "  Frisk!/")
ds_map_add(global.text_data_en, "obj_friendc_event_116", "  This is all just&  a bad dream...!/")
ds_map_add(global.text_data_en, "obj_friendc_event_117", "  Please^1, wake up...!/%%")
ds_map_add(global.text_data_en, "obj_friendc_event_181", "* Oh^1!&* You are awake^1!&* Thank goodness!/")
ds_map_add(global.text_data_en, "obj_friendc_event_183", "* W-we were so&  worried...!/")
ds_map_add(global.text_data_en, "obj_friendc_event_184", "* It felt like you&  were out forever!/")
ds_map_add(global.text_data_en, "obj_friendc_event_186", "* Yeah^1! Any longer and&  I would have freaked&  out!/")
ds_map_add(global.text_data_en, "obj_friendc_event_187", "\E2* Tell us next time&  you decide to take&  a nap^1, okay!?/")
ds_map_add(global.text_data_en, "obj_friendc_event_189", "* yeah^1.&* you made papyrus cry&  like a baby./")
ds_map_add(global.text_data_en, "obj_friendc_event_191", "WHAT!^1!&I DIDN'T CRY!!^1!&I DON'T CRY!!/")
ds_map_add(global.text_data_en, "obj_friendc_event_192", "\E3I JUST..^1.&CAUGHT SOMETHING&IN MY EYE./")
ds_map_add(global.text_data_en, "obj_friendc_event_194", "* what did you catch?/")
ds_map_add(global.text_data_en, "obj_friendc_event_196", "TEARS!!!/")
ds_map_add(global.text_data_en, "obj_friendc_event_198", "* Now^1, now./")
ds_map_add(global.text_data_en, "obj_friendc_event_199", "* The important part&  is that Frisk is&  all right./")
ds_map_add(global.text_data_en, "obj_friendc_event_200", "* Here^1, Frisk^1.&* Why not drink some&  tea?/")
ds_map_add(global.text_data_en, "obj_friendc_event_201", "* It'll make you feel&  better./")
ds_map_add(global.text_data_en, "obj_friendc_event_203", "* Errr..^1.&* How about we give&  them space^1, first?/")
ds_map_add(global.text_data_en, "obj_friendc_event_204", "\E2* They must be very&  exhausted./")
ds_map_add(global.text_data_en, "obj_friendc_event_205", "\E8* Though^1, from what^1,&  I am not certain./")
ds_map_add(global.text_data_en, "obj_friendc_event_206", "\E1* Frisk..^1.&* We do not remember&  exactly what happened./")
ds_map_add(global.text_data_en, "obj_friendc_event_207", "\E1* There was a flower..^1.&* And then^1, everything&  went white./")
ds_map_add(global.text_data_en, "obj_friendc_event_208", "\E0* But now the barrier&  is gone./")
ds_map_add(global.text_data_en, "obj_friendc_event_209", "* When you are ready^1,&  we will all return&  to the surface./")
ds_map_add(global.text_data_en, "obj_friendc_event_210", "* It seems the door to&  the east will lead&  us there now./")
ds_map_add(global.text_data_en, "obj_friendc_event_211", "\E2* But before then.../")
ds_map_add(global.text_data_en, "obj_friendc_event_212", "\E0* Perhaps you might&  want to take a&  walk?/")
ds_map_add(global.text_data_en, "obj_friendc_event_213", "* You can say goodbye&  to all of your&  wonderful friends./")
ds_map_add(global.text_data_en, "obj_friendc_event_214", "* Do as you wish^1.&* We will all wait&  for you here./%%")
ds_map_add(global.text_data_en, "obj_friendscene_182", "\E4What a miserable&creature^1, torturing&such a poor^1,&innocent, youth.../")
ds_map_add(global.text_data_en, "obj_friendscene_183", "\E0Do not be afraid^1,&my child./")
ds_map_add(global.text_data_en, "obj_friendscene_184", "\E0It is I^1, TORIEL^1,&your friend and&guardian./")
ds_map_add(global.text_data_en, "obj_friendscene_185", "\E1At first^1, I thought&I would let you&make your journey&alone.../")
ds_map_add(global.text_data_en, "obj_friendscene_186", "\E4But I could not&stop worrying about&you./")
ds_map_add(global.text_data_en, "obj_friendscene_187", "\E4Your adventure must&have been so&treacherous./")
ds_map_add(global.text_data_en, "obj_friendscene_188", "\E2... and ultimately^1,&it would burden you&with a horrible&choice./")
ds_map_add(global.text_data_en, "obj_friendscene_189", "To leave this place^1,&you would have to&take the life of&another person./")
ds_map_add(global.text_data_en, "obj_friendscene_190", "\E2You would have to&defeat ASGORE./")
ds_map_add(global.text_data_en, "obj_friendscene_191", "\E4However..^1.&I realized.../")
ds_map_add(global.text_data_en, "obj_friendscene_192", "\E1I cannot allow that./")
ds_map_add(global.text_data_en, "obj_friendscene_193", "It is not right to&sacrifice someone&simply to let&someone leave here./")
ds_map_add(global.text_data_en, "obj_friendscene_194", "\E4Is that not what&I have been trying to&prevent this&whole time?/")
ds_map_add(global.text_data_en, "obj_friendscene_195", "\E1So^1, for now^1, let&us suspend this&battle./")
ds_map_add(global.text_data_en, "obj_friendscene_196", "\E4As terrible as&ASGORE is.../")
ds_map_add(global.text_data_en, "obj_friendscene_197", "\E0He deserves mercy^1,&too./%%")
ds_map_add(global.text_data_en, "obj_friendscene_226", "Tori..^1.&You&came&back...!/%%")
ds_map_add(global.text_data_en, "obj_friendscene_236", "\E5Do not " + '"' + "Tori" + '"' + " me^1,&Dreemurr!/")
ds_map_add(global.text_data_en, "obj_friendscene_237", "\E2You pathetic whelp./")
ds_map_add(global.text_data_en, "obj_friendscene_238", "If you really wanted&to free our kind.../")
ds_map_add(global.text_data_en, "obj_friendscene_239", "You could have gone&through the barrier&after you got ONE&SOUL.../")
ds_map_add(global.text_data_en, "obj_friendscene_240", "... taken six SOULs&from the humans^1, then&come back and freed&everyone peacefully./")
ds_map_add(global.text_data_en, "obj_friendscene_241", "\E5But instead^1, you made&everyone live in&despair.../")
ds_map_add(global.text_data_en, "obj_friendscene_242", "Because you would&rather wait here^1,&meekly hoping another&human never comes./%%")
ds_map_add(global.text_data_en, "obj_friendscene_271", ".../")
ds_map_add(global.text_data_en, "obj_friendscene_272", "... Tori.../")
ds_map_add(global.text_data_en, "obj_friendscene_273", "You're right.../")
ds_map_add(global.text_data_en, "obj_friendscene_274", "I am a miserable&creature.../")
ds_map_add(global.text_data_en, "obj_friendscene_275", "... but^1, do you think&we can at least be&friends again?/%%")
ds_map_add(global.text_data_en, "obj_friendscene_301", "(Sigh.)/")
ds_map_add(global.text_data_en, "obj_friendscene_302", "NO^1,&Asgore./%%")
ds_map_add(global.text_data_en, "obj_friendscene_353", "Ngahhhhhh!!^1!&ASGORE^1! Human!!/")
ds_map_add(global.text_data_en, "obj_friendscene_354", "Nobody fight each&other!!!/")
ds_map_add(global.text_data_en, "obj_friendscene_355", "Everyone's gonna&make friends^1, or&else I'll...!!/")
ds_map_add(global.text_data_en, "obj_friendscene_356", "I'll.../")
ds_map_add(global.text_data_en, "obj_friendscene_357", ".../%%")
ds_map_add(global.text_data_en, "obj_friendscene_376", "Hello^1.&I am&TORIEL./")
ds_map_add(global.text_data_en, "obj_friendscene_377", "Are you&the&human's&friend?/")
ds_map_add(global.text_data_en, "obj_friendscene_378", "It is&nice to&meet&you./%%")
ds_map_add(global.text_data_en, "obj_friendscene_388", "Uh^1,&yeah...?/")
ds_map_add(global.text_data_en, "obj_friendscene_389", "Nice to&meet&you!/%%")
ds_map_add(global.text_data_en, "obj_friendscene_413", "Hey&ASGORE^1,&is that&your ex?/")
ds_map_add(global.text_data_en, "obj_friendscene_414", "Jeez^1.&That's&rough^1,&buddy./%%")
ds_map_add(global.text_data_en, "obj_friendscene_450", "H-hey^1!/")
ds_map_add(global.text_data_en, "obj_friendscene_451", "Nobody&hurt&each&other!!/")
ds_map_add(global.text_data_en, "obj_friendscene_452", ".../")
ds_map_add(global.text_data_en, "obj_friendscene_453", ".../%%")
ds_map_add(global.text_data_en, "obj_friendscene_477", "Oh^1!&Are you&another&friend?/")
ds_map_add(global.text_data_en, "obj_friendscene_478", "I am&TORIEL^1.&Hello!/%%")
ds_map_add(global.text_data_en, "obj_friendscene_487", "Uh^1,&h-h-hi!/")
ds_map_add(global.text_data_en, "obj_friendscene_488", ".../")
ds_map_add(global.text_data_en, "obj_friendscene_489", "(THERE'S&TWO OF&THEM???)/%%")
ds_map_add(global.text_data_en, "obj_friendscene_546", "HEY^1!&NOBODY FIGHT&ANYONE!/")
ds_map_add(global.text_data_en, "obj_friendscene_547", "IF ANYONE FIGHTS&ANYONE...!/")
ds_map_add(global.text_data_en, "obj_friendscene_548", "THEN I'LL!!^1!&BE FORCED!!!/")
ds_map_add(global.text_data_en, "obj_friendscene_549", "TO ASK UNDYNE&FOR HELP!!!/%%")
ds_map_add(global.text_data_en, "obj_friendscene_572", "Hello!/%%")
ds_map_add(global.text_data_en, "obj_friendscene_582", "OH^1!&HELLO^1, YOUR&MAJESTY!/")
ds_map_add(global.text_data_en, "obj_friendscene_583", "PSST^1!&HEY^1, HUMAN.../")
ds_map_add(global.text_data_en, "obj_friendscene_584", "DID ASGORE&SHAVE...?/")
ds_map_add(global.text_data_en, "obj_friendscene_585", "AND..^1.&CLONE HIMSELF????/%%")
ds_map_add(global.text_data_en, "obj_friendscene_631", "hey&guys..^1.&what's&up?/%%")
ds_map_add(global.text_data_en, "obj_friendscene_644", "That&voice&...!!/%%")
ds_map_add(global.text_data_en, "obj_friendscene_678", "Hello^1,&I think&we&may.../")
ds_map_add(global.text_data_en, "obj_friendscene_679", "Know&each&other?/%%")
ds_map_add(global.text_data_en, "obj_friendscene_691", "oh hey..^1.&i recognize your&voice^1, too./%%")
ds_map_add(global.text_data_en, "obj_friendscene_705", "I am&TORIEL./")
ds_map_add(global.text_data_en, "obj_friendscene_706", "So nice&to meet&you./%%")
ds_map_add(global.text_data_en, "obj_friendscene_717", "the&name's&sans./")
ds_map_add(global.text_data_en, "obj_friendscene_718", "and^1, uh^1,&same./%%")
ds_map_add(global.text_data_en, "obj_friendscene_733", "Oh^1!&Wait^1,&then...!/%%")
ds_map_add(global.text_data_en, "obj_friendscene_760", "This must be your&brother^1, Papyrus!/")
ds_map_add(global.text_data_en, "obj_friendscene_761", "Greetings^1, Papyrus^1!&It is so nice to&finally meet you!/")
ds_map_add(global.text_data_en, "obj_friendscene_762", "Your brother has&told me so much&about you./%%")
ds_map_add(global.text_data_en, "obj_friendscene_779", "WOWIE.../")
ds_map_add(global.text_data_en, "obj_friendscene_780", "I CAN'T BELIEVE&ASGORE'S CLONE&KNOWS WHO I&AM!!!/")
ds_map_add(global.text_data_en, "obj_friendscene_781", "THIS IS THE BEST&DAY OF MY&LIFE!!!!!!!/%%")
ds_map_add(global.text_data_en, "obj_friendscene_795", "Hey^1, Papyrus.../")
ds_map_add(global.text_data_en, "obj_friendscene_796", "What does a skeleton&tile his roof&with?/%%")
ds_map_add(global.text_data_en, "obj_friendscene_808", "HMMM..^1.&SNOW-PROOF ROOF&TILES???/%%")
ds_map_add(global.text_data_en, "obj_friendscene_819", "No^1, silly^1!&A skeleton tiles&his roof with.../")
ds_map_add(global.text_data_en, "obj_friendscene_820", "SHIN-gles!!!/%%")
ds_map_add(global.text_data_en, "obj_friendscene_846", "I CHANGED MY&MIND!!!/")
ds_map_add(global.text_data_en, "obj_friendscene_847", "THIS IS THE WORST&DAY OF MY LIFE!!!/%%")
ds_map_add(global.text_data_en, "obj_friendscene_863", "Come on^1, ASGORE^1!&It's gonna be OK!/")
ds_map_add(global.text_data_en, "obj_friendscene_864", "There are plenty&of fish in the&sea.../%%")
ds_map_add(global.text_data_en, "obj_friendscene_880", "Y-yeah^1, ASGORE!!/")
ds_map_add(global.text_data_en, "obj_friendscene_881", "Undyne's totally&right about that&fish thing!/")
ds_map_add(global.text_data_en, "obj_friendscene_882", "S-sometimes you've&just got to^1, uh.../")
ds_map_add(global.text_data_en, "obj_friendscene_883", "S-stop going after&furry boss monsters&and^1, uh.../")
ds_map_add(global.text_data_en, "obj_friendscene_884", "J-just get to know&a really cute&fish...?/")
ds_map_add(global.text_data_en, "obj_friendscene_885", ".../")
ds_map_add(global.text_data_en, "obj_friendscene_886", "It's a metaphor./%%")
ds_map_add(global.text_data_en, "obj_friendscene_910", "Well./")
ds_map_add(global.text_data_en, "obj_friendscene_911", "I think&it's a&good&analogy./%%")
ds_map_add(global.text_data_en, "obj_friendscene_945", "OH MY GOD!/")
ds_map_add(global.text_data_en, "obj_friendscene_946", "\XWILL YOU TWO&JUST \RSMOOCH\X &ALREADY!?/")
ds_map_add(global.text_data_en, "obj_friendscene_947", "THE AUDIENCE IS&DYING FOR SOME&ROMANTIC ACTION!!!/%%")
ds_map_add(global.text_data_en, "obj_friendscene_962", "HEY^1, SHUT UP!!!/")
ds_map_add(global.text_data_en, "obj_friendscene_963", "Man^1, the nerve of&that guy!/")
ds_map_add(global.text_data_en, "obj_friendscene_964", "Right^1,&Alphys!??/")
ds_map_add(global.text_data_en, "obj_friendscene_965", ".../")
ds_map_add(global.text_data_en, "obj_friendscene_966", "Uh^1, Alphys?/%%")
ds_map_add(global.text_data_en, "obj_friendscene_982", ".../")
ds_map_add(global.text_data_en, "obj_friendscene_983", "No./")
ds_map_add(global.text_data_en, "obj_friendscene_984", "He's&right./")
ds_map_add(global.text_data_en, "obj_friendscene_985", "LET'S&DO&IT./%%")
ds_map_add(global.text_data_en, "obj_friendscene_1003", "??????????????/")
ds_map_add(global.text_data_en, "obj_friendscene_1004", "Well??^1? Uh??^1?&I guess??^1?&If you want to??^1?&Then????/")
ds_map_add(global.text_data_en, "obj_friendscene_1005", "Don't hold anything&back!!!/%%")
ds_map_add(global.text_data_en, "obj_friendscene_1047", "W-wait!/")
ds_map_add(global.text_data_en, "obj_friendscene_1048", "Not in&front of&the&human!/%%")
ds_map_add(global.text_data_en, "obj_friendscene_1066", "Uhh^1, right^1!&S-sorry^1, I got a&little carried&away there./%%")
ds_map_add(global.text_data_en, "obj_friendscene_1082", "Hee hee hee./")
ds_map_add(global.text_data_en, "obj_friendscene_1083", "My child^1, it&seems as if you&must stay here&for a while./")
ds_map_add(global.text_data_en, "obj_friendscene_1084", "\E6But looking at&all the great&friends you have&made.../")
ds_map_add(global.text_data_en, "obj_friendscene_1085", "\E0I think.../")
ds_map_add(global.text_data_en, "obj_friendscene_1086", "\E7I think you will&be happy here./%%")
ds_map_add(global.text_data_en, "obj_friendscene_1108", "H-hey^1, that&reminds me./")
ds_map_add(global.text_data_en, "obj_friendscene_1109", "Papyrus..^1.&YOU called&everyone here^1,&right?/")
ds_map_add(global.text_data_en, "obj_friendscene_1110", "Well^1, besides^1,&uh^1, her./")
ds_map_add(global.text_data_en, "obj_friendscene_1111", "Uh^1, anyway..^1.&If I got here&before you.../")
ds_map_add(global.text_data_en, "obj_friendscene_1112", "How did you know&how to call&everybody?/%%")
ds_map_add(global.text_data_en, "obj_friendscene_1122", "LET'S&JUST&SAY.../%%")
ds_map_add(global.text_data_en, "obj_friendscene_1132", "A TINY&FLOWER&HELPED&ME./%%")
ds_map_add(global.text_data_en, "obj_friendscene_1146", "A tiny..^1.&flower?/%%")
ds_map_add(global.text_data_en, "obj_friendscene_1194", "\E0You IDIOTS./")
ds_map_add(global.text_data_en, "obj_friendscene_1195", "\E2While you guys were&having your little&pow-wow.../")
ds_map_add(global.text_data_en, "obj_friendscene_1196", "\E6I took the human&SOULS!/")
ds_map_add(global.text_data_en, "obj_friendscene_1197", "\E5And now^1, not only&are THOSE under my&power.../")
ds_map_add(global.text_data_en, "obj_friendscene_1198", "\E6But all of your&FRIENDS' SOULS are&gonna be mine^1, too!/")
ds_map_add(global.text_data_en, "obj_friendscene_1199", "\E0Hee hee hee./")
ds_map_add(global.text_data_en, "obj_friendscene_1200", "\E1And you know what&the best part is?/")
ds_map_add(global.text_data_en, "obj_friendscene_1201", "\E5It's all your&fault./")
ds_map_add(global.text_data_en, "obj_friendscene_1202", "\E6It's all because&you MADE THEM&love you./")
ds_map_add(global.text_data_en, "obj_friendscene_1203", "\E7All the time you&spent listening to&them.../")
ds_map_add(global.text_data_en, "obj_friendscene_1204", "\E2Encouraging them..^1.&Caring about them.../")
ds_map_add(global.text_data_en, "obj_friendscene_1205", "\E0Without that^1, they&wouldn't have come&here./")
ds_map_add(global.text_data_en, "obj_friendscene_1206", "\E7And now^1, with their&souls and the humans'&together.../")
ds_map_add(global.text_data_en, "obj_friendscene_1207", "\E5I will achieve my&REAL FORM./")
ds_map_add(global.text_data_en, "obj_friendscene_1208", "\E0Hee hee.../")
ds_map_add(global.text_data_en, "obj_friendscene_1209", "\E3Huh?/")
ds_map_add(global.text_data_en, "obj_friendscene_1210", "\E1WHY am I still&doing this?/")
ds_map_add(global.text_data_en, "obj_friendscene_1211", "\E7Don't you get it?/")
ds_map_add(global.text_data_en, "obj_friendscene_1212", "\E0This is all just&a GAME./")
ds_map_add(global.text_data_en, "obj_friendscene_1213", "\E3If you leave the&underground satisfied^1,&you'll " + '"' + "win" + '"' + " the&game./")
ds_map_add(global.text_data_en, "obj_friendscene_1214", "\E4If you " + '"' + "win^1," + '"' + " you&won't want to " + '"' + "play" + '"' + "&with me anymore./")
ds_map_add(global.text_data_en, "obj_friendscene_1215", "\E0And what would I&do then?/")
ds_map_add(global.text_data_en, "obj_friendscene_1216", "\E6But this game&between us will&NEVER end./")
ds_map_add(global.text_data_en, "obj_friendscene_1217", "\E5I'll hold victory&in front of you^1,&just within your&reach.../")
ds_map_add(global.text_data_en, "obj_friendscene_1218", "\E6And then tear it&away just before&you grasp it./")
ds_map_add(global.text_data_en, "obj_friendscene_1219", "\E8Over^1, and over^1,&and over.../")
ds_map_add(global.text_data_en, "obj_friendscene_1220", "\E5Hee hee hee./")
ds_map_add(global.text_data_en, "obj_friendscene_1221", "\E1Listen./")
ds_map_add(global.text_data_en, "obj_friendscene_1222", "\E0If you DO defeat&me^1, I'll give you&your " + '"' + "happy ending." + '"' + "/")
ds_map_add(global.text_data_en, "obj_friendscene_1223", "\E7I'll bring your&friends back./")
ds_map_add(global.text_data_en, "obj_friendscene_1224", "I'll destroy the&barrier./")
ds_map_add(global.text_data_en, "obj_friendscene_1225", "\E0Everyone will&finally be&satisfied./")
ds_map_add(global.text_data_en, "obj_friendscene_1226", "\E6But that WON'T&happen./")
ds_map_add(global.text_data_en, "obj_friendscene_1227", "\E8You...!/")
ds_map_add(global.text_data_en, "obj_friendscene_1228", "\E0I'll keep you here&no matter what!/%%")
ds_map_add(global.text_data_en, "obj_friendscene_1266", "\E0Even if it means&killing you&1,000,000 times!!!!/%%")
ds_map_add(global.text_data_en, "obj_friendscene_1357", "What?/%%")
ds_map_add(global.text_data_en, "obj_friendscene_1375", "Do not be afraid^1,&my child.../")
ds_map_add(global.text_data_en, "obj_friendscene_1376", "No matter what&happens.../")
ds_map_add(global.text_data_en, "obj_friendscene_1377", "We will always&be there to&protect you!/%%")
ds_map_add(global.text_data_en, "obj_friendscene_1434", "THAT'S RIGHT^1,&HUMAN^1!&YOU CAN&WIN!!/")
ds_map_add(global.text_data_en, "obj_friendscene_1435", "JUST DO&WHAT I^1,&WOULD&DO.../")
ds_map_add(global.text_data_en, "obj_friendscene_1436", "BELIEVE&IN YOU!!!/%%")
ds_map_add(global.text_data_en, "obj_friendscene_1449", "Hey^1! Human^1! If&you got past&ME^1, you can&do ANYTHING!/")
ds_map_add(global.text_data_en, "obj_friendscene_1450", "So don't worry^1!&We're with you&all the way!/%%")
ds_map_add(global.text_data_en, "obj_friendscene_1463", "huh^1?&you haven't&beaten&this guy yet?/")
ds_map_add(global.text_data_en, "obj_friendscene_1464", "come on^1, this&weirdo's got&nothin' on you./%%")
ds_map_add(global.text_data_en, "obj_friendscene_1514", "Technically^1, it's&impossible for you&to beat him.../")
ds_map_add(global.text_data_en, "obj_friendscene_1515", "B-but..^1.&Somehow^1, I know&you can do it!!/%%")
ds_map_add(global.text_data_en, "obj_friendscene_1532", "Human^1, for the&future of&humans and&monsters...!/")
ds_map_add(global.text_data_en, "obj_friendscene_1533", "You have to stay&determined...!/%%")
ds_map_add(global.text_data_en, "obj_friendscene_1589", "Urrrgh..^1. NO!/")
ds_map_add(global.text_data_en, "obj_friendscene_1590", "Unbelievable!!/")
ds_map_add(global.text_data_en, "obj_friendscene_1591", "This can't be&happening...!/")
ds_map_add(global.text_data_en, "obj_friendscene_1592", "You..^1. YOU...!/%%")
ds_map_add(global.text_data_en, "obj_friendscene_1635", "I can't believe&you're all so&STUPID./%%")
ds_map_add(global.text_data_en, "obj_friendscene_1665", "ALL OF YOUR SOULS&ARE MINE!!!/%%")
ds_map_add(global.text_data_en, "obj_froggit_30", "Kum,&kum.")
ds_map_add(global.text_data_en, "obj_froggit_31", "Kum,&kum.")
ds_map_add(global.text_data_en, "obj_froggit_32", "Hop,&hop.")
ds_map_add(global.text_data_en, "obj_froggit_33", "Meow.")
ds_map_add(global.text_data_en, "obj_froggit_36", "(Głęboko&rumieni&się.)&Kum..")
ds_map_add(global.text_data_en, "obj_froggit_39", "* Drganie")
ds_map_add(global.text_data_en, "obj_froggit_42", "%%%")
ds_map_add(global.text_data_en, "obj_froggit_184", "* Froggit nie wydaje się&  wiedzieć po co tu jest.")
ds_map_add(global.text_data_en, "obj_froggit_185", "* Froggit skacze na przód.")
ds_map_add(global.text_data_en, "obj_froggit_186", "* The battlefield is filled&  with the smell of mustard&  seed.")
ds_map_add(global.text_data_en, "obj_froggit_187", "* Jesteś zachwycony&  czystą mocą Froggita^4.&* Taki żarcik.")
ds_map_add(global.text_data_en, "obj_froggit_188", "* Froggit wydaje się&  odechciewać walki&  z tobą.")
ds_map_add(global.text_data_en, "obj_froggit_189", "* Froggit próbuje uciec.")
ds_map_add(global.text_data_en, "obj_froggit_205", "* FROGGIT - ATK 4 DEF 5&* Życie jest ciężkie&  dla tego potwora./^")
ds_map_add(global.text_data_en, "obj_froggit_214", "* Froggit nie zrozumiał&  to co powiedziałeś^1, ale&  i tak się przestraszył./^")
ds_map_add(global.text_data_en, "obj_froggit_225", "* Froggit nie zrozumiał&  to co powiedziałeś^1, ale&  i tak było mu miło./^")
ds_map_add(global.text_data_en, "obj_gameintro_fake_44", "Dawno temu^1, dwie rasy&panowały nad Ziemią^1:&LUDZIE i POTWORY. \E1 ^1 %")
ds_map_add(global.text_data_en, "obj_gameintro_fake_45", "Jednego dnia^1, ^7oni wszyscy &zniknęli bez śladu.")
ds_map_add(global.text_data_en, "obj_garbagepile_70", "* (Kupki śmieci.)&* (Jest kilka marek&  które rozpoznajesz.)/%%")
