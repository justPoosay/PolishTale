ds_map_add(global.text_data_en, "SCR_TEXT_1413", "* Nic tu nie ma!!!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1431", "* (Dostałeś Zużyty Sztylet.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1432", "* (Dostałeś Prawdziwy Nóż.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1435", "* (Nosisz zbyt wiele.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1439", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_1446", "* (W pudle jest naszyjnik&  w kształcie serca.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_1447", "* (Weźmiesz go?)& &         Weź         Zostaw  \C ")
ds_map_add(global.text_data_en, "SCR_TEXT_1448", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_1451", "* Nic tu nie ma!!!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1470", "* (Dostałeś Sercowy Naszyjnik.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1471", "* (Dostałeśt Naszyjnik.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1474", "* (Nosisz zbyt wiele.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1478", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_1483", "* (To pudło jest puste.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1492", "* Cześć...&* Chciałbyś może troche&  Fajnych Lodów...?/")
ds_map_add(global.text_data_en, "SCR_TEXT_1493", "* To nasz lokalny przysmak...&  Który ogrzewa twoje serce./")
ds_map_add(global.text_data_en, "SCR_TEXT_1494", "* Teraz tylko 12G!& &         Tak         Nie \C")
ds_map_add(global.text_data_en, "SCR_TEXT_1495", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_1499", " %")
ds_map_add(global.text_data_en, "SCR_TEXT_1500", "* Fajne Lody^1.&* To nasz lokalny przysmak^1.&  Który ogrzewa twoje serce./")
ds_map_add(global.text_data_en, "SCR_TEXT_1501", "* Teraz tylko 12G.& &         Tak         Nie \C")
ds_map_add(global.text_data_en, "SCR_TEXT_1502", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_1520", "* Trzymaj^1.&* (Dostałeś Fajne Lody.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1522", "* Nie masz wystarczająco&  pieniędzy.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1525", "* Upuść coś./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1528", "* W takim razie..^1.&* Powiedz twoim znajomym.../")
ds_map_add(global.text_data_en, "SCR_TEXT_1529", "* Życie..^1. to cierpienie./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1535", "* (Złote kwiaty.^1)&* (Musiały zamortyzować&  twój upadek.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1536", "%%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1540", "* " + '"' + "Naciśnij \*Z aby&  czytać znaki!" + '"' + "/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1544", "* Stary pilar./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1548", "* Proszę nie chodzić po&  liściach./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1552", "* Nie czytałeś tabliczki&  na dole?/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1562", "* ŁO^1, wypraszam sobie^2!&* Kto powiedział, że możesz&  mną popychać?/")
ds_map_add(global.text_data_en, "SCR_TEXT_1563", "* HMM^2?&* Więc prosisz mnie, bym się&  przesunął obok?/")
ds_map_add(global.text_data_en, "SCR_TEXT_1564", "* Okej^1, dla ciebie wszystko^1,&  habibi./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1569", "* HMM^2?&* Chcesz, żebym się przesunął&  trochę bardziej?/")
ds_map_add(global.text_data_en, "SCR_TEXT_1570", "* W porząsiu^1, może teraz?/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1575", "* HMM^2?&* To był zły kierunek?/")
ds_map_add(global.text_data_en, "SCR_TEXT_1576", "* Okej^1, chyba czaję./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1579", "* Czy to było pomocne?/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1583", "* HMM^2?&* Chciałeś, żebym tam został?/")
ds_map_add(global.text_data_en, "SCR_TEXT_1584", "* Dajesz mi dosyć&  mocne kardio./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1589", "* Czyż rzeczy nie są łatwiejsze,&  kiedy tylko poprosisz?/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1592", "* Wyjście jest otwarte^1?&* Pójdę sobie w takim razie.../")
ds_map_add(global.text_data_en, "SCR_TEXT_1593", "* Hej^1, mógłbyś mnie&  popchnąć^1, habibi?/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1603", "* 'Weź jedno.'&* Wziąć cukierka?&         Tak         Nie \C")
ds_map_add(global.text_data_en, "SCR_TEXT_1604", "* Pisze 'weź jedno.'&* Wziąć cukierka?&         Tak         Nie \C")
ds_map_add(global.text_data_en, "SCR_TEXT_1606", "* Spójrz na to, coś zrobiłeś./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1607", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_1624", "* Wziąłeś cukierka.&* (Naciśnij \*C, aby&  otworzyć menu.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1625", "* Wziąłeś kolejnego^1.&* Wstydziłbyś się../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1626", "* Wziąłeś kolejnego.&* Czujesz się jak&  szumowina na ziemi.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1628", "* Wziąłeś zbyt wiele.&* Cukierki rozsypują się&  na ziemię./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1631", "* W tym brutalnym świecie^1,&  możesz wziąć tylko 3&  cukierki.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1635", "* Spróbowałeś wziąć cukierka^1,&  ale nie miałeś więcej&  wolnego miejsca./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1639", "* Zdecydowałeś nie&  częstować się./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1675", "* Pisze 'Weź wszystkie.'&* Wziąć cukierka?&         Tak         Nie \C")
ds_map_add(global.text_data_en, "SCR_TEXT_1676", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_1692", "* Wziąłeś cukierka.&* Rany^1, to jest ciężkie./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1694", "* Nie możesz nieść więcej.&* Po prostu są&  zbyt ciężkie./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1695", "* Spróbowałeś wziąć cukierka^1,&  ale nie miałeś więcej&  wolnego miejsca./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1698", "* Zdecydowałeś nie&  częstować się./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1644", "* zzzzzzzzzzzzzzz..^1.&* zzzzzzzzzzzzzz.../")
ds_map_add(global.text_data_en, "SCR_TEXT_1645", "* zzzzzzzzzz..^1.&* (czy on już sobie poszedł^1)&* zzzzzzzzzzzzzzz.../")
ds_map_add(global.text_data_en, "SCR_TEXT_1646", "* (Duch dalej mówi 'z'&  głośno w pętli^1,&  udając, że śpi.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_1647", "* Przesunąć siłą?& &         Tak         Nie \C")
ds_map_add(global.text_data_en, "SCR_TEXT_1648", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_1705", "* Zostawić 7G w sieci?& &         Tak         Nie \C")
ds_map_add(global.text_data_en, "SCR_TEXT_1706", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_1723", "* Kilka pająkow wypełznęły&  i dało ci pączka./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1724", "* Nie miałeś wystarczająco&  pieniędzy./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1726", "* Nosisz zbyt wiele rzeczy./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1729", "*%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1736", "* Zostawić 18G w sieci?& &         Tak         Nie \C")
ds_map_add(global.text_data_en, "SCR_TEXT_1737", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_1754", "* Kilka pająów wypełznęło&  i dało ci słoik./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1755", "* Nie miałeś wystarczająco&  pieniędzy./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1757", "* Nosisz zbyt wiele rzeczy./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1760", "*%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1771", "* Znalazłeś Wyblakłą Wstążkę./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1772", "* Nosisz zbyt wiele./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1778", "* To przełącznik.&* Nacisnąć?&         Tak         Nie \C")
ds_map_add(global.text_data_en, "SCR_TEXT_1779", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_1788", "* Nic się nie wydarzyło./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1789", "%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1790", "* Sprawiasz, że guziki się czują&  niekomfortowo całą&  tą atencją./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1796", "* To przełącznik.&* Nacisnąć?&         Tak         Nie \C")
ds_map_add(global.text_data_en, "SCR_TEXT_1797", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_1806", "* Słyszysz kliknięcie./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1807", "%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1817", "* Znalazłeś Zabawkowy Nóż./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1818", "* Nosisz zbyt wiele./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1824", "* To dzienniczek TORIEL.&* Przeczytać zaznaczony fragment?&         Tak         Nie \C")
ds_map_add(global.text_data_en, "SCR_TEXT_1825", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_1830", "* Czytasz fragment.../")
ds_map_add(global.text_data_en, "SCR_TEXT_1831", "* " + '"' + "Co mowią sobie&  szkielety przy obiedzie?" + '"' + "/")
ds_map_add(global.text_data_en, "SCR_TEXT_1832", "* " + '"' + "Bone-apetit..." + '"' + "/")
ds_map_add(global.text_data_en, "SCR_TEXT_1833", "* Reszta strony jest&  wypełniona żartami&  podobnego kalibru./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1835", "%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1842", "* Znalazłeś kawałek&  cynamonowo-toffi ciasta./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1843", "* Nosisz zbyt wiele./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1853", "* Znalazłeś kawałek&  ślimakowego ciasta.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1854", "* Nosisz zbyt wiele./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1859", "* Dzień dobry^1,&  malutki!/")
ds_map_add(global.text_data_en, "SCR_TEXT_1860", "* Ciasto jeszcze&  nie wystygło./")
ds_map_add(global.text_data_en, "SCR_TEXT_1861", "* Być może utniesz& sobie drzemkę.&  Tak         Nie      \C ")
ds_map_add(global.text_data_en, "SCR_TEXT_1862", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_1867", "* Słodkich snów./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1870", "\E1* Wolisz nie spać i&  porozmawiać ze&  mną^1, w takim razie?/")
ds_map_add(global.text_data_en, "SCR_TEXT_1871", "* Już wstałeś^1, widzę?/")
ds_map_add(global.text_data_en, "SCR_TEXT_1872", "\E0* Um^1, chcę, abyś wiedział&  jak bardzo się cieszę^1,&  że mam tu kogoś./")
ds_map_add(global.text_data_en, "SCR_TEXT_1873", "* Jest tyle starych&  książek, którymi chcę&  się podzielić./")
ds_map_add(global.text_data_en, "SCR_TEXT_1874", "* Chcę ci pokazać moje&  ulubione miejsce do&  łapania robaczków./")
ds_map_add(global.text_data_en, "SCR_TEXT_1875", "* Przygotowałam również&  program edukacyjny&  specjalnie dla ciebie./")
ds_map_add(global.text_data_en, "SCR_TEXT_1876", "* To może być nielada&  niespodzianka dla&  ciebie.../")
ds_map_add(global.text_data_en, "SCR_TEXT_1877", "* Ale od zawsze&  chciałam zostać&  nauczycielem./")
ds_map_add(global.text_data_en, "SCR_TEXT_1878", "\E1* ... choć^1, być może&  to nie jest jakoś&  bardzo zaskakujące./")
ds_map_add(global.text_data_en, "SCR_TEXT_1879", "\E5* NATOMIAST./")
ds_map_add(global.text_data_en, "SCR_TEXT_1880", "\E0* Tak bardzo się cieszę&  że tu mieszkasz./")
ds_map_add(global.text_data_en, "SCR_TEXT_1881", "\E1* Oh^1, czyżbyś&  czegoś chciał?/")
ds_map_add(global.text_data_en, "SCR_TEXT_1882", "* O co chodzi?&              Kiedy mogę&  Nic         iść do domu?\C ")
ds_map_add(global.text_data_en, "SCR_TEXT_1883", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_1891", "* Cóż^1, zagadaj ze mną^1,&  jeśli będziesz&  czegoś potrzebował./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1895", "\E1* Co^1?&* To..^1. to JEST teraz&  twój dom./")
ds_map_add(global.text_data_en, "SCR_TEXT_1896", "* Um..^1. chciałbyś&  posłuchać o czym jest&  książka^1, którą czytam?/")
ds_map_add(global.text_data_en, "SCR_TEXT_1897", "\E0* Oh^1, witaj!/")
ds_map_add(global.text_data_en, "SCR_TEXT_1898", "* Chciałeś posłuchać o&  książce^1, którą czytam?/")
ds_map_add(global.text_data_en, "SCR_TEXT_1899", "\E0* Tytuł tej książki to&  " + '"' + "72 Pożytki&   ze Ślimaków." + '"' + "/")
ds_map_add(global.text_data_en, "SCR_TEXT_1900", "* Chcesz posłuchać?&              Jak opuścić&  Chętnie     RUINY\C ")
ds_map_add(global.text_data_en, "SCR_TEXT_1901", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_1907", "* Mam ekscytujący&  fakt o ślimakach./")
ds_map_add(global.text_data_en, "SCR_TEXT_1908", "\E1* Um^1.^1.^1.&*\E0 Co powiesz na ciekawy&  fakt o ślimakach?/")
ds_map_add(global.text_data_en, "SCR_TEXT_1909", "\E2* Wiedziałeś^1,&  że ślimaki.../")
ds_map_add(global.text_data_en, "SCR_TEXT_1911", "\E0* Mają języki&  w kształcie&  piły łańcuchowej?/")
ds_map_add(global.text_data_en, "SCR_TEXT_1912", "\E0* Czasami obracają&  układ trawienny&  wraz z dojrzewaniem?/")
ds_map_add(global.text_data_en, "SCR_TEXT_1913", "\E0* Robią okropne&  sznurówki?/")
ds_map_add(global.text_data_en, "SCR_TEXT_1914", "\E0* Gadają^2. Bardzo^2. Wolno^2?&* Taki żarcik^1, ślimaki&  ie gadają./")
ds_map_add(global.text_data_en, "SCR_TEXT_1915", "\E0* Fascynujące.&              Jak opuścić&  Rel         RUINY\C ")
ds_map_add(global.text_data_en, "SCR_TEXT_1916", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_1921", "* Cóż^1, zaczep mnie&  jeśli będziesz czegoś&  jeszcze potrzebował./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1924", "\E1* ... Muszę coś&  zrobić^1.&* Zostań tu./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1927", "\E0* Co tam?&              Jak opuścić&  Nic         RUINY\C ")
ds_map_add(global.text_data_en, "SCR_TEXT_1930", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_1934", "* Jeśli czegoś&  potrzebujesz^1,&  po prostu spytaj./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1935", "\E1* ... Muszę coś&  zrobić.&* Zostań tu./%%.")
ds_map_add(global.text_data_en, "SCR_TEXT_1936", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_1940", "\E2NYOO HOO HOO.../")
ds_map_add(global.text_data_en, "SCR_TEXT_1941", "NIE MOGĘ NAWET ZA-&TRZYMAĆ KOGOŚ TAK&SŁABEGO JAK TY.../")
ds_map_add(global.text_data_en, "SCR_TEXT_1942", "UNDYNE BĘDZIE&MNĄ BARDZO&ROZCZAROWANA./")
ds_map_add(global.text_data_en, "SCR_TEXT_1943", "NIGDY NIE DOŁĄCZĘ&DO KRÓLEWSKIEJ&STRAŻY I...^1./")
ds_map_add(global.text_data_en, "SCR_TEXT_1944", "ILOŚĆ MOICH PRZYJA-&CIÓŁ ZOSTANIE&NIEZMIENNA!/")
ds_map_add(global.text_data_en, "SCR_TEXT_1945", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_1946", "* (Czym odpowiesz?)&         Bądźmy      Co za&         BFF's       przegryw\C")
ds_map_add(global.text_data_en, "SCR_TEXT_1947", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_1956", "\E0WOWIE!^1!&ZROBIŁEŚ TO!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_1957", "NIE ZNIŻYŁEŚ SIĘ&DO PRZEMOCY!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_1958", "\E5SZCZERZE MÓWIĄC^1,&ZACZĄŁEM SIĘ&TROCHĘ NIEPOKOIĆ.../")
ds_map_add(global.text_data_en, "SCR_TEXT_1959", "\E0ALE TY JUŻ SIĘ&STAJESZ ŚWIETNĄ&OSOBĄ!/")
ds_map_add(global.text_data_en, "SCR_TEXT_1960", "\E7JESTEM TAK DUMNY&ŻE MÓGŁBYM SIĘ&ROZPŁAKAĆ!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_1961", "\E3... CHWILA^1, NIE&POWINIENEM BYŁ&CIĘ PORWAĆ...?/")
ds_map_add(global.text_data_en, "SCR_TEXT_1962", "\E0CÓŻ^1, ZAPOMNIJMY&O TYM!/")
ds_map_add(global.text_data_en, "SCR_TEXT_1963", "PO PROSTU CHCĘ&ABYŚ BYŁ NAJLEPSZĄ&OSOBĄ JAK SIĘ DA./")
ds_map_add(global.text_data_en, "SCR_TEXT_1964", "WIĘC^1, CO BYŁO&TO BYŁO./")
ds_map_add(global.text_data_en, "SCR_TEXT_1965", "DAM CI NAWET&KIERUNKI DO&WYJŚCIA Z PODZIEMI!/")
ds_map_add(global.text_data_en, "SCR_TEXT_1966", "PO PROSTU PODĄŻAJ&NA WCHÓD!/")
ds_map_add(global.text_data_en, "SCR_TEXT_1967", "PO JAKIMŚ CZASIE&TRAFISZ DO ZAMKU&KRÓLA./")
ds_map_add(global.text_data_en, "SCR_TEXT_1968", "WTEDY BĘDZIESZ&MÓGŁ WYJŚĆ!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_1978", "NAPRAWDĘ!^1?&CHCESZ ZOSTAĆ PRZY-&JACIÓŁMI^1, ZE MNĄ???/")
ds_map_add(global.text_data_en, "SCR_TEXT_1979", "W TAKIM RAZIE.../")
ds_map_add(global.text_data_en, "SCR_TEXT_1980", "\E0MYŚLĘ..^1./")
ds_map_add(global.text_data_en, "SCR_TEXT_1981", "MYŚLĘ^1, ŻE MOGĘ&SIĘ NA TO ZGODZIĆ!/")
ds_map_add(global.text_data_en, "SCR_TEXT_1982", " %")
ds_map_add(global.text_data_en, "SCR_TEXT_1987", "HUH^1?&DLACZEGO&MIAŁBYŚ.../")
ds_map_add(global.text_data_en, "SCR_TEXT_1988", "TAK SIEBIE&KRYTYKOWAĆ???/")
ds_map_add(global.text_data_en, "SCR_TEXT_1989", "CZY TO DLATEGO.../")
ds_map_add(global.text_data_en, "SCR_TEXT_1990", "\E3ŻE MYŚLISZ^1, ŻE NIE&NADAJESZ SIĘ DO&BYCIA PRZYJACIELEM?/")
ds_map_add(global.text_data_en, "SCR_TEXT_1991", "\E0NIE!!^1!&JESTEŚ ŚWIETNY!!^1!&BĘDĘ PRZYJACIELEM!/")
ds_map_add(global.text_data_en, "SCR_TEXT_1996", "WOWIE!^1!&NIE MIELIŚMY NAWET&PIERWSZEJ RANDKI.../")
ds_map_add(global.text_data_en, "SCR_TEXT_1997", "A JUŻ ZDOŁAŁEM&OSIĄGNĄĆ STREFĘ&PRZYJACIÓŁ!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_1998", "KTO BY POMYŚLAŁ&ŻE JEDYNE CO&MUSIAŁEM ZROBIĆ.../")
ds_map_add(global.text_data_en, "SCR_TEXT_2002", "WOW!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_2003", "MAM PRZYJACIÓŁ!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_2004", "I KTO BY POMYŚLAŁ&ŻE JEDYNE CO&MUSIAŁEM ZROBIĆ.../")
ds_map_add(global.text_data_en, "SCR_TEXT_2006", "TO WCISNĄĆ LUDZIOM&OKROPNE PUZZLE I&POTOCZYĆ WALKĘ??/")
ds_map_add(global.text_data_en, "SCR_TEXT_2007", "NAUCZYŁEŚ MNIE&WIELE^1, CZŁOWIEKU./")
ds_map_add(global.text_data_en, "SCR_TEXT_2008", "NINIEJSZYM DAJĘ&CI PRZYZWOLENIE^1,&ABY PRZEJŚĆ DALEJ!/")
ds_map_add(global.text_data_en, "SCR_TEXT_2009", "I NAWET CI&DAM KIERUNKI&NA POWIERZCHNIĘ./")
ds_map_add(global.text_data_en, "SCR_TEXT_2010", "PODĄŻAJ NA PRZÓD&DOPÓKI NIE DODZIESZ&DO KOŃCA GROTY./")
ds_map_add(global.text_data_en, "SCR_TEXT_2011", "\WWTEDY..^1. GDY DOJ-&DZIESZ DO STOLICY^1,&PRZEKROCZ \YBARIERĘ\W./")
ds_map_add(global.text_data_en, "SCR_TEXT_2012", "TO MAGICZNA PIECZĘĆ&KTÓRA NAS WIĘZI&POD ZIEMIĄ./")
ds_map_add(global.text_data_en, "SCR_TEXT_2013", "WSZYSTKO MOŻE&TĘDY WEJŚĆ^1, ALE NIC&NIE MOŻE OPUŚCIĆ.../")
ds_map_add(global.text_data_en, "SCR_TEXT_2014", "POZA KIMŚ Z&POTĘŻNĄ DUSZĄ^1.^1.^1./")
ds_map_add(global.text_data_en, "SCR_TEXT_2015", "... KIMŚ JAK TY!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_2016", "TO DLATEGO&KRÓL POSZUKUJE&CZŁOWIEKA./")
ds_map_add(global.text_data_en, "SCR_TEXT_2017", "ON CHCE OTWORZYĆ&BARIERĘ POSŁUGUJĄC&SIĘ MOCĄ DUSZY../")
ds_map_add(global.text_data_en, "SCR_TEXT_2018", "WTEDY MY^1, POTWORY^1,&MOŻEMY POWRÓCIĆ NA&POWIERZCHNIĘ!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2023", "WRÓCIŁEŚ&SPOWROTEM?!?!/")
ds_map_add(global.text_data_en, "SCR_TEXT_2024", "W KOŃCU ZDAŁEM&SOBIE SPRAWĘ&DLACZEGO./")
ds_map_add(global.text_data_en, "SCR_TEXT_2025", "TY.../")
ds_map_add(global.text_data_en, "SCR_TEXT_2026", "PO PROSTU BARDZO&TĘSKNISZ ZA&MOJĄ TWARZĄ.../")
ds_map_add(global.text_data_en, "SCR_TEXT_2027", "NIE JESTEM PEWIEN^1,&CZY MOGĘ WALCZYĆ&Z KIMŚ ZNACZĄCYM./")
ds_map_add(global.text_data_en, "SCR_TEXT_2028", "ALE SZCZERZE..^1.&MĘCZY MNIE CIĄGŁE&PORYWANIE CIĘ!/")
ds_map_add(global.text_data_en, "SCR_TEXT_2029", "WIĘC..^1.&CO TY NA TO?/")
ds_map_add(global.text_data_en, "SCR_TEXT_2030", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_2031", "* (Walczyć z Papyrusem?)& &         Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_2032", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2036", "\TP %")
ds_map_add(global.text_data_en, "SCR_TEXT_2039", "OKEJ.../")
ds_map_add(global.text_data_en, "SCR_TEXT_2040", "NAJWYRAŹNIEJ./")
ds_map_add(global.text_data_en, "SCR_TEXT_2041", "JEŚLI CHCESZ^1, ABYM&CIĘ PORWAŁ./")
ds_map_add(global.text_data_en, "SCR_TEXT_2042", "TO SPRÓBUJĘ&JESZCZE RAZ!!!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2047", "... OKEJ.../")
ds_map_add(global.text_data_en, "SCR_TEXT_2048", "CHYBA BĘDĘ MUSIAŁ&ZAAKCEPTOWAĆ&MOJĄ PORAŻKĘ.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2058", "* Witaj w Zaśnieżonej Karczmie^1!&* Przytulny hotelik w Snowdin!/")
ds_map_add(global.text_data_en, "SCR_TEXT_2059", "* Jedna noc kosztuje 80G.& &         Zostań      Opuść\C")
ds_map_add(global.text_data_en, "SCR_TEXT_2062", "* Już spowrotem^1?&* Cóż^1, zostań tak długo^1,&  jak potrzebujesz./")
ds_map_add(global.text_data_en, "SCR_TEXT_2063", "* Co ty na to?& &         Zostań      Opuść\C")
ds_map_add(global.text_data_en, "SCR_TEXT_2065", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2069", "* Co^1?&* Nie^1, nie dostaniesz&  drugiego pokoju!")
ds_map_add(global.text_data_en, "SCR_TEXT_2074", "* Witaj^1!&* Sorki^1, nie ma czasu&  na drzemkę.../")
ds_map_add(global.text_data_en, "SCR_TEXT_2075", "* Zaśnieżona Karczma jest&  zamykana^1, żebyśmy wszyscy&  mogli wyjść na powierzchnię./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2078", "* Oh^1, tutaj jesteś^1.&* Martwiłem się&  o ciebie!/")
ds_map_add(global.text_data_en, "SCR_TEXT_2079", "* Wszystko będzie OK^1,&  rozumiesz?/")
ds_map_add(global.text_data_en, "SCR_TEXT_2080", "* Wszyscy niebawem&  idziemy na świat&  zewnętrzny.../")
ds_map_add(global.text_data_en, "SCR_TEXT_2081", "* Na pewno się znajdzie&  tam miejsce dla ciebie!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2089", "Error./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2092", "* Oto twój numer pokoju^1.&* Odpocznij dobrze!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2098", "* ... Nie masz nawet 80G?/")
ds_map_add(global.text_data_en, "SCR_TEXT_2099", "* Oh^1! Biedactwo^1.&* Mogę tylko wyobrażać sobie&  przez co musiałeś przechodzić./")
ds_map_add(global.text_data_en, "SCR_TEXT_2100", "* Jedno z pomieszczeń&  jest puste^1./")
ds_map_add(global.text_data_en, "SCR_TEXT_2101", "* Możesz się tam przespać&  za darmo^1, okej?/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2109", "* Oto twój numer pokoju^1.&* Odpocznij dobrze!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2116", "* Nie masz wystarczająco&  pieniędzy./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2121", "* Teraz, &  przychodź kiedy&  tylko masz ochotę./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2125", "* (Spojrzeć przez teleskop?)& &         Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_2126", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2130", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_2131", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2139", "* myślę o założeniu&  tego biznesu&  teleskopowego./")
ds_map_add(global.text_data_en, "SCR_TEXT_2140", "* to normalnie 50000G&  aby użyć ten&  teleskop premium.../")
ds_map_add(global.text_data_en, "SCR_TEXT_2141", "* ale..^1.&*\E1 ponieważ się znamy^1, mo-&  żesz go użyć za darmo./")
ds_map_add(global.text_data_en, "SCR_TEXT_2142", "\E2* pasi?/")
ds_map_add(global.text_data_en, "SCR_TEXT_2143", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_2144", "* (Użyć teleskopu?)& &         Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_2148", "* huh^1?&* nie jesteś&  usatysfakcjonowany?/")
ds_map_add(global.text_data_en, "SCR_TEXT_2149", "\E1* nie martw się./")
ds_map_add(global.text_data_en, "SCR_TEXT_2150", "\E2* dam ci pełny&  zwrot pieniędzy./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2152", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2157", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_2158", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2169", "* cóż^1, wracaj&  kiedy tylko&  zechcesz./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2180", "* Dzyn..\E0./")
ds_map_add(global.text_data_en, "SCR_TEXT_2182", "HALO^1!&MÓWI PAPYRUS!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_2183", "\E3JAK DOSTAŁEM TEN&NUMER...?/")
ds_map_add(global.text_data_en, "SCR_TEXT_2184", "\E0PROSTE!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_2185", "\E0PO PROSTU WPISYWA-&ŁEM LOSOWE LICZBY I&TRAFIŁEM NA CIEBIE!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_2186", "NYEH HEH HEH HEH!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_2187", "\E2WIĘC..^1.&CO TAK WOGULE&NA SOBIE NOSISZ...?/")
ds_map_add(global.text_data_en, "SCR_TEXT_2188", "\E3JA..^1.&PYTAM DLA&PRZYJACIELA./")
ds_map_add(global.text_data_en, "SCR_TEXT_2189", "\E0MYŚLAŁA^1, ŻE ONA&WIDZIAŁA JAK NOSISZ&\[1]./")
ds_map_add(global.text_data_en, "SCR_TEXT_2190", "\E3CZY SIĘ ZGADZA^1?&CZY TY NOSISZ&\[1]?/")
ds_map_add(global.text_data_en, "SCR_TEXT_2191", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_2192", "* (Co mu odpowiesz?)& &         Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_2193", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2206", "A WIĘC NOSISZ& \[1].../")
ds_map_add(global.text_data_en, "SCR_TEXT_2207", "ROZUMIEM!!^1!&MRÓG MRÓG!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_2208", "MIŁEGO DNIA!/")
ds_map_add(global.text_data_en, "SCR_TEXT_2209", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_2210", "* Klik.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2215", "A WIĘC NIE NOSISZ&\[1].../")
ds_map_add(global.text_data_en, "SCR_TEXT_2216", "ROZUMIEM!/")
ds_map_add(global.text_data_en, "SCR_TEXT_2217", "JESTEŚ PRZYJACIELEM^1,&WIĘC CI UFAM NA&STO PROCENT./")
ds_map_add(global.text_data_en, "SCR_TEXT_2218", "MIŁEGO DNIA!/")
ds_map_add(global.text_data_en, "SCR_TEXT_2219", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_2220", "* Klik.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2227", "* (Jest pusta blacha do ciasta&  w kuchence.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2231", "\E0MÓJ BRAT ZAWSZE&IDZIE SOBIE NA&JEDZENIE^1. ALE.../")
ds_map_add(global.text_data_en, "SCR_TEXT_2232", "\E3OSTATNIO^1, ON SPRÓ-&BOWAŁ COŚ 'UPIEC'&SAMEMU./")
ds_map_add(global.text_data_en, "SCR_TEXT_2233", "TO BYŁO JAKBY..^1.&KISZ./")
ds_map_add(global.text_data_en, "SCR_TEXT_2234", "ALE WYPEŁNIONY&CUKROWĄ^1, BEZJAJ-&KOWĄ SUBSTANCJĄ./")
ds_map_add(global.text_data_en, "SCR_TEXT_2235", "\E0JAKIE ABSURDALNE!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2240", "* (To książka z sucharami.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_2241", "* (Zajrzeć do środka?)& &         Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_2242", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2248", "* (W środku książki była&  książka o fizyce kwantowej.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_2249", "* (Zaglądasz do środka...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_2250", "* (W książce o fizyce kwantowej&  była kolejna książka z&  sucharami.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_2251", "* (Zaglądasz do środka...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_2252", "* (Jest kolejna książka o&  fizyce kwantowej...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_2253", "* (Postanawiasz przestać.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2257", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_2265", "TO MÓJ POKÓJ^1!/")
ds_map_add(global.text_data_en, "SCR_TEXT_2266", "JEŚLI SKOŃCZYŁEŚ&JUŻ SIĘ SZPĘDAĆ&W DOMU.../")
ds_map_add(global.text_data_en, "SCR_TEXT_2267", "MOŻEMY IŚĆ DO&ŚRODKA I.../")
ds_map_add(global.text_data_en, "SCR_TEXT_2268", '"' + "SPĘDZIĆ CZAS" + '"' + " JAK&GRUPKA BARDZO&CZADOWYCH ZIOMÓW?/")
ds_map_add(global.text_data_en, "SCR_TEXT_2269", "\E3ROBIĆ COKOLWIEK&SIĘ ROBI NA&RANDCE???/")
ds_map_add(global.text_data_en, "SCR_TEXT_2270", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_2271", "* (Wejść do środka?)& &         Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_2272", " %")
ds_map_add(global.text_data_en, "SCR_TEXT_2276", "* (To drzwi do&  pokoju Papurysa.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_2277", "* (Są pokryte&  wieloma oznaczeniami...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_2278", "\TP %")
ds_map_add(global.text_data_en, "SCR_TEXT_2279", "* (DZIEWCZYNOM WSTĘP WZBRONIONY!)/")
ds_map_add(global.text_data_en, "SCR_TEXT_2280", "* (CHŁOPAKOM WSTĘP WZBRONIONY!)/")
ds_map_add(global.text_data_en, "SCR_TEXT_2281", "* (PAPYRUS MOŻE WEJŚĆ.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2286", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_2297", "NIE MA ŻADNYCH&SZKIELETÓW W MOJEJ&GARDEROBIE!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_2298", "\E3NO OPRÓCZ MNIE&CZASAMI./")
ds_map_add(global.text_data_en, "SCR_TEXT_2299", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_2300", "* (Spojrzeć do garderoby?)& &         Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_2301", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2305", "* (Spojrzeć do garderoby?)& &         Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_2306", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2313", "* (Ubrania są schludnie&  powieszone w środku.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2317", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_2322", "TO NORMALNE BYĆ&ZAFASCYNOWANY&MOJĄ MODĄ./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2328", "\E3WIĘC^1, UM.../")
ds_map_add(global.text_data_en, "SCR_TEXT_2329", "\E3JEŚLI JUŻ WSZYSTKO&WIDZIAŁEŚ.../")
ds_map_add(global.text_data_en, "SCR_TEXT_2330", "\E2CHCESZ ZACZĄĆ&SPĘDZAĆ CZAS?/")
ds_map_add(global.text_data_en, "SCR_TEXT_2331", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_2332", "* (Rozpocząć spędzanie czasu?)& &         Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_2333", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2336", "\E2CHCESZ ZACZĄĆ&NASZĄ RANDKĘ?/")
ds_map_add(global.text_data_en, "SCR_TEXT_2337", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_2338", "* (Rozpocząć randkę?)& &         Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_2339", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2348", "\E0OKEJ!!^1!&ZACZYNAMY RANDKĘ!!!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2349", "\E0OKEJ!!^1!&ZACZNIJMY SPĘDZAĆ&CZAS!!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2354", "\E2NIE SPIESZ SIĘ..^1.&POCZEKAM NA CIEBIE./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2359", "* (Ta skrzynka jest oznaczona&  " + '"' + "PAPYRUS" + '"' + ".)/")
ds_map_add(global.text_data_en, "SCR_TEXT_2360", "* (Zajrzeć do środka?)& &         Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_2361", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2366", "* (Jest puste.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2368", "* (Uświadomiłeś sobie^1, że to&  byłoby pewnie nielegalne.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2372", "* co^1?&* nie widziałeś nigdy kogoś&  z dwoma etatami?/")
ds_map_add(global.text_data_en, "SCR_TEXT_2373", "\E1* na szczęście^1, dwa etaty&  oznacza dwa prawnie&  nakazane przerwy./")
ds_map_add(global.text_data_en, "SCR_TEXT_2374", "\E0* idę do grillby's^1.&* chcesz się przyłączyć?&  Jasne       Mam plany \C")
ds_map_add(global.text_data_en, "SCR_TEXT_2375", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2376", "* .../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2380", "\E2* hej^1, wyglądasz  jakbyś&  się naprawdę nudził./")
ds_map_add(global.text_data_en, "SCR_TEXT_2381", "\E0* co ty na to żebym ci&  postawił obiad w&  grillby's?/")
ds_map_add(global.text_data_en, "SCR_TEXT_2382", "\E1* ... kiedy każdego kogo&  wystraszyłeś powraca^1,&  znaczy się./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2389", "* cóż^1, jeśli nalegasz..^1.&* odkleję się od pracy&  na chwilę.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2394", "* OK^1. trzymaj się./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2399", "\E1* whoops^1, uważaj&  gdzie siadasz./")
ds_map_add(global.text_data_en, "SCR_TEXT_2400", "* czasami ludzie&  podkładają pierdziuszki&  na siedzeniach./")
ds_map_add(global.text_data_en, "SCR_TEXT_2401", "\E0* w każdym razie^1,&  zamówmy coś./")
ds_map_add(global.text_data_en, "SCR_TEXT_2402", "* co chcesz...?& &  Frytki      Burger\C")
ds_map_add(global.text_data_en, "SCR_TEXT_2403", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2407", "* ok^1, już zamawiam./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2411", "* hej^1, dobry wybór./")
ds_map_add(global.text_data_en, "SCR_TEXT_2412", "* grillby^1, poprosimy&  o dwa frytki./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2418", "* hej^1, dobry wybór./")
ds_map_add(global.text_data_en, "SCR_TEXT_2419", "* grillby^1, poprosimy&  o dwa burgery./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2426", "* więc^1, co myślisz.../")
ds_map_add(global.text_data_en, "SCR_TEXT_2427", "* o moim bracie?& &  Czadowy     Dzban\C")
ds_map_add(global.text_data_en, "SCR_TEXT_2428", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2434", "* oczywiście że jest&  czadowy./")
ds_map_add(global.text_data_en, "SCR_TEXT_2435", "\E1* ty też byś był gdybyś&  nosił ten outfit&  każdego dnia./")
ds_map_add(global.text_data_en, "SCR_TEXT_2436", "\E0* on tylko go zdejmuje&  kiedy to absolutnie&  konieczne./")
ds_map_add(global.text_data_en, "SCR_TEXT_2437", "* no dobra^1.&* przynajmniej go&  regularnie myje./")
ds_map_add(global.text_data_en, "SCR_TEXT_2438", "\E1* a tym mam na myśli&  że  nosi go pod&  prysznicem./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2442", "* hey^1, pal./")
ds_map_add(global.text_data_en, "SCR_TEXT_2443", "\E1* sarkazm nie jest& śmieszny^1, okej?/")
ds_map_add(global.text_data_en, "SCR_TEXT_2444", "\E0* mój brat to&  prawdziwa gwiazda./")
ds_map_add(global.text_data_en, "SCR_TEXT_2445", "* to on mnie przekonał&  do pracy./")
ds_map_add(global.text_data_en, "SCR_TEXT_2446", "* może to trochę&  dziwne^1, ale&  czasami.../")
ds_map_add(global.text_data_en, "SCR_TEXT_2447", "* ... fajnie mieć kogoś&  kto cię wyzywa od&  bycia leniwym./")
ds_map_add(global.text_data_en, "SCR_TEXT_2448", "\E1* nawet jeśli nie ma&  niczego dalszego&  od prawdy./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2453", "* nadchodzi gruber./")
ds_map_add(global.text_data_en, "SCR_TEXT_2454", "* chcesz trochę ketchupu^1?& &  Tak         Nie    \C")
ds_map_add(global.text_data_en, "SCR_TEXT_2455", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2461", "\E2* bone appetit./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2465", "\E2* więcej dla mnie./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2472", "\W* słyszałeś kiedykolwiek&  o \Ygadającym kwiatku\W?&  Tak         Nie    \C")
ds_map_add(global.text_data_en, "SCR_TEXT_2473", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2477", "\E1* a więc już wiesz./")
ds_map_add(global.text_data_en, "SCR_TEXT_2478", "\E1* w takim razie ci&  opowiem^1./")
ds_map_add(global.text_data_en, "SCR_TEXT_2479", "\W*\E0 \Bkwiatek echa\W./")
ds_map_add(global.text_data_en, "SCR_TEXT_2480", "* są wszędzie tu w&  tym terenie./")
ds_map_add(global.text_data_en, "SCR_TEXT_2481", "* powiedz im coś^1, a&  one to powtórzą&  w kółko.../")
ds_map_add(global.text_data_en, "SCR_TEXT_2482", "* no i co z tym?/")
ds_map_add(global.text_data_en, "SCR_TEXT_2483", "* cóż^1, papyrus mi&  powiedział kiedyś&  coś ciekawego./")
ds_map_add(global.text_data_en, "SCR_TEXT_2484", "* czasami^1, kiedy nikogo&  nie ma w pobliżu.../")
ds_map_add(global.text_data_en, "SCR_TEXT_2485", "* pojawia się kwiatek i&  mu szepcze rzeczy./")
ds_map_add(global.text_data_en, "SCR_TEXT_2486", "* urok..^1.&* rady..^1.&* podziw.../")
ds_map_add(global.text_data_en, "SCR_TEXT_2487", "* ... przepowiednie./")
ds_map_add(global.text_data_en, "SCR_TEXT_2488", "* dziwne^1, huh?/")
ds_map_add(global.text_data_en, "SCR_TEXT_2489", "* ktoś musi używać&  kwiatka echa^1, by&  stroić na nim żarty./")
ds_map_add(global.text_data_en, "SCR_TEXT_2490", "* trzymaj otwarte oczy^1,&  ok?/")
ds_map_add(global.text_data_en, "SCR_TEXT_2491", "* dzięki./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2495", "\E1* oh^1, tak wogule.../")
ds_map_add(global.text_data_en, "SCR_TEXT_2496", "\E0* nie mam kasy^1.&* zapłacisz za rachunek?/")
ds_map_add(global.text_data_en, "SCR_TEXT_2497", "* to tylko 10000G.& &  Tak         Nie    \C")
ds_map_add(global.text_data_en, "SCR_TEXT_2498", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2502", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_2580", "* (Wziąć parasolkę?)& &         Weź jedną   Nie bierz\C")
ds_map_add(global.text_data_en, "SCR_TEXT_2581", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2585", "* (Zwrócić parasolkę?)& &         Zwróć       Nie zwracaj\C")
ds_map_add(global.text_data_en, "SCR_TEXT_2586", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2597", "* (Wziąłeś parasolkę.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2608", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_2615", "* (Zwróciłeś parasolkę.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2626", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_2634", "* (To statuetka^1.)&* (Fundament u podłoża jego nóg&  wydaje się wyschnięty.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2637", "* (Postawić parasolkę na&  statuetce?)&         Tak         Lol nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_2638", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2642", "* (Muzyka kontynuuje^1, i&  nie zatrzymuje się.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2651", "* (Położyłeś parasolkę&  nad statuetką.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_2652", "* (W środku statuetki^1, stara&  pozytywka zaczyna grać...)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2667", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_2674", "* (To zardzewiała stara&  lodówka.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_2675", "* (Zajrzeć do środka?)& &         Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_2676", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2682", "* (Otwierasz lodówkę.^1)&* (Powietrze wypełnia się&  zapachem zgnilizny.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_2683", "* (Całe jedzenie w środku się&  zepsuło dawno temu.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2686", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_2692", "* error/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2694", "* (Chłodnik jest pusty.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2698", "* (Wziąć kosmiczne jedzenie z&  chłodnicy?)&         Tak         Nie \C")
ds_map_add(global.text_data_en, "SCR_TEXT_2699", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2704", "* (To chłodnica^1.&* Nie ma żadnej marki^1, i&  nie ma oznak używania...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_2705", "* (W środku jest kilka&  mrożono-wysuszonych&  kosmicznych batoników.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_2706", "* (Wziąć jedno?)& &         Tak         Nie \C")
ds_map_add(global.text_data_en, "SCR_TEXT_2707", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2726", "* (Dostałeś Jedzenie&  Astronautów.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2728", "* (Nosisz zbyt wiele.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2732", "* %%")
ds_map_add(global.text_data_en, "SCR_TEXT_2739", "* (Wygląda na zwyczajny&  manekin treningowy.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_2740", "* (Chcesz go podbić?)& &         Tak         Nie \C")
ds_map_add(global.text_data_en, "SCR_TEXT_2741", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2744", "* (Już masz dość manekina.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2752", "* (Dotykasz manekina pięścią.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_2753", "* (Czujesz się źle.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2757", "* (Uderzasz manekina lekko.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_2758", "* (Nie czujesz^1, żebyś się&  czegokolwiek nauczył.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2762", "* (Zliściowałeś manekina.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_2763", "* (Kogo to obchodzi?)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2767", "* (Walisz manekina z&  całej siły.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_2768", "* (Dobre uczucie.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2774", "* (Gapicie się na swoje&  oczy przez moment...)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2837", "* (Ta płyta CD się nazywa&  " + '"' + "Spooktunes." + '"' + ")/")
ds_map_add(global.text_data_en, "SCR_TEXT_2838", "* (Włączyć?)& &         Włącz      Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_2839", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2842", "* (Ta płyta CD się nazywa&  " + '"' + "Spooktunes." + '"' + ")/")
ds_map_add(global.text_data_en, "SCR_TEXT_2843", "* (Ta płyta CD jest odtwarzana.)&* (Wyłączyć?)&         Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_2844", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2853", "* (Odtwarzasz płytę.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2859", "* (Spooktunes są przestarzałe.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2867", "* (Płyta przestaje grać.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2873", "* %%")
ds_map_add(global.text_data_en, "SCR_TEXT_2881", "* (Ta płyta CD się nazywa&  " + '"' + "Spookwave." + '"' + ")/")
ds_map_add(global.text_data_en, "SCR_TEXT_2882", "* (Włączyć?)& &         Włącz      Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_2883", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2886", "* (Ta płyta CD się nazywa&  " + '"' + "Spookwave." + '"' + ")/")
ds_map_add(global.text_data_en, "SCR_TEXT_2887", "* (Ta płyta CD jest odtwarzana.)&* (Wyłączyć?)&         Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_2888", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2897", "* (Odtwarzasz płytę.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2903", "* %%")
ds_map_add(global.text_data_en, "SCR_TEXT_2911", "* (Płyta przestaje grać.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2917", "* %%")
ds_map_add(global.text_data_en, "SCR_TEXT_2924", "* (Ta płyta CD się nazywa&  " + '"' + "Ghouliday Music." + '"' + ")/")
ds_map_add(global.text_data_en, "SCR_TEXT_2925", "* (Włączyć?)& &         Włącz      Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_2926", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2929", "* (Ta płyta CD się nazywa&  " + '"' + "Ghouliday Music." + '"' + ")/")
ds_map_add(global.text_data_en, "SCR_TEXT_2930", "* (Ta płyta CD jest odtwarzana.)&* (Wyłączyć?)&         Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_2931", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2940", "* (Odtwarzasz płytę.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2946", "* %%")
ds_map_add(global.text_data_en, "SCR_TEXT_2954", "* (Płyta przestaje grać.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2960", "* %%")
ds_map_add(global.text_data_en, "SCR_TEXT_2968", "* (Spojrzeć do lodówki?)& &         Otwórz      Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_2969", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_2977", "* (Jest w środku pojedyncza&  kanapka.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2983", "* (Jest puste.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2988", "%%")
ds_map_add(global.text_data_en, "SCR_TEXT_2993", "* to jest duchowa kanapka.../")
ds_map_add(global.text_data_en, "SCR_TEXT_2994", "* chcesz ją spróbować...& &         Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_2995", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_3001", "* (Spróbowałeś wgryźć się w&  duchową kanapkę.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_3002", "* (Przechodzisz prosto&  przez nią...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_3003", "* oh.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3004", "* nieważne.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3008", "* oh.....................&  ....................&  ................./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3014", "* po zjedzeniu lubię się&  kłaść na podłogę i&  czuć jak śmieć.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3015", "* to rodzinna tradycja.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3016", "* czy chcesz..^1.&* ... do mnie przyłączyć...&         Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_3017", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_3023", "* okej..^1.&* podążaj moim śladem.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3028", "* oh.....................&  ....................&  ................./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3034", "* chcesz zagrać w grę^1?&* nazywa się thundersnail./")
ds_map_add(global.text_data_en, "SCR_TEXT_3035", "* ślimaki się ścigają^1, i&  jeśli żółty ślimak wygra^1,&  ty wygrywasz./")
ds_map_add(global.text_data_en, "SCR_TEXT_3036", "* to 10G za rundę.& &         Zagraj      Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_3037", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_3045", "* um..^1.&* nie masz wogule kasy?/")
ds_map_add(global.text_data_en, "SCR_TEXT_3046", "* n-nie^1, i tak możesz zagrać^1,&  nie przejmuj się tym.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3047", "* okej..^1.&* naciskaj \*Z wielokrotnie&  aby kibicować ślimakowi./")
ds_map_add(global.text_data_en, "SCR_TEXT_3048", "* gotowy?/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3052", "* um..^1. to mniej niż 10G./")
ds_map_add(global.text_data_en, "SCR_TEXT_3053", "* ale jako że jesteś moim jedynym&  prawdziwym klientem^1, chyba po&  prostu wezmę to co masz.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3054", "* okej..^1.&* naciskaj \*Z wielokrotnie&  aby kibicować ślimakowi./")
ds_map_add(global.text_data_en, "SCR_TEXT_3055", "* gotowy?/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3061", "* okej..^1.&* naciskaj \*Z wielokrotnie&  aby kibicować ślimakowi./")
ds_map_add(global.text_data_en, "SCR_TEXT_3062", "* gotowy?/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3068", "* oh.........../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3073", "* .../")
ds_map_add(global.text_data_en, "SCR_TEXT_3074", "* Siedem./")
ds_map_add(global.text_data_en, "SCR_TEXT_3075", "* Siedem ludzkich dusz./")
ds_map_add(global.text_data_en, "SCR_TEXT_3076", "* Z siłą siedmiu ludzkich&  dusz^1, nasz król.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3077", "\W* \YKról \RASGORE \YDreemurr\W.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3078", "* ... stanie się bogiem./")
ds_map_add(global.text_data_en, "SCR_TEXT_3079", "\W* Z tą mocą^1, \RASGORE\W &  w końcu będzie mógł&  roztrzaskać barierę./")
ds_map_add(global.text_data_en, "SCR_TEXT_3080", "* On w końcu odbierze&  spowrotem powierzchnię&  od ludzkości.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3081", "* I da im spowrotem&  ból i cierpienie&  które my odnieśliśmy./")
ds_map_add(global.text_data_en, "SCR_TEXT_3082", "* .../")
ds_map_add(global.text_data_en, "SCR_TEXT_3083", "* Rozumiesz^1, człowieku?/")
ds_map_add(global.text_data_en, "SCR_TEXT_3084", "* Oto twoja jedyna szansa&  na odkupienie./")
ds_map_add(global.text_data_en, "SCR_TEXT_3085", "* Oddaj swoją duszę.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3086", "* Albo ją wyrwę z&  twojego ciała./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3104", "* Jo^1, Wiem, że nie powinienem&  tutaj być^1, ale.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3105", "* Chcę cię o coś spytać./")
ds_map_add(global.text_data_en, "SCR_TEXT_3106", "* .../")
ds_map_add(global.text_data_en, "SCR_TEXT_3107", "* Ziom^1, jeszcze nigdy nie&  musiałem nikogo o to pytać.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3108", "* Um.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3109", "* Jo..^1. Jesteś człowiekiem^1,&  co nie?&* Haha./")
ds_map_add(global.text_data_en, "SCR_TEXT_3110", "* Bro^1! Wiedziałem!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3111", "* ... cóż^1, teraz to wiem^1,&  w sensie.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3112", "* Undyne mi powiedziała^1, um^1,&  " + '"' + "trzymaj się z daleka od&  tego człowieka." + '"' + "/")
ds_map_add(global.text_data_en, "SCR_TEXT_3113", "* Więc^1, jakby^1, ummm.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3114", "* To chyba znaczy, że jesteśmy&  wrogami czy coś./")
ds_map_add(global.text_data_en, "SCR_TEXT_3115", "* Ale nie jestem w tym za&  bardzo dobry^1, haha./")
ds_map_add(global.text_data_en, "SCR_TEXT_3116", "* Jo^1, powiedz coś niemiłego&  żebym mógł cię nienawidzić?/")
ds_map_add(global.text_data_en, "SCR_TEXT_3117", "* Proszę? & &         Tak         Nie \C")
ds_map_add(global.text_data_en, "SCR_TEXT_3118", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_3124", "* Huh...?/")
ds_map_add(global.text_data_en, "SCR_TEXT_3125", "* Jo^1, to według ciebie jest&  czymś niemiłym?/")
ds_map_add(global.text_data_en, "SCR_TEXT_3126", "* Moja siostra mi to mówi&  CAŁY CZAS!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3127", "* Chyba ja to muszę zrobić^1, haha./")
ds_map_add(global.text_data_en, "SCR_TEXT_3128", "* Jo^1, ja..^1. Nienawidzę&  twojej odwagi./")
ds_map_add(global.text_data_en, "SCR_TEXT_3129", "* .../")
ds_map_add(global.text_data_en, "SCR_TEXT_3130", "* Bro^1, j..^1. jestem takim&  kretynem./")
ds_map_add(global.text_data_en, "SCR_TEXT_3131", "* Ja..^1. Pójdę teraz&  do domu./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3135", "* Jo^1, serio^1?&* Więc ja muszę to zrobić?/")
ds_map_add(global.text_data_en, "SCR_TEXT_3136", "* No to lecimy.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3137", "* Jo^1, ja..^1. Nienawidzę&  twojej odwagi./")
ds_map_add(global.text_data_en, "SCR_TEXT_3138", "* .../")
ds_map_add(global.text_data_en, "SCR_TEXT_3139", "* Bro^1, j..^1. jestem takim&  kretynem./")
ds_map_add(global.text_data_en, "SCR_TEXT_3140", "* Ja..^1. Pójdę teraz&  do domu./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3148", "* (To stacyjka z wodą.)&* (Nalać kubek wody?)&         Tak         Nie \C")
ds_map_add(global.text_data_en, "SCR_TEXT_3149", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_3153", "* (Nie ma już więcej wody&  w baniaku.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3155", "* (Sadystycznie^1, wylałeś&  całą wodę tuż przed&  oczami Undyne.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3163", "* (Bierzesz kubek wody.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3171", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_3177", "* (Pozbyć się wody?)& &         Tak         Nie \C")
ds_map_add(global.text_data_en, "SCR_TEXT_3178", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_3184", "* (Wylewasz wodę na ziemię&  obok podajnika.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3196", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_3201", "* A rousing error./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3205", "* (Dać wodę Undyne?)& &         Tak         Nie \C")
ds_map_add(global.text_data_en, "SCR_TEXT_3206", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_3210", "* (Wygląda na wyschniętą...)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3215", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_3238", "* Dzyn..\E0./")
ds_map_add(global.text_data_en, "SCR_TEXT_3240", "HALO^1!&MÓWI PAPYRUS!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3241", "PAMIĘTASZ KIEDY&SPYTAŁEM CIĘ O&CIUCHY?/")
ds_map_add(global.text_data_en, "SCR_TEXT_3242", "\E3CÓŻ^1, TEN PRZYJA-&CIEL KTÓRY CHCIAŁ&WIEDZIEĆ.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3243", "\E0JEJ OPINIA NA TWÓJ&TEMAT JEST&BARDZO.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3244", "\E3MORDERCZA./")
ds_map_add(global.text_data_en, "SCR_TEXT_3245", "\E0ERROR!!^1!&SEE YOU LATER!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3250", "\E0ALE PEWNIE JUŻ&O TYM WIEDZIAŁEŚ!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3251", "\E3I PONIEWAŻ TO&WIEDZIAŁEŚ.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3252", "\E0POWIEDZIAŁEM JEJ&TO CO TY MI POWIE-&DZIAŁEŚ CO NOSISZ!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3253", "MIANOWICIE&\[1]!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3254", "PONIEWAŻ&WIEDZIAŁEM^1,&OCZYWIŚCIE.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3255", "\E3PO TAKIM&PODEJRZANYM&PYTANIU.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3256", "\E0OD RAZU BYŚ&ZMIENIŁ SWOJE&UBRANIE!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3257", "JESTEŚ TAKIM&MĄDRYM CIASTKIEM!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3258", "TYM SPOSOBEM JES-&TEŚ BEZPIECZNY A&JA NIE SKŁAMAŁEM!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3259", "NIE MA NIGDZIE&ZDRADY!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3260", "BYCIE PRZYJACIELEM&Z WSZYSTKIMI JEST&TAKIE ŁATWE!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3261", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_3262", "* Klik.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3268", "\E0CÓŻ^1, NIE PRZEJMUJ&SIĘ DROGI&CZŁOWIEKU!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3269", "PAPYRUS BY CIĘ&NNIGDY NIE&ZDRADZIŁ!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3270", "\E3NIE JESTEM&OKROPNĄ OSOBĄ./")
ds_map_add(global.text_data_en, "SCR_TEXT_3271", "\E0JA CELUJĘ NA&KOMFORTOWĄ I&UPRZEJMĄ./")
ds_map_add(global.text_data_en, "SCR_TEXT_3272", "PAPYRUS!&ON PACHNIE JAK&KSIĘŻYC./")
ds_map_add(global.text_data_en, "SCR_TEXT_3273", "WIĘC, DZIĘKI MOJEJ&NIEDZIEDZICZONEJ&DOBROCI.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3274", "POWIEDZIAŁEM JEJ^1, ŻE&NIE MASZ NA SOBIE&\[1]!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3275", "\E3NAWET JEŚLI MI&POWIEDZIAŁEŚ ŻE&NOSISZ!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3276", "ZAMIAST TEGO^1,&ZMYŚLIŁEM!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3277", "POWIEDZIAŁEM JEJ^1,&ŻE NOSISZ.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3278", "\E0\[2]./")
ds_map_add(global.text_data_en, "SCR_TEXT_3279", "\E3TO BYŁO TRUDNE&POWIEDZIEĆ TAKĄ&NIEPRAWDĘ./")
ds_map_add(global.text_data_en, "SCR_TEXT_3280", "WIEM^1, ŻE NIGDY PRZE-&NIGDY NIE NOSIŁBYŚ&\[2]./")
ds_map_add(global.text_data_en, "SCR_TEXT_3281", "\E0ALE TWOJE BEZPIE-&CZEŃSTWO JEST&WAŻNIEJSZE./")
ds_map_add(global.text_data_en, "SCR_TEXT_3282", "\E3KURCZĘ!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3283", "JA PO PROSTU CHCĘ&BYĆ WSZYSTKICH&PRZYJACIELEM.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3284", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_3285", "* Klik.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3291", "\E0CÓŻ^1, NIE PRZEJMUJ&SIĘ DROGI&CZŁOWIEKU!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3292", "\E3PAPYRUS BY CIĘ&NIGDY NIE ZDRADZIŁ!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3293", "\W\E0POWIEDZIAŁEŚ^1, ŻE\Y &NIE NOSISZ TERAZ&\[1]\W./")
ds_map_add(global.text_data_en, "SCR_TEXT_3294", "\E3WIĘC OCZYWIŚCIE&POWIEDZIAŁEM JEJ.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3295", "\E0ŻE RZECZYWIŚCIE&WTEDY NOSIŁEŚ& \[1]!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3296", "\E3TO BYŁO TRUDNE&POWIEDZIEĆ TAKĄ&NIEPRAWDĘ./")
ds_map_add(global.text_data_en, "SCR_TEXT_3297", "ALE JAKO ŻE NIE&NOSISZ TERAZ&\[1]./")
ds_map_add(global.text_data_en, "SCR_TEXT_3298", "\E0ONA Z PEWNOŚCIĄ&CIĘ NIE ZAATAKUJE!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3299", "TERAZ JESTEŚ&BEZPIECZNY./")
ds_map_add(global.text_data_en, "SCR_TEXT_3300", "\E2WOWIE..^1.&TO JEST CIĘŻKIE./")
ds_map_add(global.text_data_en, "SCR_TEXT_3301", "PO PROSTU CHCĘ&BYĆ KAŻDEGO&PRZYJACIELEM!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3302", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_3303", "* Klik.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3309", "\E0ALE PEWNIE JUŻ&O TYM WIEDZIAŁEŚ!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3310", "\E3I PONIEWAŻ TO&WIEDZIAŁEŚ.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3311", "\E0WIEDZIAŁEM^1, ŻE&KIEDY POWIEDZIAŁEŚ:/")
ds_map_add(global.text_data_en, "SCR_TEXT_3312", "\E3" + '"' + "NIE NOSZĘ NA SOBIE&\[1]." + '"' + "/")
ds_map_add(global.text_data_en, "SCR_TEXT_3313", "\E0TO BYŁO TAK&NAPRAWDĘ&SZYFR!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3314", "\E3TAK NAPRAWDĘ&MIAŁEŚ NA MYŚLI.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3315", "\E0" + '"' + "TAK NAPRAWDĘ&NOSZĘ NA SOBIE&\[1]!" + '"' + "/")
ds_map_add(global.text_data_en, "SCR_TEXT_3316", "PRÓBOWAŁEŚ&SIEBIE&OCHRONIĆ.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3317", "I JEDNOCZEŚNIE&SPRAWIŁEŚ^1, ŻE NIE&MUSIAŁEM SKŁAMAĆ!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3318", "ZAŁAPAŁEM TO&I PODĄŻAŁEM ZA&TWOIM PLANEM./")
ds_map_add(global.text_data_en, "SCR_TEXT_3319", "POWIEDZIAŁEM JEJ^1, ŻE&NIE MASZ NA SOBIE&\[1]!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3320", "A NAWET WZIĄŁEM&TO O STOPIEŃ&WYŻEJ!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3321", "\E3POWIEDZIAŁEM JEJ^1,&ŻE TY PEWNIE&NOSIŁEŚ.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3322", "\E0\[2]!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3323", "\E3OCZYWIŚCIE^1, NIGDY&BYŚ TEGO NIE&ZAŁOŻYŁ./")
ds_map_add(global.text_data_en, "SCR_TEXT_3324", "\E0ALE O TO CHODZI!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3325", "TERAZ ONA CIĘ&NIE ROZPOZNA!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3326", "I NIE MUSIAŁEM&ZDRADZIĆ ŻADNEGO&Z WAS!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3327", "JAKO ŻE POWIE-&DZIAŁEM JEJ TO CO&TY MI POWIEDZIAŁEŚ!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3328", "WOWIE^1!&JESTEŚ TAKIM&MĄDRYM CIASTKIEM!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3329", "NAPRAWDĘ MOGĘ&BYĆ PRZYACIÓŁMI&ZE WSZYSTKIMI!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3330", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_3331", "* Klik.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3337", "* Dzyn..\E0./")
ds_map_add(global.text_data_en, "SCR_TEXT_3339", "HEJ^1!&CO TAM!?/")
ds_map_add(global.text_data_en, "SCR_TEXT_3340", "MYŚLAŁEM&SOBIE.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3341", "TY^1, JA^1, I UNDYNE&MUSIMY WSZYSCY&SIĘ KIEDYŚ SPOTKAĆ!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3342", "MYŚLĘ^1, ŻE&BYLIBYŚMY&SUPER ZIOMKAMI!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3343", "SPOTKAJMY SIĘ U&JEJ DOMU PÓŹNIEJ!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3344", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_3345", "* Klik.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3348", "PO TYM JAK ZE&MNĄ SIĘ SPOTKASZ.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3349", "SPOTKAJMY SIĘ&U NIEJ W DOMU!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3350", "MYŚLĘ^1, ŻE&BYLIBYŚMY&SUPER ZIOMKAMI!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3351", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_3352", "* Klik.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3393", "* (To książka oznaczona tytułem&  " + '"' + "Historia Potworów część 7" + '"' + ".)&         Czytaj      Hell nah\C")
ds_map_add(global.text_data_en, "SCR_TEXT_3394", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_3398", "* Kiedy człowiek umiera^1,&  jego dusza pozostaje&  stabilna poza ciałem./")
ds_map_add(global.text_data_en, "SCR_TEXT_3399", "* Podczas kiedy dusza potwora&  znika niemalże natychmiastowo&  po śmierci./")
ds_map_add(global.text_data_en, "SCR_TEXT_3400", "* To pozwala potworom&  pochłaniać ludzkie dusze.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3401", "* Chociaż jest to niesamowicie&  trudne dla człowieka by&  wchłonić duszę potwora./")
ds_map_add(global.text_data_en, "SCR_TEXT_3402", "* Dlatego się nas obawiali./")
ds_map_add(global.text_data_en, "SCR_TEXT_3403", "* Chociaż potwory są słabe^1,&  to z wystarczającą ilością&  ludzkich duszy.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3404", "* Mogliby z łatwością&  całkowicie zniszczyć&  ludzką rasę./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3407", "* (Postanawiasz nie czytać.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3413", "* (To książka oznaczona tytułem&  " + '"' + "Historia Potworów część 8" + '"' + ".)&         Czytaj      Hell nah\C")
ds_map_add(global.text_data_en, "SCR_TEXT_3414", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_3418", "* Natomiast istnieje jeden&  wyjątek powyższych praw:/")
ds_map_add(global.text_data_en, "SCR_TEXT_3419", "* Specyficzny typ potwora^1,&  nazywany " + '"' + "bossowym" + '"' + " potworem./")
ds_map_add(global.text_data_en, "SCR_TEXT_3420", "* Ze względu na swój cykl życia^1,&  posiadają niesamowicie silną&  duszę jak na potwora./")
ds_map_add(global.text_data_en, "SCR_TEXT_3421", "* Ta dusza może pozostać&  stabilna po śmierci^1,&  choćby na krótką chwilę./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3424", "* (Postanawiasz nie czytać.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3429", "* (Wszystkie te książki mają&  tytuł " + '"' + "Historia Ludzi" + '"' + ".)&         Czytaj      Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_3430", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_3434", "* (Zaglądasz do książki.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_3435", "* (To komiks gigantycznego&  robota walczącego z piękną&  kosmitą-księżniczką.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_3436", "* (To nie wygląda dla ciebie&  za bardzo na dokładne...)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3441", "* (Postanawiasz nie czytać.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3446", "* (Wszystkie te książki mają&  tytuł " + '"' + "Historia Ludzi" + '"' + ".)&         Czytaj      Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_3447", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_3451", "* (Zaglądasz do książki.)&* (To tylko komiks.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_3452", "* (Dwóch skąpo-ubranych kucharzy&  rzucają w siebie kalorycznymi&  naleśnikami.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_3453", "* (To nie wygląda dla ciebie&  za bardzo na dokładne...)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3458", "* (Postanawiasz nie czytać.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3463", "* (Wszystkie te książki mają&  tytuł " + '"' + "Historia Ludzi" + '"' + ".)&         Czytaj      Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_3464", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_3469", "* (Zaglądasz do książki.)&* (To tylko komiks.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_3470", "* (Brzydki android biegnie do&  szkoły z tostem w ustach.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_3471", "* (Wygląda na to, że&  jest już późno.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_3472", "* (To nie wygląda dla ciebie&  za bardzo na dokładne...)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3477", "* (Postanawiasz nie czytać.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3482", "* (Stoi tu stare pianino.^1)&* (Zagrać na nim?)&         Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_3483", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_3487", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_3488", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_3495", "Widzisz to serce^1? &To jest twoja DUSZA^1,&sama kulminacja&twojego istnienia!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3496", "Twoja dusza zaczyna&słabo^1, ale możesz&ją umocnić, jeśli&zyskasz dużo LV./")
ds_map_add(global.text_data_en, "SCR_TEXT_3497", "Czym jest LV^1?&Cóż^1, LOVE^1,&oczywiście!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3498", "Chcesz trochę&miłości, prawda?/")
ds_map_add(global.text_data_en, "SCR_TEXT_3499", "Nie przejmuj się,&podzielę się&z tobą!/%")
ds_map_add(global.text_data_en, "SCR_TEXT_3503", "U nas na dole^1,&LOVE jest&dzielona poprzez..^1./")
ds_map_add(global.text_data_en, "SCR_TEXT_3504", "Małe białe..^2.\E1 &" + '"' + "przyjacielskie&pigułki." + '"' + "/")
ds_map_add(global.text_data_en, "SCR_TEXT_3505", "\E2Gotowy\E0?/%")
ds_map_add(global.text_data_en, "SCR_TEXT_3509", "Ruszaj się^1!&Zgarnij jak najwięcej&ile możesz^2!%%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3510", "%%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3514", "Ty idioto./")
ds_map_add(global.text_data_en, "SCR_TEXT_3515", "W tym świecie^1,&panuje jedna zasada.&Zabić albo&BYĆ ZABITYM./")
ds_map_add(global.text_data_en, "SCR_TEXT_3516", "Czemu KTOKOLWIEK by&porzucił taką okazję&jak tą!?/%")
ds_map_add(global.text_data_en, "SCR_TEXT_3520", "Umieraj./%")
ds_map_add(global.text_data_en, "SCR_TEXT_3524", "Hej koleżko^1,&ominąłeś je./")
ds_map_add(global.text_data_en, "SCR_TEXT_3525", "Spróbujmy jeszcze&raz^1, okej?/%")
ds_map_add(global.text_data_en, "SCR_TEXT_3528", "Czy to jest&jakiś żart^2?^2?&WEJDŹ^2. W^2. TE^2.&NABOJE!!!")
ds_map_add(global.text_data_en, "SCR_TEXT_3531", "Wiesz co się&tu dzieje^1,&co nie?/")
ds_map_add(global.text_data_en, "SCR_TEXT_3532", "Po prostu&chciałeś zobaczyć,&jak cierpię./%")
ds_map_add(global.text_data_en, "SCR_TEXT_3535", "\E1Co za okropne&stworzenie^1,&torturujące takie&niewinne dziecię.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3536", "\E2Ah, nie obawiaj się^1,&słońce./")
ds_map_add(global.text_data_en, "SCR_TEXT_3537", "\XNazywam się \BTORIEL\X,&jestem opiekunką&\RRUIN\X./")
ds_map_add(global.text_data_en, "SCR_TEXT_3538", "Przechodzę przez to&miejsce codziennie,&by patrzeć, czy ktoś&nowy nie wpadł./")
ds_map_add(global.text_data_en, "SCR_TEXT_3539", "Jesteś pierwszym&człowiekiem, który&tu wpadł od&bardzo dawna./")
ds_map_add(global.text_data_en, "SCR_TEXT_3540", "Zrobię wszystko w mojej&mocy, by zapewnić ci&bezpieczeństwo podczas&twojego pobytu tutaj./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3541", "\E2Chodź^2!&Pokieruję cię przez&lochy./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3542", "%%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3548", "* Trzy G za podwózkę.& &         Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_3549", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_3553", "* Papatki./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3554", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_3559", "* Wskakuj!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3564", "* (To przycisk.)&                     Nie&         Naciśnij    naciskaj\C")
ds_map_add(global.text_data_en, "SCR_TEXT_3565", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_3571", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_3584", "* (Lasery zostały&  zdezaktywowane.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3591", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_3604", "* (Lasery zostały&  zreaktywowane.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3612", "* Dzyn.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3613", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "SCR_TEXT_3614", "\E1* Um.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3615", "\E0* Zauważyłam^1, że jesteś&  nieco cicho.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3616", "\W*\E8 Czy m-martwisz się&  spotkaniem \RASGORE\W'a...?/")
ds_map_add(global.text_data_en, "SCR_TEXT_3617", "\E2* .../")
ds_map_add(global.text_data_en, "SCR_TEXT_3618", "\E0* W-well^1, don't worry^1,&  okay?/")
ds_map_add(global.text_data_en, "SCR_TEXT_3619", "\E7* Th-the king is a&  really nice guy.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3620", "\E0* I'm sure you can&  talk to him^1, and.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3621", "* W-with your human&  soul^1, you can pass&  through the barrier!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3622", "* S-so no worrying^1, OK^1?&* J-just forget about it&  and smile./")
ds_map_add(global.text_data_en, "SCR_TEXT_3623", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_3624", "* Klik.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3630", "* hey buddy^1, what's up^1?&* wanna buy a hot dog?/")
ds_map_add(global.text_data_en, "SCR_TEXT_3631", "* it's only 30G.& &  Yes         No \C")
ds_map_add(global.text_data_en, "SCR_TEXT_3632", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_3638", "* here^1.&* have fun./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3641", "* here's another hot&  dog./")
ds_map_add(global.text_data_en, "SCR_TEXT_3642", "* it's on the house^1.&* well^1, no^1.&* it's on you./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3653", "* sorry^1, thirty is&  the limit on&  head-dogs./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3656", "\TS*^1 \Tsi'll be 'frank' with&  you./")
ds_map_add(global.text_data_en, "SCR_TEXT_3657", "* as much as i like&  putting hot dogs&  on your head.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3658", "* thirty is just&  an excessive number./")
ds_map_add(global.text_data_en, "SCR_TEXT_3659", "* twenty-nine^1, now&  that's fine^1, but&  thirty.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3660", "* does it look like&  my arms can reach&  that high?/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3687", "* thanks, kid^1.&* here's your hot dog./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3690", "* thanks, kid^1.&* here's your 'dog./")
ds_map_add(global.text_data_en, "SCR_TEXT_3691", "* yeah^1. 'dog^1.&* apostrophe-dog^1.&* it's short for hot-dog./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3695", "* another h'dog^1?&* here you go.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3696", "* whoops^1, i'm actually&  out of hot dogs./")
ds_map_add(global.text_data_en, "SCR_TEXT_3697", "* here^1, you can have&  a hot cat instead./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3701", "* another dog^1, coming&  right up.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3702", "* ... you really like&  hot animals^1, don't&  you?/")
ds_map_add(global.text_data_en, "SCR_TEXT_3703", "* hey^1, i'm not judging./")
ds_map_add(global.text_data_en, "SCR_TEXT_3704", "* i'd be out of a job&  without folks like you./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3708", "* cool^1.&* here's that ''dog./")
ds_map_add(global.text_data_en, "SCR_TEXT_3709", "* apostrophe-apostrophe&  dog./")
ds_map_add(global.text_data_en, "SCR_TEXT_3710", "* it's short for&  apostrophe-dog./")
ds_map_add(global.text_data_en, "SCR_TEXT_3711", "* which is^1, in turn^1,&  short for.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3715", "* another one^1?&* okay./")
ds_map_add(global.text_data_en, "SCR_TEXT_3716", "* careful^1.&* if you eat&  too many hot dogs.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3717", "* you'll probably get&  huge like me./")
ds_map_add(global.text_data_en, "SCR_TEXT_3718", "* huge as in super-&  popular^1, i mean./")
ds_map_add(global.text_data_en, "SCR_TEXT_3719", "* i'm practically&  a hot-dog tycoon now./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3725", "* whoops^1, you don't have&  enough cash./")
ds_map_add(global.text_data_en, "SCR_TEXT_3726", "* you should get a job^1.&* i've heard being a&  sentry pays well./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3729", "* you're holding too much^1.&* ... guess i'll just put&  it on your head./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3738", "* yeah^1, you've gotta&  save your money for&  college and spiders./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3743", "* Dzyn.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3744", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "SCR_TEXT_3745", "* L-looks like you&  beat him!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3746", "\E0* Y-you did a really&  great job out there./")
ds_map_add(global.text_data_en, "SCR_TEXT_3747", " &  All thanks&  to you      ... \C")
ds_map_add(global.text_data_en, "SCR_TEXT_3748", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_3754", "\E3* What^1?&* Oh no^1, I mean.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3755", "\E4* You were the one&  doing everything cool!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3756", "\E0* I just wrote some&  silly programs for&  your phone./")
ds_map_add(global.text_data_en, "SCR_TEXT_3760", "\E1* .../")
ds_map_add(global.text_data_en, "SCR_TEXT_3761", "\E2* .../")
ds_map_add(global.text_data_en, "SCR_TEXT_3762", "\E1* .../")
ds_map_add(global.text_data_en, "SCR_TEXT_3765", "\E2* .../")
ds_map_add(global.text_data_en, "SCR_TEXT_3766", "\E4* ... umm^1, h-hey^1, this&  might sound strange^1,&  but.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3767", "\E6* ... c-can I tell&  you something?/")
ds_map_add(global.text_data_en, "SCR_TEXT_3768", "\E9* .../")
ds_map_add(global.text_data_en, "SCR_TEXT_3769", "\E4* B-before I met you^1,&  I d-didn't really.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3770", "\E9* I didn't really&  like myself very&  much./")
ds_map_add(global.text_data_en, "SCR_TEXT_3771", "* For a long time^1,&  I f-felt like a&   total screw-up./")
ds_map_add(global.text_data_en, "SCR_TEXT_3772", "\E9* L-like I couldn't&  do a-anything&  w-without.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3773", "\E9* W-without ending up&  letting everyone&  down./")
ds_map_add(global.text_data_en, "SCR_TEXT_3774", "\E3* B-but...!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3775", "\E4* Guiding you has&  made me feel.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3776", "\E9* A lot better about&  myself./")
ds_map_add(global.text_data_en, "SCR_TEXT_3777", "\E0* So... thanks for&  letting me help&  you./")
ds_map_add(global.text_data_en, "SCR_TEXT_3778", "\E9* .../")
ds_map_add(global.text_data_en, "SCR_TEXT_3779", "\E4* Uhhh^1, anyway^1, we're&  almost to the CORE./")
ds_map_add(global.text_data_en, "SCR_TEXT_3780", "\E0* It's just past&  MTT Resort./")
ds_map_add(global.text_data_en, "SCR_TEXT_3781", "\E6* Come on^1!&* Let's finish this!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3782", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_3783", "* Klik.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3787", "\E0EUREKA!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3788", "ROZWIĄZAŁEM&ZAGADKĘ!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3789", "\E3ALE WYDAJESZ SIĘ&JAKBYŚ SIĘ DOBRZE&BAWIŁ..^1./")
ds_map_add(global.text_data_en, "SCR_TEXT_3790", "\E0CZY TY ABSOLUTNIE^1,&DAPSOLUTNIE CHCESZ&ZNAĆ ROZWIĄZANIE???/")
ds_map_add(global.text_data_en, "SCR_TEXT_3791", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_3792", "* (Chcesz absolutnie^1, dapsolutnie&  znać rozwiązanie?)&         Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_3793", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_3800", "ROZWIĄZANIEM^1!&JEST^1!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3801", "(PROSZĘ WYOBRAŹ&SOBIE BĘBNY&W USZACH)/")
ds_map_add(global.text_data_en, "SCR_TEXT_3802", "... TO DRZEWO TAM O&MA NA TRZONIE&PRZYCISK!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3803", "SPRAWDŹ&SOBIE UWU!!!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3807", "WOW..^1.&NAPRAWDĘ JESTEŚ&PASJONATEM PUZZLI!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3808", "JESTEM ZACHWY-&CONY TWOIM&ENTUZJAZMEM!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3809", "DASZ RADĘ^1,&CZŁOWIEKU!!!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3814", "ROZWIĄZAŁEM&ZAGADKĘ!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3815", "\E0CZY TY ABSOLUTNIE^1,&DAPSOLUTNIE CHCESZ&ZNAĆ ROZWIĄZANIE???/")
ds_map_add(global.text_data_en, "SCR_TEXT_3816", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_3817", "* (Chcesz absolutnie^1, dapsolutnie&  znać rozwiązanie?)&         Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_3818", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_3825", "ROZWIĄZANIEM^1!&JEST^1!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3826", "(PROSZĘ WYOBRAŹ&SOBIE BĘBNY&W USZACH)/")
ds_map_add(global.text_data_en, "SCR_TEXT_3827", "... TO DRZEWO TAM O&MA NA TRZONIE&PRZYCISK!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3828", "SPRAWDŹ&SOBIE UWU!!!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3832", "WOW..^1.&NAPRAWDĘ JESTEŚ&PASJONATEM PUZZLI!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3833", "JESTEM ZACHWY-&CONY TWOIM&ENTUZJAZMEM!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3834", "DASZ RADĘ^1,&CZŁOWIEKU!!!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3839", "* (Jest guzik w trzonie&  tego drzewa.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_3840", "* (Nacisnąć?)& &         Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_3841", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_3845", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_3859", "OHO^1!&ZJAWIA SIĘ&CZŁOWIEK!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3860", "JESTEŚ GOTOWY&SPĘDZIĆ CZAS Z&UNDYNE?/")
ds_map_add(global.text_data_en, "SCR_TEXT_3861", "MAM PLAN BY ZROBIĆ&Z WAS ŚWIETNYCH&PRZYJACIÓŁ!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3862", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_3863", "* (Pójdziesz spędzić czas?)& &         Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_3864", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_3872", "OKEJ^1!&STÓJ ZA MNĄ!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3878", "HMMM..^1.&JESZCZE SIĘ&OGARNIASZ?/")
ds_map_add(global.text_data_en, "SCR_TEXT_3879", "\E0NIE SPIESZ SIĘ!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3884", "OKEJ^1!&JUŻ GOTOWY NA&SPĘDZANIE CZASU!?/")
ds_map_add(global.text_data_en, "SCR_TEXT_3885", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_3886", "* (Pójdziesz spędzić czas?)& &         Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_3887", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_3895", "OKEJ^1!&STÓJ ZA MNĄ!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3901", "NIE SPIESZ SIĘ!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3910", "OKEJ^1!&STÓJ ZA MNĄ!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3916", "NIE SPIESZ SIĘ!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3921", "\E4* .../")
ds_map_add(global.text_data_en, "SCR_TEXT_3922", "\E5* Więc czemu TY&  tu jesteś?/")
ds_map_add(global.text_data_en, "SCR_TEXT_3923", "\E4* Aby wytrzeć mi twoje&  zwycięstwo po twarzy?/")
ds_map_add(global.text_data_en, "SCR_TEXT_3924", "\E4* Żeby jeszcze bardziej&  mnie upokorzyć?/")
ds_map_add(global.text_data_en, "SCR_TEXT_3925", "\E1* CZY O TO CHODZI? & &  Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_3926", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_3932", "\E2* Oo-ho-ho./")
ds_map_add(global.text_data_en, "SCR_TEXT_3933", "\E1* Cóż^1, mam dla ciebie&  wiadomość^1, BRACIE./")
ds_map_add(global.text_data_en, "SCR_TEXT_3934", "\E2* Teraz jesteś na&  MOIM terytorium./")
ds_map_add(global.text_data_en, "SCR_TEXT_3935", "\E3* A ty NIE BĘDZIESZ&  mnie upokarzał./")
ds_map_add(global.text_data_en, "SCR_TEXT_3936", "\E3* Ja ci POWIEM&  co się teraz&  stanie./")
ds_map_add(global.text_data_en, "SCR_TEXT_3937", "\E0* Spędzimy razem czas./")
ds_map_add(global.text_data_en, "SCR_TEXT_3938", "\E2* Spędzimy razem fajnie&  czas./")
ds_map_add(global.text_data_en, "SCR_TEXT_3939", "\M1* Staniemy się&  " + '"' + "przyjaciółmi." + '"' + "/")
ds_map_add(global.text_data_en, "SCR_TEXT_3940", "\E3* Tak się zakochasz&  we mnie.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3941", "\E1* że to TY będziesz&  się czuł upokorzony&  za twoje czyny!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3942", "\E6* Fuhuhuhu!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3943", "\M2* To idealna zemsta!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3944", "\E1* Er.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3945", "\E9* Czemu sobie nie&  usiądziesz?/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3951", "\E4* Więc czemu tu&  jesteś?/")
ds_map_add(global.text_data_en, "SCR_TEXT_3952", "\E1* ...!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3953", "\E2* Chwila^1, rozumiem./")
ds_map_add(global.text_data_en, "SCR_TEXT_3954", "\E3* Myślisz^1, że ja będę&  twoim przyjacielem^1,&  huh?/")
ds_map_add(global.text_data_en, "SCR_TEXT_3955", "* Prawda???&              Z tobą &  Tak         NIGDY\C")
ds_map_add(global.text_data_en, "SCR_TEXT_3956", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_3963", "\E6* Serio^1?&* Jak miło!^1!&* Akceptuję!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3964", "* Chodźmy pobiegać&  po polach&  przyjaźni!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3965", "\E2* ...NIE!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3966", "\E2* Czemu JA^1 miałabym&  być TWOIM&  przyjacielem!?/")
ds_map_add(global.text_data_en, "SCR_TEXT_3967", "\E3* Gdybyś nie był moim&  gościem^1, pobiłabym&  cię tu i teraz!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3968", "\E0* Jesteś wrogiem&  wszystkich nadziei&  i marzeń!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3969", "\E1* NIGDY NIE BĘDĘ&  TWOIM PRZYJACIELEM./")
ds_map_add(global.text_data_en, "SCR_TEXT_3970", "\E3* Teraz wynoś się z&  mojego domu!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3976", "\E1* CO?/")
ds_map_add(global.text_data_en, "SCR_TEXT_3977", "\E4* Najpierw wbijasz na&  moją chatę^1, a potem&  śmiesz mnie PONIŻAĆ?/")
ds_map_add(global.text_data_en, "SCR_TEXT_3978", "\E2* Ty mały SZCZURU^1!&* Tak bardzo cię&  chcę teraz.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3979", "\E1* .../")
ds_map_add(global.text_data_en, "SCR_TEXT_3980", "\E3* Albo wiesz co./")
ds_map_add(global.text_data_en, "SCR_TEXT_3981", "\E2* Udowodnię ci&  INACZEJ./")
ds_map_add(global.text_data_en, "SCR_TEXT_3982", "\E3* My BĘDZIEMY&  przyjaciółmi./")
ds_map_add(global.text_data_en, "SCR_TEXT_3983", "\E1* Do tego stopnia^1, że.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3984", "\E3* My./")
ds_map_add(global.text_data_en, "SCR_TEXT_3985", "\M1* Będziemy&  PSIAPSIÓŁAMI./")
ds_map_add(global.text_data_en, "SCR_TEXT_3986", "* Sprawię^1, że mnie&  polubisz tak bardzo.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3987", "\E1* że całe twoje ŻYCIE&  będzie się krążyło&  wokół mnie!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3988", "\M2* To idealna zemsta!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3989", "\E6* FUHUHUHU!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_3990", "\E1* Er.../")
ds_map_add(global.text_data_en, "SCR_TEXT_3991", "\E9* Teraz^1, czemu sobie&  nie siądziesz?/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_3998", "* (Siąść i progresować?)& &         Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_3999", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4003", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4010", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4011", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4016", "* Ten cukier jest do&  herbaty./")
ds_map_add(global.text_data_en, "SCR_TEXT_4017", "\E2* Przecież ci nie dam&  pół kilo cukru!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4018", "\E6* What do I look&  like^1, the ice-cream&  woman?/")
ds_map_add(global.text_data_en, "SCR_TEXT_4019", "\E2* Do human ice-cream&  women TERRORIZE HUMANITY&  with ENERGY SPEARS?/")
ds_map_add(global.text_data_en, "SCR_TEXT_4020", "\E3* Are their ice-cream&  songs a PRELUDE TO&  DESTRUCTION?/")
ds_map_add(global.text_data_en, "SCR_TEXT_4021", "\E1* CZY O TO CHODZI? & &  Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4022", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4028", "\E1* ... what^1?&* REALLY?/")
ds_map_add(global.text_data_en, "SCR_TEXT_4029", "\E6* That rules!!!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4033", "\E3* That's what I&  thought./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4038", "* Envision these&  vegetables as your&  greatest enemy!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4039", "\E2* Now!^1!&* Pound them to dust&  with your fists!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4041", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_4042", "* (How will you pound?)& &         Strong      Wimpy\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4043", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4050", "* (You punch the vegetables&  at full force^1.&* You knock over a tomato.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_4052", "* YEAH^1!&* YEAH!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4053", "\E1* Our hearts are&  uniting against these&  healthy ingredients!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4054", "\M2* NOW IT'S MY TURN!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4055", "* NGAHHH!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4060", "* (You pet the vegetables&  in an affectionate&  manner.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_4062", "* OH MY GOD!!^1!&* STOP PETTING THE&  ENEMY!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4063", "\M2* I'll show you&  how it's done!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4064", "* NGAHHH!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4071", "* ... we add the&  noodles!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4072", "\E0* Homemade noodles&  are the best!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4073", "\E6* BUT I JUST BUY&  STORE-BRAND!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4074", "\M2* THEY'RE THE&  CHEAPEST!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4075", "\E1* NGAHHHHHHHHH&  HHHHHHHHHH!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4076", "\E9* Uhh^1, just put them&  in the pot./")
ds_map_add(global.text_data_en, "SCR_TEXT_4077", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_4078", "\M0* (How will you put them in?)& &         Fiercely    Careful\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4079", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4086", "* (You throw everything into&  the pot as hard as you can^1,&  including the box.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_4087", "* (It clanks against the&  empty bottom.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_4089", "\M2* YEAH!!^1!&* I'M INTO IT!!!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4094", "* (You place the noodles&  in one at a time.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_4095", "* (They clank against the&  empty bottom.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_4097", "* Nice???/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4103", "\E0* Humans suck^1, but&  their history..^1.&* Kinda rules./")
ds_map_add(global.text_data_en, "SCR_TEXT_4104", "\E2* Case in point^1:&* This giant sword!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4105", "\E0* Historically^1, humans&  wielded swords up&  to 10x their size./")
ds_map_add(global.text_data_en, "SCR_TEXT_4106", "\E1* RIGHT?& &  True        False\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4107", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4113", "\E6* Heh^1, I knew it!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4114", "\E2* When I first heard&  that^1, I immediately&  wanted one!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4115", "\E0* So me and Alphys&  built a giant&  sword together./")
ds_map_add(global.text_data_en, "SCR_TEXT_4116", "\E0* She figured out all&  the specs herself.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4117", "\E6* She's smart^1, huh!?/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4121", "\E2* Pfft^1!&* You liar!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4122", "\E3* I've READ Alphys's&  human history book&  collection!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4123", "\E3* I know all about&  your giant swords.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4124", "\E3* Your colossal^1,&  alien-fighting&  robots.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4125", "* Your supernatural&  princesses.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4126", "\E6* Heh^1! There's no&  way you're gonna&  fool me!!!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4131", "* (Look inside the bone drawer?)& &         Yes         No\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4132", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4136", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4147", "\M5* CO ZA REWELACYJNA OKAZJA&  NA CIEKAWĄ HISTORIĘ!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4148", "\M3* JUŻ WIDZĘ NAGŁÓWKI:/")
ds_map_add(global.text_data_en, "SCR_TEXT_4149", "\M4* " + '"' + "PIES SOBIE GDZIEŚ ISTNIEJE." + '"' + "/")
ds_map_add(global.text_data_en, "SCR_TEXT_4150", "\M2* SZCZERZE^1, JESTEM ZACHWYCONY./")
ds_map_add(global.text_data_en, "SCR_TEXT_4151", "* (ZROBIĆ O TYM REPORTAŻ?)& &         Relacjuj    Szukaj\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4152", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4159", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4165", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4170", "\M5* TEN PIES..^1.&* NADAL ISTNIEJE!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4171", "* TA HISTORIA..^1.&* ROBI SIĘ TYLKO&  CORAZ LEPSZA!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4172", "\M2* (ZROBIĆ O TYM REPORTAŻ?)& &         Relacjuj    Szukaj\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4173", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4179", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4185", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4191", "\M5* OJEJ!!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4192", "\M2* ... TO KOMPLETNIE NIEOKREŚ-&  LALNA SZKLANKA WODY./")
ds_map_add(global.text_data_en, "SCR_TEXT_4193", "\M4* ALE WSZYSTKO MOŻE BYĆ&  WSPANIAŁĄ HISTORIĄ Z&  LEKKIM PRZERYSOWANIEM!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4194", "\M2* (ZROBIĆ O TYM REPORTAŻ?)& &         Relacjuj    Szukaj\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4195", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4201", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4207", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4214", "\M3* JESTEM ZASZCZYCONY&  OBECNOŚCIĄ TAK OGROMNEGO&  OBSESYWNEGO FANA WODY!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4215", "\M2* (ZROBIĆ O TYM REPORTAŻ?)& &         Relacjuj    Szukaj\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4216", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4222", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4228", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4234", "\M5* O NIE!!^1!&* TEN SCENARIUSZ FILMOWY!!^1!&* JAK??^1? SIĘ TU DOSTAŁO???/")
ds_map_add(global.text_data_en, "SCR_TEXT_4235", "\M4* TO SUPER SOCZYSTA ZAPOWIEDŹ&  MOJEGO NAJNOWSZEGO FILMU Z&  GWARANTOWANĄ PREMIERĄ:/")
ds_map_add(global.text_data_en, "SCR_TEXT_4236", "\M6* METTATON THE MOVIE XXVIII..^1.&  W ROLI GŁÓWNEJ METTATON!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4237", "\M1* SŁYSZAŁEM ŻE TAK JAK&  W INNYCH FILMACH.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4238", "\M1* SKŁADA SIĘ GŁÓWNIE Z JEDNEGO&  CZTEROGODZINNEGO KADRU PŁATKÓW&  RÓŻ LECĄCYCH NA MOJE CIAŁO./")
ds_map_add(global.text_data_en, "SCR_TEXT_4239", "\M5* UUU!!^1!&* ALE TO!!^1!&* NIE JEST POTWIERDZONE!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4240", "\M5* NIE ZEPSUŁBYŚ WSZYSTKIM&  MOJEGO FILMU JAKĄŚ KOMERCYJNĄ&  HISTORIĄ^1, PRAWDA?/")
ds_map_add(global.text_data_en, "SCR_TEXT_4241", "\M2* (ZROBIĆ O TYM REPORTAŻ?)& &         Relacjuj    Szukaj\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4242", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4248", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4254", "\M5* UF!!^1! BLISKO BYŁO!^1!&* PRAWIE PODAROWAŁEŚ MI&  DARMOWE REKLAMY!!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4255", "\M2 %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4260", "\M3* OH^1!&* WITAJ SPOWROTEM!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4261", "\M6* ZGADZA SIĘ^1, WIDZOWIE^1!&* WYGLĄDA NA TO, ŻE NIKT NIE&  MOŻE SIĘ OPRZEĆ MOJEJ PREMIERY!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4262", "\M2* (ZROBIĆ O TYM REPORTAŻ?)& &         Relacjuj    Szukaj\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4263", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4270", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4276", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4282", "\M4* KOSZYKÓWKA JEST SUPER^1,&  CZYŻ NIE^1, SŁONKO?/")
ds_map_add(global.text_data_en, "SCR_TEXT_4283", "\M1* SZKODA TYLKO^1, ŻE NIE&  MOŻESZ SIĘ BAWIĆ&  TYMI BALLSAMI./")
ds_map_add(global.text_data_en, "SCR_TEXT_4284", "\M4* TO SĄ MTT-BRAND FASHION&  PIŁKI DO SIATKÓWKI^1.&* DO NOSZENIA^1, NIE GRANIA./")
ds_map_add(global.text_data_en, "SCR_TEXT_4285", "\M6* NIE MOŻESZ SIĘ STAĆ BOGATY I&  POPULARNY JAK JA BEZ&  UPIĘKSZANIA KILKU RZECZY./")
ds_map_add(global.text_data_en, "SCR_TEXT_4286", "\M2* (ZROBIĆ O TYM REPORTAŻ?)& &         Relacjuj    Szukaj\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4287", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4293", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4299", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4304", "* CHYBA NASZ DZIENNIKARZ JEST&  PRZYWIĄZANY DO SPORTÓW JAK&  GŁUPIE ĆMY DO LAMPY./")
ds_map_add(global.text_data_en, "SCR_TEXT_4305", "\M2* (ZROBIĆ O TYM REPORTAŻ?)& &         Relacjuj    Szukaj\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4306", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4312", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4318", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4326", "\M5* O RANY^1! TO PREZENT^1!&* I JEST ZAADRESOWANY DO&  CIEBIE^1, SŁONKO!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4327", "\M6* CZYŻ NIE JESTEŚ&  WYPEŁNIONY RADOŚCIĄ?/")
ds_map_add(global.text_data_en, "SCR_TEXT_4328", "\M5* CO MOŻE BYĆ W ŚRODKU^1?&* CÓŻ^1, ROBIĆ NIC INNEGO&  NIŻ " + '"' + "ZAPREZENTOWAĆ" + '"' + " GO!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4329", "\M2* (ZROBIĆ O TYM REPORTAŻ?)& &         Relacjuj    Szukaj\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4330", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4336", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4342", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4347", "\M4* GOTOWY NA TWOJĄ..^1.&* PREZENTACJĘ?/")
ds_map_add(global.text_data_en, "SCR_TEXT_4348", "\M4* (... UTNIJMY TO DO SCENY.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_4349", "\M2* (ZROBIĆ O TYM REPORTAŻ?)& &         Relacjuj    Szukaj\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4350", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4356", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4362", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4369", "\M5* UU LA LA^1!&* TA GRA WIDEO..^1.&* TO DYNAMIT!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4370", "\M4* CHOCIAŻ NIE POJAWIAM SIĘ&  W NIEJ AŻ DO TRZECH-&  CZWARTYCH W GRZE./")
ds_map_add(global.text_data_en, "SCR_TEXT_4371", "\M3* ALE PODOBA MI SIĘ./")
ds_map_add(global.text_data_en, "SCR_TEXT_4372", "\M6* POJAWIAM SIĘ Z NIEBA JAK&  ANIOŁ^1, NAKARMIAJĄC PRAGNIENIE&  WIDOWNI NA GORĄCE ANDROIDY.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4373", "\M5* OOH^1!&* TO METTATON!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4374", "\M2* (ZROBIĆ O TYM REPORTAŻ?)& &         Relacjuj    Szukaj\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4375", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4381", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4387", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4392", "* AH^1, ROZUMIESZ./")
ds_map_add(global.text_data_en, "SCR_TEXT_4393", "* TO JEST GRA W KRÓREJ&  POWINIENEŚ WSZYSTKO&  SPRAWDZAĆ DWA RAZY./")
ds_map_add(global.text_data_en, "SCR_TEXT_4394", "\M2* (ZROBIĆ O TYM REPORTAŻ?)& &         Relacjuj    Szukaj\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4395", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4401", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4407", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4415", "* Kupić Wywar z Pająków&  za 9999G?&          Tak         Nie \C")
ds_map_add(global.text_data_en, "SCR_TEXT_4416", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4433", "* Kilka pająów wypełznęło&  i dało ci słoik./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4434", "* Nie miałeś wystarczająco&  pieniędzy./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4436", "* Nosisz zbyt wiele rzeczy./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4439", "*%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4447", "* Kupić Pajęczy Pączak za 9999G?& &          Tak         Nie \C")
ds_map_add(global.text_data_en, "SCR_TEXT_4448", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4465", "* Kilka pająkow wypełznęły&  i dało ci pączka./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4466", "* Nie miałeś wystarczająco&  pieniędzy./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4468", "* Nosisz zbyt wiele rzeczy./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4471", "*%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4477", "* Kum^1, kum.&* (Słyszałem^1, że jesteś całkiem&  empatyczny jak na człowieka...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_4478", "\W* (Z pewnością już wiesz że&  potwór nosi \YŻÓŁTE\W imię&  kiedy możesz go \YOSZCZĘDZIĆ\W.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_4479", "* (Co o tym myślisz?)&         Bardzo      Nie-&         Pomocne     Potrzebne\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4480", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4486", "* (To jest dosyć pomocne.^1)&* (Pamiętaj^1, oszczędzanie to po&  prostu odmawianie walki.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_4487", "* (Może jednego dnia^1, będziesz&  musiał to zrobić^1, nawet jeśli&  jego imie nie jest żółte.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4491", "* (Naprawdę^1? W takim razie powiem&  wszystkim przyjaciołom^1, żeby&  przekazali ich przyjaciołom...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_4492", "* (..Żeby nie używali już nigdy&  więcej żółtych imion.^1)&* (Pasuje?)/")
ds_map_add(global.text_data_en, "SCR_TEXT_4493", "         Zachowaj    Nie używaj&         Żółte       Żółtych&         Imiona      Imion\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4494", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4501", "* (OK^1, będą dalej używać&  żółte imiona.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4505", "* (OK^1, dam im znać żeby&  przestali używać&  żółte imiona.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4511", "* Kum^1, kum^1.&* (Jak się trzymasz bez&  żółtych imion?)/")
ds_map_add(global.text_data_en, "SCR_TEXT_4512", "                     Przywróc &         Jest        te imiona&         świetnie    spowrotem\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4513", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4519", "* (Miło mi słyszeć.^1)&* (Chociaż^1, nie wiem dlaczego&  masz niesmak do żółtego.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_4520", "* (Miej nadzieję że nie&  napotkasz bananowego&  potwora.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4524", "* (Huh^1? To raczej niespodziewane&  że zmieniłeś zdanie ot tak.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_4525", "* (Jako że powiedziałem wszystkim&  aby nie używali żółtych imion^1,&  wszyscy się ich pozbyli.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_4526", "* (To naprawdę kłopotliwe...^1)&* (Hmmm...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_4527", "\W* (Cóż^1, w poprzednim roku modne&  było używanie \próżowych\W imion.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_4528", "* (Wydaje mi się^1, że oni jeszcze&  je mają w gdzieś w swoich&  garderobach...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_4529", "* (Poproszę wszystkich^1,&  żeby poszukali.^1)&* (Ale to już ostatni raz!)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4535", "* Kum^1, kum...&* (Mam nadzieję^1, że jesteś&  szczęśliwy.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4540", "* \YNAPSTABLOOK22 wysłał ci&  zaproszenie do znajomych.\W /")
ds_map_add(global.text_data_en, "SCR_TEXT_4541", "* Zaakceptować prośbę?& &         Akceptuj    Odrzuć\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4542", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4547", "* (Wydaje się^1, że samo się&  odrzuciło...)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4588", "* hey^1.&* i heard you're going&  to the core./")
ds_map_add(global.text_data_en, "SCR_TEXT_4589", "\E0* how about grabbing some&  dinner with me first?&  Yeah        I'm busy \C")
ds_map_add(global.text_data_en, "SCR_TEXT_4590", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4591", "* .../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4597", "* great^1, thanks for&  treating me./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4602", "* well^1, have fun in&  there./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4609", "* This is the barrier./")
ds_map_add(global.text_data_en, "SCR_TEXT_4610", "* This is what keeps&  us all trapped&  underground./")
ds_map_add(global.text_data_en, "SCR_TEXT_4611", "* .../")
ds_map_add(global.text_data_en, "SCR_TEXT_4612", "* If.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4613", "* If by chance you&  have any unfinished&  business.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4614", "* Please do what you&  must./")
ds_map_add(global.text_data_en, "SCR_TEXT_4615", " & &         Continue    Go Back\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4616", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4623", "* ..^2.&* ... I see.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4624", "* This is it^1, then./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4630", "* I see./")
ds_map_add(global.text_data_en, "SCR_TEXT_4631", "* Anything you want to&  do is important&  enough./")
ds_map_add(global.text_data_en, "SCR_TEXT_4632", "* Even something as small&  as reading a book^1,&  or taking a walk.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4633", "* Please take your time./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4639", "* Oh..^1.&* Back so soon?/")
ds_map_add(global.text_data_en, "SCR_TEXT_4640", "* How are you feeling?/")
ds_map_add(global.text_data_en, "SCR_TEXT_4641", " & &         Ready       Go Back\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4642", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4649", "* ..^2.&* ... I see.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4650", "* This is it^1, then./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4655", "* I see./")
ds_map_add(global.text_data_en, "SCR_TEXT_4656", "* Do what you have to./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4662", "* Tra la la^1.&* I am the riverman./")
ds_map_add(global.text_data_en, "SCR_TEXT_4663", "* Or am I the riverwoman...^1?&* It doesn't really matter./")
ds_map_add(global.text_data_en, "SCR_TEXT_4664", "* I love to ride in my boat^1.&* Would you care to join me?/")
ds_map_add(global.text_data_en, "SCR_TEXT_4665", "* (Ride in the boat?)& &         Yes         No\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4666", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4669", "* Tra la la^1.&* Care for a ride?/")
ds_map_add(global.text_data_en, "SCR_TEXT_4670", "* (Ride in the boat?)& &         Yes         No\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4671", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4678", "* Where will we go today?& &         Error       Error\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4680", "* Where will we go today?& &         Snowdin     Waterfall\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4682", "* Where will we go today?& &         Snowdin     Hotland\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4684", "* Where will we go today?& &         Waterfall   Hotland\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4686", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4691", "* Then perhaps another time^1.&* Or perhaps not^1.&* It doesn't really matter./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4713", "* Then we're off.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4720", "* (There's a switch on the&  wall.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_4721", "* (Nacisnąć?)& &         Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4722", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4725", "* (The switch doesn't do&  anything.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4729", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4743", "* (Seems like a comfortable&  bed.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_4744", "* (Lie on it?)& &         Yes         No\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4745", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4749", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4763", "* (It's just a regular suspicious&  bed now.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4767", "* (It's a yellow key.^1)&* (You put it on your&  keychain.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4772", "* (There's something under&  the sheets.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_4773", "* (Check it out?)& &         Yes         No\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4774", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4779", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4791", "* (The power has been turned&  on.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4794", "* (It seems like this controls&  the elevator's power.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_4795", "* (Turn it on?)& &         Yes         No\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4796", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4801", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_4816", "\E7* I always was a crybaby^1,&  wasn't I^1, \[C]?/")
ds_map_add(global.text_data_en, "SCR_TEXT_4817", "\E1* .../")
ds_map_add(global.text_data_en, "SCR_TEXT_4818", "\E2* ... I know./")
ds_map_add(global.text_data_en, "SCR_TEXT_4819", "\E0* You're not actually&  \[C], are you?/")
ds_map_add(global.text_data_en, "SCR_TEXT_4820", "\E7* \[C]'s been gone for&  a long time./")
ds_map_add(global.text_data_en, "SCR_TEXT_4821", "* .../")
ds_map_add(global.text_data_en, "SCR_TEXT_4822", "\E9* Um..^1. what.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4823", "\E0* What IS your name?/")
ds_map_add(global.text_data_en, "SCR_TEXT_4824", "\E2* .../")
ds_map_add(global.text_data_en, "SCR_TEXT_4825", "\E5* " + '"' + "Frisk?" + '"' + "/")
ds_map_add(global.text_data_en, "SCR_TEXT_4826", "\E7* That's.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4827", "\E5* A nice name./")
ds_map_add(global.text_data_en, "SCR_TEXT_4828", "* .../")
ds_map_add(global.text_data_en, "SCR_TEXT_4829", "\E7* Frisk.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4830", "\E0* I haven't felt like&  this for a long time./")
ds_map_add(global.text_data_en, "SCR_TEXT_4831", "\E2* As a flower^1, I was&  soulless./")
ds_map_add(global.text_data_en, "SCR_TEXT_4832", "\E1* I lacked the power to&  love other people./")
ds_map_add(global.text_data_en, "SCR_TEXT_4833", "\E2* However^1, with everyone's&  souls inside me.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4834", "\E7* I not only have my own&  compassion back.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4835", "\E5* But I can feel every&  other monster's as&  well./")
ds_map_add(global.text_data_en, "SCR_TEXT_4836", "\E7* They all care about&  each other so much./")
ds_map_add(global.text_data_en, "SCR_TEXT_4837", "\E0* And..^1. they care about&  you too^1, Frisk./")
ds_map_add(global.text_data_en, "SCR_TEXT_4838", "* .../")
ds_map_add(global.text_data_en, "SCR_TEXT_4839", "\E7* I wish I could tell&  you how everyone&  feels about you./")
ds_map_add(global.text_data_en, "SCR_TEXT_4840", "* Papyrus..^1. Sans..^1.&* Undyne..^1. Alphys.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4841", "\E0* ... Toriel./")
ds_map_add(global.text_data_en, "SCR_TEXT_4842", "\E7* Monsters are weird./")
ds_map_add(global.text_data_en, "SCR_TEXT_4843", "\E5* Even though they barely&  know you.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4844", "\E6* It feels like they&  all really love&  you./")
ds_map_add(global.text_data_en, "SCR_TEXT_4845", "\E8* Haha./")
ds_map_add(global.text_data_en, "SCR_TEXT_4846", "* .../")
ds_map_add(global.text_data_en, "SCR_TEXT_4847", "\E1* Frisk..^1. I..^1.&* I understand if you&  can't forgive me./")
ds_map_add(global.text_data_en, "SCR_TEXT_4848", "* I understand if you&  hate me./")
ds_map_add(global.text_data_en, "SCR_TEXT_4849", "* I acted so strange and&  horrible./")
ds_map_add(global.text_data_en, "SCR_TEXT_4850", "\E3* I hurt you./")
ds_map_add(global.text_data_en, "SCR_TEXT_4851", "* I hurt so many people./")
ds_map_add(global.text_data_en, "SCR_TEXT_4852", "\E1* Friends^1, family^1,&  bystanders.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4853", "\E3* There's no excuse for&  what I've done./")
ds_map_add(global.text_data_en, "SCR_TEXT_4855", " & &  Forgive     Do not\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4856", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4862", "\E3* Wh..^1. what?/")
ds_map_add(global.text_data_en, "SCR_TEXT_4863", "\E7* ... Frisk^1, come on./")
ds_map_add(global.text_data_en, "SCR_TEXT_4864", "\E0* You're..^1.&* You're gonna make me&  cry again./")
ds_map_add(global.text_data_en, "SCR_TEXT_4865", "\E7* ... besides^1, even if&  you do forgive me.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4869", "\E2* ... right^1./")
ds_map_add(global.text_data_en, "SCR_TEXT_4870", "* I understand./")
ds_map_add(global.text_data_en, "SCR_TEXT_4871", "\E1* I just hope that.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4872", "* I can make up for&  it a little right&  now./")
ds_map_add(global.text_data_en, "SCR_TEXT_4875", "\E1* I can't keep these&  souls inside of me./")
ds_map_add(global.text_data_en, "SCR_TEXT_4876", "\E0* The least I can do&  is return them./")
ds_map_add(global.text_data_en, "SCR_TEXT_4877", "\E2* But first.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4878", "\E4* There's something I&  have to do./")
ds_map_add(global.text_data_en, "SCR_TEXT_4879", "* Right now^1, I can feel&  everyone's hearts&  beating as one./")
ds_map_add(global.text_data_en, "SCR_TEXT_4880", "* They're all burning&  with the same&  desire./")
ds_map_add(global.text_data_en, "SCR_TEXT_4881", "* With everyone's power..^1.&* With everyone's&  determination.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4882", "* It's time for&  monsters.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4883", "* To finally go free./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4887", "\E7* Frisk.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4888", "\E0* I have to go now./")
ds_map_add(global.text_data_en, "SCR_TEXT_4889", "\E7* Without the power of&  everyone's souls.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4890", "\E1* I can't keep&  maintaining this&  form./")
ds_map_add(global.text_data_en, "SCR_TEXT_4891", "* In a little while.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4892", "* I'll turn back into&  a flower./")
ds_map_add(global.text_data_en, "SCR_TEXT_4893", "\E3* I'll stop being&  " + '"' + "myself." + '"' + "/")
ds_map_add(global.text_data_en, "SCR_TEXT_4894", "* I'll stop being able&  to feel love again./")
ds_map_add(global.text_data_en, "SCR_TEXT_4895", "\E1* So..^1. Frisk./")
ds_map_add(global.text_data_en, "SCR_TEXT_4896", "\E7* It's best if you&  just forget about&  me^1, OK?/")
ds_map_add(global.text_data_en, "SCR_TEXT_4897", "\E0* Just go be with&  the people who&  love you./")
ds_map_add(global.text_data_en, "SCR_TEXT_4898", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_4899", " &         Comfort&         him         Do not\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4900", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4919", "\E0* So^1, Alphys.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4920", "\E9* What do you want&  to do now that&  we're all free?/")
ds_map_add(global.text_data_en, "SCR_TEXT_4921", "\E0* We have the whole&  world to explore&  now./")
ds_map_add(global.text_data_en, "SCR_TEXT_4923", "\E3* W-well^1, of course&  I'm going to go&  out and.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4924", "\E4* Um.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4925", "\E3* No^1, I should be&  honest!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4926", "\E1* I'm gonna stay inside&  and watch anime like&  a total loser!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4928", "\E0THAT'S THE SPIRIT!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4929", "EVERYONE!!^1!&A CELEBRATION!!!&TO BEING LOSERS!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4931", "\E9* Heh^1.&* Papyrus has the&  right idea./")
ds_map_add(global.text_data_en, "SCR_TEXT_4932", "\E0* Losing to Frisk is&  the best thing to&  ever happen to me./")
ds_map_add(global.text_data_en, "SCR_TEXT_4933", "\E0* So I'm glad that&  we.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4934", "\E9* Huh^1?&* What is it^1, Asgore?/")
ds_map_add(global.text_data_en, "SCR_TEXT_4936", "\E2* Um..^1. what's an.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4937", "\E0* ... anime?/")
ds_map_add(global.text_data_en, "SCR_TEXT_4939", "\E1* (Oh My God?)/")
ds_map_add(global.text_data_en, "SCR_TEXT_4940", "\E3* (Frisk^1. Please.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_4941", "\E2* (Help me explain what&  anime is to Asgore.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_4942", "\E0* Y-you see^1, it's&  like a cartoon^1,&  but.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4943", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_4944", " &         With        With&         Sword's     Gun's\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4945", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4950", "\E2* So it's like a&  cartoon..^1.&* But with swords?/")
ds_map_add(global.text_data_en, "SCR_TEXT_4952", "\E2* So it's like a&  cartoon..^1.&* But with guns?/")
ds_map_add(global.text_data_en, "SCR_TEXT_4953", "\E0* Golly^1!&* That sounds neato!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4954", "\E3* Where is this^1?&* Where can I see the&  Anime./")
ds_map_add(global.text_data_en, "SCR_TEXT_4956", "\E3* H-hold on^1, uh..^1.&* I think I have&  some on my phone./")
ds_map_add(global.text_data_en, "SCR_TEXT_4957", "\E0* Here^1, l-look at&  this!/")
ds_map_add(global.text_data_en, "SCR_TEXT_4958", "\E0* .../")
ds_map_add(global.text_data_en, "SCR_TEXT_4959", "\E3*...Oh^1, uh.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4960", "\E4* Um..^1. that's the..^1.&* That's the wrong.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4961", "\E5* Uh^1, nevermind./")
ds_map_add(global.text_data_en, "SCR_TEXT_4963", "* Golly^1.&* Were those two robots.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4965", "\E9* ... kissing?/")
ds_map_add(global.text_data_en, "SCR_TEXT_4967", "\E0* Boy^1!&* Technology sure is&  something^1, isn't it?/")
ds_map_add(global.text_data_en, "SCR_TEXT_4969", "\E5* Eheheh..^1. yeah^1!&* It sure is!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4973", "\E0* Psst..^1.&* F-Frisk./")
ds_map_add(global.text_data_en, "SCR_TEXT_4974", "\E3* Um^1, you've gotta&  tell me./")
ds_map_add(global.text_data_en, "SCR_TEXT_4975", "\E6* D..^1. do you think&  Asgore and Toriel&  are...?/")
ds_map_add(global.text_data_en, "SCR_TEXT_4976", "\E3* Uh^1, ever gonna get&  back together?/")
ds_map_add(global.text_data_en, "SCR_TEXT_4977", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_4978", "& &         Yeah        Nope\C")
ds_map_add(global.text_data_en, "SCR_TEXT_4979", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_4983", "* Error.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4987", "\E7* Y-yeah!!^1!&* Yeah^1, that's what&  I hope^1, too./")
ds_map_add(global.text_data_en, "SCR_TEXT_4988", "\E7* Just think about how&  cute they must have&  been together./")
ds_map_add(global.text_data_en, "SCR_TEXT_4989", "\E0* It's quickly becoming&  my number one ship&  of all time./")
ds_map_add(global.text_data_en, "SCR_TEXT_4990", "\E7* Tori and Gorey.../")
ds_map_add(global.text_data_en, "SCR_TEXT_4991", "\E5* My..^1.&* My old boss and&  his ex-wife./")
ds_map_add(global.text_data_en, "SCR_TEXT_4992", "\E8* ... uh^1, that sounds&  a lot less cool&  all of a sudden./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_4998", "\E8* ... yeah^1, that's what&  I thought./")
ds_map_add(global.text_data_en, "SCR_TEXT_4999", "\E7* A woman can dream&  though^1, right?/")
ds_map_add(global.text_data_en, "SCR_TEXT_5000", "\E2* And write fanfiction./")
ds_map_add(global.text_data_en, "SCR_TEXT_5001", "\E1* A LOT of fanfiction./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5007", "\E0* Frisk^1!&* I just realized!/")
ds_map_add(global.text_data_en, "SCR_TEXT_5008", "\E3* Now that we aren't&  fighting each&  other.../")
ds_map_add(global.text_data_en, "SCR_TEXT_5009", "\E2* I can finally ask&  you.../")
ds_map_add(global.text_data_en, "SCR_TEXT_5010", "\E0* " + '"' + "Would you like a&  cup of tea?" + '"' + "/")
ds_map_add(global.text_data_en, "SCR_TEXT_5011", "\E2* .../")
ds_map_add(global.text_data_en, "SCR_TEXT_5012", "\E0* Would you like a&  cup of tea?/")
ds_map_add(global.text_data_en, "SCR_TEXT_5013", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_5014", "& &         Yes         No\C")
ds_map_add(global.text_data_en, "SCR_TEXT_5015", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_5019", "* Error.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5023", "* Oh^1!&* Well!/")
ds_map_add(global.text_data_en, "SCR_TEXT_5024", "\E3* Actually^1, the cup I&  had is cold now./")
ds_map_add(global.text_data_en, "SCR_TEXT_5025", "* So you shouldn't&  have it./")
ds_map_add(global.text_data_en, "SCR_TEXT_5026", "\E0* But^1, I am so&  happy you said&  yes./")
ds_map_add(global.text_data_en, "SCR_TEXT_5027", "\E0* As soon as I can^1,&  I will make some&  more for you./")
ds_map_add(global.text_data_en, "SCR_TEXT_5028", "\E0* Then we can be&  great pals./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5034", "\E3* Oh.../")
ds_map_add(global.text_data_en, "SCR_TEXT_5035", "\E3* Okay./")
ds_map_add(global.text_data_en, "SCR_TEXT_5037", "\E2* Frisk^1! Stop^1!&* You're breaking his&  big burly heart!/")
ds_map_add(global.text_data_en, "SCR_TEXT_5039", "\E2* Um^1, it's OK^1, Undyne./")
ds_map_add(global.text_data_en, "SCR_TEXT_5040", "\E0* My heart's already&  broken./")
ds_map_add(global.text_data_en, "SCR_TEXT_5042", "\E6* ASGORE^1! STOP^1!&* YOU'RE BREAKING MY&  BIG BURLY HEART!/")
ds_map_add(global.text_data_en, "SCR_TEXT_5044", "\E9* Y-yeah^1, Asgore^1.&* Don't break Undyne's&  heart./")
ds_map_add(global.text_data_en, "SCR_TEXT_5045", "\E2* That's my job./")
ds_map_add(global.text_data_en, "SCR_TEXT_5047", "\E2* OH MY GOD!&* YOU'RE GOING BACK&  IN THE TRASH!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_5049", "\E0CAN I GO IN THE&TRASH TOO?/")
ds_map_add(global.text_data_en, "SCR_TEXT_5051", "\E9* Sure^1, Papyrus./")
ds_map_add(global.text_data_en, "SCR_TEXT_5053", "\E1* guess i have to&  go in the trash&  too./")
ds_map_add(global.text_data_en, "SCR_TEXT_5055", "\E0* Oh^1, may I enter&  the trash as well?/")
ds_map_add(global.text_data_en, "SCR_TEXT_5057", "\E1* Uh^1, okay?/")
ds_map_add(global.text_data_en, "SCR_TEXT_5059", "\E0* Am I invited to&  the trash?/")
ds_map_add(global.text_data_en, "SCR_TEXT_5061", "\E6* SURE!!!&* WHY NOT!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_5063", "\E1* On second thought^1,&  do not put me&  in the trash./")
ds_map_add(global.text_data_en, "SCR_TEXT_5065", "\E5* Oh.../")
ds_map_add(global.text_data_en, "SCR_TEXT_5067", "\E1* OH MY GOD!!!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5073", "* (If you leave here^1, your&  adventure will really&  be over.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5074", "* (Your friends will follow&  you out of the underground.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5075", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_5076", " &         Don't       I'm&         leave       ready\C")
ds_map_add(global.text_data_en, "SCR_TEXT_5077", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_5081", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_5095", "\E0* Oh my.../")
ds_map_add(global.text_data_en, "SCR_TEXT_5097", "\E0* Isn't it beautiful^1,&  everyone?/")
ds_map_add(global.text_data_en, "SCR_TEXT_5099", "\E3* Wow..^1. it's e-even&  better than on TV./")
ds_map_add(global.text_data_en, "SCR_TEXT_5100", "\E7* WAY better^1!&* Better than I ever&  imagined!/")
ds_map_add(global.text_data_en, "SCR_TEXT_5102", "\E1* Frisk^1, you LIVE with&  this!?/")
ds_map_add(global.text_data_en, "SCR_TEXT_5103", "\E9* The sunlight is so&  nice..^1. and the air&  is so fresh!/")
ds_map_add(global.text_data_en, "SCR_TEXT_5104", "* I really feel alive!/")
ds_map_add(global.text_data_en, "SCR_TEXT_5106", "\E0HEY SANS.../")
ds_map_add(global.text_data_en, "SCR_TEXT_5107", "\E3WHAT'S THAT GIANT&BALL?/")
ds_map_add(global.text_data_en, "SCR_TEXT_5109", "\E1* we call that&  " + '"' + "the sun^1," + '"' + " my friend./")
ds_map_add(global.text_data_en, "SCR_TEXT_5111", "\E0THAT'S THE SUN!^1?&WOWIE!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_5112", "I CAN'T BELIEVE&I'M FINALLY MEETING&THE SUN!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_5114", "\E0* I could stand here&  and watch this for&  hours.../")
ds_map_add(global.text_data_en, "SCR_TEXT_5116", "\E0* Yes^1, it is beautiful^1,&  is it not?/")
ds_map_add(global.text_data_en, "SCR_TEXT_5117", "\E1* But we should really&  think about what comes&  next./")
ds_map_add(global.text_data_en, "SCR_TEXT_5119", "\E3* Oh^1, right./")
ds_map_add(global.text_data_en, "SCR_TEXT_5120", "\E0* Everyone.../")
ds_map_add(global.text_data_en, "SCR_TEXT_5121", "* This is the beginning&  of a bright new&  future./")
ds_map_add(global.text_data_en, "SCR_TEXT_5122", "* An era of peace between&  humans and monsters./")
ds_map_add(global.text_data_en, "SCR_TEXT_5123", "\E2* Frisk.../")
ds_map_add(global.text_data_en, "SCR_TEXT_5124", "* I have something to&  ask of you./")
ds_map_add(global.text_data_en, "SCR_TEXT_5125", "\E0* Will you act as our&  ambassador to the&  humans?/")
ds_map_add(global.text_data_en, "SCR_TEXT_5126", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_5127", "* (Be the ambassador?)& &         Yes         No\C")
ds_map_add(global.text_data_en, "SCR_TEXT_5128", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_5133", "WOWi, Nice error./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5136", "\E0YEAH^1!&FRISK WILL BE THE&BEST AMBASSADOR!/")
ds_map_add(global.text_data_en, "SCR_TEXT_5137", "AND I^1, THE GREAT&PAPYRUS.../")
ds_map_add(global.text_data_en, "SCR_TEXT_5138", "WILL BE THE BEST&MASCOT!/")
ds_map_add(global.text_data_en, "SCR_TEXT_5139", "I'LL GO MAKE A&GOOD FIRST&IMPRESSION!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5143", "\E0IT'S OK FRISK^1!&I'VE GOT YOU&COVERED!/")
ds_map_add(global.text_data_en, "SCR_TEXT_5144", "IF YOU DON'T WANT&TO BE THE&AMBASSADOR.../")
ds_map_add(global.text_data_en, "SCR_TEXT_5145", "I CAN DO IT FOR&YOU!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_5146", "I'LL GO MAKE A&GOOD FIRST&IMPRESSION!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5151", "* Frisk.../")
ds_map_add(global.text_data_en, "SCR_TEXT_5152", "\E2* You came from this&  world^1, right...?/")
ds_map_add(global.text_data_en, "SCR_TEXT_5153", "\E1* So you must have&  a place to return to^1,&  do you not?/")
ds_map_add(global.text_data_en, "SCR_TEXT_5154", "\E2* What will you do&  now?/")
ds_map_add(global.text_data_en, "SCR_TEXT_5155", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_5156", "         I want      I have&         to stay     places&         with you    to go\C")
ds_map_add(global.text_data_en, "SCR_TEXT_5157", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_5161", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_5182", "* (The door has no mail slot.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5183", "* (Slide the letter under?)& &         Slide       NO!!!! \C")
ds_map_add(global.text_data_en, "SCR_TEXT_5184", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_5197", "* (You slide the letter under&  the door and give it a&  knock.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5206", "* (You'll keep the letter&  warm for a little longer.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5212", "* (It's a note from Alphys.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5213", "* (Read it...?)& &         Read        Do not \C")
ds_map_add(global.text_data_en, "SCR_TEXT_5214", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_5220", "* (It's hard to read because&  of the handwriting^1, but&  you try your best...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5221", "* Hey./")
ds_map_add(global.text_data_en, "SCR_TEXT_5222", "* Thanks for your help back&  there./")
ds_map_add(global.text_data_en, "SCR_TEXT_5223", "* You guys..^1.&* Your support really means a&  lot to me./")
ds_map_add(global.text_data_en, "SCR_TEXT_5224", "* But..^1.&* As difficult as it is&  to say this.../")
ds_map_add(global.text_data_en, "SCR_TEXT_5225", "* You guys alone can't&  magically make my own&  problems go away./")
ds_map_add(global.text_data_en, "SCR_TEXT_5226", "* I want to be a better&  person./")
ds_map_add(global.text_data_en, "SCR_TEXT_5227", "* I don't want to be&  afraid anymore./")
ds_map_add(global.text_data_en, "SCR_TEXT_5228", "* And for that to happen^1,&  I have to be able to&  face my own mistakes./")
ds_map_add(global.text_data_en, "SCR_TEXT_5229", "* I'm going to start&  doing that now./")
ds_map_add(global.text_data_en, "SCR_TEXT_5230", "* I want to be clear./")
ds_map_add(global.text_data_en, "SCR_TEXT_5231", "* This isn't anyone else's&  problem but mine./")
ds_map_add(global.text_data_en, "SCR_TEXT_5232", "* But if you don't ever&  hear from me again.../")
ds_map_add(global.text_data_en, "SCR_TEXT_5233", "* If you want to know&  " + '"' + "the truth." + '"' + "/")
ds_map_add(global.text_data_en, "SCR_TEXT_5234", "* Enter the door to the&  north of this note./")
ds_map_add(global.text_data_en, "SCR_TEXT_5235", "* You all at least deserve&  to know what I did./")
ds_map_add(global.text_data_en, "SCR_TEXT_5236", "* (That's all she wrote.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5240", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_5250", "* (Buy chips for 25G?)& &         Buy         No \C")
ds_map_add(global.text_data_en, "SCR_TEXT_5251", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_5255", "* (There were no chips left&  in the machine.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5256", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_5274", "* (The vending machine&  dispensed some chisps.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5275", "* (You didn't have enough&  gold.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5277", "* (You are carrying too&  many items.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5280", "*%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5285", "* Dzyn dzyn..\E0.\TT /")
ds_map_add(global.text_data_en, "SCR_TEXT_5286", "\F1 %")
ds_map_add(global.text_data_en, "SCR_TEXT_5290", "* Halo?&* Mówi TORIEL./")
ds_map_add(global.text_data_en, "SCR_TEXT_5291", "* Bez konkretnego&  powodu...&* Które preferujesz?/")
ds_map_add(global.text_data_en, "SCR_TEXT_5292", "* Cynamon czy&  toffi?/")
ds_map_add(global.text_data_en, "SCR_TEXT_5293", "\E1* ... czekaj^1.&* Nie mów mi./")
ds_map_add(global.text_data_en, "SCR_TEXT_5294", "\E0* It is ERROR MESSAGE!& &  Yes         No      \C")
ds_map_add(global.text_data_en, "SCR_TEXT_5295", "\E0* Czy to Toffi?& &  Tak         Nie      \C")
ds_map_add(global.text_data_en, "SCR_TEXT_5296", "\E0* Czy to Cynamon?& &  Tak         Nie      \C")
ds_map_add(global.text_data_en, "SCR_TEXT_5297", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_5309", "\E0* Hee hee hee^1.&* Miałam takie przeczucie./")
ds_map_add(global.text_data_en, "SCR_TEXT_5310", "\E1* Kiedy ludzie tu&  spadają^1, odziwo..^1.&* Ja.../")
ds_map_add(global.text_data_en, "SCR_TEXT_5311", "\E1* Często czuję, jakbym&  ich już znała./")
ds_map_add(global.text_data_en, "SCR_TEXT_5312", "\E0* Szczerze^1, kiedy cię&  zauważyłam poraz&  pierwszy^1, czułam.../")
ds_map_add(global.text_data_en, "SCR_TEXT_5313", "\E1* ...jakbym widziała&  dawnego przyjaciela&  poraz pierwszy./")
ds_map_add(global.text_data_en, "SCR_TEXT_5314", "\E0* Dziwne^1, czyż nie?/")
ds_map_add(global.text_data_en, "SCR_TEXT_5315", "* Cóż^1, dziękuję za&  twoją selekcję./")
ds_map_add(global.text_data_en, "SCR_TEXT_5316", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_5317", "* Klik.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5323", "\E1* Oh..^1. Rozumiem./")
ds_map_add(global.text_data_en, "SCR_TEXT_5324", "\E0* W takim razie^1, dziękuję^1.&* Papa na razie./")
ds_map_add(global.text_data_en, "SCR_TEXT_5325", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_5326", "* Klik.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5337", "* (Seems like you could skip&  Mettaton's monologue by&  turning him around now.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5338", "* (What will you do?)& &         Skip        Hear again\C")
ds_map_add(global.text_data_en, "SCR_TEXT_5339", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_5345", "* (You told Mettaton there&  was something cool&  behind him.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5353", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_5359", "* though.../")
ds_map_add(global.text_data_en, "SCR_TEXT_5360", "* one thing about you&  always struck me&  as kinda odd./")
ds_map_add(global.text_data_en, "SCR_TEXT_5361", "* now^1, i understand&  acting in self-defense./")
ds_map_add(global.text_data_en, "SCR_TEXT_5362", "* you were thrown into&  those situations&  against your will./")
ds_map_add(global.text_data_en, "SCR_TEXT_5363", "* but.../")
ds_map_add(global.text_data_en, "SCR_TEXT_5364", "* sometimes.../")
ds_map_add(global.text_data_en, "SCR_TEXT_5365", "* you act like you&  know what's gonna&  happen./")
ds_map_add(global.text_data_en, "SCR_TEXT_5366", "* like you've already&  experienced it all&  before./")
ds_map_add(global.text_data_en, "SCR_TEXT_5367", "* this is an odd thing&  to say^1, but.../")
ds_map_add(global.text_data_en, "SCR_TEXT_5368", "\W* if you have some sort&  of \Yspecial power\W.../")
ds_map_add(global.text_data_en, "SCR_TEXT_5369", "* isn't it your&  responsibility to do&  the right thing?/")
ds_map_add(global.text_data_en, "SCR_TEXT_5370", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_5371", " & &         Yes         No\C")
ds_map_add(global.text_data_en, "SCR_TEXT_5372", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_5379", "\E1* ah./")
ds_map_add(global.text_data_en, "SCR_TEXT_5380", "\E0* i see./")
ds_map_add(global.text_data_en, "SCR_TEXT_5381", "\E3* .../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5390", "\E1* heh./")
ds_map_add(global.text_data_en, "SCR_TEXT_5391", "\E0* well^1, that's your&  viewpoint./")
ds_map_add(global.text_data_en, "SCR_TEXT_5392", "\E2* i won't judge you&  for it./")
ds_map_add(global.text_data_en, "SCR_TEXT_5393", "\E3* .../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5402", "* (Ring...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5404", "\E0* Hey!/")
ds_map_add(global.text_data_en, "SCR_TEXT_5405", "\E3* This um^1, doesn't have&  anything to do with&  guiding you..^1. but.../")
ds_map_add(global.text_data_en, "SCR_TEXT_5406", "\E2* .../")
ds_map_add(global.text_data_en, "SCR_TEXT_5407", "\E6* Uhh^1, hey^1, would you want&  to watch a human TV&  show together???/")
ds_map_add(global.text_data_en, "SCR_TEXT_5408", "* Sometime???/")
ds_map_add(global.text_data_en, "SCR_TEXT_5409", "\E4* It's called^1, um^1,&  M..^1.Mew Mew Kissy&  Cutie.../")
ds_map_add(global.text_data_en, "SCR_TEXT_5410", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_5411", " & &         Sure!       ...no...\C")
ds_map_add(global.text_data_en, "SCR_TEXT_5412", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_5420", "* R-really!?/")
ds_map_add(global.text_data_en, "SCR_TEXT_5421", "\E3* It's so good^1!&* It's um^1, my favorite&  show!/")
ds_map_add(global.text_data_en, "SCR_TEXT_5422", "* It's all about this&  human girl named Mew Mew&  who has cat ears!%")
ds_map_add(global.text_data_en, "SCR_TEXT_5423", "\E3* Which humans don't have!&* S-so she's all&  sensitive about them!%")
ds_map_add(global.text_data_en, "SCR_TEXT_5424", "\E6* But like...&* Eventually!%")
ds_map_add(global.text_data_en, "SCR_TEXT_5425", "* She realizes that her&  ears don't matter!%")
ds_map_add(global.text_data_en, "SCR_TEXT_5426", "* That her friends like&  her despite the ears!%")
ds_map_add(global.text_data_en, "SCR_TEXT_5427", "\E7* It's really moving!%")
ds_map_add(global.text_data_en, "SCR_TEXT_5428", "\E5* Whoops, spoilers%")
ds_map_add(global.text_data_en, "SCR_TEXT_5429", "\E6* Also, this sounds&  weird, but she has&  the power!%")
ds_map_add(global.text_data_en, "SCR_TEXT_5430", "\E5* To control the minds&  of anyone she kisses!%")
ds_map_add(global.text_data_en, "SCR_TEXT_5431", "\E3* She kisses people and&  controls them to fix&  her problems!!%")
ds_map_add(global.text_data_en, "SCR_TEXT_5432", "\E5* They don't remember&  anything after the&  kiss I mean!!%")
ds_map_add(global.text_data_en, "SCR_TEXT_5433", "\E3* BUT IF SHE MISSES&  THE KISS!!!&* THEN!!%")
ds_map_add(global.text_data_en, "SCR_TEXT_5434", "\E4* Then^1, uh^1, and^1, uh^1,&  also I mean^1, of course%")
ds_map_add(global.text_data_en, "SCR_TEXT_5435", "\E5* Eventually^1, she&  realizes that&  controlling people%")
ds_map_add(global.text_data_en, "SCR_TEXT_5436", "\E3* OKAY WELL I almost&  spoiled the whole&  show^1, but%")
ds_map_add(global.text_data_en, "SCR_TEXT_5437", "\E5* Uhhh^1, I think you'd&  really like it!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_5438", "\E0* We should watch it^1!&* After you get through&  all this!/")
ds_map_add(global.text_data_en, "SCR_TEXT_5439", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_5440", "* (Klik...)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5445", "\E5* Um^1! Well^1!&* That's okay!/")
ds_map_add(global.text_data_en, "SCR_TEXT_5446", "* Just thought I'd!^1!&* Ask!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_5447", "\E6* B-but I think you'd&  really like it!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_5448", "* If you gave it a&  chance!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_5449", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_5450", "* (Klik...)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5455", "\M1* Did y'hear!^1?&* You're back!/")
ds_map_add(global.text_data_en, "SCR_TEXT_5456", "\M0* I'll tell you a big secret./")
ds_map_add(global.text_data_en, "SCR_TEXT_5457", "\M1* I'm starting a band^1, y'hear?/")
ds_map_add(global.text_data_en, "SCR_TEXT_5458", "\M1* It's called the Red Hot&  Chibi Peppers./")
ds_map_add(global.text_data_en, "SCR_TEXT_5459", "\M0* All I've thought of is&  the name./")
ds_map_add(global.text_data_en, "SCR_TEXT_5460", "\M3* And I don't^1, play...&* Instruments^1, or sing./")
ds_map_add(global.text_data_en, "SCR_TEXT_5461", "\M1* Well^1!&* Do you think we'll be&  popular!!!/")
ds_map_add(global.text_data_en, "SCR_TEXT_5462", " & &         Yeah        No\C")
ds_map_add(global.text_data_en, "SCR_TEXT_5463", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_5471", "\M0* Yeah^1, me too.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5477", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_5485", "* (It's a lamp.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5486", "* (Turn it on?)& &         Yes         No\C")
ds_map_add(global.text_data_en, "SCR_TEXT_5487", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_5493", "* (There's no lightbulb.^1)&* (A flashlight is stuck in&  the bulb socket.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5494", "* (Turn it on?)& &         Yes         No\C")
ds_map_add(global.text_data_en, "SCR_TEXT_5495", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_5499", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_5506", "* (The flashlight is out of&  batteries.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5510", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_5517", "* Hej^1, hej^1!&* Zapamiętałeś moje imię?/")
ds_map_add(global.text_data_en, "SCR_TEXT_5518", "* (Zapamiętałeś?)& &         Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_5519", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_5527", "* C-CO!^1?&* PAMIĘTASZ!?/")
ds_map_add(global.text_data_en, "SCR_TEXT_5528", "* Jak mogłeb być tak łatwo&  pokonanyyyyyyyyyym!?/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5533", "* C-CO!^1?&* NIE PAMIĘTASZ!?/")
ds_map_add(global.text_data_en, "SCR_TEXT_5534", "* Jak mogłeb być tak łatwo&  pokonanyyyyyyyyyym!?/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5541", "* (It's a small white dog.^1)&* (It's fast asleep...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5542", "* (Fight the dog?)& &         Yes         No\C")
ds_map_add(global.text_data_en, "SCR_TEXT_5543", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_5550", "* (Can't fight the dog.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5551", "* (Seems like the fabric it's&  sleeping on has too many&  holes in it.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5552", "* (Seems like the dog needs&  to " + '"' + "patch" + '"' + " the fabric.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5553", "* (Then you can fight the dog.^1)&* (... maybe.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5554", "* (Upon closer examination^1,&  the holes in the fabric&  seem to be growing.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5555", "* (Might take a while for the&  dog to fix all of them.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5556", "* (Dogs aren't usually very&  good at knitting.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5557", "* (A crocheting dog is out of&  the question.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5561", "* (Let sleeping dogs lie^1, instead&  of fighting them.^1)&* (That's how the saying goes.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5566", "* (Knock knock)./")
ds_map_add(global.text_data_en, "SCR_TEXT_5569", "* Oooooaaah ^1!&* Room service !/")
ds_map_add(global.text_data_en, "SCR_TEXT_5570", "* Got my " + '"' + "Sea Tea" + '"' + " ?& &         Yes         No\C")
ds_map_add(global.text_data_en, "SCR_TEXT_5571", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_5575", "* Room service never came ^1.&* (Sigh ...)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5581", "* Thanks a million ./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5585", "* (No response.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5598", "* (You pour the Sea Tea under&  the door.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5599", "* HUH !?!?!?!^2?&* That's just the way I want ^1!&* Here's a tip ./")
ds_map_add(global.text_data_en, "SCR_TEXT_5600", "* (You got 99G.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5604", "* ..^1.&* No you don't ./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5609", "* Then ...!?/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5614", "* (Knock knock)./")
ds_map_add(global.text_data_en, "SCR_TEXT_5617", "* Oooooaaah ^1!&* Room service !/")
ds_map_add(global.text_data_en, "SCR_TEXT_5618", "* Got my " + '"' + "Cinnamon Bun" + '"' + " ?& &         Yes         No\C")
ds_map_add(global.text_data_en, "SCR_TEXT_5619", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_5623", "* Room service never came ^1.&* (Sigh ...)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5628", "* Thanks a trillion ./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5632", "* (No response.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5646", "* (You flatten the Cinnamon Bun&  until it's paper thin.)&* (You slide it under the door.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5647", "* HUH !?!?!?!^2?&* That's just the way I want ^1!&* Here's a tip ./")
ds_map_add(global.text_data_en, "SCR_TEXT_5648", "* (You got 99G.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5652", "* ..^1.&* No you don't ./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5657", "* Then ...!?/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5662", "* (You hear shuffling.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5663", "* (Seems like you could put&  something under the door.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5664", " & &         Put         No Put\C")
ds_map_add(global.text_data_en, "SCR_TEXT_5665", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_5669", "* (No response.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5676", "* (...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5677", "* (But you didn't have anything&  appealing.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5705", "* (You put a Hot Dog in front&  of the door.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5706", "* (A white paw shoots out from&  under the door.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5707", "* (It tries to pull the Hot Dog&  into its room...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5708", "* (But it keeps pressing down too&  hard^1, and the hot dog keeps&  spinning away.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5709", "* (...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5710", "* (It finally succeeds.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5711", "* (...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5712", "* (You hear the grinding of&  stone.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5713", "* (A single hushpuppy slides&  out from under the door.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5714", "* (You got Hush Puppy.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5720", "* (You put a Hot Cat in front&  of the door.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5721", "* (You hear growling...)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5727", "* (You put a Dog Salad in front&  of the door.^1)&* (It slides underneath.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5728", "* (...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5729", "* (The Dog Salad was absorbed&  by the darkness.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5736", "* (You put a Dog Residue in&  front of the door.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5737", "* (It slides underneath the door^1,&  as if pulled by a magnet.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5738", "* (...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5743", "* (ZOMMM!!^1!)&* (It shoots back out at a&  high speed!)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5747", "* (Two Dog Residues slowly slide&  back out from underneath&  the door.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5755", " %%")
ds_map_add(global.text_data_en, "SCR_TEXT_5761", "* Yes^1, we know^1.&* The elevator to the city&  is NOT working./")
ds_map_add(global.text_data_en, "SCR_TEXT_5762", "* Because of this incident^1, rooms&  are running at a special rate!/")
ds_map_add(global.text_data_en, "SCR_TEXT_5763", "* 200G a room^1. Interested^1?& &         Stay        Do not\C")
ds_map_add(global.text_data_en, "SCR_TEXT_5764", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_5768", "* 200G a room^1. Interested^1?& &         Stay        Do not\C")
ds_map_add(global.text_data_en, "SCR_TEXT_5769", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_5774", "* Did you enjoy your stay?/")
ds_map_add(global.text_data_en, "SCR_TEXT_5775", "* What^1?&* Room..^1.&* Key?/")
ds_map_add(global.text_data_en, "SCR_TEXT_5776", "* No^1, we don't do that./")
ds_map_add(global.text_data_en, "SCR_TEXT_5777", "* If you leave your room^1,&  you'll have to pay again./")
ds_map_add(global.text_data_en, "SCR_TEXT_5778", "* 200G a room^1. Interested^1?& &         Stay        Do not\C")
ds_map_add(global.text_data_en, "SCR_TEXT_5779", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_5791", "* Fabulous^1!&* We'll escort you to your&  room!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5797", "* ... that's not enough money./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5802", "* Do let us know if you&  change your mind^1.&* Have a sparkular day!/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5807", "* ... MY ONE TRUE LOVE?/")
ds_map_add(global.text_data_en, "SCR_TEXT_5808", "* .../")
ds_map_add(global.text_data_en, "SCR_TEXT_5809", "* (YOU LOOK BORED^1, DARLING.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5810", "* (I WANT THIS TO BE A STELLAR&  PERFORMANCE^1, SO IF YOU&  WON'T GIVE IT YOUR ALL...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5811", "* (THEN I'LL SKIP AHEAD FOR&  THE AUDIENCE'S SAKE.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_5812", "* (Perform?)& &         Yeah        Skip this\C")
ds_map_add(global.text_data_en, "SCR_TEXT_5813", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_5819", "* (UNDERSTOOD.^1)&* (LET'S KNOCK 'EM DEAD!)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5823", "* (KA-SIGH...^1)&* (THE SHOW MUST GO ON!)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5829", "Fascynujące./")
ds_map_add(global.text_data_en, "SCR_TEXT_5830", "Chcesz wrócić spowrotem./")
ds_map_add(global.text_data_en, "SCR_TEXT_5831", "Chcesz wrócić&sp^1owrotem do świat^2a^1,&którego zniszczyłeś./")
ds_map_add(global.text_data_en, "SCR_TEXT_5832", "To ty postanowi^1ł&wszystko zniszczyć./")
ds_map_add(global.text_data_en, "SCR_TEXT_5833", "To ty doprowadziłe^1ś&do jego destrukcji./")
ds_map_add(global.text_data_en, "SCR_TEXT_5834", "Ale nie możesz&tego zaakceptować./")
ds_map_add(global.text_data_en, "SCR_TEXT_5835", "Myślisz, że konsekwencje&ciebie nie dotyczą.&         Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_5836", "")
ds_map_add(global.text_data_en, "SCR_TEXT_5842", "Dokładnie./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5846", "Czego szukasz w takim razie?/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5851", "Być może./")
ds_map_add(global.text_data_en, "SCR_TEXT_5852", "Możemy osiągnąc kompromis./")
ds_map_add(global.text_data_en, "SCR_TEXT_5853", "Dalej posiadasz co^1ś&czego chcę./")
ds_map_add(global.text_data_en, "SCR_TEXT_5854", "Daj mi to./")
ds_map_add(global.text_data_en, "SCR_TEXT_5855", "A przywrócę&spowrotem&ten świat./")
ds_map_add(global.text_data_en, "SCR_TEXT_5856", " & &         Yes         No\C")
ds_map_add(global.text_data_en, "SCR_TEXT_5857", "")
ds_map_add(global.text_data_en, "SCR_TEXT_5863", "W takim razie jest&to uzgodnione./")
ds_map_add(global.text_data_en, "SCR_TEXT_5864", "Oddasz mi twoją DUSZĘ.& &         Tak         Nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_5865", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_5869", "W takim razie zostań&tu na całą wieczność./")
ds_map_add(global.text_data_en, "SCR_TEXT_5870", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_5877", ".../")
ds_map_add(global.text_data_en, "SCR_TEXT_5878", "W takim razie^1,&jest to postanowione./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5882", "W takim razie zostań&tu na całą wieczność./")
ds_map_add(global.text_data_en, "SCR_TEXT_5883", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_5888", "* hej./")
ds_map_add(global.text_data_en, "SCR_TEXT_5889", "* czy twoja lodówka&  działa prawidłowo?/")
ds_map_add(global.text_data_en, "SCR_TEXT_5890", " & &         tak         nie\C")
ds_map_add(global.text_data_en, "SCR_TEXT_5891", " ")
ds_map_add(global.text_data_en, "SCR_TEXT_5897", "* dobrze^1.&* przyjdę odłożyć&  moje browary./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_5901", "* ok^1, wyśle kogoś^1,&  by to naprawił./")
ds_map_add(global.text_data_en, "SCR_TEXT_5902", "* dzięki, że dałeś&  znać./")
ds_map_add(global.text_data_en, "SCR_TEXT_5903", "* dobra komunikacja&  jest ważna./%%")
