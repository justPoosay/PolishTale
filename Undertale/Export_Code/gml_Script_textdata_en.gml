ds_map_add(global.text_data_en, "obj_shyren_279", "Si Fa&Si Fa&So Fa So&Mi Re Re")
ds_map_add(global.text_data_en, "obj_shyren_280", "Mi So&Mi So&Mi Si Mi&La Si So")
