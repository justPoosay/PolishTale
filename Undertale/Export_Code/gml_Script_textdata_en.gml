ds_map_add(global.text_data_en, "obj_maddummy_1152", "* Zły Manekin robi bezramienne&  dzikie ruchy.")
ds_map_add(global.text_data_en, "obj_maddummy_1153", "* Zły Manekin rozkazuje swoim&  pociskom.")
ds_map_add(global.text_data_en, "obj_maddummy_1154", "* Zły Manekin gapi się na&  lustro^1, wtedy obraca się do&  ciebie z tą samą ekspresją.")
ds_map_add(global.text_data_en, "obj_maddummy_1155", "* Zły Manekin skacze złośliwie.")
ds_map_add(global.text_data_en, "obj_maddummy_1156", "* Pachnie jak stary lumpeks.")
ds_map_add(global.text_data_en, "obj_maddummy_1157", "* Ta wiadomość NIGDY się&  nie pojawi.")
ds_map_add(global.text_data_en, "obj_maddummy_1158", "* Zły Manekin rozrzuca swoją&  bawełnę po całym oknie&  dialogowym.")
ds_map_add(global.text_data_en, "obj_maddummy_1174", "* ZŁY MANEKIN - ATK 30 DEF TAK&* Jako że jest duchem^1, fizyczne&  ataki nie mają efektu./^")
ds_map_add(global.text_data_en, "obj_maddummy_1194", "* Rozmawiasz z MANEKINEM^1.&* .../")
ds_map_add(global.text_data_en, "obj_maddummy_1195", "* Nie wydaje się materiałem&  na konwersację./")
ds_map_add(global.text_data_en, "obj_maddummy_1196", "* Nikt nie jest szczęśliwy./^")
ds_map_add(global.text_data_en, "obj_maddummy_1259", "* Zły Manekin wygląda na&  zestresowanego.")
ds_map_add(global.text_data_en, "obj_maddummy_1313", "* Zły Manekin rozrzuca swoją&  bawełnę po całym oknie&  dialogowym.")
ds_map_add(global.text_data_en, "obj_maddummy_1329", "\E1HEJ GUYS!/%%")
ds_map_add(global.text_data_en, "obj_maddummy_1370", "\E0Głupcy^1.&Głupcy^1!&GŁUPCY!/")
ds_map_add(global.text_data_en, "obj_maddummy_1371", "\E1Pamiętacie jak&mówiłem żeby NIE&strzelać we mnie?/")
ds_map_add(global.text_data_en, "obj_maddummy_1372", "\E0Cóż.../")
ds_map_add(global.text_data_en, "obj_maddummy_1373", "\E3PORAŻKI^1!&ZWALNIAM WAS^1!&WSZYSCY JESTEŚ-&CIE ZASTĄPYWANI!!!/%%")
ds_map_add(global.text_data_en, "obj_maddummy_1414", "\E0Hahaha^1.&Hahaha^1!&HAHAHAHAHA!/")
ds_map_add(global.text_data_en, "obj_maddummy_1415", "Teraz zobaczysz&moją prawdziwą&moc:/")
ds_map_add(global.text_data_en, "obj_maddummy_1416", "Poleganie na osobach&które nie są do dupy!/%%")
ds_map_add(global.text_data_en, "obj_maddummy_1420", "* Mechaniczne brzdęki wypełniają&  pomieszczenie.")
ds_map_add(global.text_data_en, "obj_maddummy_1464", "\E2(N..^1. nie wierzę!)/")
ds_map_add(global.text_data_en, "obj_maddummy_1465", "\E2(Te boty są&jeszcze GORSZE&od tych zwkłych!)/")
ds_map_add(global.text_data_en, "obj_maddummy_1466", "\E3Nieważne^1.&Nieważne^1!&NIEWAŻNE!!/")
ds_map_add(global.text_data_en, "obj_maddummy_1467", "NIE POTRZEBUJĘ&PRZYJACIÓŁ!!!/%%")
ds_map_add(global.text_data_en, "obj_maddummy_1500", "\E3KIEDY MAM&NOŻE!!!/%%")
ds_map_add(global.text_data_en, "obj_maddummy_1539", "\E0Um..^1./")
ds_map_add(global.text_data_en, "obj_maddummy_1540", "\E2To był mój&jedyny./")
ds_map_add(global.text_data_en, "obj_maddummy_1541", "\E3ALE TO NIE&MA ZNACZENIA&!!!/")
ds_map_add(global.text_data_en, "obj_maddummy_1542", "NIE MOŻESZ MNIE&SKRZYWDZIĆ ANI&JA CIEBIE!/")
ds_map_add(global.text_data_en, "obj_maddummy_1543", "UTKNIESZ W&WALCE ZE MNĄ.../")
ds_map_add(global.text_data_en, "obj_maddummy_1544", "Na zawsze./")
ds_map_add(global.text_data_en, "obj_maddummy_1545", "Na zawsze!/")
ds_map_add(global.text_data_en, "obj_maddummy_1546", "NA ZAWSZE!!!!/")
ds_map_add(global.text_data_en, "obj_maddummy_1547", "AHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHA%")
ds_map_add(global.text_data_en, "obj_maddummy_1548", "AHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHA%")
ds_map_add(global.text_data_en, "obj_maddummy_1549", "AHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHA%")
ds_map_add(global.text_data_en, "obj_maddummy_1550", "AHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHAHA%")
ds_map_add(global.text_data_en, "obj_maddummy_1613", "\E2C..^1.&Co do&cholery!?/")
ds_map_add(global.text_data_en, "obj_maddummy_1614", "\E3Ergh^1!&Kwasowy&deszcz!?!/")
ds_map_add(global.text_data_en, "obj_maddummy_1615", "Eh^1, ZAPOMNIJ^1!&Spadam ztąd!/%%")
ds_map_add(global.text_data_en, "obj_maddummy_1654", "... sorry^1, &przerwałem ci^1,&czyż nie?/")
ds_map_add(global.text_data_en, "obj_maddummy_1655", "kiedy tylko &przyszełem^1, twój&kolega poszedł.../")
ds_map_add(global.text_data_en, "obj_maddummy_1656", "o nie..^1.&wyglądaliście^1,&lakbyście się&bawili.../")
ds_map_add(global.text_data_en, "obj_maddummy_1657", "o nie..^1.&po prostu chciałem&powiedzieć cześć.../")
ds_map_add(global.text_data_en, "obj_maddummy_1658", "o nie.................................................%%")
ds_map_add(global.text_data_en, "obj_maddummy_1663", "o chwila..^1. czy ty&mnie nie atakowałeś&wcześniej.../")
ds_map_add(global.text_data_en, "obj_maddummy_1664", "uhhh..^1.&troche siara./")
ds_map_add(global.text_data_en, "obj_maddummy_1665", "sorry^1.&miłego dnia./%%")
ds_map_add(global.text_data_en, "obj_mainend_158", "* (Dzyn^1, dzyn...)/")
ds_map_add(global.text_data_en, "obj_mainend_160", "* heya./")
ds_map_add(global.text_data_en, "obj_mainend_161", "\E1* is anyone there...?/")
ds_map_add(global.text_data_en, "obj_mainend_162", "\E2* well^1, i'll just leave&  a message.../%%")
ds_map_add(global.text_data_en, "obj_mainend_169", "\E1* is anyone there...?/")
ds_map_add(global.text_data_en, "obj_mainend_170", "\E2* well..^1. just calling&  to say./")
ds_map_add(global.text_data_en, "obj_mainend_171", "\E1* you made a snowman&  really happy./")
ds_map_add(global.text_data_en, "obj_mainend_172", "\E2* ... guess i should&  say something else^1,&  too./%%")
ds_map_add(global.text_data_en, "obj_mainend_177", "* heya./")
ds_map_add(global.text_data_en, "obj_mainend_178", "\E2* well..^1. just calling&  to say./")
ds_map_add(global.text_data_en, "obj_mainend_179", "\E1* it's been a while^1.&* shouldn't you SAVE?/")
ds_map_add(global.text_data_en, "obj_mainend_180", "\E2* ... guess i should&  say something else^1,&  too./%%")
ds_map_add(global.text_data_en, "obj_mainend_186", "\E1* is anyone there...?/")
ds_map_add(global.text_data_en, "obj_mainend_187", "\E2* well..^1. just calling&  to ask./")
ds_map_add(global.text_data_en, "obj_mainend_188", "\E1* did you ever take&  off that gross&  bandage...?/")
ds_map_add(global.text_data_en, "obj_mainend_189", "\E2* ... guess i should&  say something else^1,&  too./%%")
ds_map_add(global.text_data_en, "obj_mainend_195", "\E1* is anyone there...?/")
ds_map_add(global.text_data_en, "obj_mainend_196", "\E2* well..^1. just calling&  to ask./")
ds_map_add(global.text_data_en, "obj_mainend_197", "\E1* did you ever get&  something to eat?/")
ds_map_add(global.text_data_en, "obj_mainend_198", "\E2* ... guess i should&  say something else^1,&  too./%%")
ds_map_add(global.text_data_en, "obj_mainend_204", "\E1* is anyone there...?/")
ds_map_add(global.text_data_en, "obj_mainend_205", "\E2* well..^1. just calling&  to ask./")
ds_map_add(global.text_data_en, "obj_mainend_206", "\E1* you really like to&  challenge yourself^1,&  huh...?/")
ds_map_add(global.text_data_en, "obj_mainend_207", "\E2* well..^1. good job^1./")
ds_map_add(global.text_data_en, "obj_mainend_208", "\E1* just promise not to&  brag about it^1,&  okay?/")
ds_map_add(global.text_data_en, "obj_mainend_209", "\E2* ... guess i should&  say something else^1,&  too./%%")
ds_map_add(global.text_data_en, "obj_mainend_214", "* .../")
ds_map_add(global.text_data_en, "obj_mainend_215", "* alright^1, i've got the&  number./%%")
ds_map_add(global.text_data_en, "obj_mainend_250", "* so..^1.&* it's been a while./")
ds_map_add(global.text_data_en, "obj_mainend_251", "\E0* the queen returned^1, and&  is now ruling over&  the underground./")
ds_map_add(global.text_data_en, "obj_mainend_252", "* she's enstated a new&  policy.../")
ds_map_add(global.text_data_en, "obj_mainend_253", "\E3* all the humans who fall&  here will be treated&  not as enemies.../")
ds_map_add(global.text_data_en, "obj_mainend_254", "\E0* but as friends./")
ds_map_add(global.text_data_en, "obj_mainend_255", "\E1* it's probably for the&  best^1, anyway./")
ds_map_add(global.text_data_en, "obj_mainend_256", "\E0* the human souls the king&  gathered.../")
ds_map_add(global.text_data_en, "obj_mainend_257", "\E3* seem to have&  disappeared./")
ds_map_add(global.text_data_en, "obj_mainend_258", "\E1* so^1, uh^1, that plan&  ain't happening any&  time soon./")
ds_map_add(global.text_data_en, "obj_mainend_263", "* but even though people&  are heartbroken over&  the king.../")
ds_map_add(global.text_data_en, "obj_mainend_264", "\E1* ... and things are&  looking grim for our&  freedom.../")
ds_map_add(global.text_data_en, "obj_mainend_265", "\E0* the queen's trying her&  best not to let us&  give up hope./")
ds_map_add(global.text_data_en, "obj_mainend_267", "\E1* so^1, uh^1, hey.../")
ds_map_add(global.text_data_en, "obj_mainend_268", "\E1* if we're not giving&  up down here.../")
ds_map_add(global.text_data_en, "obj_mainend_269", "\E2* don't give up wherever&  you are^1, ok?/")
ds_map_add(global.text_data_en, "obj_mainend_270", "\E3* who knows how long&  it will take.../")
ds_map_add(global.text_data_en, "obj_mainend_271", "\E0* but we will get out&  of here./")
ds_map_add(global.text_data_en, "obj_mainend_272", "\E2* that's a promise./")
ds_map_add(global.text_data_en, "obj_mainend_274", "SANS!!!&WHO ARE YOU&TALKING TO???/")
ds_map_add(global.text_data_en, "obj_mainend_276", "* oh^1, nobody./")
ds_map_add(global.text_data_en, "obj_mainend_278", "WHAT!^1?&NOBODY!?/")
ds_map_add(global.text_data_en, "obj_mainend_279", "\E0CAN I TALK TO&THEM TOO???/")
ds_map_add(global.text_data_en, "obj_mainend_281", "* here^1, knock yourself&  out./%%")
ds_map_add(global.text_data_en, "obj_mainend_292", "WAIT A SECOND.../")
ds_map_add(global.text_data_en, "obj_mainend_293", "\E1I RECOGNIZE THIS&NUMBER!!!/")
ds_map_add(global.text_data_en, "obj_mainend_294", "\E0ATTENTION^1, HUMAN!/")
ds_map_add(global.text_data_en, "obj_mainend_295", "\E2I^1, THE GREAT&PAPYRUS.../")
ds_map_add(global.text_data_en, "obj_mainend_296", "\E0AM NOW CAPTAIN OF&THE ROYAL GUARD!/")
ds_map_add(global.text_data_en, "obj_mainend_297", "\E2IT'S EVERYTHING I'VE&EVER DREAMED OF.../")
ds_map_add(global.text_data_en, "obj_mainend_298", "\E3EXCEPT^1, INSTEAD&OF FIGHTING^1, WE&JUST WATER FLOWERS./")
ds_map_add(global.text_data_en, "obj_mainend_299", "\E0SO THAT'S EVER-&SO-SLIGHTLY&DIFFERENT./")
ds_map_add(global.text_data_en, "obj_mainend_300", "\E0AND^1, WE'RE HELPING&DR. ALPHYS&WITH HER RESEARCH!/")
ds_map_add(global.text_data_en, "obj_mainend_301", "\E0SHE'S GONNA FIND A&WAY TO GET US OUT&OF HERE./")
ds_map_add(global.text_data_en, "obj_mainend_302", "UNDYNE IS HELPING&HER TOO!/")
ds_map_add(global.text_data_en, "obj_mainend_303", "\E3THOUGH^1, TO BE&HONEST^1, HER METHOD&OF HELPING.../")
ds_map_add(global.text_data_en, "obj_mainend_304", "\E2SEEMS KIND OF.../")
ds_map_add(global.text_data_en, "obj_mainend_305", "\E3EXPLOSION-INDUCING./")
ds_map_add(global.text_data_en, "obj_mainend_306", "\E0BUT I THINK ALPHYS&LIKES HAVING HER&AROUND./")
ds_map_add(global.text_data_en, "obj_mainend_307", "\E5UH OH!!!/%%")
ds_map_add(global.text_data_en, "obj_mainend_311", "\E0HEY!!^1! HUMAN!!!/")
ds_map_add(global.text_data_en, "obj_mainend_312", "HOW ARE YOU DOING^1?&I'M DOING FINE!!!/")
ds_map_add(global.text_data_en, "obj_mainend_313", "\E3WELL, BESIDES ONE&THING.../")
ds_map_add(global.text_data_en, "obj_mainend_314", "\E3THE QUEEN&DISBANDED THE&ROYAL GUARD./")
ds_map_add(global.text_data_en, "obj_mainend_315", "SINCE WE DON'T&HAVE TO FIGHT&HUMANS ANYMORE./")
ds_map_add(global.text_data_en, "obj_mainend_316", "\E0WOW!!!/")
ds_map_add(global.text_data_en, "obj_mainend_317", "\E3I HAVE NO IDEA&WHAT TO DO&WITH MY LIFE./")
ds_map_add(global.text_data_en, "obj_mainend_318", "\E0BUT^1, THAT'S&OKAY!/")
ds_map_add(global.text_data_en, "obj_mainend_319", "BECAUSE I'M&STILL WORKING&HARD!/")
ds_map_add(global.text_data_en, "obj_mainend_320", "\E4EVEN IF IT'S&ON NOTHING AT&ALL!/")
ds_map_add(global.text_data_en, "obj_mainend_321", "\E0SO DON'T FEEL&BAD!/")
ds_map_add(global.text_data_en, "obj_mainend_322", "PAPYRUS IS FINE!/")
ds_map_add(global.text_data_en, "obj_mainend_323", "\E5UNDYNE IS THE&ONE THAT'S GOT&IT BAD!/")
ds_map_add(global.text_data_en, "obj_mainend_324", "\E3SHE LOST HER&JOB.../")
ds_map_add(global.text_data_en, "obj_mainend_325", "THEN SHE LOST&HER HOUSE.../")
ds_map_add(global.text_data_en, "obj_mainend_326", "\E2IT WAS SAD..^1.&BUT WE'RE TAKING&CARE OF HER!/")
ds_map_add(global.text_data_en, "obj_mainend_327", "\E0SHE LIVES ON&OUR COUCH NOW./")
ds_map_add(global.text_data_en, "obj_mainend_328", "IT'S LIKE A&SLEEPOVER EVERY&NIGHT!/")
ds_map_add(global.text_data_en, "obj_mainend_329", "A SLEEPOVER&THERE'S NO&ESCAPE FROM./")
ds_map_add(global.text_data_en, "obj_mainend_330", "OH^1, WE GAVE HER&A JOB^1, TOO./")
ds_map_add(global.text_data_en, "obj_mainend_331", "\E3SANS HIRED HER AT&HIS ILLEGAL HOT&DOG STAND./")
ds_map_add(global.text_data_en, "obj_mainend_332", "\E5SHE HATES WORKING&THERE!/")
ds_map_add(global.text_data_en, "obj_mainend_333", "\E3BUT SHE MAKES&A MEAN HOT DOG./")
ds_map_add(global.text_data_en, "obj_mainend_334", "\E3.../")
ds_map_add(global.text_data_en, "obj_mainend_335", "\E5OH YEAH./")
ds_map_add(global.text_data_en, "obj_mainend_338", "I DON'T KNOW HOW&TO PUT THIS^1,&BUT.../")
ds_map_add(global.text_data_en, "obj_mainend_339", "\E3SHE^1, UM^1, REALLY&HATES YOU NOW./")
ds_map_add(global.text_data_en, "obj_mainend_340", "\E6EVEN MORE THAN&SHE EVER HAS./")
ds_map_add(global.text_data_en, "obj_mainend_341", "IT'S BECAUSE SHE&MADE FRIENDS WITH&YOU^1, THEN.../")
ds_map_add(global.text_data_en, "obj_mainend_342", "\E5SHE SAID YOU&KILLED SOMEONE?/")
ds_map_add(global.text_data_en, "obj_mainend_343", "\E3I KNOW^1, THAT&SOUNDS RIDICULOUS&DOESN'T IT?/")
ds_map_add(global.text_data_en, "obj_mainend_344", "\E6BUT SHE FEELS SO&HURT AND BETRAYED./")
ds_map_add(global.text_data_en, "obj_mainend_345", "AND ANGRY AT&HERSELF^1, TOO./")
ds_map_add(global.text_data_en, "obj_mainend_346", "SHE SAYS.../")
ds_map_add(global.text_data_en, "obj_mainend_347", "SHE DOESN'T&UNDERSTAND WHY.../")
ds_map_add(global.text_data_en, "obj_mainend_348", "SHE EVER LET&HERSELF BECOME&FRIENDS WITH YOU./")
ds_map_add(global.text_data_en, "obj_mainend_349", "THAT SHE KNEW&WHAT HUMANS WERE&LIKE.../")
ds_map_add(global.text_data_en, "obj_mainend_350", "\E3AND YET SHE&STILL FAILED TO&RESIST./")
ds_map_add(global.text_data_en, "obj_mainend_351", "\E6MORE PEOPLE GOT&HURT BECAUSE OF&HER MISTAKE./")
ds_map_add(global.text_data_en, "obj_mainend_352", "\E5I REALLY CAN'T&UNDERSTATE./")
ds_map_add(global.text_data_en, "obj_mainend_353", "HOW MUCH SHE&HATES YOU./")
ds_map_add(global.text_data_en, "obj_mainend_354", "\E6IT PAINS ME TO&SAY THIS^1, BUT.../")
ds_map_add(global.text_data_en, "obj_mainend_355", "YOU SHOULD&PROBABLY NEVER&COME BACK HERE./")
ds_map_add(global.text_data_en, "obj_mainend_356", "\E3IF YOU DO^1, UNDYNE&WILL DEFINITELY&DESTROY YOU./")
ds_map_add(global.text_data_en, "obj_mainend_357", "\E5NOT EVEN THE QUEEN&CAN STOP HER./")
ds_map_add(global.text_data_en, "obj_mainend_358", "\E6SO^1, UH..^1.&GOODBYE FOREVER./")
ds_map_add(global.text_data_en, "obj_mainend_359", "I'LL MISS YOU^1,&MY FRIEND./%%")
ds_map_add(global.text_data_en, "obj_mainend_364", "\E5AND YOU MADE&ASGORE DISAPPEAR?/")
ds_map_add(global.text_data_en, "obj_mainend_365", "\E3AND MADE ALPHYS&DISAPPEAR^1, TOO./")
ds_map_add(global.text_data_en, "obj_mainend_366", "\E6SHE'S NOT VERY&HAPPY./")
ds_map_add(global.text_data_en, "obj_mainend_367", "SHE SAYS THINGS&LIKE.../")
ds_map_add(global.text_data_en, "obj_mainend_368", '"' + "I COULDN'T PROTECT&HER.../" + '"')
ds_map_add(global.text_data_en, "obj_mainend_369", "IT'S HARD TO GET&HER TO DO ANYTHING&NOW./")
ds_map_add(global.text_data_en, "obj_mainend_370", "\E5I EVEN SUGGESTED&WE TRY TO GET&REVENGE ON YOU./")
ds_map_add(global.text_data_en, "obj_mainend_371", "\E0YOU KNOW^1, SO I&COULD SEE YOU&AGAIN./")
ds_map_add(global.text_data_en, "obj_mainend_372", "\E5BUT SHE JUST&LOOKED AT ME AND&SAID.../")
ds_map_add(global.text_data_en, "obj_mainend_373", "\E6REVENGE WON'T BRING&ANYBODY BACK./")
ds_map_add(global.text_data_en, "obj_mainend_374", "\E3I HAVE NO IDEA&WHAT YOU DID^1,&BUT.../")
ds_map_add(global.text_data_en, "obj_mainend_375", "\E5CAN YOU PLEASE&BRING BACK HER&FRIENDS?/")
ds_map_add(global.text_data_en, "obj_mainend_376", "IF YOU MADE THEM&DISAPPEAR?/")
ds_map_add(global.text_data_en, "obj_mainend_377", "\E6PLEASE.../")
ds_map_add(global.text_data_en, "obj_mainend_378", "UNDYNE'S NOT&DOING VERY WELL./")
ds_map_add(global.text_data_en, "obj_mainend_379", "BYE./%%")
ds_map_add(global.text_data_en, "obj_mainend_385", "\E3SHE STILL BLAMES&YOU.../")
ds_map_add(global.text_data_en, "obj_mainend_386", "\E3FOR THE&DISAPPEARANCE&OF ASGORE./")
ds_map_add(global.text_data_en, "obj_mainend_387", "\E3.../")
ds_map_add(global.text_data_en, "obj_mainend_388", "\E3SHE TALKS TO ME&A LOT.../")
ds_map_add(global.text_data_en, "obj_mainend_389", "\E5ABOUT GETTING&REVENGE ON YOU./")
ds_map_add(global.text_data_en, "obj_mainend_390", "SHE HAS A&LUDICROUS PLAN.../")
ds_map_add(global.text_data_en, "obj_mainend_391", "TO CROSS THE&BARRIER AND&BEAT YOU UP./")
ds_map_add(global.text_data_en, "obj_mainend_392", "\E3TO BE HONEST^1,&I THINK IT'S&IMPOSSIBLE./")
ds_map_add(global.text_data_en, "obj_mainend_393", "\E0BUT I'D LIKE TO&BELIEVE IT'S&NOT!!!/")
ds_map_add(global.text_data_en, "obj_mainend_394", "CAUSE I WANT TO&GO WITH HER!/")
ds_map_add(global.text_data_en, "obj_mainend_395", "THEN I'D GET TO&SEE YOU AGAIN!/")
ds_map_add(global.text_data_en, "obj_mainend_396", "\E3EVEN IF I'D HAVE&TO FIGHT YOU./")
ds_map_add(global.text_data_en, "obj_mainend_397", "\E0WELL^1, KEEP YOUR&FINGERS CROSSED!/")
ds_map_add(global.text_data_en, "obj_mainend_398", "AND KEEP IN&TOUCH.../")
ds_map_add(global.text_data_en, "obj_mainend_399", "IT'LL MAKE OUR&PLANS EASIER./")
ds_map_add(global.text_data_en, "obj_mainend_400", "BYE!/%%")
ds_map_add(global.text_data_en, "obj_mainend_404", "\E5AND ALPHYS'&DISAPPEARANCE^1, TOO./")
ds_map_add(global.text_data_en, "obj_mainend_405", "\E3SHE'S NOT VERY&HAPPY./")
ds_map_add(global.text_data_en, "obj_mainend_406", "\E6SHE SAYS THINGS&LIKE.../")
ds_map_add(global.text_data_en, "obj_mainend_407", '"' + "I COULDN'T PROTECT&HER.../" + '"')
ds_map_add(global.text_data_en, "obj_mainend_408", "IT'S HARD TO GET&HER TO DO ANYTHING&NOW./")
ds_map_add(global.text_data_en, "obj_mainend_409", "\E5I EVEN SUGGESTED&WE TRY TO GET&REVENGE ON YOU./")
ds_map_add(global.text_data_en, "obj_mainend_410", "\E0YOU KNOW^1, SO I&COULD SEE YOU&AGAIN./")
ds_map_add(global.text_data_en, "obj_mainend_411", "\E3BUT SHE JUST&LOOKED AT ME AND&SAID.../")
ds_map_add(global.text_data_en, "obj_mainend_412", "\E6REVENGE WON'T BRING&ANYBODY BACK./")
ds_map_add(global.text_data_en, "obj_mainend_413", "I HAVE NO IDEA&WHAT YOU DID^1,&BUT.../")
ds_map_add(global.text_data_en, "obj_mainend_414", "\E5CAN YOU PLEASE&BRING BACK HER&FRIENDS?/")
ds_map_add(global.text_data_en, "obj_mainend_415", "IF YOU MADE THEM&DISAPPEAR?/")
ds_map_add(global.text_data_en, "obj_mainend_416", "\E6PLEASE.../")
ds_map_add(global.text_data_en, "obj_mainend_417", "UNDYNE'S NOT&DOING VERY WELL./")
ds_map_add(global.text_data_en, "obj_mainend_418", "BYE./%%")
ds_map_add(global.text_data_en, "obj_mainend_434", "* Hey^1!&* What are you up&  to^1, punk!?/")
ds_map_add(global.text_data_en, "obj_mainend_435", "\E1* Ngahhhh!/")
ds_map_add(global.text_data_en, "obj_mainend_437", "PLEASE DON'T NOOGIE&THE PHONE./")
ds_map_add(global.text_data_en, "obj_mainend_439", "\E2* Hey^1!&* Who's in charge&  here!?/")
ds_map_add(global.text_data_en, "obj_mainend_441", "ME./")
ds_map_add(global.text_data_en, "obj_mainend_443", "* Oh..^1. yeah^1, that's&  right!/")
ds_map_add(global.text_data_en, "obj_mainend_444", "\E0* I quit my job as&  leader of the Royal&  Guard./")
ds_map_add(global.text_data_en, "obj_mainend_445", "\E4* Actually^1, since we&  won't be fighting&  anymore.../")
ds_map_add(global.text_data_en, "obj_mainend_446", "\E1* The Royal Guard&  totally disbanded./")
ds_map_add(global.text_data_en, "obj_mainend_447", "\E9* There's^1, uh^1, only&  one member now./")
ds_map_add(global.text_data_en, "obj_mainend_449", "BUT HE'S EXTREMELY&GOOD./")
ds_map_add(global.text_data_en, "obj_mainend_451", "* Yeah!^1! He is!!^1!&* C'mere!!/")
ds_map_add(global.text_data_en, "obj_mainend_453", "PLEASE DON'T NOOGIE&THE SKELETON./")
ds_map_add(global.text_data_en, "obj_mainend_455", "* Anyways^1, now I'm&  working as Alphy's&  lab assistant.../")
ds_map_add(global.text_data_en, "obj_mainend_456", "\E2* We're gonna find a&  way out of this dump&  once and for all!!/")
ds_map_add(global.text_data_en, "obj_mainend_457", "\E9* Oh^1, yeah^1, and I'm a&  gym teacher at the&  queen's new school./")
ds_map_add(global.text_data_en, "obj_mainend_458", "\E6* Did you know I can&  bench-press seven&  children!?/")
ds_map_add(global.text_data_en, "obj_mainend_459", "\E9* Awesome^1, right?/")
ds_map_add(global.text_data_en, "obj_mainend_460", "* .../")
ds_map_add(global.text_data_en, "obj_mainend_461", "\E0* Hey./")
ds_map_add(global.text_data_en, "obj_mainend_462", "\E4* I'm sorry about what&  happened with ASGORE./")
ds_map_add(global.text_data_en, "obj_mainend_463", "\E4* You were just doing&  what you had to./")
ds_map_add(global.text_data_en, "obj_mainend_464", "* It's not your fault&  he.../")
ds_map_add(global.text_data_en, "obj_mainend_465", "* .../")
ds_map_add(global.text_data_en, "obj_mainend_466", "\E7* Ah^1, darn it./")
ds_map_add(global.text_data_en, "obj_mainend_467", "* I miss the big guy./")
ds_map_add(global.text_data_en, "obj_mainend_469", "\E7* .../")
ds_map_add(global.text_data_en, "obj_mainend_470", "\E1* Come on^1, Undyne^1!&* Snap out of it!/")
ds_map_add(global.text_data_en, "obj_mainend_471", "\E4* Uh^1, I guess I'll&  tell you how Alphys&  is doing./")
ds_map_add(global.text_data_en, "obj_mainend_472", "\E0* Well^1, she's the&  same as ever./")
ds_map_add(global.text_data_en, "obj_mainend_473", "\E4* Maybe a little more&  reclusive than&  normal./")
ds_map_add(global.text_data_en, "obj_mainend_474", "\E7* Seems like something's&  really bothering&  her.../")
ds_map_add(global.text_data_en, "obj_mainend_475", "\E1* But she can get&  through it!/")
ds_map_add(global.text_data_en, "obj_mainend_476", "\E2* I'm there supporting&  her!!/")
ds_map_add(global.text_data_en, "obj_mainend_477", "\E9* That's what friends&  are for^1, right?/")
ds_map_add(global.text_data_en, "obj_mainend_478", "\E9* .../")
ds_map_add(global.text_data_en, "obj_mainend_479", "\E0* Hey^1, where-ever you&  are.../")
ds_map_add(global.text_data_en, "obj_mainend_480", "\E4* I hope it's better&  than here./")
ds_map_add(global.text_data_en, "obj_mainend_481", "\E7* It took a lot of&  sacrifice for you&  to get there.../")
ds_map_add(global.text_data_en, "obj_mainend_482", "* So^1, where-ever you&  are.../")
ds_map_add(global.text_data_en, "obj_mainend_483", "\E6* You have to try to&  be happy^1, okay!?/")
ds_map_add(global.text_data_en, "obj_mainend_484", "\E2* For our sakes!/")
ds_map_add(global.text_data_en, "obj_mainend_485", "\E0* We'll feel better&  knowing our trouble&  was worth it./")
ds_map_add(global.text_data_en, "obj_mainend_486", "\E9* We're all with you^1!&* Everyone is^1!&* Even the queen!/")
ds_map_add(global.text_data_en, "obj_mainend_487", "\E1* .../")
ds_map_add(global.text_data_en, "obj_mainend_488", "\E2* HEYYY^1!&* WAIT a second!/")
ds_map_add(global.text_data_en, "obj_mainend_489", "\E6* TORIEL^1!&* TORIEL^1!&* Do you wanna...?/")
ds_map_add(global.text_data_en, "obj_mainend_490", "\E1* .../")
ds_map_add(global.text_data_en, "obj_mainend_491", "\E9* Heh^1, she says&  she's busy./")
ds_map_add(global.text_data_en, "obj_mainend_493", "BUT IF SHE KNEW&WHO WE WERE&TALKING TO.../")
ds_map_add(global.text_data_en, "obj_mainend_495", "* we wouldn't get the&  phone back for at&  least a few hours./")
ds_map_add(global.text_data_en, "obj_mainend_497", "WE HAVE THE&MERCY TO SPARE&YOU FROM HER!!/")
ds_map_add(global.text_data_en, "obj_mainend_499", "* But call back any&  time^1, ok?!&* She'd love to talk!/")
ds_map_add(global.text_data_en, "obj_mainend_501", "* oh^1, whoops./")
ds_map_add(global.text_data_en, "obj_mainend_502", "\E0* this thing's almost&  outta batteries./")
ds_map_add(global.text_data_en, "obj_mainend_503", "\E1* so^1, hate to cut this&  short^1, but.../")
ds_map_add(global.text_data_en, "obj_mainend_504", "\E2* be seeing you^1, ok^1,&  buddy?/")
ds_map_add(global.text_data_en, "obj_mainend_506", "BYE BYE FOR NOW!/")
ds_map_add(global.text_data_en, "obj_mainend_508", "* See ya^1, punk!/%%")
ds_map_add(global.text_data_en, "obj_mainend_524", "* H-hey^1, Undyne^1, are&  you okay...?/")
ds_map_add(global.text_data_en, "obj_mainend_526", "* I'm fine^1.&* Why don't you talk&  for a while?/")
ds_map_add(global.text_data_en, "obj_mainend_528", "* U..^1. uh^1, okay!/%%")
ds_map_add(global.text_data_en, "obj_mainend_541", "* Man^1, she's tsundere.../")
ds_map_add(global.text_data_en, "obj_mainend_542", "\E1* .../")
ds_map_add(global.text_data_en, "obj_mainend_543", "\E2* .../")
ds_map_add(global.text_data_en, "obj_mainend_544", "\E7* Um^1, hi.../")
ds_map_add(global.text_data_en, "obj_mainend_545", "\E4* S-sorry^1, I hate&  talking on the&  phone./")
ds_map_add(global.text_data_en, "obj_mainend_546", "\E3* I don't really know&  what to say./")
ds_map_add(global.text_data_en, "obj_mainend_547", "\E1* .../")
ds_map_add(global.text_data_en, "obj_mainend_548", "\E7* Hey^1, why didn't you&  tell me the queen&  was so cute?/")
ds_map_add(global.text_data_en, "obj_mainend_549", "\E3* Uh^1, I mean^1, uh.../")
ds_map_add(global.text_data_en, "obj_mainend_550", "\E6* Mettaton's doing OK!/")
ds_map_add(global.text_data_en, "obj_mainend_551", "* And^1! Um!/")
ds_map_add(global.text_data_en, "obj_mainend_552", "\E6* I'm trying to figure&  a way for us to&  get out of here!/")
ds_map_add(global.text_data_en, "obj_mainend_553", "\E4* B-but I kinda have&  no idea what I'm&  doing./")
ds_map_add(global.text_data_en, "obj_mainend_554", "\E0* I'll figure it out&  eventually^1, though./")
ds_map_add(global.text_data_en, "obj_mainend_555", "\E3* The queen is a lot&  different from&  ASGORE.../")
ds_map_add(global.text_data_en, "obj_mainend_556", "\E7* She actually checks to&  see if I'm doing&  anything./")
ds_map_add(global.text_data_en, "obj_mainend_557", "\E0* She's really turned&  this whole place&  around!/")
ds_map_add(global.text_data_en, "obj_mainend_558", "\E2* .../")
ds_map_add(global.text_data_en, "obj_mainend_559", "\E3* Oh^1!&* Hey^1!&* Wait a second!/")
ds_map_add(global.text_data_en, "obj_mainend_560", "\E0* Hey^1! TORIEL^1!&* Do you wanna talk&  to...?/")
ds_map_add(global.text_data_en, "obj_mainend_561", "\E1* .../")
ds_map_add(global.text_data_en, "obj_mainend_562", "\E0* Well^1, she says she's&  busy./")
ds_map_add(global.text_data_en, "obj_mainend_564", "* Oh^1, she SAYS she's&  busy./")
ds_map_add(global.text_data_en, "obj_mainend_566", "IF SHE KNEW WHO&WE WERE TALKING&TO.../")
ds_map_add(global.text_data_en, "obj_mainend_568", "* we wouldn't get the&  phone back for at&  least a few hours./")
ds_map_add(global.text_data_en, "obj_mainend_570", "WE HAVE THE&MERCY TO SPARE&YOU FROM HER!!/")
ds_map_add(global.text_data_en, "obj_mainend_572", "* B-but^1, if you want&  to^1, call and talk&  to her any time./")
ds_map_add(global.text_data_en, "obj_mainend_574", "* Yeah^1!&* She'd be happy to&  hear from ya!/")
ds_map_add(global.text_data_en, "obj_mainend_576", "* oh^1, whoops./")
ds_map_add(global.text_data_en, "obj_mainend_577", "\E0* this thing's almost&  outta batteries./")
ds_map_add(global.text_data_en, "obj_mainend_578", "\E1* so^1, hate to cut this&  short^1, but.../")
ds_map_add(global.text_data_en, "obj_mainend_579", "\E2* be seeing you^1, ok^1,&  buddy?/")
ds_map_add(global.text_data_en, "obj_mainend_581", "BYE BYE FOR NOW!/")
ds_map_add(global.text_data_en, "obj_mainend_583", "* See ya^1, punk!/")
ds_map_add(global.text_data_en, "obj_mainend_585", "* G-good..^1.&* Good.../")
ds_map_add(global.text_data_en, "obj_mainend_586", "\E4* Hey^1, why do I&  have to be the one&  to hang up?/")
ds_map_add(global.text_data_en, "obj_mainend_587", "\E7* Eheheh..^1.&* I hate goodbyes.../")
ds_map_add(global.text_data_en, "obj_mainend_588", "\E3* Um^1, we'll see you&  again someday!/%%")
ds_map_add(global.text_data_en, "obj_mainend_612", "* (Klik...)/%%")
ds_map_add(global.text_data_en, "obj_mainend_650", "* so..^1.&* it's been a while./")
ds_map_add(global.text_data_en, "obj_mainend_651", "\E0* the queen returned^1, and&  attempted to resume&  ruling the underground./")
ds_map_add(global.text_data_en, "obj_mainend_652", "* she enstated a new&  policy.../")
ds_map_add(global.text_data_en, "obj_mainend_653", "\E3* all the humans who fall&  here would be treated&  not as enemies.../")
ds_map_add(global.text_data_en, "obj_mainend_654", "\E0* but as friends./")
ds_map_add(global.text_data_en, "obj_mainend_655", "\E3* .../")
ds_map_add(global.text_data_en, "obj_mainend_656", "\E1* but people REALLY&  didn't like that&  policy./")
ds_map_add(global.text_data_en, "obj_mainend_665", "\E0* because of you^1, not&  only was the king&  gone.../")
ds_map_add(global.text_data_en, "obj_mainend_666", "\E3* but the human souls&  had gone missing as&  well.../")
ds_map_add(global.text_data_en, "obj_mainend_667", "* along with the lives&  of countless citizens./")
ds_map_add(global.text_data_en, "obj_mainend_669", "* along with the life&  of.../")
ds_map_add(global.text_data_en, "obj_mainend_671", "* along with the life&  of undyne^1, their&  greatest hero./")
ds_map_add(global.text_data_en, "obj_mainend_673", "* along with the lives&  of countless citizens./")
ds_map_add(global.text_data_en, "obj_mainend_674", "* nobody wanted to see&  that happen ever again./")
ds_map_add(global.text_data_en, "obj_mainend_675", "\E0* so the people started&  a rebellion to&  overthrow the queen./")
ds_map_add(global.text_data_en, "obj_mainend_676", "\E2* but^1, she^1, uh^1, pretty&  much gave up peacefully&  when she realized./")
ds_map_add(global.text_data_en, "obj_mainend_677", "\E1* so she went back&  to the ruins./")
ds_map_add(global.text_data_en, "obj_mainend_678", "\E0* the underground's&  basically an uneasy&  anarchy now./")
ds_map_add(global.text_data_en, "obj_mainend_679", "\E0* everyone's trying to&  live life like they&  always have.../")
ds_map_add(global.text_data_en, "obj_mainend_680", "\E3* but it's not really&  easy^1, you know?/")
ds_map_add(global.text_data_en, "obj_mainend_681", "* when all of your&  hope has pretty much&  been thrown away.../%%")
ds_map_add(global.text_data_en, "obj_mainend_682", "* .../%%")
ds_map_add(global.text_data_en, "obj_mainend_688", "\E1* undyne spearheaded&  the revolution^1, of&  course./")
ds_map_add(global.text_data_en, "obj_mainend_691", "\E3* she was pretty mad&  after what happened&  to asgore./")
ds_map_add(global.text_data_en, "obj_mainend_695", "\E3* she was pretty mad&  after what happened&  to asgore and alphys./")
ds_map_add(global.text_data_en, "obj_mainend_697", "\E1* she threw the queen&  out of the castle&  with her strength./")
ds_map_add(global.text_data_en, "obj_mainend_698", "\E0* then she became the&  empress of the&  underground.../")
ds_map_add(global.text_data_en, "obj_mainend_699", "* and banished the&  queen back to the&  ruins./")
ds_map_add(global.text_data_en, "obj_mainend_700", "\E1* seems like undyne's..^1.&* hmmm.../")
ds_map_add(global.text_data_en, "obj_mainend_701", "\E3* even more vehement&  about destroying&  humanity than ASGORE./")
ds_map_add(global.text_data_en, "obj_mainend_702", "\E1* .../%%")
ds_map_add(global.text_data_en, "obj_mainend_716", "\E2* but hey^1!&* it's not all bad!/")
ds_map_add(global.text_data_en, "obj_mainend_717", "\E0* she's not so lonely&  anymore./")
ds_map_add(global.text_data_en, "obj_mainend_718", "\E1* me and papyrus go&  and visit her.../")
ds_map_add(global.text_data_en, "obj_mainend_719", "\E0* we bring her books&  from the library^1,&  or play games.../")
ds_map_add(global.text_data_en, "obj_mainend_720", "\E2* we've even convinced&  her to leave&  sometimes./")
ds_map_add(global.text_data_en, "obj_mainend_721", "\E1* as long as me or&  papyrus stay behind&  to watch for humans./")
ds_map_add(global.text_data_en, "obj_mainend_722", "\E2* but papyrus loves&  doing that./")
ds_map_add(global.text_data_en, "obj_mainend_724", "YEAH!!^1!&I LOVE STANDING IN&FOR THE QUEEN!!!/")
ds_map_add(global.text_data_en, "obj_mainend_725", "I'VE BEEN PRACTICING&FOR WHEN A HUMAN&COMES./")
ds_map_add(global.text_data_en, "obj_mainend_726", "I'M GOING TO BE&A GREAT MOM!!!/")
ds_map_add(global.text_data_en, "obj_mainend_727", "\E3BY THE WAY^1,&WHO ARE YOU&TALKING TO?/")
ds_map_add(global.text_data_en, "obj_mainend_729", "* oh^1, nobody./")
ds_map_add(global.text_data_en, "obj_mainend_731", "OH, COOL^1.&TELL THEM I SAY&HI!!!/")
ds_map_add(global.text_data_en, "obj_mainend_733", "* papyrus says hi./")
ds_map_add(global.text_data_en, "obj_mainend_734", "\E0* well^1, i hope things&  are better where&  you are./")
ds_map_add(global.text_data_en, "obj_mainend_735", "\E2* later./%%")
ds_map_add(global.text_data_en, "obj_mainend_740", "\E2* but hey^1!&* it's not all bad!/")
ds_map_add(global.text_data_en, "obj_mainend_741", "\E1* when the queen went&  back to the ruins.../")
ds_map_add(global.text_data_en, "obj_mainend_742", "\E2* i decided to go&  with her./")
ds_map_add(global.text_data_en, "obj_mainend_743", "\E1* and i took out some&  books from the&  library^1, too./")
ds_map_add(global.text_data_en, "obj_mainend_744", "\E1* so she won't have&  to read the same&  ones./")
ds_map_add(global.text_data_en, "obj_mainend_745", "\E0* she's a good roomie^1.&* we have a lot of&  fun./")
ds_map_add(global.text_data_en, "obj_mainend_746", "\E1* .../")
ds_map_add(global.text_data_en, "obj_mainend_747", "\E1* you know./")
ds_map_add(global.text_data_en, "obj_mainend_748", "\E1* sometimes the queen&  talks about.../")
ds_map_add(global.text_data_en, "obj_mainend_749", "\E0* how she'd like to&  see you again./")
ds_map_add(global.text_data_en, "obj_mainend_750", "\E1* isn't that nice?/")
ds_map_add(global.text_data_en, "obj_mainend_751", "\E3* .../")
ds_map_add(global.text_data_en, "obj_mainend_752", "\E3* i don't have the&  heart to tell her&  what you did./")
ds_map_add(global.text_data_en, "obj_mainend_753", "\E0* do you know how she'd&  react?/")
ds_map_add(global.text_data_en, "obj_mainend_754", "\E3* if i told her that&  'cause she protected&  you.../")
ds_map_add(global.text_data_en, "obj_mainend_755", "\E4* ... you went on to&  kill my brother...?/")
ds_map_add(global.text_data_en, "obj_mainend_756", "\E3* .../")
ds_map_add(global.text_data_en, "obj_mainend_757", "\E1* anyway^1, never come&  back here./")
ds_map_add(global.text_data_en, "obj_mainend_758", "\E0* you are not welcome./")
ds_map_add(global.text_data_en, "obj_mainend_759", "\E2* later./%%")
ds_map_add(global.text_data_en, "obj_mainend_784", "* since you left^1,&  things down here.../")
ds_map_add(global.text_data_en, "obj_mainend_785", "\E3* are different./")
ds_map_add(global.text_data_en, "obj_mainend_786", "* with ASGORE gone.../")
ds_map_add(global.text_data_en, "obj_mainend_787", "\E0* undyne became the&  ruler of the&  underground./")
ds_map_add(global.text_data_en, "obj_mainend_788", "\E3* she's decided to&  destroy every human&  that comes here./")
ds_map_add(global.text_data_en, "obj_mainend_789", "\E3* and since the human&  souls disappeared.../")
ds_map_add(global.text_data_en, "obj_mainend_790", "\E0* she's also looking&  for a new way to&  break the barrier.../")
ds_map_add(global.text_data_en, "obj_mainend_791", "* and when she does^1,&  she's going to wage&  war on humanity./")
ds_map_add(global.text_data_en, "obj_mainend_792", "\E1* i mean^1, that was&  asgore's plan^1, too./")
ds_map_add(global.text_data_en, "obj_mainend_793", "\E2* but he was really^1,&  uh^1, bad at it./")
ds_map_add(global.text_data_en, "obj_mainend_794", "\E0* undyne has also&  expanded the royal&  guard massively./")
ds_map_add(global.text_data_en, "obj_mainend_795", "* she says the first&  thing she'll do after&  we get out of here.../")
ds_map_add(global.text_data_en, "obj_mainend_796", "* is take her army.../")
ds_map_add(global.text_data_en, "obj_mainend_797", "\E3* and personally hunt&  you down and destroy&  you./")
ds_map_add(global.text_data_en, "obj_mainend_801", "\E1* meanwhile.../")
ds_map_add(global.text_data_en, "obj_mainend_802", "* i've been knocking&  on the door to&  the RUINs.../")
ds_map_add(global.text_data_en, "obj_mainend_803", "\E3* but the woman that's&  there hasn't been&  answering me./")
ds_map_add(global.text_data_en, "obj_mainend_804", "\E1* maybe she's not&  feeling well?/")
ds_map_add(global.text_data_en, "obj_mainend_805", "\E3* heh./")
ds_map_add(global.text_data_en, "obj_mainend_806", "\E4* or maybe she's not&  feeling anything at&  all...?/")
ds_map_add(global.text_data_en, "obj_mainend_807", "\E4* you'd better watch&  yourself^1, kid./")
ds_map_add(global.text_data_en, "obj_mainend_808", "\E4* things are lookin&  real bad for you./%%")
ds_map_add(global.text_data_en, "obj_mainend_813", "\E1* meanwhile.../")
ds_map_add(global.text_data_en, "obj_mainend_814", "\E3* i've been knocking on&  the door to the&  RUINS.../")
ds_map_add(global.text_data_en, "obj_mainend_815", "\E3* but that woman hasn't&  been answering me.../")
ds_map_add(global.text_data_en, "obj_mainend_816", "\E1* maybe she's not&  feeling well?/")
ds_map_add(global.text_data_en, "obj_mainend_818", "HEY^1, SANS^1, WHO ARE&YOU TALKING TO?/")
ds_map_add(global.text_data_en, "obj_mainend_820", "* oh^1, just the human./")
ds_map_add(global.text_data_en, "obj_mainend_822", "OH^1, COOL./")
ds_map_add(global.text_data_en, "obj_mainend_823", "\E3.../")
ds_map_add(global.text_data_en, "obj_mainend_824", "\E5WAIT, DID YOU&SAY THE HUMAN!?/")
ds_map_add(global.text_data_en, "obj_mainend_825", "\E0CAN I TALK TO&THEM???/")
ds_map_add(global.text_data_en, "obj_mainend_827", "* sure^1, knock yourself&  out./")
ds_map_add(global.text_data_en, "obj_mainend_829", "HEY!!^1!&UNDYNE'S THE&EMPRESS NOW!!/")
ds_map_add(global.text_data_en, "obj_mainend_830", "IT'S AMAZING!!!/")
ds_map_add(global.text_data_en, "obj_mainend_831", "AND SHE APPOINTED&ME TO BE.../")
ds_map_add(global.text_data_en, "obj_mainend_832", "THE MOST IMPORTANT&ROYAL POSITION!!!/")
ds_map_add(global.text_data_en, "obj_mainend_833", "\E3.../")
ds_map_add(global.text_data_en, "obj_mainend_834", "\E3THAT'S IT^1.&THAT'S LITERALLY&THE TITLE./")
ds_map_add(global.text_data_en, "obj_mainend_835", "\E0WHAT DO I DO?/")
ds_map_add(global.text_data_en, "obj_mainend_836", "\E3SHE TOLD ME TO^1,&UM.../")
ds_map_add(global.text_data_en, "obj_mainend_837", "\E3STAND AROUND AND&LOOK CUTE./")
ds_map_add(global.text_data_en, "obj_mainend_838", "\E0WELL!!^1!&THAT'S THE PERFECT&JOB FOR ME!!!/")
ds_map_add(global.text_data_en, "obj_mainend_839", "I DO THAT ALL THE&TIME^1, WITHOUT&TRYING!!/")
ds_map_add(global.text_data_en, "obj_mainend_840", "FINALLY!^1!&I'M IMPORTANT./")
ds_map_add(global.text_data_en, "obj_mainend_841", "AND IT'S ALL&THANKS TO YOU,/")
ds_map_add(global.text_data_en, "obj_mainend_842", "AND THE HORRIBLE&THINGS YOU DID./")
ds_map_add(global.text_data_en, "obj_mainend_843", "THANK YOU^1, HUMAN!/")
ds_map_add(global.text_data_en, "obj_mainend_844", "COME BACK AND&VISIT SOMETIME!!/")
ds_map_add(global.text_data_en, "obj_mainend_845", "\E3WAIT..^1.&UNDYNE WOULD&PROBABLY KILL YOU./")
ds_map_add(global.text_data_en, "obj_mainend_846", "\E0BUT..^1.&YOU'D GET TO&SEE ME./")
ds_map_add(global.text_data_en, "obj_mainend_847", "SO YOU GOTTA&RISK IT!!!/")
ds_map_add(global.text_data_en, "obj_mainend_848", "YOU GOTTA!!!/")
ds_map_add(global.text_data_en, "obj_mainend_849", "SEE YOU SOON./%%")
ds_map_add(global.text_data_en, "obj_mainend_875", "* so^1, it's been a&  while./")
ds_map_add(global.text_data_en, "obj_mainend_876", "\E1* since you left^1, things&  have..^1.&* gotten interesting./")
ds_map_add(global.text_data_en, "obj_mainend_877", "\E0* with ASGORE gone^1, the&  people looked to&  undyne to rule.../")
ds_map_add(global.text_data_en, "obj_mainend_878", "\E3* but she was nowhere&  to be found./")
ds_map_add(global.text_data_en, "obj_mainend_879", "\E2* so mettaton just&  kind of..^1.&* took over?/")
ds_map_add(global.text_data_en, "obj_mainend_880", "\E1* he's brainwashed&  everyone with his&  stupid TV show./")
ds_map_add(global.text_data_en, "obj_mainend_881", "* and made the&  underground into his&  personal paradise./")
ds_map_add(global.text_data_en, "obj_mainend_882", "\E3* it's honestly..^1.&* kinda disturbing./")
ds_map_add(global.text_data_en, "obj_mainend_883", "\E1* as for me^1?&* oh^1, yeah.../")
ds_map_add(global.text_data_en, "obj_mainend_884", "\E2* i'm his agent./%%")
ds_map_add(global.text_data_en, "obj_mainend_896", "\E0* HEY THERE^1, DARLING!/")
ds_map_add(global.text_data_en, "obj_mainend_897", "* THANK YOU SO MUCH FOR&  YOUR HARD WORK.../")
ds_map_add(global.text_data_en, "obj_mainend_898", "* THANKS TO YOU, THE&  UNDERGROUND IS MORE&  EXCITING THAN EVER!/")
ds_map_add(global.text_data_en, "obj_mainend_899", "\E7* OOH LA LA...&* STATUES... MONUMENTS&  TO MY BEAUTY.../")
ds_map_add(global.text_data_en, "obj_mainend_900", "\E6* FLOWERS IN THE&  ARRANGEMENT OF MY&  NAME.../")
ds_map_add(global.text_data_en, "obj_mainend_901", "\E5* HEDGES IN THE SHAPE&  OF MY SMILE.../")
ds_map_add(global.text_data_en, "obj_mainend_902", "\E8* UNDER MY RULE, THE&  UNDERGROUND'S PROBLEMS&  ARE OVER, BABY!/")
ds_map_add(global.text_data_en, "obj_mainend_903", "\E7* CROWDING?&* DREARINESS???/")
ds_map_add(global.text_data_en, "obj_mainend_904", "\E9* WHO NEEDS THE SUN&  WHEN YOU'VE GOT&  THE SPOTLIGHT!!?/")
ds_map_add(global.text_data_en, "obj_mainend_905", "\E1* ECONOMIC COLLAPSE?&* EDUCATION PROBLEMS?&* WHAT!?/")
ds_map_add(global.text_data_en, "obj_mainend_906", "\E8* EVERYTHING'S COVERED&  IN GOLDEN GLITTER!/")
ds_map_add(global.text_data_en, "obj_mainend_907", "\E6* THERE ARE NO&  PROBLEMS, BEAUTIFUL!/")
ds_map_add(global.text_data_en, "obj_mainend_908", "\E0* AND, I'VE ENSTATED&  A NEW POLICY ON&  HUMANITY./")
ds_map_add(global.text_data_en, "obj_mainend_909", "\E1* IF A HUMAN FALLS DOWN&  HERE.../")
ds_map_add(global.text_data_en, "obj_mainend_910", "\E6* THEY CAN JOIN MY&  FAN CLUB FOR FREE!/")
ds_map_add(global.text_data_en, "obj_mainend_911", "\E1* OH, YOU MIGHT BE&  WONDERING ABOUT&  ALPHYS./")
ds_map_add(global.text_data_en, "obj_mainend_912", "\E0* DON'T WORRY!/")
ds_map_add(global.text_data_en, "obj_mainend_913", "\E9* I BUILT A STATUE&  OF HER, TOO./")
ds_map_add(global.text_data_en, "obj_mainend_914", "\E1* .../")
ds_map_add(global.text_data_en, "obj_mainend_915", "\E3* REALLY THOUGH.&* I REALIZED I WAS.../")
ds_map_add(global.text_data_en, "obj_mainend_916", "\E4* NOT THE GREATEST&  TO HER./")
ds_map_add(global.text_data_en, "obj_mainend_917", "\E1* SO I WENT TO&  APOLOGIZE./")
ds_map_add(global.text_data_en, "obj_mainend_918", "\E9* AND, TO ASK HER&  TO HELP ME RULE./")
ds_map_add(global.text_data_en, "obj_mainend_919", "\E1* .../")
ds_map_add(global.text_data_en, "obj_mainend_920", "\E3* BUT I COULDN'T FIND&  HER./")
ds_map_add(global.text_data_en, "obj_mainend_921", "\E4* TRUST ME.&* I LOOKED./")
ds_map_add(global.text_data_en, "obj_mainend_922", "\E3* .../")
ds_map_add(global.text_data_en, "obj_mainend_923", "\E1* ANYWAY./")
ds_map_add(global.text_data_en, "obj_mainend_924", "\E2* I HOPE YOUR LIFE&  AFTER MEETING ME.../")
ds_map_add(global.text_data_en, "obj_mainend_925", "\E7* HAS BEEN WORTH LIVING./")
ds_map_add(global.text_data_en, "obj_mainend_926", "\E6* IT MUST BE A STRUGGLE./")
ds_map_add(global.text_data_en, "obj_mainend_927", "\E0* PLEASE, THINK OF ME&  ALWAYS./")
ds_map_add(global.text_data_en, "obj_mainend_928", "\E5* JUST CONSTANTLY.&* THINK OF ME POSING.&* BEAUTIFULLY.../")
ds_map_add(global.text_data_en, "obj_mainend_929", "\E6* OH YESSSS!!!/")
ds_map_add(global.text_data_en, "obj_mainend_933", "\E6* OH YESSSS!!!/%%")
ds_map_add(global.text_data_en, "obj_mainend_937", "\E2* OH^1, MY OTHER AGENT&  WANTS TO TALK./")
ds_map_add(global.text_data_en, "obj_mainend_939", "HEY!!^1!&IT'S ME^1, PAPYRUS!!/")
ds_map_add(global.text_data_en, "obj_mainend_940", "\E2IMAGINE ME WEARING&COOL GLASSES^1, AND&A SUIT./")
ds_map_add(global.text_data_en, "obj_mainend_941", "\E0AND IMAGINE SANS&WEARING SUNGLASSES&BEING A BOUNCER./")
ds_map_add(global.text_data_en, "obj_mainend_942", "THAT'S OUR LIFE..^1.&IT'S SO COOL!!!/")
ds_map_add(global.text_data_en, "obj_mainend_943", "THINGS HAVE GOTTEN&WAY BETTER SINCE&YOU CAME HERE!!!/")
ds_map_add(global.text_data_en, "obj_mainend_944", "\E3WELL^1, MINUS THE&FACT THAT&EVERYTHING SUCKS.../")
ds_map_add(global.text_data_en, "obj_mainend_945", "\E5FOR ANYONE THAT&DOESNT WORSHIP&METTATON./")
ds_map_add(global.text_data_en, "obj_mainend_946", "\E3AND MINUS THE FACT&THAT MY FRIEND&UNDYNE IS MISSING./")
ds_map_add(global.text_data_en, "obj_mainend_947", "WHO KNOWS WHERE&SHE WENT./")
ds_map_add(global.text_data_en, "obj_mainend_948", "SHE NEVER LIKED&METTATON'S SHOW./")
ds_map_add(global.text_data_en, "obj_mainend_949", "\E3PEOPLE WHO DON'T&TEND TO KIND OF.../")
ds_map_add(global.text_data_en, "obj_mainend_950", "\E5DISAPPEAR./")
ds_map_add(global.text_data_en, "obj_mainend_951", "\E6I MISS HER A&LOT SOMETIMES./")
ds_map_add(global.text_data_en, "obj_mainend_952", "\E0IF YOU SEE HER^1,&CAN YOU TELL HER&I SAID HI?/")
ds_map_add(global.text_data_en, "obj_mainend_953", "THANKS^1!&SEE YOU LATER!/%%")
ds_map_add(global.text_data_en, "obj_mainend_984", "\E3* so.^1.&* it's been a while./")
ds_map_add(global.text_data_en, "obj_mainend_985", "* since you left.../")
ds_map_add(global.text_data_en, "obj_mainend_986", "\E1* things have gotten&  really strange./")
ds_map_add(global.text_data_en, "obj_mainend_987", "\E0* overnight^1, a bunch of&  people mysteriously&  disappeared./")
ds_map_add(global.text_data_en, "obj_mainend_988", "\E3* as well as the&  human souls./")
ds_map_add(global.text_data_en, "obj_mainend_989", "\E3* people were heart-&  broken. everyone they&  looked up to.../")
ds_map_add(global.text_data_en, "obj_mainend_990", "* everything they were&  relying on^1, in one&  night, disappeared./")
ds_map_add(global.text_data_en, "obj_mainend_991", "* everyone clamored to&  elect a new ruler as&  fast as possible./")
ds_map_add(global.text_data_en, "obj_mainend_992", "\E1* so^1, uh..^1.&* by process of&  elimination.../")
ds_map_add(global.text_data_en, "obj_mainend_993", "\E2* papyrus became the&  ruler?/")
ds_map_add(global.text_data_en, "obj_mainend_994", "\E1* why doesn't he talk&  to you about this.../")
ds_map_add(global.text_data_en, "obj_mainend_996", "\E0HELLO!!^1!&HUMAN!!!/")
ds_map_add(global.text_data_en, "obj_mainend_997", "\E3IT'S STRANGE./")
ds_map_add(global.text_data_en, "obj_mainend_998", "\E3ASGORE^1, ALPHYS^1,&METTATON^1, AND&UNDYNE WENT AWAY./")
ds_map_add(global.text_data_en, "obj_mainend_999", "\E0SANS SAYS THEY&WENT ON VACATION./")
ds_map_add(global.text_data_en, "obj_mainend_1000", "I HOPE THEY'RE&HAVING FUN!!!/")
ds_map_add(global.text_data_en, "obj_mainend_1001", "\E3OH YEAH./")
ds_map_add(global.text_data_en, "obj_mainend_1002", "\E0I'M THE RULER OF&THE UNDERGROUND&NOW!!!/")
ds_map_add(global.text_data_en, "obj_mainend_1003", "EVERYTHING IS&IMPROVING A LOT&HERE./")
ds_map_add(global.text_data_en, "obj_mainend_1004", "PRODUCTIVITY IS UP!/")
ds_map_add(global.text_data_en, "obj_mainend_1005", "BECAUSE I TELL&EVERYONE TO KEEP&WORKING./")
ds_map_add(global.text_data_en, "obj_mainend_1006", "AND^1, NO ONE GOES&HUNGRY!!!/")
ds_map_add(global.text_data_en, "obj_mainend_1007", "BECAUSE I COOK&EVERYONE&SPAGHETTI./")
ds_map_add(global.text_data_en, "obj_mainend_1008", "\E3MEANWHILE^1, MY&BROTHER HANDLES&THE PAPERWORK./")
ds_map_add(global.text_data_en, "obj_mainend_1009", "\E3STRANGELY..^1.&HE SEEMS TO BE&WORKING HARD?/")
ds_map_add(global.text_data_en, "obj_mainend_1010", "\E3THIS SOUNDS MESSED&UP..^1. BUT.../")
ds_map_add(global.text_data_en, "obj_mainend_1011", "\E5I'M PROUD..^1.&OF HIM???/")
ds_map_add(global.text_data_en, "obj_mainend_1012", "OH NO!!!!/")
ds_map_add(global.text_data_en, "obj_mainend_1013", "\E0AS FOR OUR HUMAN&POLICY.../")
ds_map_add(global.text_data_en, "obj_mainend_1014", "\E3WE'VE DECIDED^1, UM./")
ds_map_add(global.text_data_en, "obj_mainend_1015", "SANS^1, WHAT WAS IT?/")
ds_map_add(global.text_data_en, "obj_mainend_1017", "\E2* we can't judge&  humans to be all&  good or all bad./")
ds_map_add(global.text_data_en, "obj_mainend_1019", "\E0RIGHT^1!&SO IT'S CASE-BY-&CASE!/")
ds_map_add(global.text_data_en, "obj_mainend_1020", "IF THEY'RE EVIL..^1.&WE GIVE THEM&PUZZLES!/")
ds_map_add(global.text_data_en, "obj_mainend_1021", "IF THEY'RE GOOD..^1.&WE ALSO GIVE&THEM PUZZLES!/")
ds_map_add(global.text_data_en, "obj_mainend_1022", "THAT SEEMS TO BE&THE BEST WAY!/")
ds_map_add(global.text_data_en, "obj_mainend_1023", "\E0.../")
ds_map_add(global.text_data_en, "obj_mainend_1024", "\E3.../")
ds_map_add(global.text_data_en, "obj_mainend_1025", "IS SANS GONE?/")
ds_map_add(global.text_data_en, "obj_mainend_1026", "\E6YOU KNOW.../")
ds_map_add(global.text_data_en, "obj_mainend_1027", "DON'T TELL MY&BROTHER, BUT.../")
ds_map_add(global.text_data_en, "obj_mainend_1028", "DESPITE THE&IMPROVEMENTS&WE'VE MADE.../")
ds_map_add(global.text_data_en, "obj_mainend_1029", "SOMETIMES THIS JOB&IS KIND OF HARD./")
ds_map_add(global.text_data_en, "obj_mainend_1030", "SINCE THE KING&WENT AWAY.../")
ds_map_add(global.text_data_en, "obj_mainend_1031", "LOTS OF PEOPLE&JUST WANT TO&GIVE UP./")
ds_map_add(global.text_data_en, "obj_mainend_1032", "SOMETIMES, EVEN MY&BEST&ENCOURAGEMENT.../")
ds_map_add(global.text_data_en, "obj_mainend_1033", "DOESN'T WORK./")
ds_map_add(global.text_data_en, "obj_mainend_1034", "AND^1, AND^1, I MISS&UNDYNE^1, TOO./")
ds_map_add(global.text_data_en, "obj_mainend_1035", "SHE NEVER ANSWERS&MY PHONE CALLS.../")
ds_map_add(global.text_data_en, "obj_mainend_1036", "\E5SHE MUST BE& HAVING A LOT OF&FUN ON VACATION./")
ds_map_add(global.text_data_en, "obj_mainend_1037", "\E6I JUST WISH SHE'D&SEND A POSTCARD./")
ds_map_add(global.text_data_en, "obj_mainend_1038", ".../")
ds_map_add(global.text_data_en, "obj_mainend_1039", "\E5BUT HEY!!!/")
ds_map_add(global.text_data_en, "obj_mainend_1040", "\E4I WON'T GIVE UP!/")
ds_map_add(global.text_data_en, "obj_mainend_1041", "I CAN'T GIVE UP!/")
ds_map_add(global.text_data_en, "obj_mainend_1042", "I HAVE TO MAKE&EVERYONE GIVE UP&GIVING UP!/")
ds_map_add(global.text_data_en, "obj_mainend_1043", "\E0WE'LL GET OUT&OF HERE^1, SLOWLY!!!/")
ds_map_add(global.text_data_en, "obj_mainend_1044", "THEN WE CAN ALL&HANG OUT AGAIN!!!/")
ds_map_add(global.text_data_en, "obj_mainend_1045", "\E0NYEH HEH HEH!!!/%%")
ds_map_add(global.text_data_en, "obj_mainend_1055", "\E3* it's been a while^1,&  huh?/")
ds_map_add(global.text_data_en, "obj_mainend_1056", "* .../")
ds_map_add(global.text_data_en, "obj_mainend_1057", "* things have gotten&  pretty bad here./")
ds_map_add(global.text_data_en, "obj_mainend_1058", "\E0* everyone considered a&  leader disappeared&  overnight./")
ds_map_add(global.text_data_en, "obj_mainend_1059", "\E1* it's gotten so quiet./")
ds_map_add(global.text_data_en, "obj_mainend_1060", "\E3* there's a bad feeling&  hanging over&  everyone./")
ds_map_add(global.text_data_en, "obj_mainend_1061", "* like everyone's just&  going to die here^1,&  trapped in the dark.../")
ds_map_add(global.text_data_en, "obj_mainend_1062", "\E2* ... i bet you're&  wondering why i'm&  not the ruler./")
ds_map_add(global.text_data_en, "obj_mainend_1063", "\E1* eh./")
ds_map_add(global.text_data_en, "obj_mainend_1064", "\E1* i'm not cut out&  for something like&  that./")
ds_map_add(global.text_data_en, "obj_mainend_1065", "\E2* i like to take it&  easy^1, you know?/")
ds_map_add(global.text_data_en, "obj_mainend_1066", "\E2* .../")
ds_map_add(global.text_data_en, "obj_mainend_1067", "\E3* ... that's a joke./")
ds_map_add(global.text_data_en, "obj_mainend_1068", "\E3* this is what happens&  when people like me&  take it easy./")
ds_map_add(global.text_data_en, "obj_mainend_1069", "* .../")
ds_map_add(global.text_data_en, "obj_mainend_1070", "\E4* see ya./%%")
ds_map_add(global.text_data_en, "obj_mainend_1074", "\E0* hey^1, at least things&  are less crowded./")
ds_map_add(global.text_data_en, "obj_mainend_1075", "\E1* 'cause of all the&  people you killed./")
ds_map_add(global.text_data_en, "obj_mainend_1076", "\E2* hope that was a good&  experience for you./")
ds_map_add(global.text_data_en, "obj_mainend_1077", "\E3* .../")
ds_map_add(global.text_data_en, "obj_mainend_1078", "\E2* just kidding^1.&* i don't really hope&  that./")
ds_map_add(global.text_data_en, "obj_mainend_1079", "\E4* go to hell./%%")
ds_map_add(global.text_data_en, "obj_mainend_1092", "\E3* it's been a while^1,&  huh?/")
ds_map_add(global.text_data_en, "obj_mainend_1093", "* .../")
ds_map_add(global.text_data_en, "obj_mainend_1094", "\E1* it seems a number of&  important people&  disappeared overnight./")
ds_map_add(global.text_data_en, "obj_mainend_1095", "* but no one else was&  harmed./")
ds_map_add(global.text_data_en, "obj_mainend_1096", "\E0* the people were&  confused^1.&* it was complete bedlam./")
ds_map_add(global.text_data_en, "obj_mainend_1097", "\E3* somehow^1, at the end of&  the day.../")
ds_map_add(global.text_data_en, "obj_mainend_1098", "\E1* a small^1, white dog&  became president of&  the underground./")
ds_map_add(global.text_data_en, "obj_mainend_1099", "\E0* it sleeps on the&  throne and does&  absolutely nothing./")
ds_map_add(global.text_data_en, "obj_mainend_1100", "\E1* strangely^1, it seems&  this is the best&  life for everyone./")
ds_map_add(global.text_data_en, "obj_mainend_1101", "\E2* thanks./%%")
ds_map_add(global.text_data_en, "obj_mainend_1112", "\E3* it's been a while^1,&  huh?/")
ds_map_add(global.text_data_en, "obj_mainend_1113", "* .../")
ds_map_add(global.text_data_en, "obj_mainend_1114", "\E1* i'll be honest./")
ds_map_add(global.text_data_en, "obj_mainend_1115", "\E2* i have no idea what&  happened for you&  to get here./")
ds_map_add(global.text_data_en, "obj_mainend_1116", "\E1* this is actually some&  sort of error-&  handling message./")
ds_map_add(global.text_data_en, "obj_mainend_1117", "\E3* so^1, if you're getting&  this ending.../")
ds_map_add(global.text_data_en, "obj_mainend_1118", "\E1* tell whoever made the&  game^1, okay?/")
ds_map_add(global.text_data_en, "obj_mainend_1119", "\E2* they'll fix it^1, or&  if it's a novel&  situation.../")
ds_map_add(global.text_data_en, "obj_mainend_1120", "\E1* they might even add&  another ending to&  the game./")
ds_map_add(global.text_data_en, "obj_mainend_1121", "\E3* chances are^1, though.../")
ds_map_add(global.text_data_en, "obj_mainend_1122", "\E4* you're just a dirty&  hacker^1, aren't you?/")
ds_map_add(global.text_data_en, "obj_mainend_1123", "\E1* yeah^1, get outta here./%%")
ds_map_add(global.text_data_en, "obj_mainend_1136", "\E1* H..^1. hey./")
ds_map_add(global.text_data_en, "obj_mainend_1137", "\E0* So..^1. you're the one&  who killed all my&  friends./")
ds_map_add(global.text_data_en, "obj_mainend_1139", "\E1* I just called to tell&  you./")
ds_map_add(global.text_data_en, "obj_mainend_1141", "\E0* I hate you./")
ds_map_add(global.text_data_en, "obj_mainend_1143", "\E1* Yet..^1. strangely..^1.&* It's because of you^1,&  that.../")
ds_map_add(global.text_data_en, "obj_mainend_1145", "\E2* That I was forced to&  become a better&  person./")
ds_map_add(global.text_data_en, "obj_mainend_1147", "\E0* When I first saw you&  hurting people.../")
ds_map_add(global.text_data_en, "obj_mainend_1148", "* I just sat there^1.&* Watching you./")
ds_map_add(global.text_data_en, "obj_mainend_1149", "\E1* I felt so guilty knowing&  I hadn't do anything&  to stop you./")
ds_map_add(global.text_data_en, "obj_mainend_1150", "\E3* I felt like all I&  do was.../")
ds_map_add(global.text_data_en, "obj_mainend_1151", "\E4* Was hope you would&  destroy me^1, too./")
ds_map_add(global.text_data_en, "obj_mainend_1152", "\E1* But when Undyne called^1,&  with crazed desperation&  in her voice.../")
ds_map_add(global.text_data_en, "obj_mainend_1153", "\E0* I..^1.&* I realized I had to do&  something./")
ds_map_add(global.text_data_en, "obj_mainend_1154", "\E1* Even if it meant&  everybody would.../")
ds_map_add(global.text_data_en, "obj_mainend_1155", "* Have to learn the&  truth about me./")
ds_map_add(global.text_data_en, "obj_mainend_1156", "\E2* It's strange^1.&* You know?/")
ds_map_add(global.text_data_en, "obj_mainend_1157", "\E5* Even after all the&  bad things I did./")
ds_map_add(global.text_data_en, "obj_mainend_1158", "* People treated me like&  a hero./")
ds_map_add(global.text_data_en, "obj_mainend_1159", "\E2* And then they..^1.&* Asked me to run&  everything./")
ds_map_add(global.text_data_en, "obj_mainend_1160", "\E5* So I'm trying my&  best^1, here./")
ds_map_add(global.text_data_en, "obj_mainend_1161", "\E2* I think I have some&  good policies^1, but^1,&  y-you know.../")
ds_map_add(global.text_data_en, "obj_mainend_1162", "\E1* Talking to people&  still makes me&  nervous./")
ds_map_add(global.text_data_en, "obj_mainend_1163", "\E0* I'm no ASGORE^1,&  you know?/")
ds_map_add(global.text_data_en, "obj_mainend_1164", "\E2* .../")
ds_map_add(global.text_data_en, "obj_mainend_1165", "\E4* God..^1.&* I miss everyone./")
ds_map_add(global.text_data_en, "obj_mainend_1166", "\E3* Now that they're&  gone^1, it.../")
ds_map_add(global.text_data_en, "obj_mainend_1167", "* It feels so clear what&  I should have done./")
ds_map_add(global.text_data_en, "obj_mainend_1168", "\E3* What I should have&  said./")
ds_map_add(global.text_data_en, "obj_mainend_1169", "\E6* Undyne..^1.&* Asgore.../")
ds_map_add(global.text_data_en, "obj_mainend_1170", "* Mettaton.../")
ds_map_add(global.text_data_en, "obj_mainend_1171", "\E5* At least Sans is&  still here./")
ds_map_add(global.text_data_en, "obj_mainend_1172", "\E4* He's..^1.&* He's a good guy^1.&* And with him around.../")
ds_map_add(global.text_data_en, "obj_mainend_1173", "\E4* I.../")
ds_map_add(global.text_data_en, "obj_mainend_1174", "\E2* Sigh./")
ds_map_add(global.text_data_en, "obj_mainend_1175", "\E1* You know^1.&* Just daydreaming here^1.&* But.../")
ds_map_add(global.text_data_en, "obj_mainend_1176", "\E5* I really should have&  killed you when I&  had the chance./%%")
ds_map_add(global.text_data_en, "obj_mandog_251", "Weź moją&żonę...&w sensie&pchły!")
ds_map_add(global.text_data_en, "obj_mandog_252", "Nie&tykaj&mojej&hot doga.")
ds_map_add(global.text_data_en, "obj_mandog_253", "Niee&Nuzzle&Champs&'98!!")
ds_map_add(global.text_data_en, "obj_mandog_254", "Skopmy&ludzki&ogon!!")
ds_map_add(global.text_data_en, "obj_mandog_259", "Hm?&Co to&za&zapach?")
ds_map_add(global.text_data_en, "obj_mandog_260", "Co!&Pachnie&jak...")
ds_map_add(global.text_data_en, "obj_mandog_264", "Łapy precz&śmierdzący&człowieku.")
ds_map_add(global.text_data_en, "obj_mandog_267", "Wow!!!&Głask&od innej&psinę!!!")
ds_map_add(global.text_data_en, "obj_mandog_272", "Stop!&Nie&dotykaj&jej!")
ds_map_add(global.text_data_en, "obj_mandog_273", "A co&ze mną&......&........")
ds_map_add(global.text_data_en, "obj_mandog_280", "Płacz.")
ds_map_add(global.text_data_en, "obj_mandog_281", "Skom-&lanie.")
ds_map_add(global.text_data_en, "obj_mandog_284", "%%%")
ds_map_add(global.text_data_en, "obj_mandog_474", "* Dogamy ma złamane serce.")
ds_map_add(global.text_data_en, "obj_mandog_490", "* DOGAMY - ATK 14 DEF 5&* Mąż Dogaressy.&* Wie tylko to co powąchał./^")
ds_map_add(global.text_data_en, "obj_mandog_498", "* Psy cię ponownie wąchają.../")
ds_map_add(global.text_data_en, "obj_mandog_499", "* Ale pachniesz tak samo&  dziwnie jak poprzednio!/^")
ds_map_add(global.text_data_en, "obj_mandog_500", "* Psy cię ponownie wąchają.../")
ds_map_add(global.text_data_en, "obj_mandog_501", "* Po tarzaniu się po ziemi^1,&  pachniesz w porządku!/^")
ds_map_add(global.text_data_en, "obj_mandog_502", "* Psy już dobrze znają&  twój zapach./^")
ds_map_add(global.text_data_en, "obj_mandog_503", "* Dogamy nawet nie podniesie&  swojego pyska./^")
ds_map_add(global.text_data_en, "obj_mandog_513", "* Dogamy tylko na ciebie&  warczy./^")
ds_map_add(global.text_data_en, "obj_mandog_516", "* Psy są zbyt podejrzliwi&  twojego zapachu./^")
ds_map_add(global.text_data_en, "obj_mandog_517", "* Głaszczesz Dogamy./^")
ds_map_add(global.text_data_en, "obj_mandog_527", "* Tarzasz się po ziemi&  i śniegu./")
ds_map_add(global.text_data_en, "obj_mandog_528", "* Pachniesz jak dziwny&  szczeniak./^")
ds_map_add(global.text_data_en, "obj_memoryhead_166", "Chodź&dołącz&do&zabawy.")
ds_map_add(global.text_data_en, "obj_memoryhead_167", "It's a&real&get&together")
ds_map_add(global.text_data_en, "obj_memoryhead_168", "Lorem&ipsum&docet")
ds_map_add(global.text_data_en, "obj_memoryhead_169", "Become&one of&us!")
ds_map_add(global.text_data_en, "obj_memoryhead_171", "Chodź&dołącz&do&zabawy.")
ds_map_add(global.text_data_en, "obj_memoryhead_181", "That's&a&shame.")
ds_map_add(global.text_data_en, "obj_memoryhead_182", "Oh&well.")
ds_map_add(global.text_data_en, "obj_memoryhead_183", "Be&seeing&you.")
ds_map_add(global.text_data_en, "obj_memoryhead_188", "Then,&hold&still.")
ds_map_add(global.text_data_en, "obj_memoryhead_189", "Just&a&moment.")
ds_map_add(global.text_data_en, "obj_memoryhead_190", "You'll&be with&us&shortly.")
ds_map_add(global.text_data_en, "obj_memoryhead_195", "%%%")
ds_map_add(global.text_data_en, "obj_memoryhead_420", "* But nobody came.")
ds_map_add(global.text_data_en, "obj_memoryhead_421", "* But nobody came.")
ds_map_add(global.text_data_en, "obj_memoryhead_422", "* But nobody came.")
ds_map_add(global.text_data_en, "obj_memoryhead_423", "* But nobody came.")
ds_map_add(global.text_data_en, "obj_memoryhead_424", "* Smells like batteries.")
ds_map_add(global.text_data_en, "obj_memoryhead_425", "* Seems like it doesn't&  care anymore.")
ds_map_add(global.text_data_en, "obj_memoryhead_426", "* Monster has low HP.")
ds_map_add(global.text_data_en, "obj_memoryhead_461", "* No data available./^")
ds_map_add(global.text_data_en, "obj_memoryhead_472", "* The enemy put a piece of&  itself in your inventory./^")
ds_map_add(global.text_data_en, "obj_memoryhead_474", "* But your inventory was full./^")
ds_map_add(global.text_data_en, "obj_memoryhead_484", "* AT - \[1] DF - \[2] /^")
ds_map_add(global.text_data_en, "obj_memoryhead_493", "* You take out your CELL PHONE^1.&* You can hear voices through&  the receiver...!/^")
ds_map_add(global.text_data_en, "obj_memoryhead_511", "* MEMORYHEAD/^")
ds_map_add(global.text_data_en, "obj_mett_bossintro_174", "Ohhhh my./")
ds_map_add(global.text_data_en, "obj_mett_bossintro_175", "If you flipped my&switch, that can&only mean one&thing./")
ds_map_add(global.text_data_en, "obj_mett_bossintro_176", "You're desperate&for the premiere&of my new body./")
ds_map_add(global.text_data_en, "obj_mett_bossintro_177", "How rude.../")
ds_map_add(global.text_data_en, "obj_mett_bossintro_178", "Lucky for you,&I've been aching&to show this off&for a long time./")
ds_map_add(global.text_data_en, "obj_mett_bossintro_179", "So..^1. as thanks^1,&I'll give you a&handsome reward./")
ds_map_add(global.text_data_en, "obj_mett_bossintro_180", "I'll make your&last living&moments.../%%")
ds_map_add(global.text_data_en, "obj_mett_bossintro_213", "ABSOLUTELY beautiful!/%%")
ds_map_add(global.text_data_en, "obj_mettaton_neo_449", "* Stage lights are blaring.")
ds_map_add(global.text_data_en, "obj_mettaton_neo_461", "* Stage lights are blaring.")
ds_map_add(global.text_data_en, "obj_mettaton_neo_482", "* METTATON NEO - 90 ATK 9 DEF&* Dr. Alphys's greatest&  invention./^")
ds_map_add(global.text_data_en, "obj_mettaton_neo_535", "\E6G...&GUESS SHE SHOULD&HAVE WORKED MORE&ON THE DEFENSES.../")
ds_map_add(global.text_data_en, "obj_mettaton_neo_536", "\E6.../")
ds_map_add(global.text_data_en, "obj_mettaton_neo_537", "\E6YOU MAY HAVE&DEFEATED ME...&BUT.../")
ds_map_add(global.text_data_en, "obj_mettaton_neo_538", "\E4I KNOW.&I CAN TELL FROM&THAT STRIKE, DARLING./")
ds_map_add(global.text_data_en, "obj_mettaton_neo_539", "\E5YOU WERE HOLDING&BACK./")
ds_map_add(global.text_data_en, "obj_mettaton_neo_540", "\E6YES, ASGORE WILL&FALL EASILY TO&YOU.../")
ds_map_add(global.text_data_en, "obj_mettaton_neo_541", "\E5BUT YOU WON'T&HARM HUMANITY,&WILL YOU?/")
ds_map_add(global.text_data_en, "obj_mettaton_neo_542", "\E1YOU AREN'T&ABSOLUTELY EVIL./")
ds_map_add(global.text_data_en, "obj_mettaton_neo_543", "\E5IF YOU WERE&TRYING TO BE,&THEN YOU MESSED UP./")
ds_map_add(global.text_data_en, "obj_mettaton_neo_544", "\E0AND SO LATE INTO&THE SHOW, TOO./")
ds_map_add(global.text_data_en, "obj_mettaton_neo_545", "\E0HA... HA.&AT LEAST NOW,&I CAN REST EASY./")
ds_map_add(global.text_data_en, "obj_mettaton_neo_546", "\E3KNOWING ALPHYS AND&THE HUMANS WILL&LIVE ON...!/%%")
ds_map_add(global.text_data_en, "obj_mettaton_neo_550", "\E6GH.../")
ds_map_add(global.text_data_en, "obj_mettaton_neo_551", "\E5GUESS YOU DON'T&WANNA JOIN MY&FAN CLUB...?/%%")
ds_map_add(global.text_data_en, "obj_mettaton_npc_63", "* Capital wenisberry./%%")
ds_map_add(global.text_data_en, "obj_mettaton_npc_69", "\W* \YMILK^1, SUGAR^1, \WAND\Y EGGS\W!&* YOU SHOULD BE ABLE TO FIND&  THEM ON THE BACK COUNTER!/%%")
ds_map_add(global.text_data_en, "obj_mettaton_npc_77", "* GREAT JOB^1!&* JUST PUT THEM IN THE MIDDLE&  OF THIS COUNTER!/%%")
ds_map_add(global.text_data_en, "obj_mettaton_npc_82", "* WHAT'S THE MATTER?&* NOT A CAN FAN?&* THAT'S TOO BAD!/")
ds_map_add(global.text_data_en, "obj_mettaton_npc_83", "* MTT-BRAND USES ONLY THE&  FRESHEST ARTIFICIAL INGREDIENTS&  AND CHEMICALS!/%%")
ds_map_add(global.text_data_en, "obj_mettatonb_quiz_255", "LET'S START WITH&AN EASY ONE!!/%%")
ds_map_add(global.text_data_en, "obj_mettatonb_quiz_258", "HERE'S YOUR TERRIFIC&PRIZE!/%%")
ds_map_add(global.text_data_en, "obj_mettatonb_quiz_262", "ENOUGH ABOUT YOU.&LET'S TALK ABOUT ME!/%%")
ds_map_add(global.text_data_en, "obj_mettatonb_quiz_266", "HERE'S ANOTHER EASY&ONE FOR YOU!/%%")
ds_map_add(global.text_data_en, "obj_mettatonb_quiz_270", "DON'T 'COUNT'&ON YOUR VICTORY.../%%")
ds_map_add(global.text_data_en, "obj_mettatonb_quiz_274", "LET'S PLAY MEMORY&GAME./%%")
ds_map_add(global.text_data_en, "obj_mettatonb_quiz_278", "BUT CAN YOU GET&THIS ONE???/%%")
ds_map_add(global.text_data_en, "obj_mettatonb_quiz_282", "HERE'S A SIMPLE&ONE./%%")
ds_map_add(global.text_data_en, "obj_mettatonb_quiz_286", "TIME TO BREAK OUT&THE BIG GUNS!!/%%")
ds_map_add(global.text_data_en, "obj_mettatonb_quiz_294", "%%%")
ds_map_add(global.text_data_en, "obj_mettatonb_quiz_490", "* Mettaton.")
ds_map_add(global.text_data_en, "obj_mettatonb_quiz_514", "* METTATON - ATK 30 DEF 255&* His metal body renders him&  invulnerable to attack./^")
ds_map_add(global.text_data_en, "obj_mettatonb_quiz_524", "* Screaming is against the&  rules./^")
ds_map_add(global.text_data_en, "obj_mettatonb_second_256", "THIS IS IT, DARLING!&SAY GOODBYE!/%%")
ds_map_add(global.text_data_en, "obj_mettatonb_second_265", "HA!&THAT BUTTON WON'T&SAVE YOU NOW, DARLING!/%%")
ds_map_add(global.text_data_en, "obj_mettatonb_second_268", "YOU WOULDN'T DARE&USE THE [ACT] COMMAND&AND PRESS THAT&BUTTON!/%%")
ds_map_add(global.text_data_en, "obj_mettatonb_second_271", "THAT'S RIGHT!&DON'T PRESS IT!&I'LL DESTROY YOU!/%%")
ds_map_add(global.text_data_en, "obj_mettatonb_second_274", "WITHOUT THAT BUTTON,&YOU ARE INCHING&CLOSER AND CLOSER&TO YOUR DEMISE!/%%")
ds_map_add(global.text_data_en, "obj_mettatonb_second_277", "ANY MINUTE NOW!&    /%%")
ds_map_add(global.text_data_en, "obj_mettatonb_second_280", "ANY... MINUTE...&....NOW!/%%")
ds_map_add(global.text_data_en, "obj_mettatonb_second_284", ".............&............/%%")
ds_map_add(global.text_data_en, "obj_mettatonb_second_290", "..........&...(COUGH)/%%")
ds_map_add(global.text_data_en, "obj_mettatonb_second_299", "OH!!!&THAT YELLOW GLOW...!/%%")
ds_map_add(global.text_data_en, "obj_mettatonb_second_300", "TOOK YOU LONG&ENOUGH!/%%")
ds_map_add(global.text_data_en, "obj_mettatonb_second_542", "* Mettaton.")
ds_map_add(global.text_data_en, "obj_mettatonb_second_564", "* METTATON - ATK 30 DEF 255&* His metal body STILL renders&  him invulnerable to attack./^")
ds_map_add(global.text_data_en, "obj_mettatonb_second_574", "* You yell..^1.&* Nothing happened./^")
ds_map_add(global.text_data_en, "obj_mettatonb_second_579", "* You press the yellow button^1.&* The phone is resonating with&  Mettaton's presence...!/^")
ds_map_add(global.text_data_en, "obj_mettatonb_second_640", "IS THAT YOUR PHONE?&YOU'D BETTER ANSWER&IT!/%%")
ds_map_add(global.text_data_en, "obj_mettatonb_second_652", "H-hey!!&Th-this seems bad,&but don't worry!!/")
ds_map_add(global.text_data_en, "obj_mettatonb_second_653", "Th-there's one last&thing I installed&on your phone...!/")
ds_map_add(global.text_data_en, "obj_mettatonb_second_654", "\WYou see that\Y &yellow button\W...?/")
ds_map_add(global.text_data_en, "obj_mettatonb_second_655", "Go to this phone's&[[ACT]] menu and&press it!!!/%%")
ds_map_add(global.text_data_en, "obj_mettatonb_second_662", "* Your phone's [[ACT]] menu is&  glowing.")
ds_map_add(global.text_data_en, "obj_mettatonb_second_703", "Now press \*Z!!!")
ds_map_add(global.text_data_en, "obj_mettatonb_second_746", "OOOH!/")
ds_map_add(global.text_data_en, "obj_mettatonb_second_747", "OOOOOOOH!/")
ds_map_add(global.text_data_en, "obj_mettatonb_second_748", "YOU'VE DEFEATED ME!!/")
ds_map_add(global.text_data_en, "obj_mettatonb_second_749", "HOW CAN THIS BE,&YOU WERE STRONGER&THAN I THOUGHT, ETC./%%")
ds_map_add(global.text_data_en, "obj_mettatonb_second_757", "WHATEVER.")
ds_map_add(global.text_data_en, "obj_mettatonb_third_214", "THIS IS IT, DARLING!&SAY GOODBYE!/%%")
ds_map_add(global.text_data_en, "obj_mettatonb_third_224", "YES, I WAS THE ONE&THAT RE-ARRANGED&THE CORE!/")
ds_map_add(global.text_data_en, "obj_mettatonb_third_225", "I WAS THE ONE THAT&HIRED EVERYONE TO&KILL YOU!/")
ds_map_add(global.text_data_en, "obj_mettatonb_third_226", "THAT, HOWEVER, WAS A&SHORT-SIGHTED PLAN./")
ds_map_add(global.text_data_en, "obj_mettatonb_third_227", "YOU KNOW WHAT WOULD&BE A HUNDRED TIMES&BETTER?/")
ds_map_add(global.text_data_en, "obj_mettatonb_third_228", "KILLING YOU MYSELF!!/%%")
ds_map_add(global.text_data_en, "obj_mettatonb_third_233", "LISTEN, DARLING.&I'VE SEEN YOU FIGHT./")
ds_map_add(global.text_data_en, "obj_mettatonb_third_234", "YOU'RE WEAK./")
ds_map_add(global.text_data_en, "obj_mettatonb_third_235", "IF YOU CONTINUE&FORWARD, ASGORE WILL&TAKE YOUR SOUL./")
ds_map_add(global.text_data_en, "obj_mettatonb_third_236", "AND WITH YOUR SOUL,&ASGORE WILL DESTROY&HUMANITY./%%")
ds_map_add(global.text_data_en, "obj_mettatonb_third_241", "BUT IF I GET YOUR&SOUL, I CAN STOP&ASGORE'S PLAN!/")
ds_map_add(global.text_data_en, "obj_mettatonb_third_242", "I CAN SAVE HUMANITY&FROM DESTRUCTION!/%%")
ds_map_add(global.text_data_en, "obj_mettatonb_third_247", "THEN, USING YOUR SOUL,&I'LL CROSS THROUGH&THE BARRIER.../")
ds_map_add(global.text_data_en, "obj_mettatonb_third_248", "AND BECOME THE STAR&I'VE ALWAYS DREAMED&OF BEING!/")
ds_map_add(global.text_data_en, "obj_mettatonb_third_249", "HUNDREDS, THOUSANDS.../")
ds_map_add(global.text_data_en, "obj_mettatonb_third_250", "NO!&MILLIONS OF HUMANS&WILL WATCH ME!/%%")
ds_map_add(global.text_data_en, "obj_mettatonb_third_255", "GLITZ! GLAMOUR!&I'LL FINALLY HAVE&IT ALL!/")
ds_map_add(global.text_data_en, "obj_mettatonb_third_256", "SO WHAT IF A FEW&PEOPLE HAVE TO DIE?/")
ds_map_add(global.text_data_en, "obj_mettatonb_third_257", "THAT'S SHOW BUSINESS,&BABY!/%%")
ds_map_add(global.text_data_en, "obj_mettatonb_third_523", "* Mettaton.")
ds_map_add(global.text_data_en, "obj_mettatonb_third_545", "* METTATON - ATK 30 DEF 255&* Seriously^1, his metal body&  is invulnerable!/^")
ds_map_add(global.text_data_en, "obj_mettatonb_third_555", "* This is probably what you'll&  do if things continue in&  this manner./^")
ds_map_add(global.text_data_en, "obj_mettatonb_third_560", "* You tell Mettaton that there's&  a mirror behind him./%%")
ds_map_add(global.text_data_en, "obj_mettatonb_third_644", "U..uh... I can't see&what's going on in&there, but.../")
ds_map_add(global.text_data_en, "obj_mettatonb_third_645", "D-d-don't give up,&okay!?/")
ds_map_add(global.text_data_en, "obj_mettatonb_third_646", "Th... there's o-one&l-l-last way to beat&Mettaton.../")
ds_map_add(global.text_data_en, "obj_mettatonb_third_647", "It's... um... it's.../")
ds_map_add(global.text_data_en, "obj_mettatonb_third_648", "This is a work in-&progress, so don't&judge it too hard.../")
ds_map_add(global.text_data_en, "obj_mettatonb_third_649", "But, you know how&Mettaton always faces&f-f-forward?/")
ds_map_add(global.text_data_en, "obj_mettatonb_third_650", "That's because&there's a switch&on his backside./")
ds_map_add(global.text_data_en, "obj_mettatonb_third_651", "S-s-so if y-y-you&c-c-can turn him&around... um.../")
ds_map_add(global.text_data_en, "obj_mettatonb_third_652", "And, umm... press&th-th-th-the&switch.../")
ds_map_add(global.text_data_en, "obj_mettatonb_third_653", "He'll be... um...&He'll be.../")
ds_map_add(global.text_data_en, "obj_mettatonb_third_654", "Vulnerable./")
ds_map_add(global.text_data_en, "obj_mettatonb_third_655", "Well, g-g-gotta go!/%%")
ds_map_add(global.text_data_en, "obj_mettatonb_third_688", "* Seems like a good time to&  turn Mettaton around.")
ds_map_add(global.text_data_en, "obj_mettatonb_third_820", "OH???&A MIRROR???/")
ds_map_add(global.text_data_en, "obj_mettatonb_third_821", "RIGHT, I HAVE TO&LOOK PERFECT FOR&OUR GRAND FINALE!/%%")
ds_map_add(global.text_data_en, "obj_mettatonb_third_831", "HMMM...&I DON'T SEE IT...&WHERE IS IT...?/%%")
ds_map_add(global.text_data_en, "obj_mettatonb_third_848", "DID YOU./")
ds_map_add(global.text_data_en, "obj_mettatonb_third_849", "JUST FLIP./")
ds_map_add(global.text_data_en, "obj_mettatonb_third_850", "MY SWITCH?/%%")
ds_map_add(global.text_data_en, "obj_mettatonb_third_943", "THAT WORTHLESS PEA-&SHOOTER WON'T WORK&ON ME, DARLING. ^3 %")
ds_map_add(global.text_data_en, "obj_mettatonb_third_944", "DON'T YOU UNDERSTAND&WHAT ACTING IS!?^3 %%")
ds_map_add(global.text_data_en, "obj_mettatonb_third_952", "* Mettaton.")
ds_map_add(global.text_data_en, "obj_mettatonex_167", ".../%%")
ds_map_add(global.text_data_en, "obj_mettatonex_190", "Lights!&Camera!&Action!/%%")
ds_map_add(global.text_data_en, "obj_mettatonex_196", "Drama!&Romance!&Blood-&shed!/%%")
ds_map_add(global.text_data_en, "obj_mettatonex_202", "I'm the&idol&everyone&craves!/%%")
ds_map_add(global.text_data_en, "obj_mettatonex_208", "Smile&for the&camera!/%%")
ds_map_add(global.text_data_en, "obj_mettatonex_214", "Oooh, it's time&for a pop quiz!/")
ds_map_add(global.text_data_en, "obj_mettatonex_215", "I hope you brought&a keyboard.../")
ds_map_add(global.text_data_en, "obj_mettatonex_215_console", "Have fun with that&on-screen keyboard.../")
ds_map_add(global.text_data_en, "obj_mettatonex_216", "This one's an&essay question!/%%")
ds_map_add(global.text_data_en, "obj_mettatonex_222", "Your essay really&showed everyone&your heart./")
ds_map_add(global.text_data_en, "obj_mettatonex_223", "Why don't I show&you mine?/%%")
ds_map_add(global.text_data_en, "obj_mettatonex_231", "Ooooh,&I'm just&warming&up!/%%")
ds_map_add(global.text_data_en, "obj_mettatonex_237", "But how are you&on the dance floor!?/%%")
ds_map_add(global.text_data_en, "obj_mettatonex_244", "Can you&keep up&the&pace!?/%%")
ds_map_add(global.text_data_en, "obj_mettatonex_253", "Lights!&Camera&Bombs!/%%")
ds_map_add(global.text_data_en, "obj_mettatonex_259", "Things&are&blowing&up!/%%")
ds_map_add(global.text_data_en, "obj_mettatonex_267", "Time for our union-&regulated break!/%%")
ds_map_add(global.text_data_en, "obj_mettatonex_274", "We've grown so&distant, darling.../")
ds_map_add(global.text_data_en, "obj_mettatonex_275", "How about another&heart-to-heart?/%%")
ds_map_add(global.text_data_en, "obj_mettatonex_285", "A.. arms?&Wh... who needs arms&with legs like&these?/")
ds_map_add(global.text_data_en, "obj_mettatonex_286", "I'm still going&to win!/%%")
ds_map_add(global.text_data_en, "obj_mettatonex_297", "Come on&...!/%%")
ds_map_add(global.text_data_en, "obj_mettatonex_307", "The show&...&must go&on!/%%")
ds_map_add(global.text_data_en, "obj_mettatonex_317", "Dr...&Drama!&A...&Action!/%%")
ds_map_add(global.text_data_en, "obj_mettatonex_329", "\E5L... lights...&C... camera.../")
ds_map_add(global.text_data_en, "obj_mettatonex_330", "Enough of this!&Do you really want&humanity to perish!?/")
ds_map_add(global.text_data_en, "obj_mettatonex_331", "\E7... or do you just&believe in yourself&that much?/%%")
ds_map_add(global.text_data_en, "obj_mettatonex_353", "Haha, how inspiring!/")
ds_map_add(global.text_data_en, "obj_mettatonex_354", "Well, darling!&It's either me&or you!/")
ds_map_add(global.text_data_en, "obj_mettatonex_355", "\E4But I think we both&already know who's&going to win./")
ds_map_add(global.text_data_en, "obj_mettatonex_356", "\E8Witness the true&power of humanity's&star!/%%")
ds_map_add(global.text_data_en, "obj_mettatonex_368", "... then.../")
ds_map_add(global.text_data_en, "obj_mettatonex_369", "\E8Are YOU the star?/")
ds_map_add(global.text_data_en, "obj_mettatonex_370", "Can you really&protect humanity!?/%%")
ds_map_add(global.text_data_en, "obj_mettatonex_638", "* Mettaton.")
ds_map_add(global.text_data_en, "obj_mettatonex_639", "* Mettaton.")
ds_map_add(global.text_data_en, "obj_mettatonex_640", "* Mettaton.")
ds_map_add(global.text_data_en, "obj_mettatonex_641", "* Mettaton.")
ds_map_add(global.text_data_en, "obj_mettatonex_642", "* Smells like Mettaton.")
ds_map_add(global.text_data_en, "obj_mettatonex_644", "* Mettaton has low HP.")
ds_map_add(global.text_data_en, "obj_mettatonex_677", "* METTATON EX - ATK 47 DEF 47&* His weak point is his&  heart-shaped core./^")
ds_map_add(global.text_data_en, "obj_mettatonex_691", "* You say you aren't going&  to get hit at ALL./")
ds_map_add(global.text_data_en, "obj_mettatonex_692", "* Ratings gradually increase&  during Mettaton's turn./^")
ds_map_add(global.text_data_en, "obj_mettatonex_706", "* You posed dramatically^1.&* The audience nods./^")
ds_map_add(global.text_data_en, "obj_mettatonex_708", "* Despite being hurt^1, you&  posed dramatically^1.&* The audience applauds./^")
ds_map_add(global.text_data_en, "obj_mettatonex_710", "* Despite being wounded^1, you&  posed dramatically^1.&* The audience gasps./^")
ds_map_add(global.text_data_en, "obj_mettatonex_712", "* With the last of your power^1,&  you pose dramatically^1.&* The audience screams./^")
ds_map_add(global.text_data_en, "obj_mettatonex_726", "* You turn and scoff at the&  audience./")
ds_map_add(global.text_data_en, "obj_mettatonex_727", "* They're rooting for your&  destruction this turn!/^")
ds_map_add(global.text_data_en, "obj_mettatonex_770", "H.. ha.../")
ds_map_add(global.text_data_en, "obj_mettatonex_771", "So I was wrong./")
ds_map_add(global.text_data_en, "obj_mettatonex_772", "Darling.../")
ds_map_add(global.text_data_en, "obj_mettatonex_773", "\E1You really are&strong enough to&get past ASGORE./")
ds_map_add(global.text_data_en, "obj_mettatonex_774", "\E0Well then.../")
ds_map_add(global.text_data_en, "obj_mettatonex_775", "It's time for&you to go./")
ds_map_add(global.text_data_en, "obj_mettatonex_776", "\E0Don't worry about&me./")
ds_map_add(global.text_data_en, "obj_mettatonex_777", "I might seem like&I'm dying now^1,&but.../")
ds_map_add(global.text_data_en, "obj_mettatonex_778", "\E1Dr. Alphys can&always repair me./")
ds_map_add(global.text_data_en, "obj_mettatonex_779", "\E0And... besides.../")
ds_map_add(global.text_data_en, "obj_mettatonex_780", "Even if I'm not&cut out to be&a star.../")
ds_map_add(global.text_data_en, "obj_mettatonex_781", "\E1I still got to&perform for a&human, didn't I?/")
ds_map_add(global.text_data_en, "obj_mettatonex_782", "So, thank you,&darling.../%%")
ds_map_add(global.text_data_en, "obj_mettatonex_804", "\E1You've been a&great audience!/%%")
ds_map_add(global.text_data_en, "obj_mettatonex_836", "OOH^1, LOOK AT&THESE RATINGS!!!/")
ds_map_add(global.text_data_en, "obj_mettatonex_837", "\E6THIS IS THE MOST&VIEWERS I'VE EVER&HAD!!!/")
ds_map_add(global.text_data_en, "obj_mettatonex_838", "WE'VE REACHED THE&VIEWER CALL-IN&MILESTONE!/")
ds_map_add(global.text_data_en, "obj_mettatonex_839", "\E8ONE LUCKY VIEWER&WILL HAVE THE CHANCE&TO TALK TO ME.../")
ds_map_add(global.text_data_en, "obj_mettatonex_840", "\E7... BEFORE I LEAVE&THE UNDERGROUND&FOREVER!!/")
ds_map_add(global.text_data_en, "obj_mettatonex_841", "\E9LET'S SEE WHO&CALLS IN FIRST!/%%")
ds_map_add(global.text_data_en, "obj_mettatonex_866", "\E0HI^1, YOU'RE ON TV!/")
ds_map_add(global.text_data_en, "obj_mettatonex_867", "WHAT DO YOU HAVE&TO SAY ON THIS^1,&OUR LAST SHOW???/%%")
ds_map_add(global.text_data_en, "obj_mettatonex_880", "...../")
ds_map_add(global.text_data_en, "obj_mettatonex_881", "oh......../")
ds_map_add(global.text_data_en, "obj_mettatonex_882", "\E1hi..^1.&mettaton.../")
ds_map_add(global.text_data_en, "obj_mettatonex_883", "i really liked&watching your show.../")
ds_map_add(global.text_data_en, "obj_mettatonex_884", "my life is pretty&boring..^1. but.../")
ds_map_add(global.text_data_en, "obj_mettatonex_885", "seeing you on the&screen..^1. brought&excitement to my&life..^1. vicariously/")
ds_map_add(global.text_data_en, "obj_mettatonex_886", "i can't tell^1, but..^1.&i guess this is&the last episode...?/")
ds_map_add(global.text_data_en, "obj_mettatonex_887", "\E3i'll miss you..^1.&mettaton....../")
ds_map_add(global.text_data_en, "obj_mettatonex_888", "... oh...^1. i didn't&mean to talk so&long.../")
ds_map_add(global.text_data_en, "obj_mettatonex_889", "\E2oh........../%%")
ds_map_add(global.text_data_en, "obj_mettatonex_900", "NO^1, WAIT^1!&WAIT^1, BL.../")
ds_map_add(global.text_data_en, "obj_mettatonex_901", "\E1H..^1.&THEY ALREADY HUNG&UP./")
ds_map_add(global.text_data_en, "obj_mettatonex_902", "\E3.../")
ds_map_add(global.text_data_en, "obj_mettatonex_903", "\E0I'LL TAKE ANOTHER&CALLER!!!/%%")
ds_map_add(global.text_data_en, "obj_mettatonex_915", "\E1Mettaton^1, your show&made us so happy!/%%")
ds_map_add(global.text_data_en, "obj_mettatonex_928", "Mettaton^1, I don't&know what I'll&watch without you./%%")
ds_map_add(global.text_data_en, "obj_mettatonex_941", "Mettaton^1, there's&a Mettaton-shaped&hole in my Mettaton-&shaped heart./%%")
ds_map_add(global.text_data_en, "obj_mettatonex_964", "\E3AH..^1. I.../")
ds_map_add(global.text_data_en, "obj_mettatonex_965", "I SEE.../")
ds_map_add(global.text_data_en, "obj_mettatonex_966", "\E4.../")
ds_map_add(global.text_data_en, "obj_mettatonex_967", "EVERYONE..^1.&THANK YOU SO MUCH./")
ds_map_add(global.text_data_en, "obj_mettatonex_968", ".../")
ds_map_add(global.text_data_en, "obj_mettatonex_969", "\E0DARLING./")
ds_map_add(global.text_data_en, "obj_mettatonex_970", "\E1PERHAPS..^1. IT MIGHT BE&BETTER IF I STAY&HERE FOR A WHILE./")
ds_map_add(global.text_data_en, "obj_mettatonex_971", "\E2HUMANS ALREADY HAVE&STARS AND IDOLS^1,&BUT MONSTERS.../")
ds_map_add(global.text_data_en, "obj_mettatonex_972", "\E0THEY ONLY HAVE ME./")
ds_map_add(global.text_data_en, "obj_mettatonex_973", "\E1IF I LEFT..^1.&THE UNDERGROUND WOULD&LOSE ITS SPARK./")
ds_map_add(global.text_data_en, "obj_mettatonex_974", "\E3I'D LEAVE AN ACHING&VOID THAT CAN NEVER&BE FILLED./")
ds_map_add(global.text_data_en, "obj_mettatonex_975", "\E0SO..^1. I THINK I'LL&HAVE TO DELAY MY&BIG DEBUT./")
ds_map_add(global.text_data_en, "obj_mettatonex_976", "\E2BESIDES./")
ds_map_add(global.text_data_en, "obj_mettatonex_977", "\E1YOU'VE PROVEN TO&BE VERY STRONG./")
ds_map_add(global.text_data_en, "obj_mettatonex_978", "\E0PERHAPS..^1. EVEN STRONG&ENOUGH TO GET PAST&ASGORE./")
ds_map_add(global.text_data_en, "obj_mettatonex_979", "\E0I'M SURE YOU'LL BE&ABLE TO PROTECT&HUMANITY./")
ds_map_add(global.text_data_en, "obj_mettatonex_980", "\E4HA^1, HA.../")
ds_map_add(global.text_data_en, "obj_mettatonex_981", "IT'S ALL FOR THE&BEST^1, ANYWAY./")
ds_map_add(global.text_data_en, "obj_mettatonex_982", "\E3THE TRUTH IS^1, THIS&FORM'S ENERGY&CONSUMPTION IS.../")
ds_map_add(global.text_data_en, "obj_mettatonex_983", "INEFFICIENT./")
ds_map_add(global.text_data_en, "obj_mettatonex_984", "IN A FEW MOMENTS^1,&I'LL RUN OUT OF&BATTERY POWER^1, AND.../")
ds_map_add(global.text_data_en, "obj_mettatonex_985", "\E4WELL./")
ds_map_add(global.text_data_en, "obj_mettatonex_986", "\E0I'LL BE ALRIGHT./")
ds_map_add(global.text_data_en, "obj_mettatonex_987", "\E5KNOCK 'EM DEAD^1,&DARLING./")
ds_map_add(global.text_data_en, "obj_mettatonex_988", "\E0AND EVERYONE..^1.&THANK YOU./")
ds_map_add(global.text_data_en, "obj_mettatonex_989", "YOU'VE BEEN A&GREAT AUDIENCE!/%%")
ds_map_add(global.text_data_en, "obj_mettboss_event_170", "* REALLY^1?&* WHERE?/%%")
ds_map_add(global.text_data_en, "obj_mettboss_event_187", "* CLEVER..^1.&* VERY CLEVER./%%")
ds_map_add(global.text_data_en, "obj_mettboss_event_230", "* OH YES.&* THERE YOU ARE, DARLING./")
ds_map_add(global.text_data_en, "obj_mettboss_event_231", "* IT'S TIME TO HAVE OUR&  LITTLE SHOWDOWN./")
ds_map_add(global.text_data_en, "obj_mettboss_event_232", "* IT'S TIME TO FINALLY STOP&  THE " + '"' + "MALFUNCTIONING" + '"' + " ROBOT./")
ds_map_add(global.text_data_en, "obj_mettboss_event_233", "* ... NOT!!!/")
ds_map_add(global.text_data_en, "obj_mettboss_event_234", "* MALFUNCTION?&* REPROGRAMMING?&* GET REAL./")
ds_map_add(global.text_data_en, "obj_mettboss_event_235", "* THIS WAS ALL JUST A BIG&  SHOW./")
ds_map_add(global.text_data_en, "obj_mettboss_event_236", "* AN ACT./")
ds_map_add(global.text_data_en, "obj_mettboss_event_237", "* ALPHYS HAS BEEN PLAYING&  YOU FOR A FOOL THE&  WHOLE TIME./")
ds_map_add(global.text_data_en, "obj_mettboss_event_238", "* AS SHE WATCHED YOU ON THE&  SCREEN^1, SHE GREW ATTACHED&  TO YOUR ADVENTURE./")
ds_map_add(global.text_data_en, "obj_mettboss_event_239", "* SHE DESPERATELY WANTED TO&  BE A PART OF IT./")
ds_map_add(global.text_data_en, "obj_mettboss_event_240", "* SO SHE DECIDED TO INSERT&  HERSELF INTO YOUR STORY./")
ds_map_add(global.text_data_en, "obj_mettboss_event_241", "* SHE REACTIVATED PUZZLES^1.&* SHE DISABLED ELEVATORS^1.&* SHE ENLISTED ME TO TORMENT YOU./")
ds_map_add(global.text_data_en, "obj_mettboss_event_242", "* ALL SO SHE COULD SAVE&  YOU FROM DANGERS THAT&  DIDN'T EXIST./")
ds_map_add(global.text_data_en, "obj_mettboss_event_243", "* ALL SO YOU WOULD THINK&  SHE'S THE GREAT PERSON.../")
ds_map_add(global.text_data_en, "obj_mettboss_event_244", "* THAT SHE'S NOT./")
ds_map_add(global.text_data_en, "obj_mettboss_event_245", "* AND NOW^1, IT'S TIME FOR&  HER FINEST HOUR./")
ds_map_add(global.text_data_en, "obj_mettboss_event_247", "* AT THIS VERY MOMENT,&  ALPHYS IS WAITING OUTSIDE&  THE ROOM./")
ds_map_add(global.text_data_en, "obj_mettboss_event_248", "* DURING OUR " + '"' + "BATTLE," + '"' + " SHE&  WILL INTERRUPT./")
ds_map_add(global.text_data_en, "obj_mettboss_event_249", "* SHE WILL PRETEND TO&  " + '"' + "DEACTIVATE" + '"' + " ME, " + '"' + "SAVING" + '"' + " YOU&  ONE FINAL TIME./")
ds_map_add(global.text_data_en, "obj_mettboss_event_250", "* FINALLY.&* SHE'LL BE THE HEROINE OF&  YOUR ADVENTURE./")
ds_map_add(global.text_data_en, "obj_mettboss_event_251", "* YOU'LL REGARD HER SO HIGHLY&  SHE'LL EVEN BE ABLE TO&  CONVINCE YOU NOT TO LEAVE./")
ds_map_add(global.text_data_en, "obj_mettboss_event_252", "* ... OR NOT./")
ds_map_add(global.text_data_en, "obj_mettboss_event_253", "* YOU SEE, I'VE HAD ENOUGH OF&  THIS PREDICTABLE CHARADE./")
ds_map_add(global.text_data_en, "obj_mettboss_event_254", "* I HAVE NO DESIRE TO HARM&  HUMANS.&* FAR FROM IT, ACTUALLY./")
ds_map_add(global.text_data_en, "obj_mettboss_event_255", "* MY ONLY DESIRE IS TO&  ENTERTAIN./")
ds_map_add(global.text_data_en, "obj_mettboss_event_256", "* AFTER ALL, THE AUDIENCE&  DESERVES A GOOD SHOW,&  DON'T THEY?/")
ds_map_add(global.text_data_en, "obj_mettboss_event_257", "* AND WHAT'S A GOOD SHOW.../")
ds_map_add(global.text_data_en, "obj_mettboss_event_258", "* WITHOUT A PLOT TWIST?/%%")
ds_map_add(global.text_data_en, "obj_mettboss_event_263", "* MY^1, MY^1.&* SO YOU'VE FINALLY ARRIVED./")
ds_map_add(global.text_data_en, "obj_mettboss_event_264", "* AFTER OUR FIRST MEETING^1, I&  REALIZED..^1.&* SOMETHING GHASTLY./")
ds_map_add(global.text_data_en, "obj_mettboss_event_265", "* YOU'RE NOT JUST A THREAT&  TO MONSTERS..^1.&* BUT HUMANITY^1, AS WELL./")
ds_map_add(global.text_data_en, "obj_mettboss_event_266", "* OH MY^1.&* THAT'S AN ISSUE./")
ds_map_add(global.text_data_en, "obj_mettboss_event_267", "* YOU SEE^1, I CAN'T BE A&  STAR WITHOUT AN AUDIENCE./")
ds_map_add(global.text_data_en, "obj_mettboss_event_268", "* AND BESIDES.../")
ds_map_add(global.text_data_en, "obj_mettboss_event_269", "* THERE ARE SOME PEOPLE..^1.&* I WANT TO PROTECT./%%")
ds_map_add(global.text_data_en, "obj_mettboss_event_303", "* H-hey!!^1!&* Wh-wh-what's going on!?/")
ds_map_add(global.text_data_en, "obj_mettboss_event_304", "* Th-th-the door just&  locked itself!/%%")
ds_map_add(global.text_data_en, "obj_mettboss_event_321", "\M1* SORRY^1, FOLKS^1!&* THE OLD PROGRAM'S BEEN&  CANCELLED!!!/")
ds_map_add(global.text_data_en, "obj_mettboss_event_322", "* BUT WE'VE GOT A FINALE&  THAT WILL DRIVE YOU WILD!!/%%")
ds_map_add(global.text_data_en, "obj_mettboss_event_341", "\M5* REAL DRAMA!!&* REAL ACTION!!&* REAL BLOODSHED!!/")
ds_map_add(global.text_data_en, "obj_mettboss_event_342", "* ON OUR NEW SHOW.../")
ds_map_add(global.text_data_en, "obj_mettboss_event_343", "* " + '"' + "ATTACK OF THE KILLER&  ROBOT!" + '"' + "/%%")
ds_map_add(global.text_data_en, "obj_mettboss_event_411", "* AH HA HA^1.&* EAGER, AS ALWAYS, EH?/")
ds_map_add(global.text_data_en, "obj_mettboss_event_412", "* BUT DON'T TOUCH THAT DIAL.&* THERE'S SOMETHING YOU&  HAVEN'T ACCOUNTED FOR./")
ds_map_add(global.text_data_en, "obj_mettboss_event_413", "* AS ANY TRUE FAN WOULD KNOW,&  I WAS FIRST CREATED AS&  A HUMAN ERADICATION ROBOT./")
ds_map_add(global.text_data_en, "obj_mettboss_event_414", "* IT WAS ONLY AFTER BECOMING A&  STAR THAT I WAS GIVEN A&  MORE... PHOTOGENIC BODY./")
ds_map_add(global.text_data_en, "obj_mettboss_event_415", "* HOWEVER./")
ds_map_add(global.text_data_en, "obj_mettboss_event_416", "* THOSE ORIGINAL FUNCTIONS&  HAVE NEVER BEEN FULLY&  REMOVED.../")
ds_map_add(global.text_data_en, "obj_mettboss_event_417", "* COME ANY CLOSER, AND&  I'LL BE FORCED TO SHOW&  YOU.../")
ds_map_add(global.text_data_en, "obj_mettboss_event_418", "\M5* MY TRUE FORM!/%%")
ds_map_add(global.text_data_en, "obj_mettboss_event_443", "\M0* FINE THEN!/")
ds_map_add(global.text_data_en, "obj_mettboss_event_444", "\M5* RRRRREADY^1?&* IIIIIIIT'S SHOWTIME!!!/%%")
ds_map_add(global.text_data_en, "obj_mettdestroyed_event_169", "* I..^1. I managed to open&  the lock^1!&* Are you two.../%%")
ds_map_add(global.text_data_en, "obj_mettdestroyed_event_197", "* Oh my god./%%")
ds_map_add(global.text_data_en, "obj_mettdestroyed_event_222", "* Mettaton!/")
ds_map_add(global.text_data_en, "obj_mettdestroyed_event_223", "\E1* Mettaton^1, are you.../%%")
ds_map_add(global.text_data_en, "obj_mettdestroyed_event_244", "* H..^1. hey.../")
ds_map_add(global.text_data_en, "obj_mettdestroyed_event_245", "* D..^1. don't worry&  about it.../")
ds_map_add(global.text_data_en, "obj_mettdestroyed_event_246", "* I can always.../")
ds_map_add(global.text_data_en, "obj_mettdestroyed_event_247", "\E5* I can always build&  a different robot!/")
ds_map_add(global.text_data_en, "obj_mettdestroyed_event_248", "\E6* .../")
ds_map_add(global.text_data_en, "obj_mettdestroyed_event_249", "\E5* Why don't you go&  on ahead?/%%")
ds_map_add(global.text_data_en, "obj_mettdestroyed_event_254", "* ... thank GOD^1, it's just&  the batteries./")
ds_map_add(global.text_data_en, "obj_mettdestroyed_event_255", "\E9* Mettaton^1, if you were&  gone^1, I would have..^1.&* I would have.../")
ds_map_add(global.text_data_en, "obj_mettdestroyed_event_256", "\E8* .../")
ds_map_add(global.text_data_en, "obj_mettdestroyed_event_257", "\E6* I m-mean^1, h-hey^1, it's&  n-^1no problem^1, you&  know?/")
ds_map_add(global.text_data_en, "obj_mettdestroyed_event_258", "\E5* He's just a robot^1, if&  you messed it up^1, I&  c-could always.../")
ds_map_add(global.text_data_en, "obj_mettdestroyed_event_259", "\E6* J-just build another./")
ds_map_add(global.text_data_en, "obj_mettdestroyed_event_260", "\E4* .../")
ds_map_add(global.text_data_en, "obj_mettdestroyed_event_261", "* Why don't you go&  on ahead?/%%")
ds_map_add(global.text_data_en, "obj_metteggs_58", "* (You found the eggs.)/%%")
ds_map_add(global.text_data_en, "obj_mettmilk_58", "* (You found the milk.)/%%")
ds_map_add(global.text_data_en, "obj_mettnews_artifact_117", "* Error Baby%%")
ds_map_add(global.text_data_en, "obj_mettnews_battleobj_199", "* Error./%%")
ds_map_add(global.text_data_en, "obj_mettnews_battleobj_204", "* Great job^1!&* Keep heading around the&  room!/")
ds_map_add(global.text_data_en, "obj_mettnews_battleobj_205", "* Try to go for the&  one in the bottom-&  left next!/%%")
ds_map_add(global.text_data_en, "obj_mettnews_battleobj_209", "* Great job^1!&* Keep heading around the&  room!/")
ds_map_add(global.text_data_en, "obj_mettnews_battleobj_210", "* Try to go for the&  one in the top-&  right next!/%%")
ds_map_add(global.text_data_en, "obj_mettnews_battleobj_214", "* Great job^1!&* Head to the left&  next!/%%")
ds_map_add(global.text_data_en, "obj_mettnews_battleobj_218", "* Great job^1!&* Head to the right&  next!/%%")
ds_map_add(global.text_data_en, "obj_mettnews_battleobj_223", "* You couldn't even&  get one bomb...!?/%%")
ds_map_add(global.text_data_en, "obj_mettnews_battleobj_246", "* Error,/%%")
ds_map_add(global.text_data_en, "obj_mettnews_battleobj_249", "* Great job^1!&* Head for the center^1!&* There's one left there!/%%")
ds_map_add(global.text_data_en, "obj_mettnews_battleobj_252", "* Great job^1!&* Head for the center!/")
ds_map_add(global.text_data_en, "obj_mettnews_battleobj_253", "* I'm using^1, uh^1, EM fields&  to trap the glass of&  water there!/%%")
ds_map_add(global.text_data_en, "obj_mettnews_battleobj_257", "* Great job^1!&* There's only one left&  in the bottom-right!/%%")
ds_map_add(global.text_data_en, "obj_mettnews_battleobj_261", "* Great job^1!&* There's only one left&  at the top!/%%")
ds_map_add(global.text_data_en, "obj_mettnews_battleobj_265", "* Great job^1!&* There's only one left&  at the top-right!/%%")
ds_map_add(global.text_data_en, "obj_mettnews_battleobj_269", "* Great job^1!&* There's only one left&  at the bottom-left!/%%")
ds_map_add(global.text_data_en, "obj_mettnews_battleobj_275", "* It's..^1. it's.../%%")
ds_map_add(global.text_data_en, "obj_mettnewsevent_88", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_mettnewsevent_89", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_mettnewsevent_90", "* Okay^1, I'm back!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_91", "\E0* A-another dark room^1,&  huh?/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_92", "\E6* Don't worry!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_93", "\E0* M-my hacking skills&  have got things&  covered!/%%")
ds_map_add(global.text_data_en, "obj_mettnewsevent_159", "\E3* Are you serious?/%%")
ds_map_add(global.text_data_en, "obj_mettnewsevent_174", "* OHHHHHH YESSS!!!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_175", "* GOOD EVENING^1, BEAUTIES AND&  GENTLEBEAUTIES!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_176", "* THIS IS METTATON^1, REPORTING&  LIVE FROM MTT NEWS!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_177", "\M2* AN INTERESTING SITUATION HAS&  ARISEN IN EASTERN HOTLAND!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_178", "\M3* FORTUNATELY^1, OUR CORRESPONDENT&  IS OUT THERE^1, REPORTING LIVE!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_179", "\M6* BRAVE CORRESPONDENT^1!&* PLEASE FIND SOMETHING&  NEWSWORTHY TO REPORT!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_180", "\M4* OUR TEN WONDERFUL VIEWERS&  ARE WAITING FOR YOU!!/%%")
ds_map_add(global.text_data_en, "obj_mettnewsevent_229", "\M3* ATTENTION^1, VIEWERS^1!&* OUR CORRESPONDENT HAS&  FOUND..^1. A DOG!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_230", "\M4* (CUE AUDIENCE AWWS)/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_231", "\M3* THAT'S RIGHT^1, FOLKS^1!&* IT'S THE FEEL-GOOD&  STORY OF THE YEAR!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_232", "\M4* LOOK AT ITS LITTLE&  EARS^1, TINY PAWS^1, FLUFFY&  TAIL.../")
ds_map_add(global.text_data_en, "obj_mettnewsevent_233", "* .../")
ds_map_add(global.text_data_en, "obj_mettnewsevent_234", "* WAIT A SECOND./")
ds_map_add(global.text_data_en, "obj_mettnewsevent_235", "\M5* THAT'S NOT A TAIL!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_236", "\M3* THAT'S.../")
ds_map_add(global.text_data_en, "obj_mettnewsevent_237", "\M5* A FUSE!!!/%%")
ds_map_add(global.text_data_en, "obj_mettnewsevent_264", "\M4* THAT'S RIGHT..^1.&* THAT DOG.../")
ds_map_add(global.text_data_en, "obj_mettnewsevent_265", "\M5* IS A BOMB!!!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_266", "\M5* BUT DON'T PANIC!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_267", "\M4* YOU HAVEN'T EVEN SEEN&  THE REST OF THE ROOM&  YET!!!/%%")
ds_map_add(global.text_data_en, "obj_mettnewsevent_283", "\M3* ATTENTION^1, VIEWERS^1!&* OUR CORRESPONDENT HAS&  FOUND..^1. A GLASS OF WATER!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_284", "\M4* BUT WHAT'S ASTONISHING&  ABOUT THIS GLASS OF&  WATER.../")
ds_map_add(global.text_data_en, "obj_mettnewsevent_285", "\M3* IS HOW UNINTERESTING IT IS!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_286", "\M4* LIKE ALL GLASSES OF WATER^1,&  IT'S COMPRISED OF WATER^1,&  GLASS^1, NITROGLYCERIN.../")
ds_map_add(global.text_data_en, "obj_mettnewsevent_287", "* .../")
ds_map_add(global.text_data_en, "obj_mettnewsevent_288", "* WAIT A SECOND./")
ds_map_add(global.text_data_en, "obj_mettnewsevent_289", "\M5* THAT'S NOT A GLASS OF&  WATER!!!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_290", "\M3* THAT'S.../")
ds_map_add(global.text_data_en, "obj_mettnewsevent_291", "\M5* A BOMB!!!/%%")
ds_map_add(global.text_data_en, "obj_mettnewsevent_318", "\M5* OH NO!!^1!&* THIS NEWS REPORT.../")
ds_map_add(global.text_data_en, "obj_mettnewsevent_319", "\M5* IS TURNING INTO A DISASTER&  REPORT!!!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_320", "\M3* BUT DON'T PANIC!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_321", "\M4* YOU HAVEN'T EVEN SEEN&  THE REST OF THE ROOM&  YET!/%%")
ds_map_add(global.text_data_en, "obj_mettnewsevent_337", "\M3* ATTENTION^1, VIEWERS^1!&* OUR CORRESPONDENT HAS&  FOUND..^1. A MOVIE SCRIPT!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_338", "\M5* OH MY^1!&* AND IT LOOKS LIKE IT'S&  FOR MY LATEST FILM!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_339", "\M3* LET'S NOT KEEP THEM WAITING^1!&* LET'S OPEN IT UP AND GET&  THE SCOOP!/%%")
ds_map_add(global.text_data_en, "obj_mettnewsevent_372", "\M4* ... OH??^1?&* WHAT'S THAT INSIDE THE&  SCRIPT?/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_373", "\M4* THAT TICKING SOUND..^1.&* THAT LIT FUSE.../")
ds_map_add(global.text_data_en, "obj_mettnewsevent_374", "\M5* OH MY!!^1!&* LOOKS LIKE I WAS WRONG&  ABOUT THE MOVIE!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_375", "* WE DEFINITELY HAVE A BOX&  OFFICE BOMB ON OUR HANDS!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_376", "* AND IT'S ABOUT TO BLAST&  YOU TO BITS!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_377", "\M3* BUT DON'T GET TOO EXCITED!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_378", "\M4* YOU HAVEN'T EVEN SEEN&  THE REST OF THE ROOM&  YET!/%%")
ds_map_add(global.text_data_en, "obj_mettnewsevent_394", "\M3* ATTENTION^1, VIEWERS^1!&* OUR CORRESPONDENT HAS&  FOUND..^1. A BASKETBALL!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_395", "\M4* AH^1.&* BASKETBALLS./")
ds_map_add(global.text_data_en, "obj_mettnewsevent_396", "\M3* CIRCLES OF FUN^1.&* ORBS OF JOY^1.&* SPHERES OF AMUSEMENT./")
ds_map_add(global.text_data_en, "obj_mettnewsevent_397", "\M4* BUT YOU SHOULDN'T PLAY&  WITH THIS ONE^1.&* IT'S AN MTT-BRAND FASHIONBALL./")
ds_map_add(global.text_data_en, "obj_mettnewsevent_398", "\M3* PROPER MAINTENANCE IS&  REQUIRED TO KEEP IT LOOKING&  GOOD./")
ds_map_add(global.text_data_en, "obj_mettnewsevent_399", "\M3* AS YOU CAN SEE^1, EVEN EXPOSURE&  TO HUMAN BODY HEAT CAUSES&  THE PAINT TO SLOUGH OFF./")
ds_map_add(global.text_data_en, "obj_mettnewsevent_400", "* .../")
ds_map_add(global.text_data_en, "obj_mettnewsevent_401", "* WAIT A SECOND./")
ds_map_add(global.text_data_en, "obj_mettnewsevent_402", "* THAT'S NOT A BASKETBALL./%%")
ds_map_add(global.text_data_en, "obj_mettnewsevent_429", "\M5* THAT'S A BOMB!!!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_430", "* OH NO!!^1!&* THIS SPORT REVIEW.../")
ds_map_add(global.text_data_en, "obj_mettnewsevent_431", "* IS TURNING INTO A SHORT&  REVIEW!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_432", "* BECAUSE IT'LL BE OVER^1.&* AFTER YOU BLOW UP./")
ds_map_add(global.text_data_en, "obj_mettnewsevent_434", "\M3* BUT DON'T GET TOO EXCITED!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_435", "\M4* YOU HAVEN'T EVEN SEEN&  THE REST OF THE ROOM&  YET!/%%")
ds_map_add(global.text_data_en, "obj_mettnewsevent_449", "\M3* ATTENTION^1, VIEWERS^1!&* OUR CORRESPONDENT HAS&  FOUND..^1. A PRESENT!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_450", "\M4* AND IT'S TIME FOR THE&  UNBOXING VIDEO!!!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_451", "\M5* LET'S FIND OUT WHAT'S&  INSIDE!!/%%")
ds_map_add(global.text_data_en, "obj_mettnewsevent_479", "\M2* THAT ROUND^1, BLACK SHAPE..^1.&* COULD IT BE???/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_480", "\M4* LOOKS LIKE CHRISTMAS CAME&  EARLY THIS YEAR./")
ds_map_add(global.text_data_en, "obj_mettnewsevent_481", "\M5* IF SANTA GAVE PEOPLE BOMBS&  INSTEAD OF PRESENTS!!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_482", "\M2* REALLY THOUGH^1.&* A BOMB^1.&* WHAT A THOUGHTFUL GIFT./")
ds_map_add(global.text_data_en, "obj_mettnewsevent_483", "\M4* THEY EVEN DECIDED TO&  LIGHT IT FOR YOU!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_484", "\M3* BUT DON'T GET TOO EXCITED!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_485", "\M4* YOU HAVEN'T EVEN SEEN&  THE REST OF THE ROOM&  YET!/%%")
ds_map_add(global.text_data_en, "obj_mettnewsevent_499", "\M3* ATTENTION^1, VIEWERS^1!&* OUR CORRESPONDENT HAS&  FOUND..^1. A VIDEO GAME!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_500", "\M4* THIS ACTION-PACKED GAME&  IS GUARANTEED TO BLOW YOU&  AWAY!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_501", "\M3* STRANGE ENEMIES^1!&* STRANGE ALLIES^1!&* ATTRACTIVE ROBOTS!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_502", "\M4* FEATURING UP TO SIX&  ARBITRARY DIALOGUE CHOICES&  AT ONCE!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_503", "\M5* CORRESPONDENT^1!&* LET'S LOOK INSIDE THE CASE!/%%")
ds_map_add(global.text_data_en, "obj_mettnewsevent_531", "\M4* ..^1.&* THOSE RED CYLINDERS WITH&  BURNING FUSES.../")
ds_map_add(global.text_data_en, "obj_mettnewsevent_532", "\M5* OH NO^1!&* THIS GAME LITERALLY IS&  DYNAMITE!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_533", "\M5* I GUESS THEY WERE RIGHT&  ALL ALONG!!!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_534", "\M5* VIDEO-GAMES DO CAUSE&  VIOLENCE!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_535", "\M4* OR AT LEAST THIS ONE'S&  ABOUT TO./")
ds_map_add(global.text_data_en, "obj_mettnewsevent_536", "\M3* BUT DON'T GET TOO EXCITED!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_537", "\M4* YOU HAVEN'T EVEN SEEN&  THE REST OF THE ROOM&  YET!/%%")
ds_map_add(global.text_data_en, "obj_mettnewsevent_609", "* OH MY!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_610", "* IT SEEMS EVERYTHING IN THIS&  AREA IS ACTUALLY A BOMB!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_613", "* THAT DOG'S A BOMB!/%%")
ds_map_add(global.text_data_en, "obj_mettnewsevent_618", "* THAT PRESENT'S A BOMB!/%%")
ds_map_add(global.text_data_en, "obj_mettnewsevent_649", "* THAT BASKETBALL'S A BOMB!/%%")
ds_map_add(global.text_data_en, "obj_mettnewsevent_654", "* THAT PRESENT'S A BOMB!/%%")
ds_map_add(global.text_data_en, "obj_mettnewsevent_684", "* EVEN MY WORDS ARE...!/%%")
ds_map_add(global.text_data_en, "obj_mettnewsevent_694", "\TS ^7  %")
ds_map_add(global.text_data_en, "obj_mettnewsevent_695", " %%")
ds_map_add(global.text_data_en, "obj_mettnewsevent_708", "\W* BRAVE CORRESPONDENT..^1.&* IF YOU DON'T DEFUSE ALL OF&  THE BOMBS.../%%")
ds_map_add(global.text_data_en, "obj_mettnewsevent_730", "\W*\M9 THIS BIG BOMB WILL BLOW&  YOU TO SMITHEREENS IN&  \YTWO MINUTES\W!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_731", "\M8* THEN YOU WON'T BE REPORTING&  " + '"' + "LIVE" + '"' + " ANY LONGER!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_732", "* HOW TERRIBLE^1!&* HOW DISTURBING!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_733", "\M9* OUR NINE VIEWERS ARE GOING&  TO LOVE WATCHING THIS!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_734", "* GOOD LUCK^1, DARLING!!/%%")
ds_map_add(global.text_data_en, "obj_mettnewsevent_827", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_mettnewsevent_828", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_mettnewsevent_829", "* D-don't worry!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_830", "\E6* I installed a&  bomb-defusing program&  on your phone!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_831", "\W* Use the 'defuse' option&  when the bomb is in the&  \GDEFUSE ZONE\W!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_832", "\E0* N-now^1, go get 'em!/%%")
ds_map_add(global.text_data_en, "obj_mettnewsevent_925", "* WELL DONE^1, DARLING!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_926", "* YOU'VE DEACTIVATED ALL OF&  THE BOMBS!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_927", "\W* IF YOU DIDN'T DEACTIVATE&  THEM^1, THE BIG BOMB WOULD&  HAVE EXPLODED IN \YTWO MINUTES\W./")
ds_map_add(global.text_data_en, "obj_mettnewsevent_928", "\W* NOW IT WON'T EXPLODE&  IN \YTWO MINUTES\W!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_929", "\W*\M9 INSTEAD IT'LL EXPLODE&  IN \YTWO SECONDS\W!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_930", "* GOODBYE^1, DARLING!/%%")
ds_map_add(global.text_data_en, "obj_mettnewsevent_934", "* TOO BAD^1, DARLING!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_935", "\W* YOU FAILED TO DEFUSE ALL&  OF THE BOMBS WITHIN \YTHREE&  MINUTES\W!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_936", "* NOW THE BIG BOMB IS&  GOING TO BLOW YOU TO&  SMITHEREENS!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_937", "* READY^1, VIEWERS^1?&* HERE COMES THE MOMENT&  YOU'VE ALL BEEN WAITING FOR!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_938", "* AHAHAH!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_939", "* GOODBYE^1, DARLING!/%%")
ds_map_add(global.text_data_en, "obj_mettnewsevent_987", "\M8* AH./")
ds_map_add(global.text_data_en, "obj_mettnewsevent_988", "* IT SEEMS THE BOMB ISN'T&  GOING OFF./")
ds_map_add(global.text_data_en, "obj_mettnewsevent_989", "\S-\Sp\T0* Ring...\S+/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_991", "* That's b-because!!!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_992", "* While you were&  monologuing... I...!!!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_993", "\E4* I f..^1. fix..^1.&* Um..^1. I ch-change.../")
ds_map_add(global.text_data_en, "obj_mettnewsevent_994", "\TS \F0 \E0 \TM %")
ds_map_add(global.text_data_en, "obj_mettnewsevent_995", "* OH NO^1.&* YOU DEACTIVATED THE BOMB&  WITH YOUR HACKING SKILLS./")
ds_map_add(global.text_data_en, "obj_mettnewsevent_997", "* Yeah^1!&* That's what I did!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_998", "\TS \F0 \E0 \TM %")
ds_map_add(global.text_data_en, "obj_mettnewsevent_999", "\M9* CURSES^1!&* IT SEEMS I'VE BEEN FOILED&  AGAIN!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_1000", "* CURSE YOU^1, HUMAN^1!&* CURSE YOU^1, DR. ALPHYS^1,&  FOR HELPING SO MUCH!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_1001", "\M8* BUT I DON'T CURSE MY&  EIGHT WONDERFUL VIEWERS&  FOR TUNING IN!!!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_1002", "* UNTIL NEXT TIME^1, DARLING!/%%")
ds_map_add(global.text_data_en, "obj_mettnewsevent_1017", "* W-wow..^1.&* W-we really showed&  him^1, huh?/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_1018", "\E2* .../")
ds_map_add(global.text_data_en, "obj_mettnewsevent_1019", "\E4* H-hey^1, I know I was&  kind of weird at&  first.../")
ds_map_add(global.text_data_en, "obj_mettnewsevent_1020", "\E0* But I really think&  I'm getting more.../")
ds_map_add(global.text_data_en, "obj_mettnewsevent_1021", "\E4* Uh^1, more.../")
ds_map_add(global.text_data_en, "obj_mettnewsevent_1022", "\E6* M-more confident about&  guiding you!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_1023", "\E0* S-so don't worry&  about that b-big&  d-dumb robot.../")
ds_map_add(global.text_data_en, "obj_mettnewsevent_1024", "\E6* I-I'll protect you&  from him!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_1025", "\E3* A-and if it really&  c-came down to it^1,&  we could just t-turn.../")
ds_map_add(global.text_data_en, "obj_mettnewsevent_1026", "\E5* Um^1, nevermind./")
ds_map_add(global.text_data_en, "obj_mettnewsevent_1027", "\E0* Later!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_1028", "\TS \F0 \E0 \T0 %")
ds_map_add(global.text_data_en, "obj_mettnewsevent_1029", "* (Klik...)/%%")
ds_map_add(global.text_data_en, "obj_mettnewsevent_1034", "* B-boy..^1.&* That was close^1, huh?/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_1035", "\E8* I guess a little&  closer than I would&  have liked./")
ds_map_add(global.text_data_en, "obj_mettnewsevent_1036", "\E9* I should have given&  you better directions.../")
ds_map_add(global.text_data_en, "obj_mettnewsevent_1037", "\E8* A-and there j-just&  w-wasn't enough&  time.../")
ds_map_add(global.text_data_en, "obj_mettnewsevent_1038", "\E6* W-well^1!&* That's Mettaton's fault^1,&  not mine!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_1039", "\E9* I c-can't second&  guess myself now./")
ds_map_add(global.text_data_en, "obj_mettnewsevent_1040", "\E4* I'm f-finally starting&  to f-feel confident&  about g-guiding you./")
ds_map_add(global.text_data_en, "obj_mettnewsevent_1041", "\E6* I'll protect you from&  that mean old robot^1,&  n-no matter what!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_1042", "\E3* If I have to^1,&  I'll even t-turn.../")
ds_map_add(global.text_data_en, "obj_mettnewsevent_1043", "\E5* Um^1, nevermind./")
ds_map_add(global.text_data_en, "obj_mettnewsevent_1044", "\E0* We're over halfway&  to the core!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_1045", "* Let's go!/")
ds_map_add(global.text_data_en, "obj_mettnewsevent_1046", "\TS \F0 \E0 \T0 %")
ds_map_add(global.text_data_en, "obj_mettnewsevent_1047", "* (Klik...)/%%")
