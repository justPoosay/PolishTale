ds_map_add(global.text_data_en, "obj_smallfrog_80", "* (Wygląda na to, że&  wyrosłeś na troskliwą i&  sumienną osobę.)/")
ds_map_add(global.text_data_en, "obj_smallfrog_81", "* (Niezależnie czy to wynika&  z moich rad czy nie...^1)&* (Jestem całkiem dumny.)/")
ds_map_add(global.text_data_en, "obj_smallfrog_82", "* Kum./%%")
ds_map_add(global.text_data_en, "obj_smallfrog_90", "* Kum^1, kum^1.&* (Tak pomiędzy nami...)/")
ds_map_add(global.text_data_en, "obj_smallfrog_91", "\W* (Widziałem \BTORIEL\W&  wychodzącą stąd jakąś&  krótką chwilę temu.)/")
ds_map_add(global.text_data_en, "obj_smallfrog_92", "* (Nosiła jakieś&  zakupy.)/")
ds_map_add(global.text_data_en, "obj_smallfrog_93", "* (Nie pytałem jednak,&  na co były jej&  potrzebne...)/")
ds_map_add(global.text_data_en, "obj_smallfrog_94", "* (Jesteśmy wszyscy zbyt&  nieśmiali, by z nią rozmawiać.^1)&* Kum./%%")
ds_map_add(global.text_data_en, "obj_smallfrog_97", "* Kum^1, kum^1.&* (Wygląda na to^1, że drzwi do&  RUIN w końcu się otworzyły.)/")
ds_map_add(global.text_data_en, "obj_smallfrog_98", "* (Może powinniśmy w końcu&  pójść eksplorować resztę&  podziemi.)/")
ds_map_add(global.text_data_en, "obj_smallfrog_99", "* (Huh^1? Bariera jest również^1,&  otwarta...?)/")
ds_map_add(global.text_data_en, "obj_smallfrog_100", "* (... chodźmty narazie małymi&  kroczkami^1, OK?)/%%")
ds_map_add(global.text_data_en, "obj_smallfrog_105", "* Kum^1, kum^1.&* (Tak pomiędzy nami...)/")
ds_map_add(global.text_data_en, "obj_smallfrog_106", "\W* (Widziałem \BTORIEL\W&  wychodzącą stąd jakąś&  krótką chwilę temu.)/")
ds_map_add(global.text_data_en, "obj_smallfrog_107", "* (Normalnie^1, ona nosi&  tutaj zakupy.)/")
ds_map_add(global.text_data_en, "obj_smallfrog_108", "* (Ale tym razem^1, ona&  nic nie nosiła.)/")
ds_map_add(global.text_data_en, "obj_smallfrog_109", "* (Wyglądała na zawiedzioną.^1)&* Kum./%%")
ds_map_add(global.text_data_en, "obj_smallfrog_117", "* Kum kum^1.&* (Słyszałem, że używanie " + '"' + "F4" + '"' + "&  może ci dać " + '"' + "pełny ekran." + '"' + ")/")
ds_map_add(global.text_data_en, "obj_smallfrog_118", "* (Ale co znaczy " + '"' + "F4" + '"' + "?^1)&* (" + '"' + "Cztery Froggity" + '"' + "?)/")
ds_map_add(global.text_data_en, "obj_smallfrog_119", "* (Widziałem maksymalnie&  trzy żaby w tym pokoju...)/")
ds_map_add(global.text_data_en, "obj_smallfrog_120", "* (To jest kłopotliwe^1,&  delikatnie mówiąc.^1)&* Kum./%%")
