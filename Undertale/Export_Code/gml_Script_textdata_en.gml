ds_map_add(global.text_data_en, "SCR_TEXT_6896", "\F1 \TT %")
ds_map_add(global.text_data_en, "SCR_TEXT_6897", "\E0* Mówi TORIEL./")
ds_map_add(global.text_data_en, "SCR_TEXT_6898", "* Nudzisz się^1?&* Powinnam była ci&  dać jakąś książkę./")
ds_map_add(global.text_data_en, "SCR_TEXT_6899", "* Moje kondolencje./")
ds_map_add(global.text_data_en, "SCR_TEXT_6900", "* Czemu nie użyjesz&  wyobraźni^1, aby&  się rozproszyć?/")
ds_map_add(global.text_data_en, "SCR_TEXT_6901", "* Udaj^1, że jesteś..^1.&* Monarchą!/")
ds_map_add(global.text_data_en, "SCR_TEXT_6902", "* Panuj nad kupką liści&  z żelazną pięścią./")
ds_map_add(global.text_data_en, "SCR_TEXT_6903", "* Możesz to dla&  mnie zrobić?/")
ds_map_add(global.text_data_en, "SCR_TEXT_6904", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_6905", "* Klik.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_6909", "\F1 \TT %")
ds_map_add(global.text_data_en, "SCR_TEXT_6910", "\E0* Mówi TORIEL./")
ds_map_add(global.text_data_en, "SCR_TEXT_6911", "* Dzień dobry^1, habibi./")
ds_map_add(global.text_data_en, "SCR_TEXT_6912", "\E1* Przepraszam^1, nie mam&  zbyt wiele do&  powiedzenia./")
ds_map_add(global.text_data_en, "SCR_TEXT_6913", "\E0* Ale miło był&  usłyszeć twój głos./")
ds_map_add(global.text_data_en, "SCR_TEXT_6914", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_6915", "* Klik.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_6920", "* Dzwonię..\E0.\TT /")
ds_map_add(global.text_data_en, "SCR_TEXT_6921", "\F1 %")
ds_map_add(global.text_data_en, "SCR_TEXT_6922", "* Mówi TORIEL./")
ds_map_add(global.text_data_en, "SCR_TEXT_6923", "\E1* Pomóc z puzzlem^1.^1.^1.?/")
ds_map_add(global.text_data_en, "SCR_TEXT_6924", "* Um^1, nie opuściłeś&  pomieszczenia^1, prawda?/")
ds_map_add(global.text_data_en, "SCR_TEXT_6925", "\E0* Poczekaj cierpliwie na&  mnie i możemy je&  rozwiązać razem!/")
ds_map_add(global.text_data_en, "SCR_TEXT_6926", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_6927", "* Klik.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_6931", "* Dzwonię..\E0.\TT /")
ds_map_add(global.text_data_en, "SCR_TEXT_6932", "\F1 %")
ds_map_add(global.text_data_en, "SCR_TEXT_6933", "* Mówi TORIEL./")
ds_map_add(global.text_data_en, "SCR_TEXT_6934", "\E1* Chcesz wiedzieć&  więcej o mnie?/")
ds_map_add(global.text_data_en, "SCR_TEXT_6935", "* Cóż^1, obawiam się^1, że&  nie ma zbyt wiele&  do powiedzenia./")
ds_map_add(global.text_data_en, "SCR_TEXT_6936", "\E0* Jestem niczym innym niż&  staruszką, która zbytnio&  się przejmuje!/")
ds_map_add(global.text_data_en, "SCR_TEXT_6937", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_6938", "* Klik.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_6943", "* Dzwonię..\E0.\TT /")
ds_map_add(global.text_data_en, "SCR_TEXT_6944", "\F1 %")
ds_map_add(global.text_data_en, "SCR_TEXT_6945", "* Mówi TORIEL./")
ds_map_add(global.text_data_en, "SCR_TEXT_6946", "\E8* Huh^2?&* Czy ty właśnie nazwałeś&  mnie... " + '"' + "Mamą" + '"' + "?/")
ds_map_add(global.text_data_en, "SCR_TEXT_6947", "\E1* Cóż...&* W takim razie.../")
ds_map_add(global.text_data_en, "SCR_TEXT_6948", "* Czy to by cię czyniło&  szczęśliwym?/")
ds_map_add(global.text_data_en, "SCR_TEXT_6949", "* Gdybyś nazywał mnie..^2.&* " + '"' + "Matką?" + '"' + "/")
ds_map_add(global.text_data_en, "SCR_TEXT_6950", "\E0* W takim razie^1, mów na&  mnie jak sobie życzysz!/!")
ds_map_add(global.text_data_en, "SCR_TEXT_6951", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_6952", "* Klik.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_6963", "* Dzwonię..\E0.\TT /")
ds_map_add(global.text_data_en, "SCR_TEXT_6964", "\F1 %")
ds_map_add(global.text_data_en, "SCR_TEXT_6965", "\E8* ...^2 huh???/")
ds_map_add(global.text_data_en, "SCR_TEXT_6966", "\E1* Oh,^1 heh..^1 heh...^1 \E0 &* Ha ha ha!/")
ds_map_add(global.text_data_en, "SCR_TEXT_6967", "* Jak słodko...^1 Mogłabym&  cię uszczypnąć za&  policzek!/")
ds_map_add(global.text_data_en, "SCR_TEXT_6968", "* Możesz z pewnością&  znaleść kogoś lepszego&  niż taką staruszkę./")
ds_map_add(global.text_data_en, "SCR_TEXT_6969", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_6970", "* Klik.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_6974", "* Dzwonię..\E0.\TT /")
ds_map_add(global.text_data_en, "SCR_TEXT_6975", "\F1 %")
ds_map_add(global.text_data_en, "SCR_TEXT_6976", "\E1* Ojejku,^1&  jesteś poważny...?/")
ds_map_add(global.text_data_en, "SCR_TEXT_6977", "\E1* Nie wiem czy to jest&  żałosne,^1 czy uprzejme./")
ds_map_add(global.text_data_en, "SCR_TEXT_6978", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_6979", "* Klik.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_6982", "\E8* I po tym, kiedy&  chciałeś na mnie mówić&  " + '"' + "matką..." + '"' + "/")
ds_map_add(global.text_data_en, "SCR_TEXT_6983", "\E0* Jesteś...^2 &  \E1... " + '"' + "specyficznym" + '"' + "&  dzieckiem./")
ds_map_add(global.text_data_en, "SCR_TEXT_6984", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_6985", "* Klik.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_6994", "* Dzwonię... /")
ds_map_add(global.text_data_en, "SCR_TEXT_6995", "* ... /")
ds_map_add(global.text_data_en, "SCR_TEXT_6996", "* Ale nikt nie przyszedł./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_7000", "* Dzwonię... /")
ds_map_add(global.text_data_en, "SCR_TEXT_7001", "* ... /")
ds_map_add(global.text_data_en, "SCR_TEXT_7002", "* Nikt nie odebrał./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_7007", "* Dzwonię... /")
ds_map_add(global.text_data_en, "SCR_TEXT_7008", "* ... /")
ds_map_add(global.text_data_en, "SCR_TEXT_7009", "* Dzwonek wychodzi z  twojego&  ekwipunku./%%")
ds_map_add(global.text_data_en, "SCR_TEXT_7016", "* Dzwonię...\TT /")
ds_map_add(global.text_data_en, "SCR_TEXT_7017", "\F1 %")
ds_map_add(global.text_data_en, "SCR_TEXT_7018", "* Hej^1, ty śmieszku./")
ds_map_add(global.text_data_en, "SCR_TEXT_7019", "* Jeśli chcesz ze&  mną porozmawiać^1, jestem&  tutaj./")
ds_map_add(global.text_data_en, "SCR_TEXT_7020", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "SCR_TEXT_7021", "* Klik.../%%")
ds_map_add(global.text_data_en, "SCR_TEXT_7025", "* Dzwonię... /")
ds_map_add(global.text_data_en, "SCR_TEXT_7026", "* ... /")
ds_map_add(global.text_data_en, "SCR_TEXT_7027", "* (Gdzieniegdzie^1, sygnały odbite&  przez psa.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_7040", "* (Brak odpowiedzi.^1)&* (Ich telefon mógł się&  rozładować.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_7052", "* (Pudło się zaplątało z&  sierścią psa.)/%%")
ds_map_add(global.text_data_en, "SCR_TEXT_7079", "* Napotkałeś Manekina.")
ds_map_add(global.text_data_en, "SCR_TEXT_7080", "%%%")
ds_map_add(global.text_data_en, "SCR_TEXT_7084", "* Froggit cię atakuje!")
ds_map_add(global.text_data_en, "SCR_TEXT_7085", "%%%")
ds_map_add(global.text_data_en, "SCR_TEXT_7089", "* Froggit przyskoczył obok!")
ds_map_add(global.text_data_en, "SCR_TEXT_7090", "%%%")
ds_map_add(global.text_data_en, "SCR_TEXT_7094", "* Whimsun zbliżył się miernie!")
ds_map_add(global.text_data_en, "SCR_TEXT_7095", "%%%")
ds_map_add(global.text_data_en, "SCR_TEXT_7099", "* Froggit and Whimsun objawili&  się obok!")
ds_map_add(global.text_data_en, "SCR_TEXT_7100", "%%%")
ds_map_add(global.text_data_en, "SCR_TEXT_7104", "* Moldsmal blokuje drogę!")
ds_map_add(global.text_data_en, "SCR_TEXT_7105", "%%%")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_5913", "* (Dog Shrine.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_5914", "* (Donate?)& &         Dognate     Dognot\C")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_5919", "* (\[1] of \[2]G in the box.)& &         Dognate     Dognot\C")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_5924", "* (Looks like the money was used&  to buy some fairy lights.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_5925", "* (It was kind of dark in here.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_5933", "* (Looks like the money was used&  to increase the size of the&  shrine.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_5941", "* (The donation box slot is even&  bigger now.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_5942", "* (You should be able to donate&  even more at once!)/")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_5943", "* (... actually^1, it looks like&  the sides of the slot are&  just painted on...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_5944", "* (Seems you'll still have to&  donate just 1G at a time...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_5954", "* (The donation box is sealed.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_5955", "* (There was seemingly no point&  to all of this...)/%")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_5958", "* (Since your adventure is over^1,&  you can reminisce about how&  useful the Dog Shrine was...)/")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_5959", "* (... it wasn't useful at all.)/%")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_5970", "* (Something is wrong with&  the box.)/%")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_5977", "* (The box is full.)/%")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_5982", "* (Not enough money.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_5983", "* (That's relieving...)/%")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_5993", "* (You donated 1G.)/%")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_5997", "* (You put 1G into the box.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_5998", "* (You feel like you're about to&  waste a lot of time...)/%")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_6003", "* (Clink!)&* (The box is filled with coins.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_6004", "* (Perhaps if you leave and&  return^1, the donations will be&  used for something.)/%")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_6015", "* (You feel a sense of relief.)/%")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_6024", "* (Donation box.)& &         Use It      Do not\C")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_6031", "* (... hand can't fit inside.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_6032", "* (Check it again to try&  donating.)/%")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_6037", "* (Right.)/%")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_6045", "* (The boombox is playing...)&* (An upbeat song.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_6046", "* (It's having a psychological&  effect on your desire to&  donate.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_6047", "* (... It's not clear what kind&  of effect that is.)/")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_6048", "* (Change the track?)& &         Change      Do not\C")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_6059", "* (Huh!?)&* (The next track is just the&  same but faster...!?)/%")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_6065", "* (You see no reason to&  change it.)/%")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_6070", "* (You returned the song&  to normal.)/%")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_6076", "* (\[1]G inside.)& &         Donate      Do not\C")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_6095", "* (1G was put inside.)/%")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_6101", "* (Not enough G.)/%")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_6106", "* (There's enough.)/%")
ds_map_add(global.text_data_en, "SCR_TEXT_dogshrine_6112", "* (Nothing was put inside.)/%")
ds_map_add(global.text_data_en, "blt_sizebone_115", " THIS IS AN ERROR& MESSAGE^1.& REALLY!!!/%%")
ds_map_add(global.text_data_en, "blt_sizebone_118", " YOU'RE TOO WEAK!!& I WAS EASILY ABLE& TO CAPTURE YOU!!!/")
ds_map_add(global.text_data_en, "blt_sizebone_119", " I WILL NOW SEND& YOU TO THE& CAPTURE ZONE!!/")
ds_map_add(global.text_data_en, "blt_sizebone_120", " OR^1, AS SANS& CALLS IT^1.../")
ds_map_add(global.text_data_en, "blt_sizebone_121", " OUR GARAGE???/")
ds_map_add(global.text_data_en, "blt_sizebone_122", " YOU'RE IN THE& DOGHOUSE NOW!/")
ds_map_add(global.text_data_en, "blt_sizebone_123", " NYEH HEH HEH HEH& HEH HEH HEH!!!/%%")
ds_map_add(global.text_data_en, "blt_sizebone_127", " WELL!!^1! YOU MAY& HAVE CLEVERLY& ESCAPED FROM& JAIL BEFORE.../")
ds_map_add(global.text_data_en, "blt_sizebone_128", " BUT THIS TIME^1,& I'VE UPGRADED& THE FACILITIES./")
ds_map_add(global.text_data_en, "blt_sizebone_129", " NOT ONLY WILL& YOU BE& TRAPPED.../")
ds_map_add(global.text_data_en, "blt_sizebone_130", " BUT YOU WON'T& EVEN WANT& TO LEAVE!!!/")
ds_map_add(global.text_data_en, "blt_sizebone_131", " NYEH HEH HEH HEH& HEH HEH HEH!!!/%%")
ds_map_add(global.text_data_en, "blt_sizebone_136", " YOU ARE...& PERSISTENT!/")
ds_map_add(global.text_data_en, "blt_sizebone_137", " BUT^1!& IT JUST WON'T& WORK ON ME!/")
ds_map_add(global.text_data_en, "blt_sizebone_138", " I AM THE& PERSISTENTEST!/")
ds_map_add(global.text_data_en, "blt_sizebone_139", " AND IF YOU& THINK YOU ARE& PERSISTENESTER.../")
ds_map_add(global.text_data_en, "blt_sizebone_140", " THAT IS WRONG^1!& GRAMATICALLY& WRONG!/")
ds_map_add(global.text_data_en, "blt_sizebone_141", " BECAUSE THE& CORRECT FORM& WOULD BE.../")
ds_map_add(global.text_data_en, "blt_sizebone_142", " NOT AS& PERSISTENTEST AS& PAPYRUS^1, THE& PERSISTENTESTEST!/" + '"')
ds_map_add(global.text_data_en, "blt_sizebone_143", " I HOPE YOU& ENJOYED THIS& LESSON./")
ds_map_add(global.text_data_en, "blt_sizebone_144", " NYEH HEH HEH HEH& HEH HEH HEH!!!/%%")
ds_map_add(global.text_data_en, "obj_6book_master_384", "You&called&for&help&...")
