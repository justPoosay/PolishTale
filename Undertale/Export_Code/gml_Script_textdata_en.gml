ds_map_add(global.text_data_en, "obj_tembattle_283", "OMG!!&czlowieki&UROCZE&(umiera)")
ds_map_add(global.text_data_en, "obj_tembattle_284", "hOI!!!&jostum&TEMMIE!!")
ds_map_add(global.text_data_en, "obj_tembattle_285", "fhsdhjf&dsfjsfd&dshjfsd")
ds_map_add(global.text_data_en, "obj_tembattle_288", "NUE!!!!!&mionśnie&......&NIE SUODKIE")
ds_map_add(global.text_data_en, "obj_tembattle_292", "NUE!!!&taki&głuodn...&(umiera)")
ds_map_add(global.text_data_en, "obj_tembattle_298", "hOI!!!&jestem&tEMMIE!!")
ds_map_add(global.text_data_en, "obj_tembattle_302", "JEBZENIE!!!")
ds_map_add(global.text_data_en, "obj_tembattle_307", "%%%")
ds_map_add(global.text_data_en, "obj_tembattle_504", "* Temmie próbuje cię przytulić.")
ds_map_add(global.text_data_en, "obj_tembattle_505", "* Temmie forgor jej&  drugiego ataku.")
ds_map_add(global.text_data_en, "obj_tembattle_506", "* Temmie wibruje intensywnie.")
ds_map_add(global.text_data_en, "obj_tembattle_507", "* Temmie robi swoje włoski.")
ds_map_add(global.text_data_en, "obj_tembattle_508", "* Temmiy ma dyslekcję i źle&  pisze swoje imię.")
ds_map_add(global.text_data_en, "obj_tembattle_509", "* Pachnie jak Temmie Flakes.")
ds_map_add(global.text_data_en, "obj_tembattle_511", "* Jak żeś to zrobił?")
ds_map_add(global.text_data_en, "obj_tembattle_527", "* TEMMIE - RATED TEM OUTTA TEM&* Kocha głaskać urocze człowieki^1.&* Ale jesteś alergiczny!/^")
ds_map_add(global.text_data_en, "obj_tembattle_539", "* Temmie tylko chce swoje&  Temmie Flakes./^")
ds_map_add(global.text_data_en, "obj_tembattle_550", "   Dać Temmie Flakes?& &   Yas             NUE!!!!!!!\C")
ds_map_add(global.text_data_en, "obj_tembattle_561", "* Flexujesz się przed Temmiem.../%%")
ds_map_add(global.text_data_en, "obj_tembattle_573", "* Mówisz Temmiemu cześć./^")
ds_map_add(global.text_data_en, "obj_tembattle_617", "NUE!!!!!&mionśnie&nue som..&SUODKIE/%%")
ds_map_add(global.text_data_en, "obj_tembattle_621", "%%%")
ds_map_add(global.text_data_en, "obj_tembattle_635", "Oo, z&tym się&nie&zgodzę; )/%%")
ds_map_add(global.text_data_en, "obj_tembattle_636", "Temmie^1,&wszystko&okej?&; )/%%")
ds_map_add(global.text_data_en, "obj_tembattle_637", "%%%")
ds_map_add(global.text_data_en, "obj_tembattle_652", "NUE!!!!&!!!!!!!/%%")
ds_map_add(global.text_data_en, "obj_tembattle_653", "%%%")
ds_map_add(global.text_data_en, "obj_temnpc_72", "* hOI!^1!&* jestem temmie!!!/")
ds_map_add(global.text_data_en, "obj_temnpc_73", "* a oto muj psyjacuel..^1.&* temmie!!!/%%")
ds_map_add(global.text_data_en, "obj_temnpc_77", "* woa..^1. tem słuyszeć..^1.&* DOBRE WUADOMOŚIĆI!!!/%%")
ds_map_add(global.text_data_en, "obj_temnpc_82", "* hOI!^1!&* jestem temmie!!!/")
ds_map_add(global.text_data_en, "obj_temnpc_83", "* ne zapomnuj o moim psyjacielu!/%%")
ds_map_add(global.text_data_en, "obj_temnpc_87", "* yaYA!!^1!&* tems mosze siem uwolnić!!/%%")
ds_map_add(global.text_data_en, "obj_temnpc_93", "* Hej./")
ds_map_add(global.text_data_en, "obj_temnpc_94", "* Jestem Bob./%%")
ds_map_add(global.text_data_en, "obj_temnpc_98", "* Niespodziewany rozwój^1, nie?/%%")
ds_map_add(global.text_data_en, "obj_temnpc_103", "* awawawah!!/")
ds_map_add(global.text_data_en, "obj_temnpc_104", "* człowieki..^1.&* som tacy.../")
ds_map_add(global.text_data_en, "obj_temnpc_105", "* SŁUODCY!!!!/%%")
ds_map_add(global.text_data_en, "obj_temnpc_109", "* woa..^1.&* jak tem pujśići na&  pofieszchunie^1, mosze zobaczuć,/")
ds_map_add(global.text_data_en, "obj_temnpc_110", "* DUZIO SŁUOTKIH CZUŁOWIEKÓF!!!/%%")
ds_map_add(global.text_data_en, "obj_temnpc_116", "* tem..^1. PILNOWAĆ JAJKO!!!/")
ds_map_add(global.text_data_en, "obj_temnpc_117", "* jajkuo..^1. sue WYKLUJE!!!/")
ds_map_add(global.text_data_en, "obj_temnpc_118", "* tem..^1. DUMNY RODZIC!!/%%")
ds_map_add(global.text_data_en, "obj_temnpc_122", "* fszyscy idom..^1.&* ALE TEM!!!/")
ds_map_add(global.text_data_en, "obj_temnpc_123", "* TEM NUE IDZUE!!!&* TEM PATRZY JAJKUO!!!/")
ds_map_add(global.text_data_en, "obj_temnpc_124", "* tem bendzue hapi famili,/%%")
ds_map_add(global.text_data_en, "obj_tobdog_pendant_137", "* (Pies pochłania artefakt.)/%%")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_153", "A oto koniec&Hard Mode'a!/%%")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_175", "\E1Eh??/")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_176", "\E2Kończysz&to TERAZ?/")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_177", "\E1I jeszcze w&takim drama-&tycznym&momencie...?/%%")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_192", "To jest&najtrudniejsza&część./")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_193", "Nie naboje./")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_194", "\M2Ale^1, akceptacja^1,&że to już koniec&.../%%")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_211", "Ale BĘDZIE&więcej^1, czyż&nie?/%%")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_224", "\M1Może./")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_225", "\M2Znajomość&odpowiedzi&jest.../")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_226", "\M2... CIĘŻKA./")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_227", "\E4.../%%")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_264", "Hej!/")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_265", "Nie powinieneś&umierać&czy coś?/%%")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_280", "Cóż^1.&Jaki jest teraz&cel gry?/%%")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_293", "Co zrobisz&dla odmiany...?/%%")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_308", "Hmmm^1.&Może ci upiekę&kolejne ciasto./")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_309", "Jako że poprzednie&się trochę&przypaliło./%%")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_324", "\E2I thought it was&good./")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_325", "\E1Theoretically./")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_326", "\E4It's not like I&ate it all while&you were&fighting./%%")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_360", "Hey^1! Hey^1!&Can I have some&pie!/%%")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_377", "You are just going&to eat it all.../%%")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_400", "I can helllp!!!/%%")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_415", "Snoring on the&floor is NOT help./%%")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_429", "I'm not snoring^1,&I'm cheering you&on in my sleep!!/")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_430", ".../")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_431", "Oh^1, you're still&here?/")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_432", "Don't you have&anything better&to do?/%%")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_512", "\E0Hey./")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_513", "\E3What's the hold&up!?/")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_514", "\E9Shouldn't she be&dead by now!?/")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_515", "\E1I've been waiting&in that room for.../")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_516", "\E6.../")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_517", "\E7... Hard mode...?/")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_518", "\E0Gee^1, you better&take a picture./")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_519", "People are gonna&think you're REALLY&cool./")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_520", "\E9... NOT!/")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_521", "\E8Golly^1, talk about&a tryhard./")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_522", "PA^1. THE^1. TIC./%%")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_544", "\E0Uh^1, so^1, are you&gonna keep going^1,&or...?/%%")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_558", "It's over./%%")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_578", "\E8Hahaha^1!&I KNEW that!/")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_579", "Why does everyone&have to be so&condescending!?/")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_580", "\E1.../")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_581", "\E8So what's YOUR&excuse^1?&Sitting around&here...?/")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_582", "\E0Don't you have&anything better to%%")
ds_map_add(global.text_data_en, "obj_torboss_2ndtime_595", "I already said&that./%%")
ds_map_add(global.text_data_en, "obj_tordogcall_64", "* Dzyn dzyn..\E0.\TT /")
ds_map_add(global.text_data_en, "obj_tordogcall_65", "\F1 %")
ds_map_add(global.text_data_en, "obj_tordogcall_66", "* Witaj^1!&* Mówi TORIEL./")
ds_map_add(global.text_data_en, "obj_tordogcall_67", "\E1* Moje sprawunki trwają&  dłużej niż myślałam&  że będą./")
ds_map_add(global.text_data_en, "obj_tordogcall_68", "\E1* Musisz jeszcze&  poczekać 5 minut./")
ds_map_add(global.text_data_en, "obj_tordogcall_69", "\E0* Dziękuję za twoją&  cierpliwość./")
ds_map_add(global.text_data_en, "obj_tordogcall_70", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_tordogcall_71", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_tordogcall_84", "* Dzyn..\E1.\TT /")
ds_map_add(global.text_data_en, "obj_tordogcall_85", "\F1 %")
ds_map_add(global.text_data_en, "obj_tordogcall_86", "* Halo..^1.&* Mówi TORIEL./")
ds_map_add(global.text_data_en, "obj_tordogcall_87", "\E1* Znalazłam to^1, czego&  szukałam./")
ds_map_add(global.text_data_en, "obj_tordogcall_88", "* Ale zanim zdołałam&  to wziąć.../")
ds_map_add(global.text_data_en, "obj_tordogcall_89", "* Mały^1, biały piesek&  mi to wyrwał./")
ds_map_add(global.text_data_en, "obj_tordogcall_90", "\E0* Jakie niefortunne./")
ds_map_add(global.text_data_en, "obj_tordogcall_91", "\E1* Czy pieski w ogóle&  LUBIĄ mąkę?/")
ds_map_add(global.text_data_en, "obj_tordogcall_92", "\E8* Err^1, to jest oczywiście&  niepowiązane pytanie./")
ds_map_add(global.text_data_en, "obj_tordogcall_93", "\E1* To mi zajmie troszę&  dłużej^1.&* Proszę o zrozumiałość./")
ds_map_add(global.text_data_en, "obj_tordogcall_94", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_tordogcall_95", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_tordogcall_109", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_tordogcall_110", "* (...)/")
ds_map_add(global.text_data_en, "obj_tordogcall_111", "* (Słyszysz ciężkie dyszenie&  przez słuchawkę w telefonie...)/")
ds_map_add(global.text_data_en, "obj_tordogcall_112", "* (...)/")
ds_map_add(global.text_data_en, "obj_tordogcall_113", "* Woof^1!&* Woof!/")
ds_map_add(global.text_data_en, "obj_tordogcall_114", "* Woof..^1.&* Woof!/")
ds_map_add(global.text_data_en, "obj_tordogcall_115", "* (Słyszysz odległy głos.)\TT/")
ds_map_add(global.text_data_en, "obj_tordogcall_116", "* Przestań^1, proszę!/")
ds_map_add(global.text_data_en, "obj_tordogcall_117", "* Wracaj tu z moją&  KOMÓRKĄ!/")
ds_map_add(global.text_data_en, "obj_tordogcall_118", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_tordogcall_119", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_tordogcall_150", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_tordogcall_151", "* (...)/")
ds_map_add(global.text_data_en, "obj_tordogcall_152", "* (Chrap..^1. chrap...)/")
ds_map_add(global.text_data_en, "obj_tordogcall_153", "* (Brzmi na małego^1, białego&  pieska śpiącego na&  komóce.)/")
ds_map_add(global.text_data_en, "obj_tordogcall_154", "* (Słyszysz odległy głos.)\TT/")
ds_map_add(global.text_data_en, "obj_tordogcall_155", "* Haaloooo^1?&* Mała psinko...?/")
ds_map_add(global.text_data_en, "obj_tordogcall_156", "* Gdzie jesteś...?/")
ds_map_add(global.text_data_en, "obj_tordogcall_157", "* Dam ci miły&  klep po głowie!\T0/")
ds_map_add(global.text_data_en, "obj_tordogcall_158", "* (Chrapanie się zatrzymuje.)\TT/")
ds_map_add(global.text_data_en, "obj_tordogcall_159", "* ... jeśli mi zwrócisz&  KOMÓRKĘ.\T0/")
ds_map_add(global.text_data_en, "obj_tordogcall_160", "* (Chrapanie kontynuuje.)/")
ds_map_add(global.text_data_en, "obj_tordogcall_161", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_tordogcall_162", "* Klik.../%%")
ds_map_add(global.text_data_en, "obj_tordogcall_176", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_tordogcall_177", "* (...)/")
ds_map_add(global.text_data_en, "obj_tordogcall_178", "* (Chrap..^1. chrap...)/")
ds_map_add(global.text_data_en, "obj_tordogcall_179", "* (Achoo!)/")
ds_map_add(global.text_data_en, "obj_tordogcall_180", "* (Brzmi na małego^1, białego&  pieska kichającego przez&  sen.)/")
ds_map_add(global.text_data_en, "obj_tordogcall_181", "* (Słyszysz odległy głos.)\TT/")
ds_map_add(global.text_data_en, "obj_tordogcall_182", "* Psinkoo^1, pspspsps!/")
ds_map_add(global.text_data_en, "obj_tordogcall_183", "* Ojej^1, Nie powinnam trzymać&  moich czekających gości./")
ds_map_add(global.text_data_en, "obj_tordogcall_184", "* ... O nie^1, ile już minęło&  odkąd z nim rozmawiałam...?/")
ds_map_add(global.text_data_en, "obj_tordogcall_185", "* Być może dzwonił na komórkę^1,&  a ja...?/")
ds_map_add(global.text_data_en, "obj_tordogcall_186", "* ... chodź^1, psinko!/")
ds_map_add(global.text_data_en, "obj_tordogcall_187", "\TS \F0 \T0 %")
ds_map_add(global.text_data_en, "obj_tordogcall_188", "* Klik.../%%")
