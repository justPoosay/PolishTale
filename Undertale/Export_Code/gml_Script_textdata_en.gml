ds_map_add(global.text_data_en, "obj_darkfridge_116", "* (It's a refrigerator.^1)&* (It's empty.)/%%")
ds_map_add(global.text_data_en, "obj_darkfridge_122", "* (To zamrażarka.^1)&* (Wydaje się zawierać&  jakiegoś rodzaju próbki.)/%%")
ds_map_add(global.text_data_en, "obj_darkfridge_126", "* Coś tutaj jest..^1.&* Wydaje się, jakby to coś&  oddychało./%%")
ds_map_add(global.text_data_en, "obj_darkfridge_133", "* (It's a refrigerator.^1)&* (It's empty.)/%%")
ds_map_add(global.text_data_en, "obj_darkfridge_136", "* Coś tutaj jest..^1.&* Wydaje się być drzewem^1,&  z przepysznymi owocami./%%")
ds_map_add(global.text_data_en, "obj_darkfridge_142", "* (To zamrażarka.^1)&* (Wydaje się zawierać&  jakiegoś rodzaju próbki.)/%%")
ds_map_add(global.text_data_en, "obj_darkfridge_145", "* Coś tutaj jest..^1.&* Coś w kształcie osoby./%%")
ds_map_add(global.text_data_en, "obj_darkfridge_151", "* (It's a refrigerator.^1)&* (It's empty.)/%%")
ds_map_add(global.text_data_en, "obj_darkfridge_154", "* Coś tutaj jest..^1.&* Wydaje się ciepłe^1,&  i wilgotne..?/%%")
ds_map_add(global.text_data_en, "obj_darkplant_64", "* (To sztuczna roślinka.)/%%")
ds_map_add(global.text_data_en, "obj_darksans1_187", "* heheh... stara sztuczka&  pierdziuszki w ręku./")
ds_map_add(global.text_data_en, "obj_darksans1_188", "* to jest ZAWSZE śmieszne./")
ds_map_add(global.text_data_en, "obj_darksans1_189", "* w każdym razie^1,&  jesteś człowiekiem,&  prawda?/")
ds_map_add(global.text_data_en, "obj_darksans1_190", "\E1* to przekomiczne./")
ds_map_add(global.text_data_en, "obj_darksans1_193", "* heh... stara sztuczka&  pierdziuszki w ręku.../")
ds_map_add(global.text_data_en, "obj_darksans1_194", "\E1* chwila..^1.&* słyszałeś o tym&  wcześniej czy coś?/")
ds_map_add(global.text_data_en, "obj_darksans1_195", "\E5* obróciłeś się zanim&  powiedziałem żebyś..^1.&* ... dziwne./")
ds_map_add(global.text_data_en, "obj_darksans1_196", "\E3* ... nieważne^1.&\E0* jesteś człowiekiem^1, prawda?/")
ds_map_add(global.text_data_en, "obj_darksans1_198", "\E0* jestem sans^1.&* szkielet sans./")
ds_map_add(global.text_data_en, "obj_darksans1_199", "* tak naprawde powinienem &  być na warcie na&  ludzi teraz./")
ds_map_add(global.text_data_en, "obj_darksans1_200", "* ale..^1. wiesz.../")
ds_map_add(global.text_data_en, "obj_darksans1_201", "\E1* mnie to nie za bardzo&  obchodzi^1, żeby kogoś&  porwać./")
ds_map_add(global.text_data_en, "obj_darksans1_202", "\E0* teraz mój brat^1,&  papyrus.../")
ds_map_add(global.text_data_en, "obj_darksans1_203", "* on jest FANATYKIEM&  łapania ludzi./")
ds_map_add(global.text_data_en, "obj_darksans1_204", "\E1* hej^1, tak naprawdę^1,&  wydaje mi się^1, że&  to on tam stoi./")
ds_map_add(global.text_data_en, "obj_darksans1_205", "\E0* mam pomysł^1.&* przejdź przez tą&  bramkę czy coś./")
ds_map_add(global.text_data_en, "obj_darksans1_206", "* ta, idź prosto przez^1.&* mój bro zrobił te pręty&  zbyt szerokie./%%")
ds_map_add(global.text_data_en, "obj_darksans1_210", "* heheh... stara sztuczka&  pierdziuszki w ręku./")
ds_map_add(global.text_data_en, "obj_darksans1_211", "* to jest ZAWSZE śmieszne./")
ds_map_add(global.text_data_en, "obj_darksans1_212", "* .../")
ds_map_add(global.text_data_en, "obj_darksans1_213", "\E1* to jest^1, uh^1.&* część^1, w której&  się smiejesz./")
ds_map_add(global.text_data_en, "obj_darksans1_214", "\E5* albo^1, uh^1, zrobić emotkę&  jeśli już...?/")
ds_map_add(global.text_data_en, "obj_darksans1_215", "\E0* .../")
ds_map_add(global.text_data_en, "obj_darksans1_216", "\E1* (rany^1, babko^1, naprawdę&  wiesz jak zepsuć&  moment, huh...?)/")
ds_map_add(global.text_data_en, "obj_darksans1_217", "\E2* OK^1, nie szkodzi^1.&* każdy ma indywidualne&  poczucie humoru./")
ds_map_add(global.text_data_en, "obj_darksans1_218", "\E0* jestem sans^1.&* szkielet sans./")
ds_map_add(global.text_data_en, "obj_darksans1_219", "* tak naprawde powinienem &  być na warcie na&  ludzi teraz./")
ds_map_add(global.text_data_en, "obj_darksans1_220", "* ale..^1. wiesz.../")
ds_map_add(global.text_data_en, "obj_darksans1_221", "\E1* mnie to nie za bardzo&  obchodzi^1, żeby kogoś&  porwać./")
ds_map_add(global.text_data_en, "obj_darksans1_222", "\E0* teraz mój brat^1,&  papyrus.../")
ds_map_add(global.text_data_en, "obj_darksans1_223", "* on jest FANATYKIEM&  łapania ludzi./")
ds_map_add(global.text_data_en, "obj_darksans1_224", "\E1* hej^1, tak naprawdę^1,&  wydaje mi się^1, że&  to on tam stoi./")
ds_map_add(global.text_data_en, "obj_darksans1_225", "\E0* mam pomysł^1.&* przejdź przez tą&  bramkę czy coś./")
ds_map_add(global.text_data_en, "obj_darksans1_226", "* ta, idź prosto przez^1.&* mój bro zrobił te pręty&  zbyt szerokie./%%")
ds_map_add(global.text_data_en, "obj_darksans1_345", "* Człowieku./")
ds_map_add(global.text_data_en, "obj_darksans1_346", "* Nie wiesz jak się wita&  nowego kolegę?/")
ds_map_add(global.text_data_en, "obj_darksans1_347", "* Obróć się i&  podaj mi rękę./%%")
ds_map_add(global.text_data_en, "obj_darksans1_354", "* Człowieku./")
ds_map_add(global.text_data_en, "obj_darksans1_355", " %")
ds_map_add(global.text_data_en, "obj_darksans1_356", " %%")
ds_map_add(global.text_data_en, "obj_darksans1_399", "* szybko^1, idź za tą&  dogodnie-kształtną&  stojącą lampą./%%")
ds_map_add(global.text_data_en, "obj_darksans1_457", "* sup^1, bro?/")
ds_map_add(global.text_data_en, "obj_darksans1_459", "WIESZ O CO&" + '"' + "SUP,^1" + '"' + " BRACIE!/")
ds_map_add(global.text_data_en, "obj_darksans1_460", "MINĘŁO OSIEM &DNI A TY&DALEJ NIE.../")
ds_map_add(global.text_data_en, "obj_darksans1_461", "ZREKALIBROWAŁEŚ^1.&TWOJE^1.&PUZZLE^1!/")
ds_map_add(global.text_data_en, "obj_darksans1_462", "TY PO PROSTU&ZBIJASZ BĄKI W&TWOJEJ STACJI!/")
ds_map_add(global.text_data_en, "obj_darksans1_463", "CO TY WOGULE&ROBISZ?!?/")
ds_map_add(global.text_data_en, "obj_darksans1_465", "* gapię się na tą lampę^1.&* jest naprawdę czadowa^1.&* chcesz popatrzeć?/%%")
ds_map_add(global.text_data_en, "obj_darksans1_480", "NIE!^1!&NIE MAM CZASU&NA TO!!/")
ds_map_add(global.text_data_en, "obj_darksans1_481", "CO JEŚLI CZŁOWIE&BĘDZIE TĘDY&PRZECHODZIŁ!?!/")
ds_map_add(global.text_data_en, "obj_darksans1_482", "JA CHCĘ BYĆ&GOTOWY!!!/")
ds_map_add(global.text_data_en, "obj_darksans1_483", "JA BĘDE TYM!&JA MUSZĘ BYĆ TYM!/")
ds_map_add(global.text_data_en, "obj_darksans1_484", "JA ZŁAPIĘ&CZŁOWIEKA!/%%")
ds_map_add(global.text_data_en, "obj_darksans1_496", "WTEDY^1, JA^1, &WIELKI PAPYRUS.../")
ds_map_add(global.text_data_en, "obj_darksans1_497", "DOSTANĘ WSZYSTKIE&RZECZY NA KTÓRE&BARDZO ZASŁUGUJĘ!/")
ds_map_add(global.text_data_en, "obj_darksans1_498", "RESPEKT..^1.&ROZPOZNAWCZOŚĆ.../")
ds_map_add(global.text_data_en, "obj_darksans1_499", "W KOŃCU BĘDĘ&W STANIE DOŁĄCZYĆ DO&GWARII KRÓLEWSKIEJ!/")
ds_map_add(global.text_data_en, "obj_darksans1_500", "LUDZIE BĘDĄ PYTAĆ^1,&BY^1, BYĆ MOIM^1,&" + '"' + "PRZYJACIELEM?" + '"' + "/")
ds_map_add(global.text_data_en, "obj_darksans1_501", "\E2BĘDĘ KĄPANY W&PRYSZNICU CAŁUSÓW&KAŻDEGO DNIA./%%")
ds_map_add(global.text_data_en, "obj_darksans1_514", "* hmm.../")
ds_map_add(global.text_data_en, "obj_darksans1_515", "\E1* może ta lampa&  ci pomoże./%%")
ds_map_add(global.text_data_en, "obj_darksans1_528", "SANS!^1! NIE POMAGASZ!^1!&TY LENIWOKOŚCIU!!/")
ds_map_add(global.text_data_en, "obj_darksans1_529", "JEDYNE CO ROBISZ&TO SIEDZISZ I&UBAGUNGA!/")
ds_map_add(global.text_data_en, "obj_darksans1_530", "ROBISZ SIĘ&CORAZ LENIWSZY&KAŻDEGO DNIA!!!/")
ds_map_add(global.text_data_en, "obj_darksans1_532", "\W* hej^1, nie denerwuj się^1.&* zrobiłem \Ytonę\W &  pracy dzisiaj./")
ds_map_add(global.text_data_en, "obj_darksans1_533", "\W*\E2 szkiele-\Ytonę\W./%%")
ds_map_add(global.text_data_en, "obj_darksans1_582", "SANS!!!/")
ds_map_add(global.text_data_en, "obj_darksans1_584", "\E1* no weź^1.&* uśmiechasz się./")
ds_map_add(global.text_data_en, "obj_darksans1_586", "UŚMIECHAM SIĘ I&TEGO NIE ZNOSZĘ!/")
ds_map_add(global.text_data_en, "obj_darksans1_587", "\E3EHH.../")
ds_map_add(global.text_data_en, "obj_darksans1_588", "\E2CZEMU KTOŚ TAK&WSPANIAŁY JAK JA.../")
ds_map_add(global.text_data_en, "obj_darksans1_589", "\E3MUSI ROBIĆ TAK WIELE&TYLKO, BY ZYSKAĆ&ROZPOZNAWCZOŚĆ.../")
ds_map_add(global.text_data_en, "obj_darksans1_591", "* wow^1, brzmi na to że&  naprawdę mocno&  pracujesz.../")
ds_map_add(global.text_data_en, "obj_darksans1_592", "\E2* aż do kości./%%")
ds_map_add(global.text_data_en, "obj_darksans1_604", "UGH!!!/")
ds_map_add(global.text_data_en, "obj_darksans1_605", "PÓJDĘ UCZESTNICZYĆ&W MOICH PUZZLACH.../")
ds_map_add(global.text_data_en, "obj_darksans1_606", "\E3A CO DO CIEBIE?/")
ds_map_add(global.text_data_en, "obj_darksans1_607", "WŁÓŻ TROCHĘ WIĘCEJ,/")
ds_map_add(global.text_data_en, "obj_darksans1_608", "\E4" + '"' + "KRĘGOSŁUPA" + '"' + "& DO TEGO!!!!/")
ds_map_add(global.text_data_en, "obj_darksans1_609", "\E2NYEHEHEHEHEHE&HEHEHEHEHEHE!!!/%%")
ds_map_add(global.text_data_en, "obj_darksans1_644", "HEH!/%%")
ds_map_add(global.text_data_en, "obj_darksans1_666", "* ok^1, możesz już&  wyjść stamtąd./%%")
ds_map_add(global.text_data_en, "obj_darksans1_720", "* .../")
ds_map_add(global.text_data_en, "obj_darksans1_721", "\E1* uh^1, ok^1, najwyraźniej&  nie musisz./%%")
ds_map_add(global.text_data_en, "obj_darksans1_750", "SANS!!^1!&ZNALAZŁEŚ JUŻ&CZŁOWIEKA!??!/")
ds_map_add(global.text_data_en, "obj_darksans1_752", "* ta./")
ds_map_add(global.text_data_en, "obj_darksans1_754", "NAPRAWDĘ!?!^1?&WOWIE!!!/")
ds_map_add(global.text_data_en, "obj_darksans1_755", "W TAKIM RAZIE TO&JEST Z GŁOWY!!/%%")
ds_map_add(global.text_data_en, "obj_darksans1_780", "* to zadziałało^1, huh?/%%")
ds_map_add(global.text_data_en, "obj_darksausagenpc_72", "* Czemu wyglądam jak&  dziwna czarna kiełbaska^1?&* Po prostu perspektya./%%")
ds_map_add(global.text_data_en, "obj_darksausagenpc_76", "* As a youth^1, I would sneak&  out to play by this creepy&  flaming pit./")
ds_map_add(global.text_data_en, "obj_darksausagenpc_77", "* Since the CORE is always&  re-arranging^1, it was like&  a game trying to find it./")
ds_map_add(global.text_data_en, "obj_darksausagenpc_78", "* Now it is my special place^1.&* It is nice for cooking s'mores&  and things like that./%%")
ds_map_add(global.text_data_en, "obj_darksausagenpc_83", "* We were hired by Mettaton&  to destroy you./")
ds_map_add(global.text_data_en, "obj_darksausagenpc_84", "* But since he never paid us^1,&  we all decided to quit./")
ds_map_add(global.text_data_en, "obj_darksausagenpc_85", "* No hard feelings./%%")
ds_map_add(global.text_data_en, "obj_darksausagenpc_90", "* Zzzzzzz.../")
ds_map_add(global.text_data_en, "obj_darksausagenpc_91", "* (It's taking a nap.)/%%")
ds_map_add(global.text_data_en, "obj_darksausagenpc_96", "* Why do I look like a black&  sausage and not a knight&  or a wizard?/")
ds_map_add(global.text_data_en, "obj_darksausagenpc_97", "* Well..^1.&* Everyone has an angle they&  look best from../%%")
ds_map_add(global.text_data_en, "obj_darksausagenpc_102", "* The core is made up of&  interchangable rooms./")
ds_map_add(global.text_data_en, "obj_darksausagenpc_103", "* Before you came here^1, the&  layout was altered so you&  would get lost and perish./")
ds_map_add(global.text_data_en, "obj_darksausagenpc_104", "* Yes^1. Just for you^1.&* Do you feel special?/%%")
ds_map_add(global.text_data_en, "obj_darksink_91", "* Error./%%")
ds_map_add(global.text_data_en, "obj_darksink_98", "* (Odkręciłeś zlew.)/%%")
ds_map_add(global.text_data_en, "obj_darksink_100", "* (Naprawdę lubisz myć ręce.)/%%")
ds_map_add(global.text_data_en, "obj_darksink_110", "* (Zakręcasz zlew.)/%%")
ds_map_add(global.text_data_en, "obj_darksink_122", "* (Odkręciłeś zlew.)/%%")
ds_map_add(global.text_data_en, "obj_darksink_132", "* (Na dnie zlewu leży&  czerwony klucz.)/")
ds_map_add(global.text_data_en, "obj_darksink_133", "* (Wziąłeś go i umieściłeś&  na twoim breloczku.)/%%")
ds_map_add(global.text_data_en, "obj_dateheart_158", "\E3I SEE^1. I SEE./")
ds_map_add(global.text_data_en, "obj_dateheart_159", "\E0YOU LIKE CARESSING&MY BICEPS WITH A&FLOATING HEART./")
ds_map_add(global.text_data_en, "obj_dateheart_160", "\E1BUT WHO DOESN'T!?/%%")
ds_map_add(global.text_data_en, "obj_dateheart_161", "\E0TRY AGAIN!/%%")
ds_map_add(global.text_data_en, "obj_dateheart_165", "\E0THIS SHIRT DIDN'T&ORIGINALLY SAY&'COOL^1,' BUT I&IMPROVED IT./")
ds_map_add(global.text_data_en, "obj_dateheart_166", "EXPERT TIP^1: ALL&CLOTHING ARTICLES&CAN BE IMPROVED&THIS WAY./%%")
ds_map_add(global.text_data_en, "obj_dateheart_167", "\E1BUT THAT'S NOT A&SECRET!!!/")
ds_map_add(global.text_data_en, "obj_dateheart_168", "IT'S JUST GOOD&ADVICE!!!/%%")
ds_map_add(global.text_data_en, "obj_dateheart_172", "\E2HOLDING MY HAND&SO I'LL TELL&YOU THE ANSWER.../")
ds_map_add(global.text_data_en, "obj_dateheart_173", "\E7NO!!^1!&I MUST RESIST!!/%%")
ds_map_add(global.text_data_en, "obj_dateheart_177", "\E0THERE'S NO SECRET&TO MY LEGS./")
ds_map_add(global.text_data_en, "obj_dateheart_178", "JUST HARD WORK&AND PERSEVERANCE.../%%")
ds_map_add(global.text_data_en, "obj_dateheart_182", "\E3HUMAN SOULS ARE&STRONGER THAN&MONSTER SOULS.../")
ds_map_add(global.text_data_en, "obj_dateheart_183", "\E0BUT THE SOLES OF&OUR SHOES ON THE&OTHER HAND...!/")
ds_map_add(global.text_data_en, "obj_dateheart_184", "\E3... ARE ABOUT THE&SAME./%%")
ds_map_add(global.text_data_en, "obj_dateheart_188", "HAT DIALOGUE./%%")
ds_map_add(global.text_data_en, "obj_dateheart_365", "\E0I UNDERSTAND&WHY YOU'RE&RUNNING AWAY./")
ds_map_add(global.text_data_en, "obj_dateheart_366", "\E2YOU'RE OVERWHELMED&BY THE SIGHT OF&MY COOL VIBES./")
ds_map_add(global.text_data_en, "obj_dateheart_367", "\E0BUT YOU CAN'T&BACK DOWN NOW!!!/%%")
ds_map_add(global.text_data_en, "obj_diamondkid_73", "\W* My fave Mettaton Moment(TM)^1?&* Right \Ywhen everything looks the&  baddest^1, he poses dramatically\W./")
ds_map_add(global.text_data_en, "obj_diamondkid_74", "* Like when he's on a cooking&  show and the eggs don't turn&  out right./%%")
ds_map_add(global.text_data_en, "obj_diamondkid_78", "* But^1!&* Then he says!/")
ds_map_add(global.text_data_en, "obj_diamondkid_79", "\W* Even if you suck at cooking^1,&  you can always \Ybuy an&  MTT-brand Glamburger\W!/")
ds_map_add(global.text_data_en, "obj_diamondkid_80", "\W* Then he \Yeats one^1!\W &* Everyone loves it!/")
ds_map_add(global.text_data_en, "obj_diamondkid_81", "* ... How does he eat it&  without a mouth?/")
ds_map_add(global.text_data_en, "obj_diamondkid_82", "* Uhhh... well..^1.&* Watch the show!/%%")
ds_map_add(global.text_data_en, "obj_diamondkid_87", "* That finale was really..^1.&* That was really sad!/")
ds_map_add(global.text_data_en, "obj_diamondkid_88", "* And Mettaton's schedule&  doesn't show any other&  shows.../%%")
ds_map_add(global.text_data_en, "obj_diamondkid_93", "* I've been thinking about&  getting a sick skateboard./%%")
ds_map_add(global.text_data_en, "obj_diamondkid_98", "\W* My fave Mettaton Moment(TM)&  is when he beats up the&  \Yheel-turning villains\W!/")
ds_map_add(global.text_data_en, "obj_diamondkid_99", "* Even if it's during what's&  supposed to be a quiz show./%%")
ds_map_add(global.text_data_en, "obj_diamondkid_106", "* Oh^1! And I like when he tries&  on all kinds of different&  fashionable outfits!/")
ds_map_add(global.text_data_en, "obj_diamondkid_107", "* Even if it's during what's&  supposed to be a newscast./%%")
ds_map_add(global.text_data_en, "obj_diamondkid_112", "* Did Mettaton retire...?/")
ds_map_add(global.text_data_en, "obj_diamondkid_113", "* Can't he unretire...?/%%")
ds_map_add(global.text_data_en, "obj_diamondkid_119", "* On the surface we'll be able&  to watch all kinds of TV.../")
ds_map_add(global.text_data_en, "obj_diamondkid_120", "* But^1, I bet none of those&  shows are as good as&  Mettaton's!/%%")
ds_map_add(global.text_data_en, "obj_disembodiedfoxhead_60", "* The door leading through&  the area is closed^1?&* So I tried the puzzle?/")
ds_map_add(global.text_data_en, "obj_disembodiedfoxhead_61", "* But I kept running out of&  ammo^1, and it kept restarting?/")
ds_map_add(global.text_data_en, "obj_disembodiedfoxhead_62", "* And my two co-workers won't&  help^1? It's like they don't&  even wanna go to work?/%%")
ds_map_add(global.text_data_en, "obj_disembodiedfoxhead_63", "* Why don't you try^1?&* Try using the console?/%%")
ds_map_add(global.text_data_en, "obj_disembodiedfoxhead_67", "* Wow^1?&* You solved it?/")
ds_map_add(global.text_data_en, "obj_disembodiedfoxhead_68", "* I'm impressed^1?&* You must be a total nerd?/%%")
ds_map_add(global.text_data_en, "obj_disembodiedfoxhead_73", "* So we're all gonna go&  free...?/")
ds_map_add(global.text_data_en, "obj_disembodiedfoxhead_74", "* Does that mean I don't&  get to go to work?/%%")
ds_map_add(global.text_data_en, "obj_disembodiedfoxhead_79", "* Maybe I don't want to go&  to work anymore...?/%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_400", "* Tra la la^1.&* The waters are wild today^1.&* That's good luck.../%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_401", "* Tra la la./%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_402", "* Tra la la^1.&* The waters are wild today^1.&* That's bad luck.../%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_403", "* Tra la la^1.&* Eat a mushroom everyday./")
ds_map_add(global.text_data_en, "obj_dogboat_thing_404", "* Why^1?&* Then I know you're listening&  to me.../%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_405", "* Tra la la^1.&* Remember to take a break&  every-so-often.../%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_406", "* Tra la la^1.&* Did you ever hear the old&  song coming from the sea?/%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_407", "* Tra la la^1.&* What's inside an acorn^1?&* It's really just a mystery./%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_408", "* Tra la la^1.&* Dancing on a boat is danger^1.&* But good exercise.../%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_409", "* Tra la la^1.&* I heard ASGORE has a favorite&  food./%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_410", "* Tra la la^1.&* I heard spiders have a&  favorite food./")
ds_map_add(global.text_data_en, "obj_dogboat_thing_411", "* It's spiders./%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_412", "* Tra la la^1.&* The piano plays the&  tinkling song./")
ds_map_add(global.text_data_en, "obj_dogboat_thing_413", "* Hmm..^1. tinkling./%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_414", "* Tra la la^1.&* You can never have too&  many hot-dogs./")
ds_map_add(global.text_data_en, "obj_dogboat_thing_415", "* ... sadly^1, that's not true./%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_416", "* Tra la la^1.&* Don't snoop behind people's&  houses.../")
ds_map_add(global.text_data_en, "obj_dogboat_thing_417", "* You might be mistaken for&  a trash-can./%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_418", "* Tra la la^1.&* The angel is coming..^1.&* Tra la la./%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_419", "* Hum hum hum^1. Hum hum hum^1.&* I'm having a little concert./%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_420", "* Pet pet pet..^1.&* The neck stretches infinitely&  into the cosmos./")
ds_map_add(global.text_data_en, "obj_dogboat_thing_421", "* ... don't worry about it./%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_422", "* Ah,/%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_423", "* Tra la la^1.&* What's a game you can play&  with a dog?/")
ds_map_add(global.text_data_en, "obj_dogboat_thing_424", "* Asking for a friend.../%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_425", "* Tra la la^1.&* Temmie Village.../")
ds_map_add(global.text_data_en, "obj_dogboat_thing_426", "* ... the room before the&  darkening lantern room./%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_427", "* Tra la la^1.&* Why don't you sing with me^1.&* Tra la la./%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_428", "* Tra la la^1.&* Uh oh^1.&* Suddenly^1, feeling tropical.../%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_429", "* Tra la la^1.&* Hmmm.../")
ds_map_add(global.text_data_en, "obj_dogboat_thing_430", "* I should have worn a few&  more pairs of pants today./%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_431", "* Tra la la^1.&* Hmmm.../")
ds_map_add(global.text_data_en, "obj_dogboat_thing_432", "* I should have worn a few&  million more pairs of pants&  today./%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_433", "* Tra la la^1.&* Tri li li^1.&* Tre le le./%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_447", "* Tra la la^1.&* Somewhere^1, it's \[1]^1.&* So be careful./%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_450", "* Tra la la^1.&* If it's hot or cold^1, you&  can count on me./%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_451", "* Tra la la^1.&* The water is very wet today./%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_452", "* Tra la la^1.&* The water is very dry today./%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_453", "* Tra la la^1.&* What's my name^1?&* ... It doesn't really matter./%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_454", "* Tra la la^1.&* Humans^1, monsters^1...&* Flowers./%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_455", "* Tra la la^1.&* Beware of the man who&  speaks in hands./%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_456", "* Tra la la^1.&* Beware of the man who came&  from the other world./%%")
ds_map_add(global.text_data_en, "obj_dogboat_thing_593", "* Come again some time^1.&* Tra la la./%%")
ds_map_add(global.text_data_en, "obj_dogetrigger1_108", "* Czy coś się ruszyło^1?&* Czy to moja wyobraźnia?/")
ds_map_add(global.text_data_en, "obj_dogetrigger1_109", "* Ja jestem w stanie widzieć&  tylko ruszające się rzeczy./")
ds_map_add(global.text_data_en, "obj_dogetrigger1_110", "* Jeśli coś się RZECZYWIŚCIE&  ruszało..^1.&* Na przykład^1, człowiek.../")
ds_map_add(global.text_data_en, "obj_dogetrigger1_111", "* Upewnię się że już NIGDY&  więcej się nie poruszy!/%%")
ds_map_add(global.text_data_en, "obj_dogetrigger1_114", "* Czy coś się ruszyło^1?&* Czy to moja wyobraźnia?/")
ds_map_add(global.text_data_en, "obj_dogetrigger1_115", "* Ja jestem w stanie widzieć&  tylko ruszające się rzeczy./")
ds_map_add(global.text_data_en, "obj_dogetrigger1_116", "* H..^1. hej!&* Nie mogę przestać się&  trząść nagle./")
ds_map_add(global.text_data_en, "obj_dogetrigger1_117", "* Kto..^1. kto tam jest!?/%%")
ds_map_add(global.text_data_en, "obj_dogetrigger1_156", "* C-C-C-Coś mnie pogłaskało...&* Coś, co się nie&  r-r-rusza.../")
ds_map_add(global.text_data_en, "obj_dogetrigger1_157", "* Będę potrzebował parę psich&  przekąsek w ramach terapii!!!/%%")
ds_map_add(global.text_data_en, "obj_dogetrigger1_160", "* Patyk pojawił się z nikąd^1,&  a potem znikł./")
ds_map_add(global.text_data_en, "obj_dogetrigger1_161", "* Czy to był duchowy patyk?/")
ds_map_add(global.text_data_en, "obj_dogetrigger1_162", "* Czy ja właśnie zwróciłem&  go do zmarłych?/")
ds_map_add(global.text_data_en, "obj_dogetrigger1_163", "* Potrzebuję psiej terapii./%%")
ds_map_add(global.text_data_en, "obj_dogfood_98", "* (Niestety^1, to tylko&  sucha karma.)/%%")
ds_map_add(global.text_data_en, "obj_dogfood_99", "* (Jest hot dog pocięty&  na małe drobinki.)/%%")
ds_map_add(global.text_data_en, "obj_dogfoodbag_57", "* (To w połowie pusty worek&  na suchą karmę dla psów.)/%%")
ds_map_add(global.text_data_en, "obj_dogfoodbag_59", "* (To worek z karmą dla psów.^1)&* (Jest w połowie pełna.)/%%")
ds_map_add(global.text_data_en, "obj_dogfoodbag_63", "* (To w połowie pusty worek&  na karmę.)/")
ds_map_add(global.text_data_en, "obj_dogfoodbag_64", "* (...)/")
ds_map_add(global.text_data_en, "obj_dogfoodbag_65", "* (Przypomniałeś sobie&  właśnie coś śmiesznego.)/%%")
ds_map_add(global.text_data_en, "obj_dogfoodbag_68", "* (Jest zbyt ciemno^1, by widzieć&  koło ścian.)/%%")
ds_map_add(global.text_data_en, "obj_doggiebed_98", "* (To zbyt małe^1, by na tym&  spać.)/%%")
ds_map_add(global.text_data_en, "obj_dogneckparent_99", "* To głowa rozwalonego&  psiobałwana./%%")
ds_map_add(global.text_data_en, "obj_dogpillarparent_117", "* To chyba nieudana baza&  psiobałwana./%%")
ds_map_add(global.text_data_en, "obj_dogpillarparent_118", "* To kupka miękkiego śniegu./%%")
ds_map_add(global.text_data_en, "obj_dogpillarparent_119", "* Ten pies gapi się na śnieg^1,&  czekając aż zamieni się&  na dzieło sztuki./%%")
ds_map_add(global.text_data_en, "obj_dogringbell_148", "* Halo^1?&* Czy jest tam kto...^1?&* Nie?/%%")
ds_map_add(global.text_data_en, "obj_dogringbell_149", "* Czy wy dwaj stroicie sobie&  żarty ze mnie^1?&* Bardzo śmieszne./%%")
ds_map_add(global.text_data_en, "obj_dogringbell_150", "* Big guy^1?&* Czy to ty^1?&* No weź.../%%")
ds_map_add(global.text_data_en, "obj_dogringbell_151", "* Cóż^1, to nie jest ten&  wysoki szkielet..^1.&* Jest zbyt głośny./%%")
ds_map_add(global.text_data_en, "obj_dogringbell_152", "* Kimkolwiek jesteś^1,&  przestań już!!!/%%")
ds_map_add(global.text_data_en, "obj_dogringbell_153", "* .../%%")
ds_map_add(global.text_data_en, "obj_dogroom_npc_74", "* Ten pies uważa siebie&  jako artystę^1, ale nigdy&  nie wie co stworzyć./")
ds_map_add(global.text_data_en, "obj_dogroom_npc_75", "* Prawdopodobnie nie pomaga&  to^1, że jego mózg jest&  niewiele większy od rodzynki./%%")
ds_map_add(global.text_data_en, "obj_dogroom_npc_79", "* That dog from earlier...^1?&* It's at Grillby's^1.&* I think./")
ds_map_add(global.text_data_en, "obj_dogroom_npc_80", "* After work^1, all of the dogs&  go there to play cards&  together./")
ds_map_add(global.text_data_en, "obj_dogroom_npc_81", "* But that dog doesn't really&  know how to express itself./")
ds_map_add(global.text_data_en, "obj_dogroom_npc_82", "* So^1, it ends up playing alone^1,&  instead of introducing&  itself to the others.../%%")
ds_map_add(global.text_data_en, "obj_dogroom_npc_87", "* Jakiś pies tu przybiegł^1,&  wypełniony inspiracją./")
ds_map_add(global.text_data_en, "obj_dogroom_npc_88", "* Próbowało zbudować psiobałwana&  który wyrażał jego własne&  emocje.../")
ds_map_add(global.text_data_en, "obj_dogroom_npc_89", "* Ale^1, kiedy budował^1, &  stawał się podekscytowany&  własną rzeźbą.../")
ds_map_add(global.text_data_en, "obj_dogroom_npc_90", "* Jego szyja robiła się coraz&  dłuższa i dodawał coraz więcej&  śniegu^1, dopóki.../")
ds_map_add(global.text_data_en, "obj_dogroom_npc_91", "* To było raczej smutne do&  oglądania^1, ale nie mogłem&  obrócić głowy./%%")
ds_map_add(global.text_data_en, "obj_dogroom_npc_96", "* We're all free?/")
ds_map_add(global.text_data_en, "obj_dogroom_npc_97", "* OK^1, OK..^1.&* I'll stop lounging around^1.&* Does that dog know?/")
ds_map_add(global.text_data_en, "obj_dogroom_npc_98", "* ... it probably doesn't^1,&  does it...?/%%")
ds_map_add(global.text_data_en, "obj_dogtreat_99", "* (Ktoś próbował palić&  przekąski dla psów.)&      \Y* SPSK1 Głuska Core *\W/%%")
