ds_map_add(global.text_data_en, "obj_triswitchevent_148", "\E2* ............./")
ds_map_add(global.text_data_en, "obj_triswitchevent_149", "\E0* H-h-hej!/")
ds_map_add(global.text_data_en, "obj_triswitchevent_150", "\E5* Wygląda na to, że!!!^1 &* Wystarczyło nacisnąć^1!&* Tylko dwa!!!/")
ds_map_add(global.text_data_en, "obj_triswitchevent_151", "\TS \F0 \E0 \T0 %")
