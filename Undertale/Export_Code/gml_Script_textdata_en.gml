ds_map_add(global.text_data_en, "obj_snowdrake_253", '"' + "Chill" + '"' + "&out...")
ds_map_add(global.text_data_en, "obj_snowdrake_254", "Przy-&chodzi&śnieg do&lekarza...")
ds_map_add(global.text_data_en, "obj_snowdrake_257", "Czy ja&naprawdę...")
ds_map_add(global.text_data_en, "obj_snowdrake_258", "Hej...")
ds_map_add(global.text_data_en, "obj_snowdrake_259", "Guys...&guys...")
ds_map_add(global.text_data_en, "obj_snowdrake_265", "Masz&dobry&humor!!&(w żartach)")
ds_map_add(global.text_data_en, "obj_snowdrake_266", "Widzisz!?&Śmiech!&Stary się&mylił!")
ds_map_add(global.text_data_en, "obj_snowdrake_267", "Dzięki,&jesteście&wszyscy&świetni.")
ds_map_add(global.text_data_en, "obj_snowdrake_268", "Widzisz!?&Śmiech!&Stary się&mylił!")
ds_map_add(global.text_data_en, "obj_snowdrake_271", "Ale&mrozi&...")
ds_map_add(global.text_data_en, "obj_snowdrake_278", "To niby&miało&być&śmieszne?")
ds_map_add(global.text_data_en, "obj_snowdrake_279", "Ha...&Ha...&zbyt&suche.")
ds_map_add(global.text_data_en, "obj_snowdrake_280", "Już to&słysza-&łem.")
ds_map_add(global.text_data_en, "obj_snowdrake_285", "TO też&nie&będzie&śmieszne!")
ds_map_add(global.text_data_en, "obj_snowdrake_286", "Wybom-&biaj!")
ds_map_add(global.text_data_en, "obj_snowdrake_287", "(Wyzywa&ludzi)")
ds_map_add(global.text_data_en, "obj_snowdrake_292", "IT'S&JUST&LIKE&'EM")
ds_map_add(global.text_data_en, "obj_snowdrake_293", "HAHA&JESTEŚ&BETTERLEPSZY")
ds_map_add(global.text_data_en, "obj_snowdrake_294", "YOU&NAILED&IT")
ds_map_add(global.text_data_en, "obj_snowdrake_299", "To mnie&nie&przypo-&mina...")
ds_map_add(global.text_data_en, "obj_snowdrake_300", "Ja tak&nie&robię...")
ds_map_add(global.text_data_en, "obj_snowdrake_301", "To&lepsze&jak ja&to robię...")
ds_map_add(global.text_data_en, "obj_snowdrake_309", "%%%")
ds_map_add(global.text_data_en, "obj_snowdrake_507", "* Snowdrake spogląda na&  publiczność.")
ds_map_add(global.text_data_en, "obj_snowdrake_508", "* Snowdrake szykuje swój&  kolejny kawał.")
ds_map_add(global.text_data_en, "obj_snowdrake_509", "* Snowdrake śmieje się z&  własnego żartu.")
ds_map_add(global.text_data_en, "obj_snowdrake_510", "* Pachnie mokrą poduszką.")
ds_map_add(global.text_data_en, "obj_snowdrake_511", "* Snowdrake zdał sobie sprawę^1,&  że jego własne imię to żart&  i jest przerażony.")
ds_map_add(global.text_data_en, "obj_snowdrake_512", "* Snowdrake jest zadowolony z&  własnego " + '"' + "fajnego" + '"' + " kawału.")
ds_map_add(global.text_data_en, "obj_snowdrake_513", "* Snowdrake śmieje się z twojej&  imitacji jego kawałów.")
ds_map_add(global.text_data_en, "obj_snowdrake_514", "* Snowdrake udaje^1, że go&  to nie obchodzi.")
ds_map_add(global.text_data_en, "obj_snowdrake_515", "* Snowdrake jest przemęczony..")
ds_map_add(global.text_data_en, "obj_snowdrake_516", "* Snowdrake pada z sił.")
ds_map_add(global.text_data_en, "obj_snowdrake_533", "* SNOWDRAKE - ATK 12 DEF 7&* Ten nieletni komik utrzymuje&  stałą widownię./^")
ds_map_add(global.text_data_en, "obj_snowdrake_542", "* Szkalujesz Snowdrake'a./^")
ds_map_add(global.text_data_en, "obj_snowdrake_543", "* Mówisz Snowdrake'owi^1, że&  nie jest śmieszny./^")
ds_map_add(global.text_data_en, "obj_snowdrake_545", "* Mówisz Snowdrake'owi^1, że&  nikt go nigdy ne pokocha&  za to kim tak naprawdę jest.../")
ds_map_add(global.text_data_en, "obj_snowdrake_546", "* Snowdrake próbuje wyjść z&  ripostą^1, ale rezygnuje&  żałośnie.../^")
ds_map_add(global.text_data_en, "obj_snowdrake_559", "* Śmiejesz się ze Snowdrake'a&  zanim powiedział coś&  śmiesznego./^")
ds_map_add(global.text_data_en, "obj_snowdrake_560", "* Śmiejesz się z kawału&  Snowdrake'a./^")
ds_map_add(global.text_data_en, "obj_snowdrake_568", "* Opowiadasz słaby kawał&  o śniegu./^")
ds_map_add(global.text_data_en, "obj_snowdrake_570", "* Opowiadasz słaby kawał&  o śniegu./")
ds_map_add(global.text_data_en, "obj_snowdrake_571", "* The other monsters think&  it's hilarious.../^")
ds_map_add(global.text_data_en, "obj_snowdrakedad_75", "* Jestem komikiem z zawodu.&* Jestem bardzo śmieszny^1.&* Inni śmieją się z moich żartów./")
ds_map_add(global.text_data_en, "obj_snowdrakedad_76", "* Słuchaj^1, mój syn^1.&* Chce być komikiem&  jak jego papa./")
ds_map_add(global.text_data_en, "obj_snowdrakedad_77", "* Ale jego żarty^1.&* Nie są śmieszne./")
ds_map_add(global.text_data_en, "obj_snowdrakedad_78", "* On robi te krindżowe gry słów^1.&* Przynosi wstyd całej rodzinie./")
ds_map_add(global.text_data_en, "obj_snowdrakedad_79", "* Ha ha ha ha.../")
ds_map_add(global.text_data_en, "obj_snowdrakedad_80", "* To nie jest śmieszne./")
ds_map_add(global.text_data_en, "obj_snowdrakedad_81", "* Odkąd jego matka znikła^1,&  on nie mógł znieść^1.&* Mieszkanie w domu./")
ds_map_add(global.text_data_en, "obj_snowdrakedad_82", "* Więc uciekł^1.&* Nie widziałem&  go do dzisiaj./")
ds_map_add(global.text_data_en, "obj_snowdrakedad_83", "* Jestem okropnym ojcem^1.&* Ha ha ha ha.../")
ds_map_add(global.text_data_en, "obj_snowdrakedad_84", "* To nie jest śmieszne./%%")
ds_map_add(global.text_data_en, "obj_snowdrakedad_87", "* Rozmawianie z tobą&  o tym..^1.&* Łamie mi serce./")
ds_map_add(global.text_data_en, "obj_snowdrakedad_88", "* Ha ha ha ha.../")
ds_map_add(global.text_data_en, "obj_snowdrakedad_89", "* To nie jest śmieszne./%%")
ds_map_add(global.text_data_en, "obj_snowdrakedad_94", "* Lekorz^1.&* Przywrócił mi żonę.&* Spowrotem od zmarłych./")
ds_map_add(global.text_data_en, "obj_snowdrakedad_95", "* Mój syn^1.&* Wydaje się znów szczęśliwy./")
ds_map_add(global.text_data_en, "obj_snowdrakedad_96", "* Nasza rodzina^1.&* Jest większa niż&  kiedykolwiek była./")
ds_map_add(global.text_data_en, "obj_snowdrakedad_97", "* Teraz jako że moja żona^1.&* Jest połączona^1.&* Z 16 innymi osobami./%%")
ds_map_add(global.text_data_en, "obj_snowdrakedad_102", "* Mój szef przestał&  odbierać moje połączenia./")
ds_map_add(global.text_data_en, "obj_snowdrakedad_103", "* Nie wiem kiedy mój&  następny występ się&  odbędzie./")
ds_map_add(global.text_data_en, "obj_snowdrakedad_104", "* Może nie powinienem się już&  starać byciem komikiem.../")
ds_map_add(global.text_data_en, "obj_snowdrakedad_105", "* To rozdziera moją rodzinę./%%")
ds_map_add(global.text_data_en, "obj_snowdrakedad_110", "* Mój syn..^1.&* On zawsze robił te&  dziwne śnieżne gry słów./")
ds_map_add(global.text_data_en, "obj_snowdrakedad_111", "* Nienawidziłem je^1, więc on&  uciekł z domu.../")
ds_map_add(global.text_data_en, "obj_snowdrakedad_112", "* Myślę^1, że powinienem&  poukładać z nim relację./")
ds_map_add(global.text_data_en, "obj_snowdrakedad_113", "* Widziałeś go^1?&* Widziałeś mojego syna?/%%")
ds_map_add(global.text_data_en, "obj_snowdrakemom_158", " zi...& m...& no...")
ds_map_add(global.text_data_en, "obj_snowdrakemom_165", " haha...& ja...& pamię..&  tam...")
ds_map_add(global.text_data_en, "obj_snowdrakemom_167", " haha...& dzię...& kuję...")
ds_map_add(global.text_data_en, "obj_snowdrakemom_173", "%%%")
ds_map_add(global.text_data_en, "obj_snowdrakemom_387", "* Jest mi tak zimno.")
ds_map_add(global.text_data_en, "obj_snowdrakemom_388", "* Jest mi tak zimno.")
ds_map_add(global.text_data_en, "obj_snowdrakemom_389", "* Jest mi tak zimno.")
ds_map_add(global.text_data_en, "obj_snowdrakemom_390", "* Jest mi tak zimno.")
ds_map_add(global.text_data_en, "obj_snowdrakemom_391", "* Pachnie jak słona breja.")
ds_map_add(global.text_data_en, "obj_snowdrakemom_392", "* Wydaje się uspokoić.")
ds_map_add(global.text_data_en, "obj_snowdrakemom_393", "* Monster has low HP.")
ds_map_add(global.text_data_en, "obj_snowdrakemom_426", "* AMALGAMAT - ATK -12 DEF -5&* Wydaje się^1, jakby to&  traciło swoją formę./^")
ds_map_add(global.text_data_en, "obj_snowdrakemom_435", "* Śmiejesz się^1, coraz głośniej^1.&* To TAKIE śmieszne^1, nie możesz&  przestać^1. Łzy ci lecą po twarzy./^")
ds_map_add(global.text_data_en, "obj_snowdrakemom_436", "* ... co^1?&* Nie zrobiłeś tego?/^")
ds_map_add(global.text_data_en, "obj_snowdrakemom_439", "* Ale to nie jest śmieszne./^")
ds_map_add(global.text_data_en, "obj_snowdrakemom_451", "* Powiedziałeś coś typu..^1.&* " + '"' + "Wyglądasz obrzydliwie.^1" + '"' + "&* " + '"' + "Czemu ty jeszcze żyjesz?^1" + '"' + "/")
ds_map_add(global.text_data_en, "obj_snowdrakemom_452", "* ... co^1?&* Nie powiedziałeś tego?/^")
ds_map_add(global.text_data_en, "obj_snowdrakemom_455", "* Nazywasz to przedstawieniem?/^")
ds_map_add(global.text_data_en, "obj_snowdrakemom_467", "* Powiedziałeś słaby żart śnieżny^1&* Jej wyraz twarzy zaczyna&  się zmieniać./^")
ds_map_add(global.text_data_en, "obj_snowdrakemom_469", "* Powiedziałeś słaby żart śnieżny^1&* Jej wyraz twarzy się zmienia&  jeszcze bardziej./^")
ds_map_add(global.text_data_en, "obj_snowdrakemom_472", "* Powiedziałeś słaby żart śnieżny^1&* Ona całkowicie się&  uspokoiła./^")
ds_map_add(global.text_data_en, "obj_snowdrakenpc_76", "* Uciekłem z domu^1.&* Czemu?/")
ds_map_add(global.text_data_en, "obj_snowdrakenpc_77", "* Bo mój ojciec był taki&  " + '"' + "zimny" + '"' + " do mnie.../")
ds_map_add(global.text_data_en, "obj_snowdrakenpc_78", "* CO!^1?&* To ŻART!^1!&* ŚMIEJ SIĘ!!/%%")
ds_map_add(global.text_data_en, "obj_snowdrakenpc_82", "* Mnie to naprawdę nie obchodzi^1!&* Nie obchodzi mnie jeśli on&  nie lubi moich żartów!/%%")
ds_map_add(global.text_data_en, "obj_snowdrakenpc_87", "* Moja mama musi teraz dzielić&  jej umysł z innymi^1, ale&  jest dalej moją mamą./")
ds_map_add(global.text_data_en, "obj_snowdrakenpc_88", "* A to jest  " + '"' + "czadowe!" + '"' + "/")
ds_map_add(global.text_data_en, "obj_snowdrakenpc_89", "* Bo^1, uhh^1, jesteśmy stworzeni&  z lodu i takie tam./")
ds_map_add(global.text_data_en, "obj_snowdrakenpc_90", "* CO!?!^1?&* To ŻART!^1!&* ŚMIEJ SIĘ!!/%%")
ds_map_add(global.text_data_en, "obj_snowpoff_100", "* To śnieżny puf./%%")
ds_map_add(global.text_data_en, "obj_snowpoff_101", "* A to..^1.&* To śnieżny puf./%%")
ds_map_add(global.text_data_en, "obj_snowpoff_102", "* To^1, jednak^1, to śnieżny puf./%%")
ds_map_add(global.text_data_en, "obj_snowpoff_103", "* Zaskakująco^1, to śnieżny puf./%%")
ds_map_add(global.text_data_en, "obj_snowpoff_104", "* Śnieżny puf.../%%")
ds_map_add(global.text_data_en, "obj_snowpoff_105", "* Czy to naprawdę śnieżny puf?/%%")
ds_map_add(global.text_data_en, "obj_snowpoff_106", "* Baczność^1!&* Śnieżny puf./%%")
ds_map_add(global.text_data_en, "obj_snowpoff_107", "* Jak się to nazywa?/%%")
ds_map_add(global.text_data_en, "obj_snowpoff_108", "* Eh^1?&* Jest 30G w środku..^1.&  co to jest?/%%")
ds_map_add(global.text_data_en, "obj_sockdrawer_60", "%%")
ds_map_add(global.text_data_en, "obj_sockdrawer_66", "* Zerkasz do środka..^2.&* Co za skandal!/")
ds_map_add(global.text_data_en, "obj_sockdrawer_67", "* To szufladka na&  skarpety TORIEL./%%")
ds_map_add(global.text_data_en, "obj_sockdrawer_68", "* Nie możesz przestać&  patrzećna nie./%%")
ds_map_add(global.text_data_en, "obj_sosorry_269", "AHHHHHHH!!!!!/%%")
ds_map_add(global.text_data_en, "obj_sosorry_274", "\E1AHHHHH!!!/%%")
ds_map_add(global.text_data_en, "obj_sosorry_279", "\E1Oh!&Ups!&To bolało!/")
ds_map_add(global.text_data_en, "obj_sosorry_280", "\E2So sorry^1, I must&have gotten in the&way!/")
ds_map_add(global.text_data_en, "obj_sosorry_281", "\E1I really shouldn't&stand so close/")
ds_map_add(global.text_data_en, "obj_sosorry_282", "\E4Ah I'm just being&troublesome/%%")
ds_map_add(global.text_data_en, "obj_sosorry_287", "\E4Darn it, I keep&getting in the way/")
ds_map_add(global.text_data_en, "obj_sosorry_288", "\E2So sorry, I'm such&an oaf/")
ds_map_add(global.text_data_en, "obj_sosorry_289", "\E2Wandering in front&of you.../%%")
ds_map_add(global.text_data_en, "obj_sosorry_294", "\E1.../")
ds_map_add(global.text_data_en, "obj_sosorry_295", "Are you...&trying to KILL me?/")
ds_map_add(global.text_data_en, "obj_sosorry_296", "\E4... so sorry, but&I've had a really&tough year./")
ds_map_add(global.text_data_en, "obj_sosorry_297", "I don't know if I&could take you&killing me on top&of everything./")
ds_map_add(global.text_data_en, "obj_sosorry_298", "\E2You should find&someone else to&kill.&So sorry./%%")
ds_map_add(global.text_data_en, "obj_sosorry_303", "\E1?????/")
ds_map_add(global.text_data_en, "obj_sosorry_304", "\E5I just said I'm&not interested in&the offer!!/")
ds_map_add(global.text_data_en, "obj_sosorry_305", "\E5.../")
ds_map_add(global.text_data_en, "obj_sosorry_306", "\E2Sorry, I must not&have enunciated&clearly enough./")
ds_map_add(global.text_data_en, "obj_sosorry_307", "\E2I am not interested&in being killed.&Thank you very much./%%")
ds_map_add(global.text_data_en, "obj_sosorry_312", "\E5Look, stranger/")
ds_map_add(global.text_data_en, "obj_sosorry_313", "\E4I... I guess I'm&going to have to&tell the truth./")
ds_map_add(global.text_data_en, "obj_sosorry_314", "My whole life, I've&never been worth a&lot of EXP./")
ds_map_add(global.text_data_en, "obj_sosorry_315", "Everyone else at my&work, in my classes,/")
ds_map_add(global.text_data_en, "obj_sosorry_316", "Would raise a&person's LV by 4&or 5 when&destroyed.../")
ds_map_add(global.text_data_en, "obj_sosorry_317", "\E1But me?/")
ds_map_add(global.text_data_en, "obj_sosorry_318", "\E6I wouldn't even&increase your LV&at LV 1./")
ds_map_add(global.text_data_en, "obj_sosorry_319", "\E4For this reason...&I...&I've always been.../")
ds_map_add(global.text_data_en, "obj_sosorry_320", "I've never been&very good at&getting killed.&So.../")
ds_map_add(global.text_data_en, "obj_sosorry_321", "\E3I'm flattered&that you...&Want to destroy me./")
ds_map_add(global.text_data_en, "obj_sosorry_322", "\E8But you are making&a big waste of&your time!!/")
ds_map_add(global.text_data_en, "obj_sosorry_323", "\E8Stop killing me!!!/%%")
ds_map_add(global.text_data_en, "obj_sosorry_328", "\E2OK, OK. Hm./")
ds_map_add(global.text_data_en, "obj_sosorry_329", ".../")
ds_map_add(global.text_data_en, "obj_sosorry_330", "\E7If you stop killing&me, I'll pay you&200G./%%")
ds_map_add(global.text_data_en, "obj_sosorry_335", "\E8220G?/%%")
ds_map_add(global.text_data_en, "obj_sosorry_340", "\E9.../")
ds_map_add(global.text_data_en, "obj_sosorry_341", "\E8300G?/%%")
ds_map_add(global.text_data_en, "obj_sosorry_346", "\E1W..^1.&Wait a second./")
ds_map_add(global.text_data_en, "obj_sosorry_347", "\E1You trying to&kill me...&C...&could it be...?/")
ds_map_add(global.text_data_en, "obj_sosorry_348", "\E6Because you&don't like me&very much...?/")
ds_map_add(global.text_data_en, "obj_sosorry_349", "\E2No, no, that&can't be!/")
ds_map_add(global.text_data_en, "obj_sosorry_350", "This is just a&friendly, um,&killing between&acquaintances!!!/")
ds_map_add(global.text_data_en, "obj_sosorry_351", "\E8Pals... we're...&we're still pals,&right!!/")
ds_map_add(global.text_data_en, "obj_sosorry_352", "\E1OK, maybe not&PALS, but, uh,/")
ds_map_add(global.text_data_en, "obj_sosorry_353", "\E2Friendly strangers?/")
ds_map_add(global.text_data_en, "obj_sosorry_354", "\E8You know, just&one step away from&being buds!!!/")
ds_map_add(global.text_data_en, "obj_sosorry_355", "\E0I mean, I was&practically.../")
ds_map_add(global.text_data_en, "obj_sosorry_356", "\E0I was about to&crack open the&sparkling cider!/")
ds_map_add(global.text_data_en, "obj_sosorry_357", "\E2Pull out some&baguettes and some&swiss cheese!/")
ds_map_add(global.text_data_en, "obj_sosorry_358", "\E8BLOW ON A FREAKING&PARTY HORN!!!/%%")
ds_map_add(global.text_data_en, "obj_sosorry_363", "\E1N... no, you don't&like me either,&huh...?/")
ds_map_add(global.text_data_en, "obj_sosorry_364", "\E4Nobody likes me...&they're just putting&up with me/")
ds_map_add(global.text_data_en, "obj_sosorry_365", "\E6I'm just annoying&you... I should just&leave/")
ds_map_add(global.text_data_en, "obj_sosorry_366", "\E1ARRRRRGHHHH!!!&Why am I such an&idiot??!?!!!!/")
ds_map_add(global.text_data_en, "obj_sosorry_367", "How did I not&see it before!!!/")
ds_map_add(global.text_data_en, "obj_sosorry_368", "\E1You weren't killing&me because you&LIKED me!!!/")
ds_map_add(global.text_data_en, "obj_sosorry_369", "\E6NOBODY does that!/")
ds_map_add(global.text_data_en, "obj_sosorry_370", " That's NOT a thing!/%%")
ds_map_add(global.text_data_en, "obj_sosorry_376", "\E2Oh. Sorry. I was&being too loud.&Ugh./")
ds_map_add(global.text_data_en, "obj_sosorry_377", "\E4I'm wasting your&time, aren't I...?/")
ds_map_add(global.text_data_en, "obj_sosorry_378", "\E9.../")
ds_map_add(global.text_data_en, "obj_sosorry_379", "\E1... whew, I feel&really...&strange./")
ds_map_add(global.text_data_en, "obj_sosorry_380", "\E2I think I need to&go home and lie&down./%%")
ds_map_add(global.text_data_en, "obj_sosorry_392", "\E1Oh, I'm so sorry!&How clumsy of me...&I've bumped into you/")
ds_map_add(global.text_data_en, "obj_sosorry_393", "\E6I'm such a klutz./")
ds_map_add(global.text_data_en, "obj_sosorry_394", "I was just here to&find something to&draw, and.../")
ds_map_add(global.text_data_en, "obj_sosorry_395", "\E2Oh no, it's ok!&It's OK!/")
ds_map_add(global.text_data_en, "obj_sosorry_396", "\E0I'll give you a&gift to make up&for your troubles./")
ds_map_add(global.text_data_en, "obj_sosorry_397", "\E0Let me look in&my vest!/%%")
ds_map_add(global.text_data_en, "obj_sosorry_402", "\E6Ummm, I couldn't&find anything I&want to give away./")
ds_map_add(global.text_data_en, "obj_sosorry_403", "\E2Wait, wait!/")
ds_map_add(global.text_data_en, "obj_sosorry_404", "\M4I've got my notebook!/")
ds_map_add(global.text_data_en, "obj_sosorry_405", "\E0I can draw you a&picture in it!/")
ds_map_add(global.text_data_en, "obj_sosorry_406", "\E7I'm quite the artist,&you know./")
ds_map_add(global.text_data_en, "obj_sosorry_407", "\E8I'll draw you a&GREAT picture!!!/%%")
ds_map_add(global.text_data_en, "obj_sosorry_413", "\E6S.. sorry...&The drawing didn't&come out very well./")
ds_map_add(global.text_data_en, "obj_sosorry_414", "\E2Wait^1!&I know the problem!/")
ds_map_add(global.text_data_en, "obj_sosorry_415", "\M0I just have to&find a better piece&of paper for it!/%%")
ds_map_add(global.text_data_en, "obj_sosorry_420", "\E6None of my papers&are good enough to&use.../")
ds_map_add(global.text_data_en, "obj_sosorry_421", "\E2IT'S OK!!!/")
ds_map_add(global.text_data_en, "obj_sosorry_422", "\E8I know what I&can do!^1!&I'll use my magic&pencil!/")
ds_map_add(global.text_data_en, "obj_sosorry_423", "\E0It has to be under&some of these papers&somewhere!!!!/%%")
ds_map_add(global.text_data_en, "obj_sosorry_429", "\E1AHHHHH!!!/%%")
ds_map_add(global.text_data_en, "obj_sosorry_434", "\M5H\E8ere!&I got it!/")
ds_map_add(global.text_data_en, "obj_sosorry_435", "My magic pencil is&amazing!/")
ds_map_add(global.text_data_en, "obj_sosorry_436", "\E2Everything I draw&with it looks.../")
ds_map_add(global.text_data_en, "obj_sosorry_437", "\E8COMPLETELY REAL!/%%")
ds_map_add(global.text_data_en, "obj_sosorry_445", "\E1I've messed up.&I've really messed up.&Oh no./")
ds_map_add(global.text_data_en, "obj_sosorry_446", "\E2I'll just use a&regular pencil!&I'll try my best!/%%")
ds_map_add(global.text_data_en, "obj_sosorry_453", "\E8Are you ready!?/")
ds_map_add(global.text_data_en, "obj_sosorry_454", "\E0I just finished./")
ds_map_add(global.text_data_en, "obj_sosorry_455", "\M6Here's your picture!&What do you think!?/")
ds_map_add(global.text_data_en, "obj_sosorry_456", "\E2It's a representation&of your deepest&essence.../")
ds_map_add(global.text_data_en, "obj_sosorry_457", "\E7It's great^1, right!?/")
ds_map_add(global.text_data_en, "obj_sosorry_458", ".../")
ds_map_add(global.text_data_en, "obj_sosorry_459", "\E8(They think my art&is terrible.)/")
ds_map_add(global.text_data_en, "obj_sosorry_460", "\M0Well!/")
ds_map_add(global.text_data_en, "obj_sosorry_461", "\E2I'll leave you with&that thought!/")
ds_map_add(global.text_data_en, "obj_sosorry_462", "\E7Goodbye!/")
ds_map_add(global.text_data_en, "obj_sosorry_463", "\E8See you later!/")
ds_map_add(global.text_data_en, "obj_sosorry_464", "\E2Sayonara!/")
ds_map_add(global.text_data_en, "obj_sosorry_465", "\E1Nice knowing ya!/")
ds_map_add(global.text_data_en, "obj_sosorry_466", "\E7Hasta la vista./")
ds_map_add(global.text_data_en, "obj_sosorry_467", "\E9.../")
ds_map_add(global.text_data_en, "obj_sosorry_468", "\E2I should leave./%%")
ds_map_add(global.text_data_en, "obj_sosorry_785", "* The enemy looks nervous.")
ds_map_add(global.text_data_en, "obj_sosorry_786", "* The enemy looks anxious.")
ds_map_add(global.text_data_en, "obj_sosorry_787", "* The enemy taps his fingers&  together like jackhammers.")
ds_map_add(global.text_data_en, "obj_sosorry_788", "* The enemy looks perturbed.")
ds_map_add(global.text_data_en, "obj_sosorry_789", "* The enemy tries to copy your&  movements so it fits in.")
ds_map_add(global.text_data_en, "obj_sosorry_790", "* The enemy uses a hypnotizing&  3D-tush-wiggle attack.")
ds_map_add(global.text_data_en, "obj_sosorry_791", "* Smells... furry.")
ds_map_add(global.text_data_en, "obj_sosorry_792", "* Are we good here!?.")
ds_map_add(global.text_data_en, "obj_sosorry_793", "* The enemy is apologizing to&  its visions of the Reaper.")
ds_map_add(global.text_data_en, "obj_sosorry_826", "* SO SORRY&* This creature is definitely&  in the wrong time and space!/^")
ds_map_add(global.text_data_en, "obj_sosorry_838", "* You wave^1.&* They're a bit preoccupied./^")
ds_map_add(global.text_data_en, "obj_sosorry_841", "* You say hello^1.&* They're a bit preoccupied./^")
ds_map_add(global.text_data_en, "obj_sosorry_844", "* You smile^1.&* They're a bit preoccupied./^")
ds_map_add(global.text_data_en, "obj_sosorry_847", "* You cough^1.&* They're a bit preoccupied./^")
ds_map_add(global.text_data_en, "obj_sosorry_850", "* You weep^1.&* They're a bit preoccupied./^")
ds_map_add(global.text_data_en, "obj_sosorry_950", "\E0Oh^1, and.../")
ds_map_add(global.text_data_en, "obj_sosorry_951", "\E1About all this./")
ds_map_add(global.text_data_en, "obj_sosorry_952", "\E4Um./")
ds_map_add(global.text_data_en, "obj_sosorry_953", "\E2Sorry./%%")
ds_map_add(global.text_data_en, "obj_sosorry_1007", "\E1Uuuuhhhh, oh no!!&That's a little too&real!/%%")
ds_map_add(global.text_data_en, "obj_spaghetti_98", "* (To talerz zamrożonego&  spaghetti.)/")
ds_map_add(global.text_data_en, "obj_spaghetti_99", "* (Jest tak zimne^1, że przykleiło&  się do stołu...)/%%")
ds_map_add(global.text_data_en, "obj_spaghetti_102", "* (To talerz letniego&  spaghetti.)/")
ds_map_add(global.text_data_en, "obj_spaghetti_103", "* (Wydaje się^1, e coś&  spróbowało to zjeśc i..^1.)&* (Poddało się.)/%%")
ds_map_add(global.text_data_en, "obj_spagnot_98", "* To notatka od Papyrusa.../")
ds_map_add(global.text_data_en, "obj_spagnot_99", "\TP %")
ds_map_add(global.text_data_en, "obj_spagnot_100", "CZŁOWIEKU!^1!&ŻYCZĘ CI&SMACZNEGO SPAGHETTI./")
ds_map_add(global.text_data_en, "obj_spagnot_101", "(NIE WIEDZIAŁEŚ^1,ŻE&TO SPAGHETTI TO&PUŁAPKA...)/")
ds_map_add(global.text_data_en, "obj_spagnot_102", "(STWORZONA^1, BY&CIĘ SKUSIĆ!!!)/")
ds_map_add(global.text_data_en, "obj_spagnot_103", "(BĘDZIESZ TAK ZAJĘTY&JEDZENIEM GO...)/")
ds_map_add(global.text_data_en, "obj_spagnot_104", "(ŻE NIE ZDASZ SOBIE&SPRAWY^1, ŻE NIE ROBISZ&ŻADNEGO PROGRESU!!)/")
ds_map_add(global.text_data_en, "obj_spagnot_105", "(UGOTOWANE PRZEZ&WIELKIEGO PAPURUSA!!!)/")
ds_map_add(global.text_data_en, "obj_spagnot_106", " &      NYEH-HEH-HEH^1,&          PAPYRUS/%%")
ds_map_add(global.text_data_en, "obj_spagnot_110", "* To notatka od Papyrusa.../")
ds_map_add(global.text_data_en, "obj_spagnot_111", "\TP %")
ds_map_add(global.text_data_en, "obj_spagnot_112", "WIDZĄC^1, ŻE&SPAGHETTI NADAL&SIĘ TU ZNAJDUJE.../")
ds_map_add(global.text_data_en, "obj_spagnot_113", "HOJNIE ROZDAJĘ TO&PUBLICZNOŚCI./")
ds_map_add(global.text_data_en, "obj_spagnot_114", "TO JEST JAK&PLAC ZABAW DLA&TWOJEJ BUZI!/")
ds_map_add(global.text_data_en, "obj_spagnot_115", " &      NYEH-HEH-HEH^1,&          PAPYRUS/%%")
ds_map_add(global.text_data_en, "obj_spagnot_120", "* To jest tak nieczytelne^1,& że tylko kurczak jest w&  stanie to rozczytać./%%")
ds_map_add(global.text_data_en, "obj_spagnot_124", "CO!^1?&TO NIEMOŻLIWE./%%")
ds_map_add(global.text_data_en, "obj_spagnot_127", "SORKI^1, MUSZĘ CIĘ ZAMKNĄĆ&W GARAŻU DOPÓKI UNDYNE&SIĘ NIE ZJAWI./")
ds_map_add(global.text_data_en, "obj_spagnot_128", "CZUJ SIĘ JAK&U SIEBIE!!!/")
ds_map_add(global.text_data_en, "obj_spagnot_129", "POMIESZCZENIE JEST&ZAOPATRZONE W&RÓŻNE PRZEKĄSKI./")
ds_map_add(global.text_data_en, "obj_spagnot_130", " & - NYEHOWO TWÓJ^1,&      PAPYRUS/%%")
ds_map_add(global.text_data_en, "obj_spagnot_134", "PROSZĘ SPYTAĆ^1,&ZANIM UCIEKNIESZ!!!/")
ds_map_add(global.text_data_en, "obj_spagnot_135", "KIEDY SIĘ ZGUBIŁEŚ&BYŁEM BARDZO&ZMARTWIONY!!!/")
ds_map_add(global.text_data_en, "obj_spagnot_136", "  - TROCHĘ POWIKŁANY^1,&         PAPYRUS/%%")
ds_map_add(global.text_data_en, "obj_spagnot_140", "JEŚLI PO PROSTU&SZUKASZ MIEJSCA DO&ZATRZYMAJIA SIĘ.../")
ds_map_add(global.text_data_en, "obj_spagnot_141", "PO PROSTU SPYTAJ!!^1!&NIE MUSISZ ZE&MNĄ WALCZYĆ!!!/")
ds_map_add(global.text_data_en, "obj_spagnot_142", " & - TWÓJ GOSPODARZ^1,&       PAPYRUS/%%")
ds_map_add(global.text_data_en, "obj_spagnot_147", "* (Ta notatka jest pisana^1,&  jakby papier się ruszał&  w trakcie pisania.)/")
ds_map_add(global.text_data_en, "obj_spagnot_148", "* (Pisze...^1)&* (Na przerwie&  obiadowej...?)/%%")
ds_map_add(global.text_data_en, "obj_spagnot_153", "* (Strzel w drugi statek!^1)&* (Ruszaj pudłami^1, by&  dokonać misję.)/%%")
ds_map_add(global.text_data_en, "obj_spagnot_158", "* (Strzel w drugi statek!^1)&* (Masz jeden nabój.)/%%")
ds_map_add(global.text_data_en, "obj_spagnot_163", "* (Hej^1!)/")
ds_map_add(global.text_data_en, "obj_spagnot_164", "* (Idź do tej mrocznej&  alejki po prawej po&  świetne oferty!)/%%")
ds_map_add(global.text_data_en, "obj_spiderb_220", "Co tam,&słonko?/%%")
ds_map_add(global.text_data_en, "obj_spiderb_224", ".../%%")
ds_map_add(global.text_data_en, "obj_spiderb_225", "Nie, nie,&czas już&wracać~/%%")
ds_map_add(global.text_data_en, "obj_spiderb_226", "...&cóż... może&JEDEN mały&dziab~~/%%")
ds_map_add(global.text_data_en, "obj_spiderb_227", "Taki żarcik,&oczywiście~/%%")
ds_map_add(global.text_data_en, "obj_spiderb_228", "Jeśli nie przesz-&kadza ci bycie&pożartym~&Ahuhuhu~/%%")
ds_map_add(global.text_data_en, "obj_spiderb_229", "Ahuhuhuhu~&Cóż, nie mam&nic przeciwko&twojej gościnie~/%%")
ds_map_add(global.text_data_en, "obj_spiderb_230", "Wygodnie ci&uwięziony w tej&pajęczynie?/%%")
ds_map_add(global.text_data_en, "obj_spiderb_231", "Czas już iść~/%%")
ds_map_add(global.text_data_en, "obj_spiderb_232", "Ahuhuhu~&Co ty&robisz~/%%")
ds_map_add(global.text_data_en, "obj_spiderb_236", "%%%")
ds_map_add(global.text_data_en, "obj_spiderb_240", "Czemu taki blady?&Powinieneś być z&siebie dumny~/%%")
ds_map_add(global.text_data_en, "obj_spiderb_245", "Dumny z tego, że&będzie z ciebie&przepyszne ciasto~&Ahuhuhu~/%%")
ds_map_add(global.text_data_en, "obj_spiderb_250", "Wypuścić cię^1?&Nie bądź&śmieszny~/%%")
ds_map_add(global.text_data_en, "obj_spiderb_255", "Twoja DUSZA uczyni&każdego pajączka&szczęśliwym~~~/%%")
ds_map_add(global.text_data_en, "obj_spiderb_256", "Odstraszasz moich&jedynych klientów!/%%")
ds_map_add(global.text_data_en, "obj_spiderb_261", "Oh, jakie niemiłe!&Prawie zapomniałam&przedstawić cię&mojemu zwierzakowi~/")
ds_map_add(global.text_data_en, "obj_spiderb_262", "Pora na śniadanie,&czyż nie? Bawcie&się dobrze~ /%%")
ds_map_add(global.text_data_en, "obj_spiderb_267", "Osoba, która&nas ostrzegała&przed tobą.../%%")
ds_map_add(global.text_data_en, "obj_spiderb_272", "Zaoferowała nam&DUŻO pieniędzy&za twoją DUSZĘ./%%")
ds_map_add(global.text_data_en, "obj_spiderb_273", "Wyglądała na&totalnego nerda./%%")
ds_map_add(global.text_data_en, "obj_spiderb_278", "Miała taki uroczy&uśmiech~ i... ahuhu~/%%")
ds_map_add(global.text_data_en, "obj_spiderb_279", "Mocno nalegała,&abym z nią&uciekła~~~&Ahuhuhu~~~/%%")
ds_map_add(global.text_data_en, "obj_spiderb_284", "To dziwne, ale&przysięgam, że&widziałam jej cień...&Zmieniający kształt...?/%%")
ds_map_add(global.text_data_en, "obj_spiderb_285", "Zostawiła mi nawet&kierunki gdzie mam&się przenieść~/%%")
ds_map_add(global.text_data_en, "obj_spiderb_291", "Oh, czas na lunch,&czyż nie? Zapomniałam&też nakarmić mojego&zwierzaczka~/%%")
ds_map_add(global.text_data_en, "obj_spiderb_296", "Z tymi pieniędzmi,&klan pająków w końcu&zostanie zjednoczony~/%%")
ds_map_add(global.text_data_en, "obj_spiderb_297", "Powiedziała że ona&zablokuje resztę&Hotlandu jak ja z&nią pójdę~/%%")
ds_map_add(global.text_data_en, "obj_spiderb_302", "Nie słyszałaś, że&pająki były uwięzione&w RUINACH od wieków?/%%")
ds_map_add(global.text_data_en, "obj_spiderb_303", "Jaka frajerka~&Pająki NIGDY nie&opuszczają swojej&sieci~/")
ds_map_add(global.text_data_en, "obj_spiderb_304", "(Z wyjątkiem kiedy&sprzedaje wypieki~)/%%")
ds_map_add(global.text_data_en, "obj_spiderb_309", "Nawet jeśli one się&prześlizgną pod drzwi,&fatalny chłód Snowdina&jest nie do zniesienia./%%")
ds_map_add(global.text_data_en, "obj_spiderb_310", "Ah^1, chociaż teraz&zaczynam troszeczkę&tego żałować.../%%")
ds_map_add(global.text_data_en, "obj_spiderb_315", "Ale z pieniędzmi za&twoją DUSZĘ, w końcu&będziemy w stanie&wukupić grzejnik~/%%")
ds_map_add(global.text_data_en, "obj_spiderb_316", "Tak^1, powinnam była&ją owinąć pajęczyną&kiedy miałam okazję~/%%")
ds_map_add(global.text_data_en, "obj_spiderb_321", "I z wszystkimi&resztkami...^1?&Moglibyśmy mieć&miłe wakacje~/")
ds_map_add(global.text_data_en, "obj_spiderb_322", "Albo nawet zbudować&pole bejsbolowe&dla pająków~/%%")
ds_map_add(global.text_data_en, "obj_spiderb_323", "Wyglądała jakby&była składnikiem&na soczystego&pączka z dżemem~~~/%%")
ds_map_add(global.text_data_en, "obj_spiderb_328", "Ale wystarczy gadki...&Nadszedł już czas&na obiad, czyż nie?&Ahuhuhu~/%%")
ds_map_add(global.text_data_en, "obj_spiderb_336", "Nie bądź taki&przygnębiony^1,&słońce~/%%")
ds_map_add(global.text_data_en, "obj_spiderb_599", "* Muffet leje ci filiżankę&  pająków.")
ds_map_add(global.text_data_en, "obj_spiderb_600", "* Wszystkie pająki klaszczą&  do muzyki.")
ds_map_add(global.text_data_en, "obj_spiderb_601", "* Muffet robi synchroniczną&  balladę z innymi pająkami.")
ds_map_add(global.text_data_en, "obj_spiderb_602", "* Muffet czyści pajęczyny&  wokół ciebie.")
ds_map_add(global.text_data_en, "obj_spiderb_603", "* Pachnie jak świeżo wypiekane&  pajęczyny.")
ds_map_add(global.text_data_en, "obj_spiderb_636", "* MUFFET - ATK 38.8 DEF 18.8&* Jeśli cię zaprosi na podwie-&  czorek^1, wymigaj się z tego./^")
ds_map_add(global.text_data_en, "obj_spiderb_646", "* Próbujesz wyrwać się z sieci^1.&* Bez efektu./^")
ds_map_add(global.text_data_en, "obj_spiderb_647", "* Próbujesz wyrwać się z sieci^1.&* Muffet zakrywa usta i&  chichocze na twój widok./^")
ds_map_add(global.text_data_en, "obj_spiderb_648", "* Próbujesz wyrwać się z sieci^1.&* Muffet śmieje się i klaszcze&  dłońmi./^")
ds_map_add(global.text_data_en, "obj_spiderb_649", "* Próbujesz wydostać się z sieci./")
ds_map_add(global.text_data_en, "obj_spiderb_650", "* Muffet jest tak zachwycona&  twoimi antykami, że daje ci&  sympatyczną zniżkę!/^")
ds_map_add(global.text_data_en, "obj_spiderb_656", "* Próbujesz wyrwać się z sieci^1.&* Bez efektu./^")
ds_map_add(global.text_data_en, "obj_spiderb_678", "* Płacisz \[1]G^1.&* Muffet redukuje jej ATAK&  na tą kolejkę!/^")
ds_map_add(global.text_data_en, "obj_spiderb_693", "* Opróżniasz kieszenie^1, ale nie&  miałeś wystarczająco pieniędzy.&* Muffet obniża cenę./^")
ds_map_add(global.text_data_en, "obj_spiderb_710", "* Wyskoczyłeś z kasy^1.&* Muffet kręci głową,&  zawiedziona./^")
ds_map_add(global.text_data_en, "obj_spiderb_714", "* Opróżniasz kieszenie..^1.&* Ale nie masz ani grosza!/")
ds_map_add(global.text_data_en, "obj_spiderb_715", "* Muffet żali się nad tobą i&  redukuje jej ATAK na tą&  kolejkę./^")
ds_map_add(global.text_data_en, "obj_spiderb_722", "* Muffet odmawia twoich&  pieniędzy./^")
ds_map_add(global.text_data_en, "obj_spiderb_762", "... Myślę, że&fioletowy lepiej&ci leży! Ahuhuhu~/%%")
ds_map_add(global.text_data_en, "obj_spiderb_774", "* Jesteś uwięziony w dziwnej&  fioletowej pajęczynie!")
ds_map_add(global.text_data_en, "obj_spiderb_783", "Jeszcze żyjesz^1?&Ahuhuhu~/")
ds_map_add(global.text_data_en, "obj_spiderb_784", "Oh, zwierzaczku~&Chyba jest pora&na deserek~/%%")
ds_map_add(global.text_data_en, "obj_spiderb_787", "Huh^1?&Gdzie ty to&zdobyłeś...?/")
ds_map_add(global.text_data_en, "obj_spiderb_788", "Ukradłeś to?/")
ds_map_add(global.text_data_en, "obj_spiderb_789", "Oh^1, zwierzaczku^1~&Czas mu pokazać&co się robi ze&złodziejaszkami~/%%")
ds_map_add(global.text_data_en, "obj_spiderb_805", "Hę?&Telegramik od&pajączków z RUIN?/")
ds_map_add(global.text_data_en, "obj_spiderb_806", "Co?&Mówią, że&widzieli cię&tam, i.../")
ds_map_add(global.text_data_en, "obj_spiderb_807", "... error bepis&kutas cycki!?/")
ds_map_add(global.text_data_en, "obj_spiderb_811", "... nawet jeśli&śmierdzisz, to ty&nigdy nie skrzyw-&dziłeś pajączka!/")
ds_map_add(global.text_data_en, "obj_spiderb_814", "... nawet jeśli&raniłeś innych,&nigdy nie skrzyw-&dziłeś pajączka!/")
ds_map_add(global.text_data_en, "obj_spiderb_819", "... pomogłeś&wesprzeć w&fundacji!/")
ds_map_add(global.text_data_en, "obj_spiderb_823", "... byłeś wielkim&pasjonatem naszych&pajączków!/")
ds_map_add(global.text_data_en, "obj_spiderb_827", "... jesteś wielkim&fanatykiem pająków!/")
ds_map_add(global.text_data_en, "obj_spiderb_832", "Mówią, że nawet&jeśli jesteś hiper-&złowieszczym&mordercą.../")
ds_map_add(global.text_data_en, "obj_spiderb_833", "To nigdy nie&uniosłeś ręki&na pajączka!/")
ds_map_add(global.text_data_en, "obj_spiderb_836", "O jejku, to było&jedno wielkie&nieporozumienie~/")
ds_map_add(global.text_data_en, "obj_spiderb_837", "Myślałam, że&tyś osobą, która&nienawidzi&pajączków~/")
ds_map_add(global.text_data_en, "obj_spiderb_838", "Ta osoba która&prosiła o tą&DUSZĘ.../")
ds_map_add(global.text_data_en, "obj_spiderb_839", "Musiała mówić o&INNYM człowieku&w pasiastej&koszulce~/")
ds_map_add(global.text_data_en, "obj_spiderb_842", "Osoba, która mnie&ostrzegała przed&tobą.../")
ds_map_add(global.text_data_en, "obj_spiderb_843", "Naprawdę nie miała&pojęcia o czym ona&gadała~/")
ds_map_add(global.text_data_en, "obj_spiderb_846", "Przepraszam&za to całe&zamieszanie~&Ahuhuhu~/")
ds_map_add(global.text_data_en, "obj_spiderb_847", "Postaram się&tobie to&wynagrodzić~/")
ds_map_add(global.text_data_en, "obj_spiderb_848", "Możesz powrócic&kiedy chcesz...&Oraz, bez obcią-&żenia podatku.../")
ds_map_add(global.text_data_en, "obj_spiderb_849", "Owinę cię i&pozwolę pobawić&znów z moim&zwierzaczkiem!/")
ds_map_add(global.text_data_en, "obj_spiderb_850", "Ahuhuhuhuhuhu~&Tylko żartuję~/")
ds_map_add(global.text_data_en, "obj_spiderb_851", "OCZCZĘDZĘ&cię teraz~/%%")
ds_map_add(global.text_data_en, "obj_spiderb_859", "* Muffet cię oszczędza.")
ds_map_add(global.text_data_en, "obj_spidergirl_shop_74", "* Witaj w naszym wypieku^1, słonko^1~&* Zainteresowany świeżościami&  lokalnych pająków?/")
ds_map_add(global.text_data_en, "obj_spidergirl_shop_75", "* Wszystkie wpłaty przekazywane&  są prawdziwym pająkom~/%%")
ds_map_add(global.text_data_en, "obj_spidergirl_shop_76", "* Zbadaj pajęczyny aby dokonać&  zakupu~/%%")
ds_map_add(global.text_data_en, "obj_spidertalkevent_103", "* Ahuhuhuhu.../")
ds_map_add(global.text_data_en, "obj_spidertalkevent_104", "* Słyszeliście co on&  powiedział?/%%")
ds_map_add(global.text_data_en, "obj_spidertalkevent_106", "* Słyszeliście co ona&  powiedziała?/%%")
ds_map_add(global.text_data_en, "obj_spidertalkevent_114", "* Mówią że człowiek w pasiastej&  koszulce będzie przechodził./%%")
ds_map_add(global.text_data_en, "obj_spidertalkevent_122", "* Słyszałam, że nienawidzi&  pająków./%%")
ds_map_add(global.text_data_en, "obj_spidertalkevent_130", "* Słyszałam, że on kocha po&  nich stompać./%%")
ds_map_add(global.text_data_en, "obj_spidertalkevent_132", "* Słyszałam, że on nienawidzi&  wszystkich i wszystko./%%")
ds_map_add(global.text_data_en, "obj_spidertalkevent_140", "* Słyszałam, że on kocha im&  odrywać kończyny./%%")
ds_map_add(global.text_data_en, "obj_spidertalkevent_149", "* Słyszałam.../%%")
ds_map_add(global.text_data_en, "obj_spidertalkevent_152", "* Jednak.../%%")
ds_map_add(global.text_data_en, "obj_spidertalkevent_154", "* I nawet jeśli on dawał nam&  pieniądze^1, to słyszałam.../%%")
ds_map_add(global.text_data_en, "obj_spidertalkevent_267", "* ... że jest okropnie skromny&  ze swoimi pieniędzmi./")
ds_map_add(global.text_data_en, "obj_spidertalkevent_271", "* ... że pewien cuchnący człowiek&  aktywnie nienawidzi pająków./%%")
ds_map_add(global.text_data_en, "obj_spidertalkevent_273", "* Ahuhuhuhu.../")
ds_map_add(global.text_data_en, "obj_spidertalkevent_274", "* Uważasz swój gust kulinarny&  za zbyt wysoki jak na nasze&  wypieki^1, czyż nie^1, słonko?/")
ds_map_add(global.text_data_en, "obj_spidertalkevent_275", "* Ahuhuhu..^1.&* Nie zgadzam się z tym./")
ds_map_add(global.text_data_en, "obj_spidertalkevent_276", "* Myślę, że twój smak.../")
ds_map_add(global.text_data_en, "obj_spidertalkevent_277", "* Jest w sam raz do naszego&  nowego wypieku!/%%")
ds_map_add(global.text_data_en, "obj_spidertalkevent_283", "* ... to nie może być prawdą^1,&  prawda?/")
ds_map_add(global.text_data_en, "obj_spidertalkevent_284", "* Ahuhuhu.../")
ds_map_add(global.text_data_en, "obj_spidertalkevent_285", "* Przekazałeś nam tak dużo&  pieniędzy./")
ds_map_add(global.text_data_en, "obj_spidertalkevent_286", "* Wszystkie pająki chcą ci&  przekazać^1, jacy są wdzięczni!/")
ds_map_add(global.text_data_en, "obj_spidertalkevent_287", "* Jesteśmy ci wiecznie&  wdzięczni^1, słonko~/%%")
ds_map_add(global.text_data_en, "obj_spidertalkevent_293", "* ... że on ma okropny smak./")
ds_map_add(global.text_data_en, "obj_spidertalkevent_294", "* Jaka szkoda^1.&* Człowiek tędy przechodzi, a&  nie jest nawet dobry w smaku~/")
ds_map_add(global.text_data_en, "obj_spidertalkevent_295", "* No cóż^1!&* Zgniłe składniki się po&  prostu wyrzuca do kosza~/%%")
ds_map_add(global.text_data_en, "obj_spidertalkevent_392", "* Ahuhuhuhu.../")
ds_map_add(global.text_data_en, "obj_spidertalkevent_393", "* Ale zabawa^1!&* Widzimy się&  później^1, słonko!/%%")
ds_map_add(global.text_data_en, "obj_stick_95", "* (To ciężko-wyglądająca gałąź.)&* (Jest zbyt ciężka^1, by&  ją podnieść.)/%%")
ds_map_add(global.text_data_en, "obj_stick_99", "* (Zostało rozmiażdzone jakby&  było niczym...)/%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_295", "A long time ago,&a human fell&into the RUINS./*")
ds_map_add(global.text_data_en, "obj_storybattle_gen_307", "Injured by its&fall, the human&called out for&help./%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_333", "ASRIEL^1, the king's&son^1, heard the&human's call./*")
ds_map_add(global.text_data_en, "obj_storybattle_gen_345", "He brought the&human back to&the castle./%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_370", "Over time^1, ASRIEL&and the human&became like&siblings./*")
ds_map_add(global.text_data_en, "obj_storybattle_gen_383", "The King and&Queen treated the&human child as&their own./*")
ds_map_add(global.text_data_en, "obj_storybattle_gen_395", "The underground&was full of&hope./%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_421", "Then..^1.&One day.../*")
ds_map_add(global.text_data_en, "obj_storybattle_gen_433", "The human became&very ill./%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_459", "The sick human&had only one&request./*")
ds_map_add(global.text_data_en, "obj_storybattle_gen_472", "To see the&flowers from&their village./*")
ds_map_add(global.text_data_en, "obj_storybattle_gen_484", "But there was&nothing we could&do./%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_511", "The next day./*")
ds_map_add(global.text_data_en, "obj_storybattle_gen_523", "The next day./%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_546", ".../* ")
ds_map_add(global.text_data_en, "obj_storybattle_gen_558", "The human died./%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_583", "ASRIEL^1, wracked&with grief^1,&absorbed the&human's SOUL./*")
ds_map_add(global.text_data_en, "obj_storybattle_gen_594", "He transformed&into a being&with incredible&power./%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_609", "With the human&SOUL^1, ASRIEL&crossed through&the barrier./*")
ds_map_add(global.text_data_en, "obj_storybattle_gen_622", "He carried the&human's body&into the sunset./*")
ds_map_add(global.text_data_en, "obj_storybattle_gen_634", "Back to the&village of the&humans./%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_649", "ASRIEL reached&the center of&the village./*")
ds_map_add(global.text_data_en, "obj_storybattle_gen_662", "There^1, he&found a bed of&golden flowers./*")
ds_map_add(global.text_data_en, "obj_storybattle_gen_674", "He carried&the human&onto it./%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_689", "Suddenly^1, screams&rang out./*")
ds_map_add(global.text_data_en, "obj_storybattle_gen_702", "The villagers&saw ASRIEL&holding the&human's body./*")
ds_map_add(global.text_data_en, "obj_storybattle_gen_714", "They thought&that he had&killed the&child./%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_727", "The humans&attacked him&with everything&they had./*")
ds_map_add(global.text_data_en, "obj_storybattle_gen_740", "He was struck&with blow after&blow./*")
ds_map_add(global.text_data_en, "obj_storybattle_gen_752", "ASRIEL had the&power to destroy&them all./%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_767", "Ale.../*")
ds_map_add(global.text_data_en, "obj_storybattle_gen_778", "ASRIEL did not&fight back./%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_805", "Clutching the&human.../*")
ds_map_add(global.text_data_en, "obj_storybattle_gen_816", "ASRIEL smiled^1,&and walked away./%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_832", "Wounded^1, ASRIEL&stumbled home./*")
ds_map_add(global.text_data_en, "obj_storybattle_gen_845", "He entered the&castle and&collapsed./*")
ds_map_add(global.text_data_en, "obj_storybattle_gen_857", "His dust spread&across the&garden./%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_872", "The kingdom fell&into despair./*")
ds_map_add(global.text_data_en, "obj_storybattle_gen_885", "The king and&queen had lost&two children&in one night./*")
ds_map_add(global.text_data_en, "obj_storybattle_gen_897", "The humans had&once again taken&everything&from us./%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_911", "The king decided&it was time to&end our&suffering./*")
ds_map_add(global.text_data_en, "obj_storybattle_gen_924", "Every human who&falls down here&must die./*")
ds_map_add(global.text_data_en, "obj_storybattle_gen_936", "With enough souls^1,&we can shatter&the barrier&forever./%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_951", "It's not long&now./%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_965", "King ASGORE&will let us&go.   /*")
ds_map_add(global.text_data_en, "obj_storybattle_gen_971", "King ASGORE&will give us&hope./*")
ds_map_add(global.text_data_en, "obj_storybattle_gen_976", "King ASGORE&will save us&all. /%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1004", "You should be&smiling^1, too./*")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1014", "Aren't&you&excited?/*")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1023", "Aren't&you&happy?/%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1047", "You're going&to be free./%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1073", "\E0Howdy^1, \[C]!/")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1074", "You finally made&it home./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1075", "\E0Remember when we&used to play here?/")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1076", "\E0Hee hee hee.../")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1077", "Boy!/")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1078", "\E9Today's gonna be&just as fun./%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1093", "\E1I remember when I&first woke up here^1,&in the garden./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1094", "I was so scared./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1095", "\E2I couldn't feel my&arms or my legs.../")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1096", "\E1My entire body had&turned into a&flower!/")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1097", "\E5" + '"' + "Mom^1! Dad^1!&Somebody help me^1!" + '"' + "&I called out./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1098", "\E9But nobody came./%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1107", "\E1Eventually^1, the king&found me^1, crying in&the garden./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1108", "I explained what had&happened to him./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1109", "Then he held me^1,&\[C]./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1110", "He held me with&tears in his eyes^1,&saying.../")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1111", '"' + "There^1, there^1.&Everything is going&to be alright." + '"' + "/")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1112", "He was so..^1.&Emotional./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1113", "\E1But..^1.&For some reason.../")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1114", "\E1I didn't feel&anything at all./%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1123", "\E1I soon realized I&didn't feel ANYTHING&about ANYONE./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1124", "My compassion had&disappeared!/")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1125", "\E7And believe me^1,&it's not like I&wasn't trying./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1126", "\E3I wasted weeks with&that stupid king^1,&vainly hoping I would&feel something./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1127", "\E1But it became too&much for me./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1128", "I ran away from&home./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1129", "Eventually^1, I reached&the RUINS./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1130", "\E0Inside I found HER^1,&\[C]./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1131", "I thought of all&people^1, SHE could&make me feel whole&again./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1132", "\E1.../")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1133", "\E7She failed./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1134", "\E6Ha ha.../%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1144", "\E1I realized those two&were useless./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1145", "I became despondent./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1146", "I just wanted to&love someone./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1147", "I just wanted to&care about someone./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1148", "\[C]^1, you might&not believe this.../")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1149", "\E2But I decided..^1.&It wasn't worth&living anymore./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1150", "\E7Not in a world&without love./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1151", "\E6Not in a world&without you./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1152", "\E1So.../")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1153", "\E0I decided to follow&in your footsteps./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1154", "\E1I would erase myself&from existence./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1155", "\E1And you know what?/")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1156", "\E0I succeeded./%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1165", "\E1But as I left this&mortal coil.../")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1166", "I started to feel&apprehensive./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1167", "\E9If you don't have&a SOUL^1, what happens&when you...?/")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1168", "\E1Something primal&started to burn&inside me./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1169", '"' + "No^1," + '"' + " I thought^1.&" + '"' + "I don't want to&die!" + '"' + "/")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1170", ".../")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1171", "Then I woke up./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1172", "Like it was all&just a bad dream./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1173", "I was back at the&garden./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1174", "\E0Back at my&" + '"' + "save point." + '"' + "/%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1183", "Interested^1, I decided&to experiment./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1184", "Again and again^1, I&brought myself to&the edge of death./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1185", "At any point^1, I&could have let this&world continue on&without me./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1186", "But as long as I&was determined to&live.../")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1187", "\E0I could go back./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1188", "\E6Amazing^1, isn't it^1,&\[C]?/")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1189", "\E0I was amazed^1, too./%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1197", "\E1At first^1, I used my&powers for good./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1198", "\E0I became " + '"' + "friends" + '"' + "&with everyone./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1199", "I solved all their&problems flawlessly./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1200", "Their companionship&was amusing.../")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1201", "\E1For a while. /")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1202", "\E1As time repeated^1,&people proved&themselves&predictable./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1203", "What would this&person say if I&gave them this?/")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1204", "What would they do&if I said this to&them?/")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1205", "Once you know the&answer^1, that's it./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1206", "That's all they are./%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1217", "\E1It all started&because I was&curious./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1218", "\E0Curious what would&happen if I killed&them./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1219", "\E2" + '"' + "I don't like this^1," + '"' + "&I told myself./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1220", "\E1" + '"' + "I'm just doing this&because I HAVE to&know what happens./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1221", "\E8Ha ha ha..^1.&What an excuse!/")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1222", "\E9You of all people&must know how&liberating it is to&act this way./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1223", "\E8At least we're better&than those sickos&that stand around and&WATCH it happen.../")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1224", "\E9Those pathetic people&that want to see it^1,&but are too weak to&do it themselves./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1225", "\E0I bet someone like&that's watching right&now^1, aren't they...?/%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1235", "\E1Nowadays^1, even that's&grown tiring./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1236", "\E7You understand^1,&\[C]./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1237", "\E6I've done everything&this world has to&offer./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1238", "\E1I've read every book^1.&I've burned every&book./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1239", "I've won every game^1.&I've lost every game./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1240", "I've appeased&everyone^1.&I've killed everyone./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1241", "Sets of numbers..^1.&Lines of dialogue..^1.&I've seen them all./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1242", "\E1But you..^1.&YOU'RE different./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1243", "\E0I never could&predict YOU^1, \[C]./%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1252", "\E1When I saw you in&the RUINS^1, I didn't&recognize you./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1253", "\E8I thought I could&frighten you^1, then&steal your SOUL./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1254", "\E1I failed./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1255", "\E0And when I tried&to load my save&file.../")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1256", "\E1It didn't work./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1257", "\E9\[C]..^1.&Your DETERMINATION!/")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1258", "\E8Somehow^1, it's even&greater than mine!/%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1267", "\E1I just have one&question for you^1,&\[C]./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1268", "How did you get&back to the RUINS&from here...?/")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1269", "\E0... wait^1, I know./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1270", "She must have taken&you when she left./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1271", "\E1And decided to give&you a proper burial^1,&rather than.../")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1272", "\E0Hanging out in the&basement forever./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1273", "\E1... but^1, why then...?/")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1274", "What made you wake&up?/")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1275", "\E6Did you hear me&calling you...?/%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1286", "\E1It doesn't matter&now./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1287", "\E1I'm so tired of&this^1, \[C]./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1288", "I'm tired of all&these people./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1289", "I'm tired of all&these places./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1290", "I'm tired of being&a flower./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1291", "\[C]./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1292", "\E0There's just one&thing left I want&to do./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1293", "Let's finish what we&started./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1294", "Let's free everyone./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1295", "\E8Then..^1. let's let&them see what&humanity is&REALLY like!/")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1296", "\E6That despite it all.../")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1297", "\E9This world is still&" + '"' + "kill or be killed!!" + '"' + "/%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1307", "\E1Then...?/")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1308", "\E7Well^1.&I had.../")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1309", "\E9Been entertaining a&few ways to use&that power./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1310", "\E8Hee hee hee.../")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1311", "\E1.../")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1312", "\E1But seeing you here&changed my mind./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1313", "\E6\[C]..^1.&I think if you're&around.../")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1314", "\E7Just living in the&surface world&doesn't seem so bad./%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1324", "\E0We don't even need&to leave to get&them this time./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1325", "The king has six of&them locked away./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1326", "\E1I've tried hundreds&of ways to get him&to show me them.../")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1327", "\E3But he just won't./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1328", "\E1\[C].../")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1329", "\E0I know he'll do it&for YOU./%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1339", "\E0Why am I telling&you all of this?/")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1340", "\E6\[C]^1, I said it&before./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1341", "\E1Even after all this&time.../")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1342", "\E0You're still the&only one that&understands me./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1343", "\E8You won't give me&any worthless pity!/%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1353", "\E9Creatures like us.../")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1354", "\E0Wouldn't hesitate to&KILL each other if&we got in each&other's way./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1355", "\E0So that's.../")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1356", "\E1So..^1. that's..^1.&Why.../%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1383", "\E2.../")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1384", "\E2... ha..^1.&Ha.../")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1385", "\E6... what's this..^1.&... feeling?/")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1386", "Why am I..^1.&Shaking?/")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1387", ".../")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1388", "Hey..^1. \[C]..^1.&No hard feelings about&back then^1, right?/")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1389", ".../")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1390", "\E4H-Hey^1, what are you&doing!?/")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1391", "B..^1. back off!!/%%")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1412", "I..^1. I've changed&my mind about all&this./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1413", "This isn't a good&idea anymore./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1414", "Y-you should go back^1,&\[C]./")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1415", "\E0This place is fine&the way it is!/")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1416", ".../")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1417", "\E4S-s-stop making that&creepy face!/")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1418", "This isn't funny!/")
ds_map_add(global.text_data_en, "obj_storybattle_gen_1419", "You've got a SICK&sense of humor!/%%")
ds_map_add(global.text_data_en, "obj_switch_100", "* (Ta maszyna nie działa.)/%%")
ds_map_add(global.text_data_en, "obj_switchadvice1_61", "* Proszę nacisnąć&ten przycisk. &            - TORIEL/%%")
ds_map_add(global.text_data_en, "obj_switchadvice2_61", "* Proszę nacisnąć również&  ten przycisk.&             - TORIEL/%%")
ds_map_add(global.text_data_en, "obj_switchhelptrigger_69", "* (You noticed there was&  a blue switch behind the&  top pillar.)/%%")
ds_map_add(global.text_data_en, "obj_telescope_71", "* Come on! What are you doing!/%%")
ds_map_add(global.text_data_en, "obj_telescope_75", "* (To dziwnie wyglądający&  teleskop.)/%%")
