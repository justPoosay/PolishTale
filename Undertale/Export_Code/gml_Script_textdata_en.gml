ds_map_add(global.text_data_en, "obj_lastsans_trigger_695", "\E1* to wyraz twarzy kogoś&  kto umarł siedem razy&  z rzędu./")
ds_map_add(global.text_data_en, "obj_lastsans_trigger_696", "\E0* hej^1, dobrze się składa^1.&* siedem to podobno&  szczęśliwa cyferka./")
