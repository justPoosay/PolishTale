ds_map_add(global.text_data_en, "obj_jetpackchara_301", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_jetpackchara_302", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_jetpackchara_303", "* C-co!^1?&* D-dlaczego ty się&  nie r-r-ruszasz?/")
ds_map_add(global.text_data_en, "obj_jetpackchara_304", "* N-nie...^1!&* Musiałam nie zalać&  baku do pełna!/")
ds_map_add(global.text_data_en, "obj_jetpackchara_305", "\E8* K-kurde..^1.&* Przepraszam.../")
ds_map_add(global.text_data_en, "obj_jetpackchara_306", "* Nawet kiedy jest&  coś takiego^1, to.../")
ds_map_add(global.text_data_en, "obj_jetpackchara_307", "* Ja nadal...^1!&* Ja nadal.../%%")
ds_map_add(global.text_data_en, "obj_jetpackchara_324", "* OH NIE^1, SPÓJRZCIE NA TO!/")
ds_map_add(global.text_data_en, "obj_jetpackchara_325", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_jetpackchara_326", "* Co?/")
ds_map_add(global.text_data_en, "obj_jetpackchara_327", "\TS \E0 \F0 \TM %")
ds_map_add(global.text_data_en, "obj_jetpackchara_328", "* ZAPOMNIAŁEM!&* DOSŁOWNIE TERAZ NADSZEDŁ&  CZAS NA NASZE REKLAMY!/")
ds_map_add(global.text_data_en, "obj_jetpackchara_329", "\TS \E3 \F6 \TA %")
ds_map_add(global.text_data_en, "obj_jetpackchara_330", "* C..^1.&* Co ty...%")
ds_map_add(global.text_data_en, "obj_jetpackchara_331", "\TS \E0 \F0 \TM %")
ds_map_add(global.text_data_en, "obj_jetpackchara_332", "* NIEFORTUNNIE, TO OZNACZA ŻE&  NIKT TERAZ TEGO NIE OGLĄDA./")
ds_map_add(global.text_data_en, "obj_jetpackchara_333", "* NIE ZNISZCZĘ CIĘ BEZ&  MOJEJ ŻYWEJ WIDOWNI&  TELEWIZYJNEJ!!/")
