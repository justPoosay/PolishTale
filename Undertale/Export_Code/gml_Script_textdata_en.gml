ds_map_add(global.text_data_en, "obj_muffetnpc2_75", "* Tutaj jesteś^1, słodziaku^1.&* Jesteś zawsze mile widziany&  w moim salonie!/")
ds_map_add(global.text_data_en, "obj_muffetnpc2_76", "* Tylko zachowuj się dobrze^1~&* Ueee hee hee hee~/%%")
ds_map_add(global.text_data_en, "obj_muffetnpc2_81", "* Bonjour^1, słodziaku^1~&* Właśnie skończyłam liczyć&  wszystkie twoje donacje!/")
ds_map_add(global.text_data_en, "obj_muffetnpc2_82", "* W końcu mamy wystarczająco&  pieniędzy by uratować&  wszystkie pajączki w RUINACH./")
ds_map_add(global.text_data_en, "obj_muffetnpc2_83", "* A także wreszcie będzie&  nas stać na...!/")
ds_map_add(global.text_data_en, "obj_muffetnpc2_84", "* ... nic^1, ponieważ my&  tylko sprzedaliśmy&  jednego pączka./")
ds_map_add(global.text_data_en, "obj_muffetnpc2_85", "* Co jest nie tak z wszystkimi^1?&* Czy oni nie lubią pająków~/%%")
ds_map_add(global.text_data_en, "obj_muffetnpc2_87", "* 4 pary stylowych okularów&  przeciwsłonecznych dla&  każdego pajączka!/%%")
ds_map_add(global.text_data_en, "obj_muffetnpc2_89", "* 4 pary wodoodpornych bucików&  dla każdego pajączka!/%%")
ds_map_add(global.text_data_en, "obj_muffetnpc2_91", "* 4 pary stylowych szpilek&  dla każdego pajączka!/%%")
ds_map_add(global.text_data_en, "obj_muffetnpc2_93", "* Pajęcze pole baseballowe^1!&* Już mamy przygotowane&  pączki do baseballu~/%%")
ds_map_add(global.text_data_en, "obj_muffetnpc2_95", "* Pajęczy stadion do baseballu^1!&* We'll play with 4 balls on the&  field at once!/%%")
ds_map_add(global.text_data_en, "obj_muffetnpc2_99", "* Świeżutka nowa cukiernia^1!&* Dziękuję ci bardzo^1, słodziaku!/")
ds_map_add(global.text_data_en, "obj_muffetnpc2_100", "* To wszystko dzięki tobie^2 &* (twoim pieniądzom)./%%")
ds_map_add(global.text_data_en, "obj_muffetnpc2_105", "* Wybrane wakacje dookoła&  świata!/")
ds_map_add(global.text_data_en, "obj_muffetnpc2_106", "* Pojedziemy na tropiki^1?&* Czy może nawiedzony dom^1?&* Ciężko wybrać~/%%")
ds_map_add(global.text_data_en, "obj_multitileevent_121", "* OH NO!&* WHATEVER SHALL I DO?/")
ds_map_add(global.text_data_en, "obj_multitileevent_122", "* MY LOVE HAS BEEN CAST AWAY&  INTO THE DUNGEON./")
ds_map_add(global.text_data_en, "obj_multitileevent_123", "* A DUNGEON WITH A PUZZLE SO&  DASTARDLY^1, MY PARAMOUR WILL&  SURELY PERISH!/%%")
ds_map_add(global.text_data_en, "obj_multitileevent_144", "* O, HEAVENS HAVE MERCY!&* THE HORRIBLE COLORED TILE&  MAZE!/")
ds_map_add(global.text_data_en, "obj_multitileevent_145", "* EACH COLORED TILE HAS ITS&  OWN SADISTIC FUNCTION./")
ds_map_add(global.text_data_en, "obj_multitileevent_146", "* FOR EXAMPLE, A GREEN TILE&  SOUNDS A NOISE, AND THEN&  YOU MUST FIGHT A MONSTER./")
ds_map_add(global.text_data_en, "obj_multitileevent_147", "* RED TILES WILL...&* ACTUALLY, WAIT A SECOND./")
ds_map_add(global.text_data_en, "obj_multitileevent_148", "* DIDN'T WE SEE THIS PUZZLE&  ABOUT A HUNDRED ROOMS&  AGO?/")
ds_map_add(global.text_data_en, "obj_multitileevent_149", "* THAT'S RIGHT.&* YOU REMEMBER ALL THE&  RULES, DON'T YOU?/")
ds_map_add(global.text_data_en, "obj_multitileevent_150", "* GREAT...&* THEN I WON'T WASTE YOUR&  TIME REPEATING THEM!!/%%")
ds_map_add(global.text_data_en, "obj_multitileevent_163", "* OH, AND YOU'D BETTER HURRY./")
ds_map_add(global.text_data_en, "obj_multitileevent_164", "\W* BECAUSE IF YOU DON'T GET&  THROUGH IN \Y30 SECONDS\W.../%%")
ds_map_add(global.text_data_en, "obj_multitileevent_192", "* YOU'LL BE INCINERATED BY&  THESE JETS OF FIRE!!/")
ds_map_add(global.text_data_en, "obj_multitileevent_193", "* AHAHAHAHAHAHA!&* AHAHA... HA... HA!/")
ds_map_add(global.text_data_en, "obj_multitileevent_194", "* MY POOR LOVE!&* I'M SO FILLED WITH GRIEF,&  I CAN'T STOP LAUGHING!/")
ds_map_add(global.text_data_en, "obj_multitileevent_195", "* GOOD LUCK, DARLING!/%%")
ds_map_add(global.text_data_en, "obj_multitileevent_279", "* OOOOH, I'M SO SORRY!&* LOOKS LIKE YOU'RE OUT OF&  TIME!!!/%%")
ds_map_add(global.text_data_en, "obj_multitileevent_304", "* HERE COME THE FLAMES, DARLING!/%%")
ds_map_add(global.text_data_en, "obj_multitileevent_330", "* THEY'RE CLOSING IN!/%%")
ds_map_add(global.text_data_en, "obj_multitileevent_356", "* GETTING!&* CLOSER!&* OH MY!/%%")
ds_map_add(global.text_data_en, "obj_multitileevent_382", "* ANY MINUTE NOW!!!/%%")
ds_map_add(global.text_data_en, "obj_multitileevent_409", "* ...&* ...&* (ROBOTIC COUGH)/%%")
ds_map_add(global.text_data_en, "obj_multitileevent_426", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_multitileevent_427", "* \TS \F6 \TA %")
ds_map_add(global.text_data_en, "obj_multitileevent_428", "* Watch out!^1!&* I'll save you!!/")
ds_map_add(global.text_data_en, "obj_multitileevent_429", "* I'm hacking into the&  firewall right now!/%%")
ds_map_add(global.text_data_en, "obj_multitileevent_447", "* OH NO!!!&* HOW COULD THIS HAPPEN???/")
ds_map_add(global.text_data_en, "obj_multitileevent_448", "* FOILED AGAIN BY THE BRILLIANT&  DOCTOR ALPHYS!!/%%")
ds_map_add(global.text_data_en, "obj_multitileevent_464", "* THA-%")
ds_map_add(global.text_data_en, "obj_multitileevent_465", "\TS \F6 \TA %")
ds_map_add(global.text_data_en, "obj_multitileevent_466", "\E6* That's right!/")
ds_map_add(global.text_data_en, "obj_multitileevent_467", "\E6* Come on^1, Mettaton^1,&  give up already!/")
ds_map_add(global.text_data_en, "obj_multitileevent_468", "* You'll never be&  able to defeat&  us.../")
ds_map_add(global.text_data_en, "obj_multitileevent_469", "\E0* Not as long as&  we work together!/")
ds_map_add(global.text_data_en, "obj_multitileevent_470", "\E6* Your puzzle's over..&* Now go home and&  leave us alone!/")
ds_map_add(global.text_data_en, "obj_multitileevent_471", "\TS \F0 \TM %")
ds_map_add(global.text_data_en, "obj_multitileevent_472", "* PUZZLE^1?&* OVER?/")
ds_map_add(global.text_data_en, "obj_multitileevent_473", "* ALPHYS^1, DARLING^1, WHAT ARE YOU&  TALKING ABOUT...?/")
ds_map_add(global.text_data_en, "obj_multitileevent_474", "* DID YOU FORGET WHAT THE&  GREEN TILES DO?/")
ds_map_add(global.text_data_en, "obj_multitileevent_475", "* THEY MAKE A SOUND, THEN&  YOU HAVE TO FIGHT A MONSTER./")
ds_map_add(global.text_data_en, "obj_multitileevent_476", "* WELL, DARLING...&* THAT MONSTER.../")
ds_map_add(global.text_data_en, "obj_multitileevent_477", "* IS ME!!/%%")
ds_map_add(global.text_data_en, "obj_multitileevent_480", "* WELL, DARLING...!/")
ds_map_add(global.text_data_en, "obj_multitileevent_481", "* WELL, WELL, WELL./")
ds_map_add(global.text_data_en, "obj_multitileevent_482", "* WELLY WELL WELL./")
ds_map_add(global.text_data_en, "obj_multitileevent_483", "* WELL WELLY WELL WELL,&  WELL WELL WELLY./")
ds_map_add(global.text_data_en, "obj_multitileevent_484", "* YOU NEVER STEPPED ON A&  GREEN TILE./")
ds_map_add(global.text_data_en, "obj_multitileevent_485", "* .../")
ds_map_add(global.text_data_en, "obj_multitileevent_486", "* AND NOW YOU'RE GOING TO DIE./%%")
ds_map_add(global.text_data_en, "obj_multitileevent_592", "* CONGRATULATIONS!/")
ds_map_add(global.text_data_en, "obj_multitileevent_593", "* YOU MADE IT THROUGH THE&  PUZZLE!!!/")
ds_map_add(global.text_data_en, "obj_multitileevent_594", "* AND NOW, WITHOUT FURTHER ADO,&  THE FLAMES WILL BE DEACTIVATED!/%%")
ds_map_add(global.text_data_en, "obj_multitileevent_614", "* NO!&* MORE!&* FIRE!/")
ds_map_add(global.text_data_en, "obj_multitileevent_615", "* ... BUT IT'S AS THE PHRASE&  GOES./")
ds_map_add(global.text_data_en, "obj_multitileevent_616", "* " + '"' + "OUT OF THE FIRE, AND INTO&  THE FRYING PAN." + '"' + "/")
ds_map_add(global.text_data_en, "obj_multitileevent_617", "* THAT'S RIGHT, DARLING!/")
ds_map_add(global.text_data_en, "obj_multitileevent_618", "* EVEN IF YOU MANAGE TO BEAT&  THE HEAT.../")
ds_map_add(global.text_data_en, "obj_multitileevent_619", "* YOU'LL NEVER BE ABLE TO&  WITHSTAND MY HOT METAL&  BODY!/")
ds_map_add(global.text_data_en, "obj_multitileevent_620", "* PREPARE YOURSELF FOR MY %%")
ds_map_add(global.text_data_en, "obj_multitileevent_631", "* Dzyn.../")
ds_map_add(global.text_data_en, "obj_multitileevent_632", "* \TS \F6 \TA %")
ds_map_add(global.text_data_en, "obj_multitileevent_633", "* Watch out!^1!&* I'll save you!!/")
ds_map_add(global.text_data_en, "obj_multitileevent_634", "* Flames^1, deactivate!!/")
ds_map_add(global.text_data_en, "obj_multitileevent_635", "* .../")
ds_map_add(global.text_data_en, "obj_multitileevent_636", "\E3* ... huh?/")
ds_map_add(global.text_data_en, "obj_multitileevent_637", "\TS \F0 \TM %")
ds_map_add(global.text_data_en, "obj_multitileevent_638", "* THE HUMAN FINISHED THE PUZZLE./")
ds_map_add(global.text_data_en, "obj_multitileevent_639", "* I ALREADY TURNED OFF THE&  FLAMES./")
ds_map_add(global.text_data_en, "obj_multitileevent_640", "* IN FACT, I WAS ABOUT TO&  FIGHT THE HUMAN./")
ds_map_add(global.text_data_en, "obj_multitileevent_641", "\TS \F6 \TA %")
ds_map_add(global.text_data_en, "obj_multitileevent_642", "* Wh-wh-what?&* TH-THAT puzzle?/")
ds_map_add(global.text_data_en, "obj_multitileevent_643", "\E5* I mean, uhh.../")
ds_map_add(global.text_data_en, "obj_multitileevent_644", "\E6* Great job!&* We've got him on&  the ropes^1, now!/")
ds_map_add(global.text_data_en, "obj_multitileevent_645", "\TS \F0 \TM %")
ds_map_add(global.text_data_en, "obj_multitileevent_646", "* ON THE ROPES^1?&* HA!/")
ds_map_add(global.text_data_en, "obj_multitileevent_647", "* I ONLY DEACTIVATED THE&  FLAMES KNOWING THAT ALPHYS&  WOULD HAVE ANYWAY./")
ds_map_add(global.text_data_en, "obj_multitileevent_648", "* ... NOW, WHERE WERE WE?/")
ds_map_add(global.text_data_en, "obj_multitileevent_649", "* OH YES./")
ds_map_add(global.text_data_en, "obj_multitileevent_650", "* I WAS GOING TO ERADICATE&  YOU!/%%")
ds_map_add(global.text_data_en, "obj_musicstatue_110", "* NO!/%%")
ds_map_add(global.text_data_en, "obj_musicstatue_114", "* (Nie ma już powodu podania&  temu parasola.)/%%")
ds_map_add(global.text_data_en, "obj_napstablook_294", "trzymam&się&dobrze,&dzięki.")
ds_map_add(global.text_data_en, "obj_napstablook_295", "po prostu&wczuwam&się w&klimat...")
ds_map_add(global.text_data_en, "obj_napstablook_296", "nnnnnn&ggghhh.")
ds_map_add(global.text_data_en, "obj_napstablook_297", "oh, jestem&TAKI&śmieszny.")
ds_map_add(global.text_data_en, "obj_napstablook_298", "no&dawaj,&zrób to.")
ds_map_add(global.text_data_en, "obj_napstablook_299", "ja bym&cię tylko&obciążał.")
ds_map_add(global.text_data_en, "obj_napstablook_300", "heh...")
ds_map_add(global.text_data_en, "obj_napstablook_301", "heh&heh...")
ds_map_add(global.text_data_en, "obj_napstablook_302", "daj mi&spróbować&coś...")
ds_map_add(global.text_data_en, "obj_napstablook_305", "wiedziałem...")
ds_map_add(global.text_data_en, "obj_napstablook_311", "o&nie...")
ds_map_add(global.text_data_en, "obj_napstablook_317", "ojej...")
ds_map_add(global.text_data_en, "obj_napstablook_329", "%%%")
ds_map_add(global.text_data_en, "obj_napstablook_339", "umm... wiesz, że&duchów nie da&się zabić, prawda?/")
ds_map_add(global.text_data_en, "obj_napstablook_340", "jesteśmy jakby&nieśmiertelni i&takie tam/")
ds_map_add(global.text_data_en, "obj_napstablook_341", "po prostu&obniżałem hp&bo nie chcę&być niemiły/")
ds_map_add(global.text_data_en, "obj_napstablook_342", "sorki..^1.&troche&siara teraz.../")
ds_map_add(global.text_data_en, "obj_napstablook_343", "udawaj, że&  mnie&    pokonałeś.../")
ds_map_add(global.text_data_en, "obj_napstablook_344", "oooooooo^1o%%")
ds_map_add(global.text_data_en, "obj_napstablook_549", "* Napstablook gapi się&  w odległość.")
ds_map_add(global.text_data_en, "obj_napstablook_550", "* Napstablook życzy,&  żeby tu nie był.")
ds_map_add(global.text_data_en, "obj_napstablook_551", "* Napstablook udaje,&  że śpi.")
ds_map_add(global.text_data_en, "obj_napstablook_552", "* Lekka woń ektoplazmy&  unosi się w powietrzu.")
ds_map_add(global.text_data_en, "obj_napstablook_553", "* Napstablook wygląda&  teraz ciut lepiej.")
ds_map_add(global.text_data_en, "obj_napstablook_554", "* Pocieszanie wydaje się&  polepszyć znów humor&  Napstablooka.")
ds_map_add(global.text_data_en, "obj_napstablook_576", "* NAPSTABLOOK - ATK 10 DEF 10&* Ten potwór nie wydaje się&  posiadać poczucia humoru.../^")
