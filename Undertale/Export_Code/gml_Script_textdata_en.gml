ds_map_add(global.text_data_en, "obj_icecap_412", "* Dałeś radę oderwać oczy&  od czapki Ice Capa./")
ds_map_add(global.text_data_en, "obj_icecap_413", "* Wygląda na wnernionego.../^")
ds_map_add(global.text_data_en, "obj_icecap_422", "* Informujesz Ice Capa że ma&  świetną czapkę!/^")
